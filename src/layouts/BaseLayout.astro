---
import "@styles/global.css";
import geistLatinWoff2 from "@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url";
import geistMonoLatinWoff2 from "@fontsource-variable/geist-mono/files/geist-mono-latin-wght-normal.woff2?url";

// Utils
import {
  navSections,
  getSectionTitle,
  getResolvedPathname,
  type NavItem,
} from "@lib/navigation";
import { normalizeRole, hasPermission } from "@lib/rbac";

// Components
import { Navbar, DrawerContent } from "./_components";
import {
  AboutProjectModal,
  FeedbackModal,
  CommandPaletteModal,
} from "@/components/ui/modals";
import ToastContainer from "@components/ui/ToastContainer.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
const resolvedPath = getResolvedPathname(Astro.request, Astro.url);
const currentPath = resolvedPath;
const rawTitle =
  title || getSectionTitle(resolvedPath) || "Portal Mesa de Ayuda";
const inferredTitle =
  rawTitle &&
  rawTitle !== "Portal MDA" &&
  rawTitle !== "Portal Mesa de Ayuda" &&
  rawTitle !== "Portal"
    ? `Portal MDA | ${rawTitle}`
    : "Portal MDA";

const flattenQuickAccessItems = (items: NavItem[]): NavItem[] =>
  items.flatMap((item) => {
    const nestedChildren = Array.isArray(item.children)
      ? item.children.map((child) => ({
          ...child,
          parentLabel: item.label,
          nested: true,
        }))
      : [];

    return [{ ...item, children: undefined }, ...nestedChildren];
  });

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const getRelativePath = (path: string) => {
  if (path.startsWith(cleanBase)) {
    return "/" + path.slice(cleanBase.length);
  }
  if (path === cleanBase.slice(0, -1)) {
    return "/";
  }
  return path;
};

const relativeCurrentPath = getRelativePath(currentPath);

const isActiveRoute = (href: string) =>
  href === "/"
    ? relativeCurrentPath === "/"
    : relativeCurrentPath === href ||
      relativeCurrentPath.startsWith(`${href}/`);

const user = Astro.locals.user;
const normalizedUserRole = normalizeRole(user.role);

const isRouteLocked = (href: string): boolean => {
  const lowerHref = href.toLowerCase();
  if (
    user.id === 0 &&
    (lowerHref === "/supervision" ||
      lowerHref.startsWith("/supervision/") ||
      lowerHref === "/admin" ||
      lowerHref.startsWith("/admin/"))
  ) {
    return true;
  }
  return !hasPermission(href, normalizedUserRole);
};

let visibleNavSections = navSections
  .map((section) => ({
    ...section,
    items: section.items.filter(
      (item) => !isRouteLocked(item.href) && item.href !== "/supervision",
    ),
  }))
  .filter((section) => section.items.length > 0);

const quickAccessItems: NavItem[] = visibleNavSections.flatMap((section) =>
  flattenQuickAccessItems(section.items),
);

const globalFontFaceCss = `
  @font-face {
    font-family: "Geist Variable";
    src: url("${geistLatinWoff2}") format("woff2");
    font-display: swap;
    font-style: normal;
    font-weight: 100 900;
  }

  @font-face {
    font-family: "Geist Mono Variable";
    src: url("${geistMonoLatinWoff2}") format("woff2");
    font-display: swap;
    font-style: normal;
    font-weight: 100 900;
  }
`;
---

<html lang="es">
  <meta charset="utf-8" />
  <head>
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("theme");
        const theme =
          savedTheme === "light" || savedTheme === "dark"
            ? savedTheme
            : "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <style is:global set:html={globalFontFaceCss}></style>
    <link
      rel="preload"
      href={geistLatinWoff2}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={geistMonoLatinWoff2}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link
      rel="icon"
      type="image/png"
      href={`${cleanBase}favicon-96x96.png`}
      sizes="96x96"
    />
    
    <link rel="icon" type="image/svg+xml" href={`${cleanBase}favicon.svg`} />
    <link rel="shortcut icon" href={`${cleanBase}favicon.ico`} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${cleanBase}apple-touch-icon.png`}
    />

    <meta name="apple-mobile-web-app-title" content="MDA" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="manifest" href={`${cleanBase}site.webmanifest`} />

    <title>{inferredTitle}</title>
  </head>

  <body class="min-h-screen max-w-full overflow-x-hidden bg-base-100 text-base-content">
    <div class="drawer lg:drawer-open h-screen overflow-hidden">
      <input
        id="main-drawer"
        type="checkbox"
        class="drawer-toggle"
        aria-label="toggle sidebar"
      />
      <div class="drawer-content flex h-screen max-w-full flex-col overflow-hidden">
        <!-- Navbar -->
        <Navbar user={user} normalizedUserRole={normalizedUserRole}/>

        <!-- Main content -->
        <main class="flex-1 overflow-x-hidden overflow-y-auto p-4 md:p-6 [scrollbar-gutter:stable_both-edges]">
          <slot />
        </main>
      </div>

      <!-- Drawer content -->
      <DrawerContent
        visibleNavSections={visibleNavSections}
        isActiveRoute={isActiveRoute}
        isRouteLocked={isRouteLocked}
      />
    </div>
  </body>

  <!-- Modals & Toast's container-->
  <CommandPaletteModal items={quickAccessItems} isRouteLocked={isRouteLocked} />
  <AboutProjectModal />
  <FeedbackModal />
  <ToastContainer />

  <script src="../../scripts/toggle-mode.ts"></script>
</html>