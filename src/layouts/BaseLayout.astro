---
import "@styles/global.css";
import { Icon } from "astro-icon/components";
import geistLatinWoff2 from "@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url";
import geistMonoLatinWoff2 from "@fontsource-variable/geist-mono/files/geist-mono-latin-wght-normal.woff2?url";
import packageJson from "../../package.json";

interface Props {
  title?: string;
}

interface NavItem {
  href: string;
  label: string;
  icon: string;
  children?: NavItem[];
  parentLabel?: string;
  nested?: boolean;
}

interface NavSection {
  id: string;
  label: string;
  items: NavItem[];
}

const { title = "Portal Mesa de Ayuda" } = Astro.props;
const currentPath = Astro.url.pathname;
const globalFontFaceCss = `
  @font-face {
    font-family: "Geist Variable";
    src: url("${geistLatinWoff2}") format("woff2");
    font-display: swap;
    font-style: normal;
    font-weight: 100 900;
  }

  @font-face {
    font-family: "Geist Mono Variable";
    src: url("${geistMonoLatinWoff2}") format("woff2");
    font-display: swap;
    font-style: normal;
    font-weight: 100 900;
  }
`;
const aboutProjectVersion = `v${packageJson.version}`;
const aboutProjectYear = new Date().getFullYear();
const aboutProjectOwners: string[] = [
  "Ignacio Revainera",
  "Franco Nahuel González",
  "Darío Altamirano",
];

const navSections: NavSection[] = [
  {
    id: "mesa-ayuda",
    label: "Mesa de ayuda",
    items: [
      {
        href: "/cronograma",
        label: "Cronograma",
        icon: "boxicons:calendar-filled",
      },
      {
        href: "/asignacion-autogestiones",
        label: "Asignacion de autogestiones",
        icon: "boxicons:git-branch-filled",
      },
      {
        href: "/titulos-tickets",
        label: "Titulos de tickets",
        icon: "boxicons:list-ul-filled",
      },
      {
        href: "/guia-soportes",
        label: "Guia de soportes",
        icon: "boxicons:buoy-filled",
      },
    ],
  },
  {
    id: "consultas-recursos",
    label: "Consultas y recursos",
    items: [
      {
        href: "/buscador-usuarios",
        label: "Buscador de usuarios",
        icon: "boxicons:group-filled",
      },
      {
        href: "/contactos-utiles",
        label: "Contactos utiles",
        icon: "boxicons:phone-filled",
      },
      {
        href: "/enlaces-importantes",
        label: "Enlaces importantes",
        icon: "boxicons:link-filled",
        children: [
          {
            href: "/catalogo-aplicativos",
            label: "Catalogo de aplicativos",
            icon: "boxicons:link-filled",
          },
        ],
      },
    ],
  },
  {
    id: "referencia",
    label: "Referencia",
    items: [
      {
        href: "/design-system",
        label: "Estándar de diseño",
        icon: "boxicons:palette-filled",
      },
    ],
  },
  {
    id: "oficinas-sucursales",
    label: "Oficinas y sucursales",
    items: [
      {
        href: "/directorio-oficinas",
        label: "Directorio de oficinas",
        icon: "boxicons:building-filled",
      },
      {
        href: "/mapa-sucursales",
        label: "Mapa de sucursales",
        icon: "boxicons:map-filled",
      },
    ],
  },
  {
    id: "terminales",
    label: "Terminales",
    items: [
      {
        href: "/cubics",
        label: "Cubics",
        icon: "boxicons:desktop-filled",
      },
      {
        href: "/inventario-terminales",
        label: "Inventario de terminales",
        icon: "boxicons:server-filled",
      },
    ],
  },
];

const flattenQuickAccessItems = (items: NavItem[]): NavItem[] =>
  items.flatMap((item) => {
    const nestedChildren = Array.isArray(item.children)
      ? item.children.map((child) => ({
          ...child,
          parentLabel: item.label,
          nested: true,
        }))
      : [];

    return [{ ...item, children: undefined }, ...nestedChildren];
  });

const drawerNavItems = navSections.flatMap((section) =>
  section.items.map((item) => ({ ...item, children: undefined })),
);
const quickAccessItems: NavItem[] = navSections.flatMap((section) =>
  flattenQuickAccessItems(section.items),
);

const isActiveRoute = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<html lang="es">
  <head>
    <style is:global set:html={globalFontFaceCss}></style>
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("theme");
        const theme =
          savedTheme === "light" || savedTheme === "dark"
            ? savedTheme
            : "light";

        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <script>
      import { themeChange } from "theme-change";

      themeChange();
    </script>
    <meta charset="utf-8" />
    <link
      rel="preload"
      href={geistLatinWoff2}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={geistMonoLatinWoff2}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <div class="drawer lg:drawer-open">
      <input
        id="main-drawer"
        type="checkbox"
        class="drawer-toggle"
        aria-label="toggle sidebar"
      />
      <div class="drawer-content flex min-h-screen flex-col">
        <header
          class="navbar sticky top-0 z-30 min-h-16 border-b border-base-300 bg-base-100/95 px-3 text-base-content backdrop-blur sm:px-4"
        >
          <div class="flex items-center gap-2">
            <label
              for="main-drawer"
              aria-label="open sidebar"
              aria-controls="main-drawer"
              role="button"
              tabindex="0"
              class="btn btn-ghost btn-circle drawer-button lg:hidden"
            >
              <Icon name="boxicons:menu-filled" class="size-5" />
            </label>
          </div>

          <div class="hidden flex-1 justify-center px-4 md:flex">
            <button
              type="button"
              data-open-command-palette
              aria-label="Abrir busqueda maestra"
              class="btn btn-ghost inline-flex w-full max-w-2xl items-center justify-start gap-2 border border-base-300 bg-base-100 px-4 font-normal normal-case"
            >
              <Icon name="boxicons:search-filled" class="size-4" />
              <span class="text-sm text-base-content/70">Buscar</span>
              <kbd class="kbd kbd-sm">Ctrl</kbd>
              <kbd class="kbd kbd-sm">K</kbd>
            </button>
          </div>

          <div class="ml-auto flex items-center gap-2">
            <button
              type="button"
              data-open-command-palette
              aria-label="Abrir busqueda maestra"
              class="btn btn-ghost btn-circle md:hidden"
            >
              <Icon name="boxicons:search-filled" class="size-5" />
            </button>

            <div class="divider divider-horizontal m-0 md:hidden"></div>

            <label class="btn btn-ghost btn-circle swap swap-rotate">
              <input
                id="theme-toggle"
                type="checkbox"
                class="theme-controller"
                data-toggle-theme="dark,light"
                data-act-class="ACTIVECLASS"
                value="dark"
                aria-label="Activar modo oscuro"
              />

              <Icon
                name="boxicons:sun-filled"
                class="swap-off size-5"
                aria-hidden="true"
              />
              <Icon
                name="boxicons:moon-filled"
                class="swap-on size-5"
                aria-hidden="true"
              />
            </label>

            <button
              type="button"
              data-open-about-project
              title="Acerca de este proyecto"
              aria-label="Acerca de este proyecto"
              class="btn btn-ghost btn-circle"
            >
              <Icon name="boxicons:help-circle-filled" class="size-5" />
            </button>
          </div>
        </header>

        <main class="flex-1 overflow-y-auto p-4 md:p-6">
          <slot />
        </main>
      </div>

      <div class="drawer-side is-drawer-close:overflow-visible">
        <label
          for="main-drawer"
          aria-label="close sidebar"
          class="drawer-overlay"></label>

        <div
          class="flex min-h-full flex-col items-start bg-secondary is-drawer-close:w-16 xl:is-drawer-close:w-20 is-drawer-open:w-56 md:is-drawer-open:w-64 xl:is-drawer-open:w-72 transition-all duration-300 ease-in-out"
        >
          <a
            href="/"
            aria-label="Ir al dashboard"
            class="flex min-h-16 w-full items-center gap-2.5 border-b border-secondary-content/10 px-3 is-drawer-close:justify-center is-drawer-close:px-0"
          >
            <div class="avatar avatar-placeholder">
              <div
                class="flex w-8 bg-primary text-primary-content items-center justify-center rounded-xl shadow-sm lg:w-9"
              >
                <Icon
                  name="boxicons:building-house-filled"
                  class="size-4 lg:size-5"
                  aria-hidden="true"
                />
              </div>
            </div>
            <div class="is-drawer-close:hidden min-w-0">
              <p class="text-[10px] uppercase font-black tracking-widest text-primary truncate leading-tight">Correo Argentino</p>
              <h1 class="text-base font-black text-secondary-content tracking-tighter truncate leading-none">Mesa de Ayuda</h1>
            </div>
          </a>

          <div class="w-full grow py-2">
            {
              navSections.map((section, sectionIndex) => (
                <>
                  <ul class="menu w-full gap-1 p-2">
                    <li class="menu-title is-drawer-close:hidden mb-1">
                      <span class="text-[11px] font-bold uppercase tracking-wider text-secondary-content/40">
                        {section.label}
                      </span>
                    </li>
                    {section.items.map((item) => {
                      const isActive = isActiveRoute(item.href);
                      return (
                        <li>
                          <a
                            href={item.href}
                            aria-label={item.label}
                            data-tip={item.label}
                            class:list={[
                              "group flex items-center gap-2.5 rounded-lg px-2.5 py-1.5 text-sm font-medium transition",
                              "is-drawer-close:justify-center is-drawer-close:px-0",
                              "is-drawer-close:tooltip is-drawer-close:tooltip-right",
                              isActive
                                ? "bg-primary text-primary-content shadow-sm"
                                : "text-secondary-content/70 hover:bg-white/10 hover:text-white",
                            ]}
                          >
                            <Icon
                              name={item.icon}
                              class="size-5 shrink-0 opacity-80 transition group-hover:opacity-100 lg:size-[22px]"
                            />
                            <span class="truncate is-drawer-close:hidden">
                              {item.label}
                            </span>
                          </a>
                        </li>
                      );
                    })}
                  </ul>

                  {sectionIndex < navSections.length - 1 && (
                    <div class="px-4 my-1">
                      <div class="h-px bg-secondary-content/10" />
                    </div>
                  )}
                </>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <dialog id="command-palette" class="modal">
      <div
        class="modal-box w-11/12 max-w-xl border border-base-300 bg-base-100 p-0"
      >
        <div class="border-b border-base-300 p-4">
          <label for="command-palette-input" class="sr-only"
            >Filtrar accesos</label
          >

          <label class="input w-full">
            <Icon name="boxicons:search-filled" class="size-5 text-base-content/60" />
            <input
              type="search"
              placeholder="Search"
              id="command-palette-input"
              type="text"
              placeholder="Buscar accesos..."
              class="grow w-full"
              autocomplete="off"
            />
          </label>
        </div>

        <ul class="menu w-full">
          {
            quickAccessItems.map((item) => (
              <li
                data-command-item
                data-search-text={`${item.label} ${item.href} ${item.parentLabel ?? ""}`.toLowerCase()}
              >
                <a href={item.href} class="justify-between gap-3">
                  <span
                    class:list={[
                      "flex min-w-0 items-center gap-2",
                      item.nested && "pl-5",
                    ]}
                  >
                    <Icon name={item.icon} class="size-4 shrink-0" />
                    <span class="min-w-0">
                      {item.parentLabel && (
                        <span class="block text-xs text-base-content/50">
                          {item.parentLabel}
                        </span>
                      )}
                      <span class="block truncate">{item.label}</span>
                    </span>
                  </span>
                  <span class="text-xs text-base-content/60">{item.href}</span>
                </a>
              </li>
            ))
          }
        </ul>

        <p
          id="command-palette-empty"
          class="hidden px-4 pb-4 text-sm text-base-content/70"
        >
          No hay accesos que coincidan.
        </p>
      </div>

      <form method="dialog" class="modal-backdrop">
        <button aria-label="Cerrar busqueda">close</button>
      </form>
    </dialog>

    <dialog id="about-project-dialog" class="modal">
      <div
        class="modal-box w-11/12 max-w-md overflow-hidden rounded-lg border-0 bg-base-100 p-0 shadow-2xl"
      >
        <div
          class="relative flex flex-col items-center justify-center overflow-hidden bg-secondary p-8 text-center"
        >
          <div class="pointer-events-none absolute -top-8 -right-8 opacity-10">
            <Icon
              name="boxicons:network-chart-filled"
              class="size-40 text-white"
              aria-hidden="true"
            />
          </div>

          <form method="dialog" class="absolute top-3 right-3 z-20">
            <button
              type="submit"
              class="btn btn-ghost btn-sm btn-circle border-0 text-white hover:bg-white/15"
              aria-label="Cerrar acerca del proyecto"
            >
              <span aria-hidden="true" class="text-base leading-none">X</span>
            </button>
          </form>

          <div class="relative z-10 flex flex-col items-center">
            <div
              class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/20 shadow-inner"
            >
              <Icon name="boxicons:building-house-filled" class="size-7 text-white" />
            </div>

            <h2
              class="flex flex-wrap items-center justify-center gap-2 text-2xl font-black tracking-tight text-white"
            >
              Mesa de Ayuda
              <span
                class="rounded-md bg-primary px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-primary-content ring-1 ring-white/30 shadow-sm"
              >
                {aboutProjectVersion}
              </span>
            </h2>
          </div>
        </div>

        <div class="space-y-5 bg-base-100 px-6 py-7">
          <div class="flex items-start gap-4">
            <div
              class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:code-alt-filled" class="size-5" />
            </div>
            <div>
              <h4 class="text-sm font-semibold text-base-content">
                Desarrollo y arquitectura
              </h4>
              <p class="mt-1 text-sm leading-relaxed text-base-content/70">
                Plataforma construida para optimizar la gestion de tickets,
                visualizacion de infraestructura y monitoreo tecnico.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:group-filled" class="size-5" />
            </div>
            <div class="w-full">
              <h4 class="mb-3 text-sm font-semibold text-base-content">
                Responsables del proyecto
              </h4>
              <ul class="grid grid-cols-3 gap-2">
                {
                  aboutProjectOwners.map((owner) => (
                    <li class="flex flex-col items-center rounded-xl border border-base-300/50 bg-base-200/50 p-2 text-center transition-colors hover:bg-base-200/80">
                      <div class="mb-1.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-secondary text-secondary-content shadow-sm">
                        <Icon
                          name="boxicons:user-filled"
                          class="size-3.5"
                          aria-hidden="true"
                        />
                      </div>
                      <span class="text-[10px] font-bold leading-tight text-base-content/90">
                        {owner}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <div class="border-t border-base-300/50 bg-base-200/40 px-6 py-4">
          <p class="text-center text-xs font-medium text-base-content/70">
            © {aboutProjectYear} Correo Argentino. Todos los derechos reservados.
          </p>
        </div>
      </div>

      <form method="dialog" class="modal-backdrop">
        <button aria-label="Cerrar acerca del proyecto">close</button>
      </form>
    </dialog>

    <script>
      const commandPalette = document.getElementById(
        "command-palette",
      ) as HTMLDialogElement | null;
      const commandPaletteInput = document.getElementById(
        "command-palette-input",
      ) as HTMLInputElement | null;
      const commandPaletteItems = Array.from(
        document.querySelectorAll("[data-command-item]"),
      ) as HTMLLIElement[];
      const commandPaletteEmpty = document.getElementById(
        "command-palette-empty",
      ) as HTMLElement | null;
      const commandPaletteTriggers = Array.from(
        document.querySelectorAll("[data-open-command-palette]"),
      ) as HTMLButtonElement[];
      const aboutProjectDialog = document.getElementById(
        "about-project-dialog",
      ) as HTMLDialogElement | null;
      const aboutProjectTriggers = Array.from(
        document.querySelectorAll("[data-open-about-project]"),
      ) as HTMLButtonElement[];

      const themeToggle = document.getElementById(
        "theme-toggle",
      ) as HTMLInputElement | null;

      const updateThemeToggle = (): void => {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark";

        if (themeToggle) {
          themeToggle.checked = isDark;
          themeToggle.setAttribute(
            "aria-label",
            isDark ? "Activar modo claro" : "Activar modo oscuro",
          );
        }
      };

      const filterCommandPalette = (): void => {
        const query = commandPaletteInput?.value.trim().toLowerCase() ?? "";
        let visibleItems = 0;

        commandPaletteItems.forEach((item: HTMLLIElement) => {
          const searchText = item.dataset.searchText ?? "";
          const isVisible = query.length === 0 || searchText.includes(query);

          item.classList.toggle("hidden", !isVisible);
          if (isVisible) {
            visibleItems += 1;
          }
        });

        commandPaletteEmpty?.classList.toggle("hidden", visibleItems > 0);
      };

      const openCommandPalette = (): void => {
        if (!commandPalette) {
          return;
        }

        if (!commandPalette.open) {
          commandPalette.showModal();
        }

        if (commandPaletteInput) {
          commandPaletteInput.value = "";
          filterCommandPalette();
          commandPaletteInput.focus();
        }
      };

      const closeCommandPalette = (): void => {
        if (commandPalette?.open) {
          commandPalette.close();
        }
      };

      const openAboutProjectDialog = (): void => {
        if (!aboutProjectDialog) {
          return;
        }

        if (!aboutProjectDialog.open) {
          aboutProjectDialog.showModal();
        }
      };

      const closeAboutProjectDialog = (): void => {
        if (aboutProjectDialog?.open) {
          aboutProjectDialog.close();
        }
      };

      commandPaletteTriggers.forEach((trigger: HTMLButtonElement) => {
        trigger.addEventListener("click", () => {
          openCommandPalette();
        });
      });
      aboutProjectTriggers.forEach((trigger: HTMLButtonElement) => {
        trigger.addEventListener("click", () => {
          openAboutProjectDialog();
        });
      });

      commandPaletteInput?.addEventListener("input", () => {
        filterCommandPalette();
      });

      commandPalette?.addEventListener("click", (event: MouseEvent) => {
        if (event.target === commandPalette) {
          closeCommandPalette();
        }
      });
      aboutProjectDialog?.addEventListener("click", (event: MouseEvent) => {
        if (event.target === aboutProjectDialog) {
          closeAboutProjectDialog();
        }
      });

      document.addEventListener("keydown", (event: KeyboardEvent) => {
        const isCommandShortcut =
          (event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k";

        if (isCommandShortcut) {
          event.preventDefault();
          openCommandPalette();
          return;
        }

        if (event.key === "Escape") {
          closeCommandPalette();
          closeAboutProjectDialog();
        }
      });

      themeToggle?.addEventListener("change", () => {
        window.setTimeout(() => {
          updateThemeToggle();
        }, 0);
      });

      const themeObserver = new MutationObserver(() => {
        updateThemeToggle();
      });

      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      updateThemeToggle();
      filterCommandPalette();
    </script>
  </body>
</html>