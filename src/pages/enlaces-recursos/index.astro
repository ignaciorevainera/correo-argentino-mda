---
import BaseLayout from "@layouts/BaseLayout.astro";
import ImportantLinksView from "./_components/ImportantLinksView.astro";
import { db } from "../../db";
import type {
  CategoryTone,
  CategoryViewModel,
} from "./_components/types";

const categoryTones: CategoryTone[] = [
  "primary",
  "secondary",
  "accent",
  "neutral",
  "success",
];

const rawCategories = await db.query.resourceCategories.findMany({
  with: {
    links: true,
  },
});

const importantCategories = rawCategories.map(
  (category, index): CategoryViewModel => ({
    id: category.id,
    category: category.title,
    icon: `boxicons:${category.iconName}`,
    tone: categoryTones[index % categoryTones.length],
    links: category.links.map(link => ({
      ...link,
      subtitle: link.subtitle ?? undefined
    })),
  }),
);
---

<BaseLayout>
  <ImportantLinksView categories={importantCategories} />
</BaseLayout>
