---
import { Icon } from "astro-icon/components";
import LinkItem from "./LinkItem.astro";
import type { CategoryTone, CategoryViewModel } from "./types";

interface Props {
  category: CategoryViewModel;
}

interface CategoryToneClasses {
  borderClass: string;
  headerClass: string;
  iconClass: string;
  badgeClass: string;
}

const { category } = Astro.props;

const toneClasses: Record<CategoryTone, CategoryToneClasses> = {
  primary: {
    borderClass: "border-t-primary",
    headerClass: "bg-primary/10",
    iconClass: "border-primary/40 bg-primary/15 text-primary",
    badgeClass: "badge-primary",
  },
  secondary: {
    borderClass: "border-t-secondary",
    headerClass: "bg-secondary/10",
    iconClass: "border-secondary/40 bg-secondary/15 text-secondary",
    badgeClass: "badge-secondary",
  },
  accent: {
    borderClass: "border-t-accent",
    headerClass: "bg-accent/10",
    iconClass: "border-accent/40 bg-accent/15 text-accent",
    badgeClass: "badge-accent",
  },
  neutral: {
    borderClass: "border-t-neutral",
    headerClass: "bg-base-200",
    iconClass: "border-neutral/40 bg-neutral/10 text-neutral",
    badgeClass: "badge-neutral",
  },
  success: {
    borderClass: "border-t-success",
    headerClass: "bg-success/10",
    iconClass: "border-success/40 bg-success/15 text-success",
    badgeClass: "badge-success",
  },
  info: {
    borderClass: "border-t-info",
    headerClass: "bg-info/10",
    iconClass: "border-info/40 bg-info/15 text-info",
    badgeClass: "badge-info",
  },
  warning: {
    borderClass: "border-t-warning",
    headerClass: "bg-warning/10",
    iconClass: "border-warning/40 bg-warning/15 text-warning",
    badgeClass: "badge-warning",
  },
  error: {
    borderClass: "border-t-error",
    headerClass: "bg-error/10",
    iconClass: "border-error/40 bg-error/15 text-error",
    badgeClass: "badge-error",
  },
};

const classes = toneClasses[category.tone];
const categorySearchText = category.category;
---

<article
  class="card mb-5 w-full break-inside-avoid border border-base-300 bg-base-100 shadow-md overflow-visible relative hover:z-20 transition-all"
  data-link-category
  data-category-search={categorySearchText}
>
  <header
    class:list={[
      "flex items-center justify-between gap-3 border-b border-base-300 px-4 py-3 rounded-t-[inherit]",
      classes.headerClass,
    ]}
  >
    <div class="min-w-0 flex-1">
      <h2
        class="truncate text-base font-bold text-base-content"
        data-highlight-target
      >
        {category.category}
      </h2>
    </div>

    <span class:list={["badge badge-sm shrink-0 font-semibold", classes.badgeClass]}>
      {category.links.length}
    </span>
  </header>

  <div class="card-body gap-0 bg-base-200/10 p-3">
    <ul class="flex flex-col gap-2">
      {
        category.links.map((link) => (
          <LinkItem link={link} category={category.category} />
        ))
      }
    </ul>
  </div>
</article>
