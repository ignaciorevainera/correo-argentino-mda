---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import MasterDetailTable from "@components/ui/MasterDetailTable.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import ViewSwitcher from "@components/ui/ViewSwitcher.astro";
import {
  officeDirectoryItems,
  type OfficeDirectoryItem,
  type OfficeAssetType,
  type OfficeType,
} from "@/data/directorio_oficinas";

// Datos de ejemplo para el mapa de sucursales (mock)
const sucursales = [
  {
