---
import { Icon } from "astro-icon/components";
import logoFirma from "@assets/firma.png";
import logoFirma2 from "@assets/firma2.png";
import logoFirma3 from "@assets/firma3.png";

interface Props {
  origin?: string;
}

const { origin = "" } = Astro.props;
---

<div
  class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start"
  id="signature-generator-container"
  data-origin={origin}
  data-logo-default={logoFirma.src}
  data-logo2={logoFirma2.src}
  data-logo3={logoFirma3.src}
>
  <section
    class="card bg-base-100 border border-base-300 shadow-md overflow-hidden"
  >
    <div class="card-body">
      <div class="flex items-center gap-2 mb-2">
        <div class="p-2 bg-primary/10 rounded-lg text-primary">
          <Icon name="boxicons:contact-book-filled" class="size-5" />
        </div>
        <h2 class="text-xl font-bold">Datos del operador</h2>
      </div>

      <form id="signature-form" class="space-y-6 mb-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold"
              >Nombre y Apellido <span class="text-error">*</span></legend
            >
            <input
              type="text"
              name="name"
              id="input-name"
              placeholder="Ej. Juan Pérez"
              class="input w-full"
              maxlength="40"
            />
          </fieldset>
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold"
              >Puesto / Cargo <span class="text-error">*</span></legend
            >
            <input
              type="text"
              name="role"
              id="input-role"
              placeholder="Ej. Operador N1"
              class="input w-full"
              maxlength="50"
            />
          </fieldset>
        </div>

        <fieldset class="fieldset w-full">
          <legend class="fieldset-legend font-semibold"
            >Departamento / Gerencia <span class="text-error">*</span></legend
          >
          <input
            type="text"
            name="department"
            id="input-department"
            placeholder="Ej. Mesa de Ayuda Corporativa"
            class="input w-full"
            maxlength="50"
          />
        </fieldset>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold"
              >Dirección (Línea 1) <span class="text-error">*</span></legend
            >
            <input
              type="text"
              name="address1"
              id="input-address1"
              placeholder="Ej. Av. Paseo Colón 740"
              class="input w-full"
              maxlength="60"
            />
          </fieldset>
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold">
              Dirección (Línea 2) <span class="text-xs font-normal opacity-50"
                >(Opcional)</span
              >
            </legend>
            <input
              type="text"
              name="address2"
              id="input-address2"
              placeholder="Ej. C1063ACU, CABA"
              class="input w-full"
              maxlength="60"
            />
          </fieldset>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold">
              Teléfono Fijo <span class="text-xs font-normal opacity-50"
                >(Opcional)</span
              >
            </legend>
            <input
              type="text"
              name="phone"
              id="input-phone"
              placeholder="Ej. 011 4891 9191"
              class="input w-full"
              maxlength="25"
            />
          </fieldset>
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold">
              Interno <span class="text-xs font-normal opacity-50"
                >(Opcional)</span
              >
            </legend>
            <input
              type="text"
              name="internal"
              id="input-internal"
              placeholder="Ej. 1234"
              class="input w-full"
              maxlength="10"
            />
          </fieldset>
          <fieldset class="fieldset w-full">
            <legend class="fieldset-legend font-semibold">
              Celular <span class="text-xs font-normal opacity-50"
                >(Opcional)</span
              >
            </legend>
            <input
              type="text"
              name="mobile"
              id="input-mobile"
              placeholder="Ej. 11 15 1234 5678"
              class="input w-full"
              maxlength="25"
            />
          </fieldset>
        </div>

        <div class="divider text-xs opacity-50 uppercase tracking-widest">
          Variante de Logo
        </div>

        <div class="grid grid-cols-3 gap-3">
          <label
            class="cursor-pointer border border-base-300 rounded-lg p-2 hover:bg-base-200 transition-colors flex flex-col items-center gap-2 has-checked:border-primary has-checked:bg-primary/5"
          >
            <input
              type="radio"
              name="logo-selection"
              value="default"
              class="radio radio-xs radio-primary"
              checked
            />
            <img src={logoFirma.src} alt="Logo 1" class="h-8 object-contain" />
            <span class="text-[10px] font-medium opacity-70">Opción 1</span>
          </label>
          <label
            class="cursor-pointer border border-base-300 rounded-lg p-2 hover:bg-base-200 transition-colors flex flex-col items-center gap-2 has-checked:border-primary has-checked:bg-primary/5"
          >
            <input
              type="radio"
              name="logo-selection"
              value="logo2"
              class="radio radio-xs radio-primary"
            />
            <img src={logoFirma2.src} alt="Logo 2" class="h-8 object-contain" />
            <span class="text-[10px] font-medium opacity-70">Opción 2</span>
          </label>
          <label
            class="cursor-pointer border border-base-300 rounded-lg p-2 hover:bg-base-200 transition-colors flex flex-col items-center gap-2 has-checked:border-primary has-checked:bg-primary/5"
          >
            <input
              type="radio"
              name="logo-selection"
              value="logo3"
              class="radio radio-xs radio-primary"
            />
            <img src={logoFirma3.src} alt="Logo 3" class="h-8 object-contain" />
            <span class="text-[10px] font-medium opacity-70">Opción 3</span>
          </label>
        </div>

        <div class="form-control mt-4 w-max">
          <label class="cursor-pointer label gap-3">
            <input
              type="checkbox"
              id="input-include-image"
              class="checkbox checkbox-primary"
              checked
            />
            <span class="label-text font-medium"
              >Incluir logo institucional y línea separadora</span
            >
          </label>
        </div>
      </form>

      <div role="alert" class="alert alert-info">
        <Icon name="boxicons:info-circle" size={24} />
        <div>
          <span class="font-bold block">¿Cómo usar?</span>
          <span>
            Copia la firma visual y pégala directamente en la configuración de
            firmas de Outlook.
          </span>
          <span class="block mt-1 text-xs font-semibold text-warning">
            * Completa todos los campos obligatorios (marcados con *) para
            habilitar los botones de descarga y copia.
          </span>
        </div>
      </div>

      <div role="alert" class="alert alert-warning">
        <Icon name="boxicons:alert-octagon" size={24} />
        <div class="flex flex-col gap-2">
          <span>
            <span class="font-bold">Importante sobre la imagen:</span> Debido a políticas
            de seguridad, Outlook solo mostrará la imagen si el portal está publicado
            en un servidor oficial. En entorno local (localhost), la imagen podría
            no visualizarse al pegar.
          </span>
          <a
            href={logoFirma.src}
            download="firma-correo-argentino.png"
            class="btn btn-soft btn-neutral"
          >
            <Icon name="boxicons:arrow-in-down-square-half-filled" size={24} />
            Descargar imagen para adjuntar manualmente
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-4">
    <div class="tabs tabs-box bg-base-200 p-1 rounded-xl self-start">
      <button id="tab-visual" class="tab tab-active"> Vista Visual </button>
      <button id="tab-code" class="tab"> Código Fuente </button>
    </div>

    <div
      class="card bg-base-100 border border-base-300 shadow-md min-h-[300px]"
    >
      <div class="card-body p-0">
        <div id="section-visual" class="flex flex-col h-full p-6">
          <div
            id="preview-container"
            class="flex-1 border border-dashed border-base-300 rounded-lg p-4 flex items-center justify-center bg-white min-h-40"
          >
          </div>
          <div class="card-actions justify-end mt-6 gap-2">
            <button
              id="btn-download-png"
              disabled
              class="btn btn-neutral btn-outline"
            >
              <span
                id="download-spinner"
                class="loading loading-spinner loading-sm hidden"></span>
              <Icon
                id="download-icon"
                name="boxicons:arrow-in-down-square-half-filled"
                class="size-5"
              />
              Descargar PNG
            </button>
            <button
              id="btn-copy-visual"
              disabled
              class="btn btn-primary transition-all duration-300"
            >
              <span id="copy-visual-content" class="flex items-center gap-2">
                <Icon name="boxicons:copy-filled" class="size-5" />
                Copiar firma visual
              </span>
            </button>
          </div>
        </div>

        <div id="section-code" class="flex flex-col h-full p-6 hidden">
          <div
            class="flex-1 bg-neutral text-neutral-content p-4 rounded-lg overflow-auto font-mono text-xs max-h-[400px]"
          >
            <pre id="code-output"></pre>
          </div>
          <div class="card-actions justify-end mt-6">
            <button
              id="btn-copy-code"
              disabled
              class="btn btn-secondary transition-all duration-300"
            >
              <span id="copy-code-content" class="flex items-center gap-2">
                <Icon name="boxicons:code-alt-filled" class="size-5" />
                Copiar código
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  import { toPng } from "html-to-image";

  const container = document.getElementById("signature-generator-container");
  const origin = container?.dataset.origin || "";
  const logos: Record<string, string> = {
    default: container?.dataset.logoDefault || "",
    logo2: container?.dataset.logo2 || "",
    logo3: container?.dataset.logo3 || "",
  };

  const inputName = document.getElementById(
    "input-name",
  ) as HTMLInputElement | null;
  const inputRole = document.getElementById(
    "input-role",
  ) as HTMLInputElement | null;
  const inputDepartment = document.getElementById(
    "input-department",
  ) as HTMLInputElement | null;
  const inputAddress1 = document.getElementById(
    "input-address1",
  ) as HTMLInputElement | null;
  const inputAddress2 = document.getElementById(
    "input-address2",
  ) as HTMLInputElement | null;
  const inputPhone = document.getElementById(
    "input-phone",
  ) as HTMLInputElement | null;
  const inputInternal = document.getElementById(
    "input-internal",
  ) as HTMLInputElement | null;
  const inputMobile = document.getElementById(
    "input-mobile",
  ) as HTMLInputElement | null;
  const inputIncludeImage = document.getElementById(
    "input-include-image",
  ) as HTMLInputElement | null;
  const logoRadios = document.querySelectorAll(
    'input[name="logo-selection"]',
  ) as NodeListOf<HTMLInputElement>;

  const previewContainer = document.getElementById("preview-container");
  const codeOutput = document.getElementById("code-output");

  const btnDownloadPng = document.getElementById(
    "btn-download-png",
  ) as HTMLButtonElement | null;
  const btnCopyVisual = document.getElementById(
    "btn-copy-visual",
  ) as HTMLButtonElement | null;
  const btnCopyCode = document.getElementById(
    "btn-copy-code",
  ) as HTMLButtonElement | null;

  const tabVisual = document.getElementById("tab-visual");
  const tabCode = document.getElementById("tab-code");
  const sectionVisual = document.getElementById("section-visual");
  const sectionCode = document.getElementById("section-code");

  const downloadSpinner = document.getElementById("download-spinner");
  const downloadIcon = document.getElementById("download-icon");

  let formData = {
    name: "",
    role: "",
    department: "",
    address1: "",
    address2: "",
    phone: "",
    internal: "",
    mobile: "",
    selectedLogo: "default",
    includeImage: true,
  };

  function updateFormData() {
    if (
      !inputName ||
      !inputRole ||
      !inputDepartment ||
      !inputAddress1 ||
      !inputAddress2 ||
      !inputPhone ||
      !inputInternal ||
      !inputMobile ||
      !inputIncludeImage
    )
      return;

    formData = {
      name: inputName.value,
      role: inputRole.value,
      department: inputDepartment.value,
      address1: inputAddress1.value,
      address2: inputAddress2.value,
      phone: inputPhone.value,
      internal: inputInternal.value,
      mobile: inputMobile.value,
      selectedLogo: (Array.from(logoRadios).find((r) => r.checked)?.value ||
        "default") as "default" | "logo2" | "logo3",
      includeImage: inputIncludeImage.checked,
    };
    renderSignature();
    validateForm();
  }

  function validateForm() {
    if (!btnDownloadPng || !btnCopyVisual || !btnCopyCode) return;

    const isValid =
      formData.name.trim() !== "" &&
      formData.role.trim() !== "" &&
      formData.department.trim() !== "" &&
      formData.address1.trim() !== "";

    btnDownloadPng.disabled = !isValid;
    btnCopyVisual.disabled = !isValid;
    btnCopyCode.disabled = !isValid;
  }

  function renderSignature() {
    if (!previewContainer || !codeOutput) return;

    const logoPath = logos[formData.selectedLogo];
    const fullLogoUrl = logoPath.startsWith("http")
      ? logoPath
      : `${window.location.origin}${logoPath}`;

    const contactInfo = [
      formData.phone ? `Tel: ${formData.phone}` : "",
      formData.internal ? `Int: ${formData.internal}` : "",
      formData.mobile ? `Cel: ${formData.mobile}` : ""
    ].filter(Boolean).join(" | ");

    const imageHtml = formData.includeImage
      ? `
    <td width="160" style="width: 160px; padding-right: 15px; vertical-align: middle;">
      <img src="${fullLogoUrl}" alt="Correo Argentino" width="160" style="display: block; border: 0; width: 160px; max-width: 160px;" />
    </td>
    <td width="2" style="background-color: #ffc72c; width: 2px; font-size: 1px; line-height: 1px;">&nbsp;</td>
    <td width="15" style="width: 15px; font-size: 1px; line-height: 1px;">&nbsp;</td>`
      : "";

    const signatureHtml = `
<table cellpadding="0" cellspacing="0" border="0" style="font-family: Arial, Helvetica, sans-serif; color: #0c0c0c; margin: 0;">
  <tr>${imageHtml}
    <td style="vertical-align: middle;">
      <table cellpadding="0" cellspacing="0" border="0" style="font-family: Arial, Helvetica, sans-serif; color: #0c0c0c;">
        <tr>
          <td style="font-size: 16px; font-weight: bold; color: #254888; padding-bottom: 2px;">
            ${formData.name || "Nombre y Apellido"}
          </td>
        </tr>
        <tr>
          <td style="font-size: 13px; font-weight: bold; color: #0c0c0c; padding-bottom: 4px;">
            ${formData.role || "Puesto / Cargo"}
          </td>
        </tr>
        <tr>
          <td style="font-size: 12px; color: #54585a; text-transform: uppercase; letter-spacing: 0.5px; padding-bottom: 4px;">
            ${formData.department || "Departamento / Gerencia"}
          </td>
        </tr>
        <tr>
          <td style="font-size: 11px; color: #54585a;">
            ${formData.address1 || "Dirección Línea 1"}${formData.address2 ? `<br />${formData.address2}` : ""}${contactInfo ? `<br />${contactInfo}` : ""}
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>`.trim();

    previewContainer.innerHTML = signatureHtml;
    codeOutput.textContent = signatureHtml;
  }

  inputName?.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    target.value = target.value.replace(/(^\w|\s\w)/g, (m) => m.toUpperCase());
    updateFormData();
  });

  inputAddress2?.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    target.value = target.value.toUpperCase();
    updateFormData();
  });

  [
    inputRole,
    inputDepartment,
    inputAddress1,
    inputPhone,
    inputInternal,
    inputMobile,
  ].forEach((el) => {
    el?.addEventListener("input", updateFormData);
  });

  inputIncludeImage?.addEventListener("change", updateFormData);

  logoRadios.forEach((radio) => {
    radio.addEventListener("change", updateFormData);
  });

  tabVisual?.addEventListener("click", () => {
    tabVisual.classList.add("tab-active");
    tabCode?.classList.remove("tab-active");
    sectionVisual?.classList.remove("hidden");
    sectionCode?.classList.add("hidden");
  });

  tabCode?.addEventListener("click", () => {
    tabCode.classList.add("tab-active");
    tabVisual?.classList.remove("tab-active");
    sectionCode?.classList.remove("hidden");
    sectionVisual?.classList.add("hidden");
  });

  btnCopyVisual?.addEventListener("click", () => {
    if (!previewContainer) return;

    try {
      const selection = window.getSelection();
      if (!selection) throw new Error("No Selection API");
      
      selection.removeAllRanges();
      const range = document.createRange();
      const table = previewContainer.querySelector("table");
      
      if (table) {
        range.selectNode(table);
      } else {
        range.selectNodeContents(previewContainer);
      }
      
      selection.addRange(range);
      const success = document.execCommand("copy");
      selection.removeAllRanges();

      if (!success) throw new Error("execCommand copy failed");

      const contentEl = document.getElementById("copy-visual-content");
      if (contentEl) {
        const originalContent = contentEl.innerHTML;
        contentEl.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="m10 15.586-3.293-3.293-1.414 1.414L10 18.414l9.707-9.707-1.414-1.414z"></path></svg>
          ¡Copiado!
        `;
        btnCopyVisual.classList.add("btn-success");
        setTimeout(() => {
          contentEl.innerHTML = originalContent;
          btnCopyVisual.classList.remove("btn-success");
        }, 2000);
      }
    } catch (err) {
      console.error("Error al copiar firma visual:", err);
      alert("No se pudo copiar la firma. Por favor, selecciona el contenido manualmente y presiona Ctrl+C.");
    }
  });

  btnCopyCode?.addEventListener("click", async () => {
    if (!codeOutput) return;

    try {
      await navigator.clipboard.writeText(codeOutput.textContent || "");
      const contentEl = document.getElementById("copy-code-content");
      if (contentEl) {
        const originalContent = contentEl.innerHTML;
        contentEl.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="m10 15.586-3.293-3.293-1.414 1.414L10 18.414l9.707-9.707-1.414-1.414z"></path></svg>
          ¡Copiado!
        `;
        btnCopyCode.classList.add("btn-success");
        setTimeout(() => {
          contentEl.innerHTML = originalContent;
          btnCopyCode.classList.remove("btn-success");
        }, 2000);
      }
    } catch (err) {
      console.error("Error al copiar código:", err);
    }
  });

  btnDownloadPng?.addEventListener("click", async () => {
    if (!previewContainer) return;

    const table = previewContainer.querySelector("table");
    if (!table || !downloadSpinner || !downloadIcon) return;

    try {
      downloadSpinner.classList.remove("hidden");
      downloadIcon.classList.add("hidden");
      btnDownloadPng.disabled = true;

      const dataUrl = await toPng(table, {
        cacheBust: true,
        backgroundColor: "#ffffff",
        style: {
          margin: "0",
          borderRadius: "0",
          border: "none",
        },
      });
      const link = document.createElement("a");
      link.download = `firma-correo-argentino.png`;
      link.href = dataUrl;
      link.click();
    } catch (err) {
      console.error("Error al generar imagen:", err);
    } finally {
      downloadSpinner.classList.add("hidden");
      downloadIcon.classList.remove("hidden");
      btnDownloadPng.disabled = false;
    }
  });

  renderSignature();
</script>
