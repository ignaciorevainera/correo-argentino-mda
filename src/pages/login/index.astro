---
import { db } from "@db/index";
import { users, sessions } from "@db/schema";
import { eq } from "drizzle-orm";
import bcrypt from "bcryptjs";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  generateSessionId,
  signSessionId,
  setSessionCookie,
} from "../../lib/session";
import { Icon } from "astro-icon/components";
import FormField from "@components/ui/forms/FormField.astro";
import PasswordField from "@components/ui/forms/PasswordField.astro";
import { getCleanBase } from "@lib/baseUrl";

if (Astro.locals.user.id !== 0) {
  return Astro.redirect(getCleanBase());
}

const cleanBase = getCleanBase();

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const usernameInput = formData.get("username")?.toString().trim();
  const passwordInput = formData.get("password")?.toString();

  if (!usernameInput || !passwordInput) {
    return Astro.redirect(
      `${cleanBase}login?toast_msg=${encodeURIComponent("Completá todos los campos")}&toast_type=warning`,
    );
  }

  const [userFound] = await db
    .select()
    .from(users)
    .where(eq(users.username, usernameInput));

  if (userFound) {
    const isPasswordValid = await bcrypt.compare(
      passwordInput,
      userFound.password,
    );

    if (isPasswordValid) {
      const sessionId = generateSessionId();
      const expiresAtMs = Date.now() + 1000 * 60 * 60 * 24 * 7;
      const expiresAtDate = new Date(expiresAtMs);

      await db.insert(sessions).values({
        id: sessionId,
        userId: userFound.id,
        expiresAt: expiresAtMs,
      });

      const signedId = signSessionId(sessionId);
      setSessionCookie(Astro.cookies, signedId, expiresAtDate);

      return Astro.redirect(cleanBase);
    }

    return Astro.redirect(
      `${cleanBase}login?toast_msg=${encodeURIComponent("Contraseña incorrecta")}&toast_type=error`,
    );
  }

  return Astro.redirect(
    `${cleanBase}login?toast_msg=${encodeURIComponent("El usuario no existe")}&toast_type=error`,
  );
}
---

<BaseLayout>
  <div class="flex min-h-[80vh] items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="card bg-base-100 shadow-md border border-base-300">
        <div class="card-body">
          <div class="text-center">
            <div
              class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-2xl bg-secondary text-secondary-content shadow-sm"
            >
              <Icon
                name="boxicons:building-house"
                size={28}
                aria-hidden="true"
              />
            </div>
            <h1 class="text-xl font-bold tracking-tight text-base-content">
              Mesa de Ayuda
            </h1>
            <p class="mt-1 text-xs text-base-content/60">
              Inicia sesión con tu usuario
            </p>
          </div>

          <form method="POST">
            <FormField
              id="login-username"
              name="username"
              label="Usuario"
              required
              placeholder="irevainera"
              autocomplete="username"
              pattern="[A-Za-z][A-Za-z0-9\\-]*"
              minlength="3"
              maxlength="30"
              title="Solo letras, números o guion"
              icon="boxicons:user-filled"
              inputClass="validator"
            />

            <PasswordField
              id="login-password"
              name="password"
              label="Contraseña"
              required
              minlength="4"
              placeholder="••••••••"
              autocomplete="current-password"
              title="Contraseña requerida (mínimo 4 caracteres)"
              icon="boxicons:lock-filled"
              inputClass="validator"
              confirmPassword={false}
              showRequirements={false}
            />

            <button type="submit" class="btn btn-primary w-full mt-4">
              Ingresar
            </button>
          </form>

          <div role="alert" class="alert alert-info mt-4">
            <Icon name="boxicons:info-circle" size={20} class="shrink-0" />
            <span>
              Si no contás con un usuario o requerís acceso al portal,
              comunicate con los administradores de la Mesa de Ayuda.
            </span>
          </div>
        </div>
      </div>

      <p class="mt-6 text-center text-xs text-base-content/40">
        © {new Date().getFullYear()} Correo Argentino · Portal interno
      </p>
    </div>
  </div>
</BaseLayout>
