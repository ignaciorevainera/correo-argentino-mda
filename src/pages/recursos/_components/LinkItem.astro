---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import CopyButton from "@components/ui/CopyButton.astro";
import OpenExternalUrlButton from "@components/ui/OpenExternalUrlButton.astro";
import type { ImportantLink } from "./types";

interface Props {
  link: ImportantLink;
  category: string;
}

interface LinkAction {
  id: string;
  title: string;
  url: string;
  description?: string;
}

const { link, category } = Astro.props;

const searchText = [
  category,
  link.title,
  link.url,
  link.subtitle ?? "",
  link.description ?? "",
].join(" ");

const isWebUrl = (url: string): boolean => /^https?:\/\//i.test(url);

const getDisplaySubtitle = (option: ImportantLink): string =>
  option.subtitle ?? option.description ?? "";

const mainAction: LinkAction = {
  id: link.id,
  title: link.title,
  url: link.url,
  description: getDisplaySubtitle(link),
};

const linkSubtitle = getDisplaySubtitle(link);

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";
const iconUrl = link.iconPath ? `${cleanBase}api/icons/${link.iconPath}` : null;
---

<li
  class:list={[
    "rounded border border-base-300 bg-base-100 relative hover:z-20 transition-all",
    link.deprecated && "opacity-50",
  ]}
  data-link-item
  data-link-search={searchText}
>
  <div
    class="group flex items-start justify-between gap-3 p-3 transition-colors hover:bg-base-200/40 focus-within:bg-base-200/40 rounded-[inherit]"
  >
    {/* Left: Icon and Details */}
    <div class="flex items-start gap-3 min-w-0 flex-1">
      <div
        class="flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded bg-base-200 p-1"
      >
        {
          iconUrl ? (
            <Image
              src={iconUrl}
              alt={`Ícono de ${link.title}`}
              width={36}
              height={36}
              class="h-full w-full object-contain"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Icon
              name="boxicons:link"
              class="h-5 w-5 text-base-content/40"
              aria-hidden="true"
            />
          )
        }
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2">
          <span
            class="truncate text-sm font-bold text-base-content"
            title={link.title}
            data-highlight-target
          >
            {link.title}
          </span>
          {
            link.deprecated && (
              <span class="badge badge-neutral badge-xs font-semibold shrink-0">
                Obsoleto
              </span>
            )
          }
        </div>

        {
          linkSubtitle && (
            <span
              class="block truncate text-xs text-base-content/60"
              data-highlight-target
            >
              {linkSubtitle}
            </span>
          )
        }

        {
          link.credentials && (
            <details class="group/creds mt-1.5">
              <summary class="list-none btn btn-xs w-full justify-start">
                <Icon name="boxicons:key" size={14} class="shrink-0" />
                <span class="group-open/creds:hidden">
                  Mostrar credenciales
                </span>
                <span class="hidden group-open/creds:inline">
                  Ocultar credenciales
                </span>
              </summary>
              <div class="mt-2 space-y-1.5 bg-base-200 p-2 rounded text-xs">
                {link.credentials.username && (
                  <div class="flex items-center justify-between gap-3">
                    <span
                      class="text-base-content/50 flex items-center gap-1 shrink-0"
                      title="Usuario"
                    >
                      <Icon
                        name="boxicons:user-filled"
                        size={14}
                        aria-hidden="true"
                      />
                    </span>
                    <div class="flex items-center gap-1.5 min-w-0 flex-1 justify-end">
                      <code
                        class="font-mono bg-base-300 px-1.5 py-0.5 rounded text-base-content font-bold truncate max-w-full"
                        title={link.credentials.username}
                      >
                        {link.credentials.username}
                      </code>
                      <CopyButton
                        value={link.credentials.username}
                        variant="icon"
                        appearance="ghost"
                        size="xs"
                        tooltipText="Copiar usuario"
                        showTooltip={true}
                        ariaLabel="Copiar usuario de credencial"
                      />
                    </div>
                  </div>
                )}
                {link.credentials.password && (
                  <div class="flex items-center justify-between gap-3">
                    <span
                      class="text-base-content/50 flex items-center gap-1 shrink-0"
                      title="Contraseña"
                    >
                      <Icon
                        name="boxicons:lock-filled"
                        size={14}
                        aria-hidden="true"
                      />
                    </span>
                    <div class="flex items-center gap-1.5 min-w-0 flex-1 justify-end">
                      <input
                        type="password"
                        value={link.credentials.password}
                        readonly
                        class="input input-xs font-mono bg-base-300 border-none flex-1 min-w-0 text-base-content text-right font-bold pr-1"
                        data-password-input
                      />
                      <button
                        type="button"
                        class="btn btn-xs btn-ghost btn-square text-base-content/60 shrink-0"
                        data-toggle-password
                        title="Mostrar/Ocultar contraseña"
                        aria-label="Mostrar u ocultar contraseña"
                      >
                        <Icon
                          name="boxicons:eye-filled"
                          size={16}
                          data-show-icon
                        />
                        <Icon
                          name="boxicons:eye-slash-filled"
                          size={16}
                          class="hidden"
                          data-hide-icon
                        />
                      </button>
                      <CopyButton
                        value={link.credentials.password}
                        variant="icon"
                        appearance="ghost"
                        size="xs"
                        tooltipText="Copiar contraseña"
                        showTooltip={true}
                        ariaLabel="Copiar contraseña de credencial"
                      />
                    </div>
                  </div>
                )}
              </div>
            </details>
          )
        }
      </div>
    </div>

    {/* Right: Floating action buttons (hover only, inline) */}
    <div
      class="flex shrink-0 items-center gap-1.5 opacity-0 transition-all duration-150 group-hover:opacity-100 focus-within:opacity-100"
    >
      <CopyButton
        value={mainAction.url}
        variant="icon"
        appearance="surface"
        size="sm"
        tooltipText={mainAction.url}
        showTooltip={true}
        ariaLabel={`Copiar URL de ${mainAction.title}`}
      />

      <OpenExternalUrlButton
        href={isWebUrl(mainAction.url) ? mainAction.url : undefined}
        variant="icon"
        appearance="solid"
        tone="secondary"
        size="sm"
        disabled={!isWebUrl(mainAction.url)}
        ariaLabel={isWebUrl(mainAction.url)
          ? `Abrir en una nueva pestaña`
          : `No se puede abrir; copiá la ruta`}
      />
    </div>
  </div>
</li>

<script>
  const initPasswordToggles = () => {
    document.querySelectorAll("[data-toggle-password]").forEach((btn) => {
      if (btn.getAttribute("data-listener-added") === "true") return;
      btn.setAttribute("data-listener-added", "true");

      btn.addEventListener("click", () => {
        const parent = btn.closest("div");
        if (!parent) return;
        const input = parent.querySelector(
          "[data-password-input]",
        ) as HTMLInputElement | null;
        const showIcon = parent.querySelector(
          "[data-show-icon]",
        ) as HTMLElement | null;
        const hideIcon = parent.querySelector(
          "[data-hide-icon]",
        ) as HTMLElement | null;

        if (input) {
          if (input.type === "password") {
            input.type = "text";
            showIcon?.classList.add("hidden");
            hideIcon?.classList.remove("hidden");
          } else {
            input.type = "password";
            showIcon?.classList.remove("hidden");
            hideIcon?.classList.add("hidden");
          }
        }
      });
    });
  };

  initPasswordToggles();
  document.addEventListener("astro:page-load", initPasswordToggles);
</script>
