---
import { Icon } from "astro-icon/components";
import CopyButton from "@components/ui/CopyButton.astro";
import OpenExternalUrlButton from "@components/ui/OpenExternalUrlButton.astro";
import type { ImportantLink } from "./types";

interface Props {
  link: ImportantLink;
  category: string;
}

interface LinkAction {
  id: string;
  title: string;
  url: string;
  description?: string;
}

const { link, category } = Astro.props;

const searchText = [
  category,
  link.title,
  link.url,
  link.subtitle ?? "",
  link.description ?? "",
].join(" ");

const isWebUrl = (url: string): boolean => /^https?:\/\//i.test(url);

const getDisplaySubtitle = (option: ImportantLink): string =>
  option.subtitle ?? option.description ?? "";

const mainAction: LinkAction = {
  id: link.id,
  title: link.title,
  url: link.url,
  description: getDisplaySubtitle(link),
};

const linkSubtitle = getDisplaySubtitle(link);

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";
const iconUrl = link.iconPath ? `${cleanBase}api/icons/${link.iconPath}` : null;
---

<li
  class:list={[
    "rounded border border-base-300 bg-base-100 relative hover:z-20 transition-all",
    link.deprecated && "opacity-50",
  ]}
  data-link-item
  data-link-search={searchText}
>
  <div
    class="group flex items-center justify-between gap-3 p-3 transition-colors hover:bg-base-200/40 focus-within:bg-base-200/40 rounded-[inherit]"
  >
    {/* Left: Icon and Details */}
    <div class="flex items-center gap-3 min-w-0 flex-1">
      <div
        class="flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded bg-base-200 p-1"
      >
        {
          iconUrl ? (
            <img
              src={iconUrl}
              alt={`Ícono de ${link.title}`}
              class="h-full w-full object-contain"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Icon
              name="boxicons:link"
              class="h-5 w-5 text-base-content/40"
              aria-hidden="true"
            />
          )
        }
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2">
          <span
            class="truncate text-sm font-bold text-base-content"
            title={link.title}
            data-highlight-target
          >
            {link.title}
          </span>
          {
            link.deprecated && (
              <span class="badge badge-neutral badge-xs font-semibold shrink-0">
                Obsoleto
              </span>
            )
          }
        </div>

        {
          linkSubtitle && (
            <span
              class="block truncate text-xs leading-normal text-base-content/60"
              data-highlight-target
            >
              {linkSubtitle}
            </span>
          )
        }
      </div>
    </div>

    {/* Right: Floating action buttons (hover only, inline) */}
    <div
      class="flex shrink-0 items-center gap-1.5 opacity-0 transition-all duration-150 group-hover:opacity-100 focus-within:opacity-100"
    >
      <CopyButton
        value={mainAction.url}
        variant="icon"
        appearance="surface"
        size="sm"
        tooltipText={mainAction.url}
        showTooltip={true}
        ariaLabel={`Copiar URL de ${mainAction.title}`}
      />

      <OpenExternalUrlButton
        href={isWebUrl(mainAction.url) ? mainAction.url : undefined}
        variant="icon"
        appearance="solid"
        tone="secondary"
        size="sm"
        disabled={!isWebUrl(mainAction.url)}
        ariaLabel={isWebUrl(mainAction.url)
          ? `Abrir en una nueva pestaña`
          : `No se puede abrir; copiá la ruta`}
      />
    </div>
  </div>
</li>
