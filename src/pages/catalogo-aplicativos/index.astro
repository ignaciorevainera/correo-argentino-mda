---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import CatalogAppCard from "./_components/CatalogAppCard.astro";
import CatalogBundleBanner from "./_components/CatalogBundleBanner.astro";
import { db } from "@db/index";
import { applications, applicationCategories } from "@db/schema";
import { eq } from "drizzle-orm";

const BUNDLE_CATEGORY_ID = "paquetes";

interface AppRow {
  id: number;
  title: string;
  categoryId: string | null;
  description: string | null;
  version: string | null;
  filePath: string | null;
  categoryTitle: string | null;
}

let allApps: AppRow[] = [];
let categories: { id: string; title: string }[] = [];
let errorMsg = "";

try {
  const rawApps = await db
    .select({
      id: applications.id,
      title: applications.title,
      categoryId: applications.categoryId,
      description: applications.description,
      version: applications.version,
      filePath: applications.filePath,
      categoryTitle: applicationCategories.title,
    })
    .from(applications)
    .leftJoin(
      applicationCategories,
      eq(applications.categoryId, applicationCategories.id),
    );

  allApps = rawApps;
  categories = await db.select().from(applicationCategories);
} catch (error: any) {
  errorMsg = "No se pudo cargar el catálogo. Intentá de nuevo más tarde.";
}

const bundleApps = allApps.filter(
  (app) => app.categoryId === BUNDLE_CATEGORY_ID,
);
const bundle = bundleApps.length > 0 ? bundleApps[0] : null;

const regularApps = allApps.filter(
  (app) => app.categoryId !== BUNDLE_CATEGORY_ID,
);

const displayCategories = categories.filter(
  (cat) => cat.id !== BUNDLE_CATEGORY_ID,
);

const appsByCategory = new Map<string, AppRow[]>();
const uncategorized: AppRow[] = [];

for (const app of regularApps) {
  if (app.categoryId) {
    const existing = appsByCategory.get(app.categoryId) ?? [];
    existing.push(app);
    appsByCategory.set(app.categoryId, existing);
  } else {
    uncategorized.push(app);
  }
}
---

<BaseLayout>
  <PageContainer width="wide">
    <PageHeader
      description="Descarga herramientas de operatoria diaria de mesa de ayuda en formato paquete .zip o por aplicativo individual según tu necesidad."
    />

    {
      errorMsg && (
        <div role="alert" class="alert alert-error alert-soft text-sm">
          <Icon
            name="boxicons:alert-circle-filled"
            size={20}
            class="shrink-0"
          />
          <span>{errorMsg}</span>
        </div>
      )
    }

    {
      bundle && (
        <CatalogBundleBanner
          title={bundle.title}
          description={bundle.description ?? ""}
          filePath={bundle.filePath}
        />
      )
    }

    {
      displayCategories.map((cat) => {
        const apps = appsByCategory.get(cat.id) ?? [];
        if (apps.length === 0) return null;

        return (
          <section class="space-y-3" aria-labelledby={`cat-${cat.id}`}>
            <div class="flex items-center gap-2">
              <Icon
                name="boxicons:folder-filled"
                size={20}
                class="text-base-content/70"
                aria-hidden="true"
              />
              <h2
                id={`cat-${cat.id}`}
                class="text-lg font-semibold text-base-content"
              >
                {cat.title}
              </h2>
              <span class="badge badge-sm badge-ghost">{apps.length}</span>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
              {apps.map((app) => (
                <CatalogAppCard
                  title={app.title}
                  description={app.description}
                  version={app.version}
                  filePath={app.filePath}
                  categoryTitle={app.categoryTitle}
                />
              ))}
            </div>
          </section>
        );
      })
    }

    {
      uncategorized.length > 0 && (
        <section class="space-y-3" aria-labelledby="cat-otros">
          <div class="flex items-center gap-2">
            <Icon
              name="boxicons:folder-filled"
              size={20}
              class="text-base-content/70"
              aria-hidden="true"
            />
            <h2 id="cat-otros" class="text-lg font-semibold text-base-content">
              Otros
            </h2>
            <span class="badge badge-sm badge-ghost">
              {uncategorized.length}
            </span>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {uncategorized.map((app) => (
              <CatalogAppCard
                title={app.title}
                description={app.description}
                version={app.version}
                filePath={app.filePath}
                categoryTitle={null}
              />
            ))}
          </div>
        </section>
      )
    }

    {
      !errorMsg && regularApps.length === 0 && !bundle && (
        <div class="card bg-base-100 border border-base-300 p-12 text-center">
          <Icon
            name="boxicons:archive-in"
            size={48}
            class="mx-auto text-base-content/30 mb-3"
          />
          <p class="text-base-content/60 text-sm">
            No hay aplicativos disponibles todavía.
          </p>
        </div>
      )
    }
  </PageContainer>
</BaseLayout>
