---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import catalogData from "../../data/catalogo_aplicativos.json";
import CatalogAppCard from "./_components/CatalogAppCard.astro";
import CatalogBundleBanner from "./_components/CatalogBundleBanner.astro";
import type { CatalogViewModel } from "./_components/types";

const { bundle, items } = catalogData as CatalogViewModel;
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      description="Descarga herramientas de operatoria diaria de mesa de ayuda en formato paquete .zip o por aplicativo individual según tu necesidad."
    />

    <CatalogBundleBanner bundle={bundle} />

    <section class="space-y-3" aria-labelledby="catálogo-individual-title">
      <div class="flex items-center gap-2">
        <Icon
          name="boxicons:link-filled"
          size={20}
          class="text-base-content/70"
          aria-hidden="true"
        />
        <h2
          id="catalogo-individual-title"
          class="text-lg font-semibold text-base-content"
        >
          Descarga por aplicativo
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
        {items.map((item) => <CatalogAppCard item={item} />)}
      </div>
    </section>
  </PageContainer>
</BaseLayout>
