---
import { Icon } from "astro-icon/components";
import CatalogSoftBadge from "./CatalogSoftBadge.astro";
import type { CatalogItem } from "./types";

interface Props {
  item: CatalogItem;
}

type BadgeTone = "primary" | "secondary" | "accent" | "neutral" | "warning";

const { item } = Astro.props;

const isWebUrl = (value: string): boolean => /^https?:\/\//i.test(value);
const itemUrl = item.url?.trim() ?? "";
const hasItemUrl = itemUrl.length > 0;
const isExternal = hasItemUrl && isWebUrl(itemUrl);
const variants = Array.isArray(item.variants) ? item.variants : [];
const hasVariants = variants.length > 0;
const typeToneMap: Partial<Record<string, BadgeTone>> = {
  Programa: "secondary",
  Extension: "accent",
};
const typeTone = typeToneMap[item.type] ?? "neutral";
---

<article
  class="card h-full border border-base-300 bg-base-100 shadow-sm transition-colors hover:border-secondary/40"
>
  <div class="card-body gap-4 p-4 sm:p-5">
    <div class="flex items-start justify-between gap-3">
      <CatalogSoftBadge tone={typeTone}>{item.type}</CatalogSoftBadge>

      {
        hasVariants ? (
          <CatalogSoftBadge tone="primary" class="shrink-0">
            {variants.length} versiones
          </CatalogSoftBadge>
        ) : (
          item.version && (
            <CatalogSoftBadge tone="neutral" class="shrink-0">
              {item.version}
            </CatalogSoftBadge>
          )
        )
      }
    </div>

    <div class="min-w-0 space-y-2">
      <h3 class="text-base font-semibold leading-tight text-base-content">
        {item.title}
      </h3>
      <p class="text-sm leading-relaxed text-base-content/70">
        {item.description}
      </p>
    </div>

    {
      hasVariants ? (
        <div class="dropdown dropdown-bottom w-full">
          <div
            tabindex="0"
            role="button"
            class="btn btn-outline btn-sm w-full justify-between border-base-300 bg-base-100 text-base-content shadow-none hover:bg-base-200"
          >
            <span>Ver versiones disponibles</span>
            <Icon
              name="boxicons:chevron-down-filled"
              class="size-4 shrink-0"
              aria-hidden="true"
            />
          </div>

          <ul
            tabindex="-1"
            class="dropdown-content menu bg-base-100 rounded-box z-10 mt-2 w-full border border-base-300 p-2 shadow-lg"
          >
            {variants.map((variant) => {
              const variantUrl = variant.url?.trim() ?? "";
              const hasVariantUrl = variantUrl.length > 0;
              const isVariantExternal =
                hasVariantUrl && isWebUrl(variantUrl);

              return (
                <li class="rounded-lg">
                  {hasVariantUrl ? (
                    <a
                      href={variantUrl}
                      class="flex items-start gap-3 rounded-lg px-3 py-3 transition hover:bg-base-100"
                      target={isVariantExternal ? "_blank" : undefined}
                      rel={
                        isVariantExternal ? "noopener noreferrer" : undefined
                      }
                    >
                      <CatalogSoftBadge tone="neutral" class="shrink-0">
                        {variant.version}
                      </CatalogSoftBadge>
                      <span class="min-w-0">
                        <span class="block text-sm font-medium text-base-content">
                          Descargar version {variant.version}
                        </span>
                        <span class="mt-1 block text-xs leading-relaxed text-base-content/70">
                          {variant.description}
                        </span>
                      </span>
                    </a>
                  ) : (
                    <div class="flex items-start gap-3 rounded-lg px-3 py-3">
                      <CatalogSoftBadge tone="warning" class="shrink-0">
                        {variant.version}
                      </CatalogSoftBadge>
                      <span class="min-w-0">
                        <span class="block text-sm font-medium text-base-content">
                          Version pendiente
                        </span>
                        <span class="mt-1 block text-xs leading-relaxed text-base-content/70">
                          {variant.description}
                        </span>
                      </span>
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ) : (
        <div class="card-actions mt-auto justify-end pt-1">
          {hasItemUrl ? (
            <a
              href={itemUrl}
              class="btn btn-secondary btn-sm gap-2"
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
            >
              <Icon
                name="boxicons:arrow-up-right-square-filled"
                class="size-4"
                aria-hidden="true"
              />
              <span>Descargar</span>
            </a>
          ) : (
            <button
              type="button"
              class="btn btn-ghost btn-disabled btn-sm gap-2"
              disabled
            >
              <Icon name="boxicons:calendar-filled" class="size-4" aria-hidden="true" />
              <span>Pendiente</span>
            </button>
          )}
        </div>
      )
    }
  </div>
</article>
