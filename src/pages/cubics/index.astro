---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import CopyButton from "@components/ui/CopyButton.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import {
  cubicMachines,
  getActiveMachineCount,
  type CubicShift,
  type CubicStatus,
} from "@lib/cubics";

const onlineCount = getActiveMachineCount(cubicMachines);
const totalMachines = cubicMachines.length;

const statusCopy: Record<CubicStatus, string> = {
  online: "Online",
  offline: "Offline",
};

const shiftIcon: Record<CubicShift, string> = {
  morning: "boxicons:sun",
  afternoon_night: "boxicons:moon",
};

const shiftIconTone: Record<CubicShift, string> = {
  morning: "border-warning/40 bg-warning text-warning-content",
  afternoon_night: "border-info/40 bg-info text-info-content",
};
---

<BaseLayout title="Cubics">
  <section class="flex flex-col gap-6">
    <div
      class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between"
    >
      <header class="space-y-2">
        <h1 class="text-3xl font-bold">Cubics</h1>
        <p class="text-sm text-base-content/70 sm:text-base">
          Monitoreo operativo de hostnames, IPs y responsables asignados.
        </p>
      </header>

      <aside
        class="card w-full border border-base-300 bg-base-100 shadow-sm lg:max-w-xs"
        aria-label="Resumen de conectividad"
      >
        <div class="card-body gap-2 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-base-content/60"
          >
            Conectividad actual
          </p>
          <div class="flex flex-wrap items-center gap-2">
            <span class="badge badge-success badge-lg font-mono"
              >{onlineCount}/{totalMachines}</span
            >
            <span class="text-sm text-base-content/70">online/total</span>
          </div>
        </div>
      </aside>
    </div>

    <div
      class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between"
    >
      <div class="w-full max-w-md">
        <SearchInput
          id="machine-search"
          label="Buscar cubic por hostname, direccion IP o usuario asignado"
          placeholder="Buscar por hostname, IP o usuario"
        />
      </div>

      <div
        class="tabs tabs-box self-start md:self-auto"
        role="radiogroup"
        aria-label="Filtros por estado"
      >
        <input
          type="radio"
          name="cubic_filters"
          class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)] checked:[--tab-border-color:var(--color-primary)]"
          aria-label="Todos"
          checked
          data-filter-tab
          data-filter="all"
        />
        <input
          type="radio"
          name="cubic_filters"
          class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)] checked:[--tab-border-color:var(--color-primary)]"
          aria-label="Online"
          data-filter-tab
          data-filter="online"
        />
        <input
          type="radio"
          name="cubic_filters"
          class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)] checked:[--tab-border-color:var(--color-primary)]"
          aria-label="Offline"
          data-filter-tab
          data-filter="offline"
        />
      </div>
    </div>

    <section class="space-y-3">
      <div
        id="cubics-empty-state"
        class="alert alert-warning hidden"
        role="status"
      >
        <Icon
          name="boxicons:alert-triangle"
          class="size-5"
          aria-hidden="true"
        />
        <span>No se encontraron resultados para la busqueda actual.</span>
      </div>

      <div
        class="overflow-x-auto rounded-box border border-base-300 bg-base-200/70 shadow-sm"
      >
        <div class="min-w-max md:min-w-full">
          <div
            class="hidden border-b border-base-300 bg-base-300/40 px-4 py-3 md:grid md:grid-cols-12 md:gap-4"
          >
            <p
              class="col-span-4 font-mono text-sm font-semibold text-base-content/70"
            >
              Hostname
            </p>
            <p
              class="col-span-3 font-mono text-sm font-semibold text-base-content/70"
            >
              Direccion IP
            </p>
            <p class="col-span-2 text-sm font-semibold text-base-content/70">
              Estado
            </p>
            <p class="col-span-3 text-sm font-semibold text-base-content/70">
              Asignado a
            </p>
          </div>

          <div>
            {
              cubicMachines.map((machine) => {
                const assignmentSearchValue =
                  machine.assignments.length > 0
                    ? machine.assignments
                        .map((assignment) => assignment.agent.name)
                        .join(" ")
                    : "Sin asignar";

                return (
                  <article
                    data-machine-row
                    data-name={machine.name}
                    data-ip={machine.ip}
                    data-agent={assignmentSearchValue}
                    data-status={machine.status}
                    class="grid grid-cols-1 gap-3 border-b border-base-300 px-4 py-4 transition-colors hover:bg-base-300/50 last:border-b-0 md:grid-cols-12 md:items-center md:gap-4"
                  >
                    <div class="space-y-2 md:col-span-4">
                      <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60 md:hidden">
                        Hostname
                      </p>
                      <div class="flex items-center gap-3">
                        <span
                          class="inline-flex size-8 shrink-0 items-center justify-center rounded-lg border border-accent/30 bg-accent/20 text-accent"
                          aria-hidden="true"
                        >
                          <Icon
                            name="boxicons:desktop"
                            class="size-4"
                          />
                        </span>
                        <div class="min-w-0 flex-1">
                          <CopyButton
                            value={machine.name}
                            variant="value"
                            appearance="ghost"
                            label={machine.name}
                            ariaLabel={`Copiar ${machine.name}`}
                            monospace
                            fullWidth
                            highlightable
                            class="-ml-2"
                          />
                        </div>
                      </div>
                    </div>

                    <div class="space-y-2 md:col-span-3">
                      <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60 md:hidden">
                        Direccion IP
                      </p>
                      <CopyButton
                        value={machine.ip}
                        variant="value"
                        appearance="ghost"
                        label={machine.ip}
                        ariaLabel={`Copiar ${machine.ip}`}
                        monospace
                        fullWidth
                        highlightable
                        class="-ml-2"
                      />
                    </div>

                    <div class="space-y-2 md:col-span-2">
                      <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60 md:hidden">
                        Estado
                      </p>
                      <div class="flex items-center gap-2">
                        <div class="inline-grid *:[grid-area:1/1]">
                          <div
                            class:list={[
                              "status",
                              machine.status === "online"
                                ? "status-success"
                                : "status-error",
                              "animate-ping",
                              "motion-reduce:animate-none",
                            ]}
                          />
                          <div
                            class:list={[
                              "status",
                              machine.status === "online"
                                ? "status-success"
                                : "status-error",
                            ]}
                          />
                        </div>
                        <span class="text-sm text-base-content/80">
                          {statusCopy[machine.status]}
                        </span>
                      </div>
                    </div>

                    <div class="space-y-2 md:col-span-3">
                      <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60 md:hidden">
                        Asignado a
                      </p>
                      <div class="min-w-0 space-y-1.5">
                        <div class="flex items-center gap-2">
                          {machine.assignments.length > 0 ? (
                            machine.assignments.map((assignment) => {
                              const assignmentTooltip = assignment.agent.name;

                              return (
                                <div
                                  class="tooltip tooltip-top tooltip-neutral z-20"
                                  data-tip={assignmentTooltip}
                                >
                                  <div class="relative inline-flex overflow-visible">
                                    <div
                                      class="avatar avatar-placeholder"
                                      role="img"
                                      tabindex="0"
                                      aria-label={`Usuario asignado: ${assignmentTooltip}`}
                                    >
                                      <div class="w-9 rounded-full bg-base-200 text-base-content/70">
                                        <span
                                          class="text-xs font-semibold select-none"
                                          aria-hidden="true"
                                        >
                                          {assignment.agent.avatarInitials}
                                        </span>
                                      </div>
                                    </div>
                                    <span
                                      class:list={[
                                        "pointer-events-none absolute -bottom-1 -right-1 z-0 inline-flex size-4 items-center justify-center rounded-full border",
                                        shiftIconTone[assignment.shift],
                                      ]}
                                    >
                                      <Icon
                                        name={shiftIcon[assignment.shift]}
                                        class="size-2.5"
                                        aria-hidden="true"
                                      />
                                    </span>
                                  </div>
                                </div>
                              );
                            })
                          ) : (
                            <div
                              class="tooltip tooltip-top tooltip-neutral z-20"
                              data-tip="Sin asignar"
                            >
                              <div
                                class="avatar avatar-placeholder"
                                role="img"
                                tabindex="0"
                                aria-label="Usuario asignado: Sin asignar"
                              >
                                <div class="w-9 rounded-full bg-base-200 text-base-content/70">
                                  <span
                                    class="text-xs font-semibold select-none"
                                    aria-hidden="true"
                                  >
                                    --
                                  </span>
                                </div>
                              </div>
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  </article>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>
  </section>

  <script>
    import {
      highlightSearchTargets,
      matchesSearchQuery,
    } from "@lib/clientSearch";

    const searchInput =
      document.querySelector<HTMLInputElement>("#machine-search");
    const filterTabs = Array.from(
      document.querySelectorAll<HTMLInputElement>("[data-filter-tab]"),
    );
    const rows = Array.from(
      document.querySelectorAll<HTMLElement>("[data-machine-row]"),
    );
    const emptyState =
      document.querySelector<HTMLElement>("#cubics-empty-state");

    if (
      searchInput instanceof HTMLInputElement &&
      emptyState instanceof HTMLElement
    ) {
      let selectedFilter = "all";

      const updateRows = () => {
        const rawSearchValue = searchInput.value.trim();
        let visibleRows = 0;

        rows.forEach((row) => {
          const status = row.dataset.status ?? "";

          const matchesSearch = matchesSearchQuery(rawSearchValue, [
            row.dataset.name,
            row.dataset.ip,
            row.dataset.agent,
          ]);
          const matchesFilter =
            selectedFilter === "all" ||
            (selectedFilter === "online" && status === "online") ||
            (selectedFilter === "offline" && status === "offline");

          const isVisible = matchesSearch && matchesFilter;
          row.classList.toggle("hidden", !isVisible);
          highlightSearchTargets(row, isVisible ? rawSearchValue : "");

          if (isVisible) {
            visibleRows += 1;
          }
        });

        emptyState.classList.toggle("hidden", visibleRows > 0);
      };

      searchInput.addEventListener("input", updateRows);

      filterTabs.forEach((tab) => {
        tab.addEventListener("change", () => {
          if (!tab.checked) {
            return;
          }

          selectedFilter = tab.dataset.filter ?? "all";
          updateRows();
        });
      });

      updateRows();
    }
  </script>
</BaseLayout>
