---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { usefulContactCategories } from "@/data/contactos_utiles";
import type { UsefulContactCategory } from "@/types/contactos-utiles";

interface CategoryTheme {
  iconContainerClass: string;
  headerClass: string;
  topBorderClass: string;
  badgeClass: string;
}

const themeByTone: Record<UsefulContactCategory["tone"], CategoryTheme> = {
  primary: {
    iconContainerClass: "border-primary bg-primary text-primary-content",
    headerClass: "bg-primary/10",
    topBorderClass: "border-t-primary",
    badgeClass: "badge-primary",
  },
  secondary: {
    iconContainerClass: "border-secondary bg-secondary text-secondary-content",
    headerClass: "bg-secondary/10",
    topBorderClass: "border-t-secondary",
    badgeClass: "badge-secondary",
  },
  accent: {
    iconContainerClass: "border-accent bg-accent text-accent-content",
    headerClass: "bg-accent/10",
    topBorderClass: "border-t-accent",
    badgeClass: "badge-accent",
  },
  info: {
    iconContainerClass: "border-info bg-info text-info-content",
    headerClass: "bg-info/10",
    topBorderClass: "border-t-info",
    badgeClass: "badge-info",
  },
  success: {
    iconContainerClass: "border-success bg-success text-success-content",
    headerClass: "bg-success/10",
    topBorderClass: "border-t-success",
    badgeClass: "badge-success",
  },
  warning: {
    iconContainerClass: "border-warning bg-warning text-warning-content",
    headerClass: "bg-warning/10",
    topBorderClass: "border-t-warning",
    badgeClass: "badge-warning",
  },
};

const getCategoryTheme = (category: UsefulContactCategory): CategoryTheme =>
  themeByTone[category.tone];

const getCategorySearchText = (category: UsefulContactCategory): string =>
  category.contacts
    .map((contact) =>
      [
        category.title,
        contact.provider,
        contact.service,
        contact.phones.join(" "),
        contact.emails.join(" "),
        contact.urls
          .map((resource) => `${resource.label} ${resource.url}`)
          .join(" "),
      ].join(" "),
    )
    .join(" ");

const getContactSearchText = (
  category: UsefulContactCategory,
  contact: UsefulContactCategory["contacts"][number],
): string =>
  [
    category.title,
    contact.provider,
    contact.service,
    contact.phones.join(" "),
    contact.emails.join(" "),
    contact.urls
      .map((resource) => `${resource.label} ${resource.url}`)
      .join(" "),
  ].join(" ");
---

<BaseLayout title="Contactos útiles | Portal Mesa de Ayuda">
  <section class="mx-auto flex w-full max-w-7xl flex-col gap-6">
    <header class="space-y-2">
      <h1 class="text-3xl font-bold text-base-content">Contactos útiles</h1>
      <p
        class="max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base"
      >
        Directorio operativo para ubicar teléfonos, correos y accesos clave sin
        salir del flujo de soporte.
      </p>
    </header>

    <div class="w-full max-w-xl">
      <label class="input input-bordered w-full" for="contacts-search">
        <Icon
          name="boxicons:search"
          class="size-4 text-base-content/50"
          aria-hidden="true"
        />
        <input
          id="contacts-search"
          type="search"
          class="grow"
          placeholder="Buscar por proveedor, servicio, teléfono, email o link"
          autocomplete="off"
          aria-label="Buscar contacto por proveedor, servicio, telefono, email o link"
        />
      </label>
    </div>

    <section
      id="contacts-empty-state"
      class="hidden min-h-100 rounded-2xl border-2 border-dashed border-base-300 bg-base-200/30 p-8"
      role="status"
      aria-live="polite"
    >
      <div
        class="flex min-h-80 flex-col items-center justify-center text-center"
      >
        <div
          class="mb-4 inline-flex size-14 items-center justify-center rounded-2xl bg-base-300/60 text-base-content/45"
          aria-hidden="true"
        >
          <Icon name="boxicons:search" class="size-7" />
        </div>
        <h2 class="text-lg font-semibold text-base-content">Sin resultados</h2>
        <p class="mt-2 max-w-md text-sm leading-relaxed text-base-content/65">
          No hay contactos que coincidan con la búsqueda actual. Probá con otro
          proveedor, servicio, teléfono, correo o enlace.
        </p>
      </div>
    </section>

    <section
      class="flex flex-col gap-5"
      aria-label="Directorio de contactos útiles"
      id="contacts-grid"
    >
      {
        usefulContactCategories.map((category) => {
          const categoryTheme = getCategoryTheme(category);

          return (
            <article
              class:list={[
                "card overflow-hidden border border-t-4 border-base-300 bg-base-100 shadow-sm transition-shadow hover:shadow-md",
                categoryTheme.topBorderClass,
              ]}
              data-contact-category-card
              data-category-search={getCategorySearchText(category)}
            >
              <header
                class:list={[
                  "flex items-center justify-between gap-3 border-b border-base-300 p-4",
                  categoryTheme.headerClass,
                ]}
              >
                <div class="flex min-w-0 items-center gap-3">
                  <span
                    class:list={[
                      "inline-flex size-10 shrink-0 items-center justify-center rounded-lg border shadow-sm",
                      categoryTheme.iconContainerClass,
                    ]}
                    aria-hidden="true"
                  >
                    <Icon name={category.icon} class="size-5" />
                  </span>

                  <div class="min-w-0">
                    <h2 class="truncate text-base font-semibold text-base-content">
                      {category.title}
                    </h2>
                    <p class="text-xs text-base-content/60">
                      {category.contacts.length} referencias disponibles
                    </p>
                  </div>
                </div>
              </header>

              <div class="card-body p-0">
                <div class="overflow-x-auto">
                  <table class="table table-sm table-fixed min-w-max">
                    <colgroup>
                      <col class="w-2/12" />
                      <col class="w-2/12" />
                      <col class="w-2/12" />
                      <col class="w-3/12" />
                      <col class="w-3/12" />
                    </colgroup>
                    <thead>
                      <tr class="border-b border-base-300 text-xs uppercase tracking-wider text-base-content/60">
                        <th class="py-3 font-semibold">Servicio</th>
                        <th class="py-3 font-semibold">Proveedor</th>
                        <th class="py-3 font-semibold">Teléfono</th>
                        <th class="py-3 font-semibold">Correo</th>
                        <th class="py-3 font-semibold">Sitio web</th>
                      </tr>
                    </thead>
                    <tbody>
                      {category.contacts.map((contact) => (
                        <tr
                          class="group/row border-b border-base-300/70 transition-colors last:border-b-0 hover:bg-base-200/50"
                          data-contact-row
                          data-contact-search={getContactSearchText(
                            category,
                            contact,
                          )}
                        >
                          <td class="align-top">
                            <p
                              class="text-sm font-medium leading-snug text-base-content"
                              data-highlight-target
                            >
                              {contact.service}
                            </p>
                          </td>

                          <td class="align-top">
                            <p
                              class="text-xs font-semibold uppercase tracking-wider text-base-content/55"
                              data-highlight-target
                            >
                              {contact.provider}
                            </p>
                          </td>

                          <td class="align-top">
                            {contact.phones.length > 0 ? (
                              <div class="flex flex-col gap-1.5">
                                {contact.phones.map((phone) => (
                                  <div class="group flex min-w-0 items-center gap-1">
                                    <button
                                      type="button"
                                      class="inline-flex min-w-0 flex-1 items-center gap-2 rounded-lg border border-transparent px-2 py-1.5 text-left transition-colors hover:border-base-300 hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-accent"
                                      data-contact-copy-button
                                      data-copy-value={phone}
                                      aria-label={`Copiar telefono ${phone}`}
                                    >
                                      <span
                                        class="inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-primary text-primary-content"
                                        aria-hidden="true"
                                      >
                                        <Icon
                                          name="boxicons:phone"
                                          class="size-3.5"
                                        />
                                      </span>
                                      <span
                                        class="min-w-0 flex-1 truncate font-mono text-xs text-base-content/80 md:text-sm"
                                        data-copy-label
                                        data-highlight-target
                                      >
                                        {phone}
                                      </span>
                                      <span
                                        class="relative inline-flex size-4 shrink-0 items-center justify-center opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100"
                                        data-copy-action
                                        aria-hidden="true"
                                      >
                                        <Icon
                                          name="boxicons:clipboard"
                                          class="absolute inset-0 m-auto size-4 text-primary"
                                          data-copy-icon-default
                                        />
                                        <Icon
                                          name="boxicons:check"
                                          class="absolute inset-0 m-auto hidden size-4 text-success"
                                          data-copy-icon-success
                                        />
                                      </span>
                                    </button>
                                  </div>
                                ))}
                              </div>
                            ) : (
                              <span class="text-xs italic text-base-content/45">
                                Sin teléfono
                              </span>
                            )}
                          </td>

                          <td class="align-top">
                            {contact.emails.length > 0 ? (
                              <div class="flex flex-col gap-1.5">
                                {contact.emails.map((email) => (
                                  <div class="group flex min-w-0 items-center gap-1">
                                    <button
                                      type="button"
                                      class="inline-flex min-w-0 flex-1 items-center gap-2 rounded-lg border border-transparent px-2 py-1.5 text-left transition-colors hover:border-base-300 hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-accent"
                                      data-contact-copy-button
                                      data-copy-value={email}
                                      aria-label={`Copiar correo ${email}`}
                                    >
                                      <span
                                        class="inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-primary text-primary-content"
                                        aria-hidden="true"
                                      >
                                        <Icon
                                          name="boxicons:envelope"
                                          class="size-3.5"
                                        />
                                      </span>
                                      <span
                                        class="min-w-0 flex-1 truncate font-mono text-xs text-base-content/80 md:text-sm"
                                        data-copy-label
                                        data-highlight-target
                                      >
                                        {email}
                                      </span>
                                      <span
                                        class="relative inline-flex size-4 shrink-0 items-center justify-center opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100"
                                        data-copy-action
                                        aria-hidden="true"
                                      >
                                        <Icon
                                          name="boxicons:clipboard"
                                          class="absolute inset-0 m-auto size-4 text-primary"
                                          data-copy-icon-default
                                        />
                                        <Icon
                                          name="boxicons:check"
                                          class="absolute inset-0 m-auto hidden size-4 text-success"
                                          data-copy-icon-success
                                        />
                                      </span>
                                    </button>

                                    <a
                                      href={`mailto:${email}`}
                                      class="btn btn-ghost btn-square btn-xs shrink-0 text-secondary opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                      aria-label={`Abrir cliente de correo para ${email}`}
                                    >
                                      <Icon
                                        name="boxicons:arrow-up-right-square"
                                        class="size-4"
                                        aria-hidden="true"
                                      />
                                    </a>
                                  </div>
                                ))}
                              </div>
                            ) : (
                              <span class="text-xs italic text-base-content/45">
                                Sin correo
                              </span>
                            )}
                          </td>

                          <td class="align-top">
                            {contact.urls.length > 0 ? (
                              <div class="flex flex-col gap-1.5">
                                {contact.urls.map((resource) => (
                                  <div class="group flex min-w-0 items-center gap-1">
                                    <button
                                      type="button"
                                      class="inline-flex min-w-0 flex-1 items-center gap-2 rounded-lg border border-transparent px-2 py-1.5 text-left transition-colors hover:border-base-300 hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-accent"
                                      data-contact-copy-button
                                      data-copy-value={resource.url}
                                      aria-label={`Copiar link ${resource.label} de ${contact.service}`}
                                    >
                                      <span
                                        class="inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-primary text-primary-content"
                                        aria-hidden="true"
                                      >
                                        <Icon
                                          name="boxicons:link"
                                          class="size-3.5"
                                        />
                                      </span>
                                      <span class="min-w-0 flex-1">
                                        <span
                                          class="block truncate font-mono text-xs text-base-content/80 md:text-sm"
                                          data-copy-label
                                          data-highlight-target
                                        >
                                          {resource.url}
                                        </span>
                                        <span
                                          class="block truncate text-xs text-base-content/50"
                                          data-highlight-target
                                        >
                                          {resource.label}
                                        </span>
                                      </span>
                                      <span
                                        class="relative inline-flex size-4 shrink-0 items-center justify-center opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100"
                                        data-copy-action
                                        aria-hidden="true"
                                      >
                                        <Icon
                                          name="boxicons:clipboard"
                                          class="absolute inset-0 m-auto size-4 text-primary"
                                          data-copy-icon-default
                                        />
                                        <Icon
                                          name="boxicons:check"
                                          class="absolute inset-0 m-auto hidden size-4 text-success"
                                          data-copy-icon-success
                                        />
                                      </span>
                                    </button>

                                    <a
                                      href={resource.url}
                                      target="_blank"
                                      rel="noopener noreferrer"
                                      class="btn btn-ghost btn-square btn-xs shrink-0 text-secondary opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                      aria-label={`Abrir ${resource.label} en una nueva pestaña`}
                                    >
                                      <Icon
                                        name="boxicons:arrow-up-right-square"
                                        class="size-4"
                                        aria-hidden="true"
                                      />
                                    </a>
                                  </div>
                                ))}
                              </div>
                            ) : (
                              <span class="text-xs italic text-base-content/45">
                                Sin sitio web
                              </span>
                            )}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </article>
          );
        })
      }
    </section>
  </section>

  <script>
    interface CopyVisualState {
      defaultIcon: Element | null;
      successIcon: Element | null;
      actionIcon: HTMLElement | null;
      label: HTMLElement | null;
      originalLabel: string;
      resetTimer: number | null;
    }

    const feedbackDurationMs = 2000;

    const normalizeValue = (value: string): string =>
      value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    const escapeRegExp = (value: string): string =>
      value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const escapeHtml = (value: string): string =>
      value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const highlightText = (element: HTMLElement, query: string): void => {
      const originalText =
        element.dataset.originalText ?? element.textContent ?? "";

      if (!element.dataset.originalText) {
        element.dataset.originalText = originalText;
      }

      if (query.length === 0) {
        element.textContent = originalText;
        return;
      }

      const matcher = new RegExp(`(${escapeRegExp(query)})`, "ig");

      if (!matcher.test(originalText)) {
        element.textContent = originalText;
        return;
      }

      matcher.lastIndex = 0;
      const highlighted = originalText
        .split(matcher)
        .map((chunk, index) =>
          index % 2 === 1
            ? `<mark class=\"rounded bg-warning/30 px-0.5 text-base-content\">${escapeHtml(chunk)}</mark>`
            : escapeHtml(chunk),
        )
        .join("");

      element.innerHTML = highlighted;
    };

    const fallbackCopyToClipboard = (value: string): boolean => {
      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.setAttribute("readonly", "");
      textarea.setAttribute("aria-hidden", "true");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      textarea.style.top = "0";
      textarea.style.opacity = "0";

      document.body.append(textarea);
      textarea.focus();
      textarea.select();

      let copied = false;

      try {
        const legacyCopyApi = document as unknown as {
          execCommand?: (commandId: string) => boolean;
        };
        copied =
          typeof legacyCopyApi.execCommand === "function"
            ? legacyCopyApi.execCommand("copy")
            : false;
      } catch {
        copied = false;
      }

      textarea.remove();
      return copied;
    };

    const copyToClipboard = async (value: string): Promise<boolean> => {
      const canUseClipboardApi =
        typeof navigator !== "undefined" &&
        typeof navigator.clipboard !== "undefined" &&
        typeof navigator.clipboard.writeText === "function";

      if (canUseClipboardApi) {
        try {
          await navigator.clipboard.writeText(value);
          return true;
        } catch {
          return fallbackCopyToClipboard(value);
        }
      }

      return fallbackCopyToClipboard(value);
    };

    const searchInput =
      document.querySelector<HTMLInputElement>("#contacts-search");
    const emptyState = document.querySelector<HTMLElement>(
      "#contacts-empty-state",
    );
    const categoryCards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-contact-category-card]"),
    );
    const contactRows = Array.from(
      document.querySelectorAll<HTMLElement>("[data-contact-row]"),
    );

    const updateContactSearch = (): void => {
      if (!(searchInput instanceof HTMLInputElement)) {
        return;
      }

      const rawSearchValue = searchInput.value.trim();
      const searchValue = normalizeValue(rawSearchValue);
      let visibleRows = 0;

      contactRows.forEach((row) => {
        const searchableContent = normalizeValue(
          row.dataset.contactSearch ?? "",
        );
        const isVisible =
          searchValue.length === 0 || searchableContent.includes(searchValue);

        row.classList.toggle("hidden", !isVisible);

        const rowTargets = Array.from(
          row.querySelectorAll<HTMLElement>("[data-highlight-target]"),
        );

        rowTargets.forEach((target) => {
          highlightText(target, isVisible ? rawSearchValue : "");
        });

        if (isVisible) {
          visibleRows += 1;
        }
      });

      categoryCards.forEach((categoryCard) => {
        const categoryRows = Array.from(
          categoryCard.querySelectorAll<HTMLElement>("[data-contact-row]"),
        );
        const hasVisibleRows = categoryRows.some(
          (row) => !row.classList.contains("hidden"),
        );

        categoryCard.classList.toggle("hidden", !hasVisibleRows);
      });

      emptyState?.classList.toggle("hidden", visibleRows > 0);
    };

    searchInput?.addEventListener("input", updateContactSearch);
    updateContactSearch();

    const copyButtonStates = new WeakMap<HTMLButtonElement, CopyVisualState>();

    const resetCopiedState = (
      button: HTMLButtonElement,
      state: CopyVisualState,
    ): void => {
      button.classList.remove(
        "border-success/40",
        "bg-success/10",
        "text-success",
        "ring-1",
        "ring-success/30",
      );
      button.removeAttribute("data-copied");

      if (state.label instanceof HTMLElement) {
        state.label.classList.remove("text-success");
        highlightText(state.label, searchInput?.value.trim() ?? "");
      }

      if (state.actionIcon instanceof HTMLElement) {
        state.actionIcon.classList.remove("opacity-100");
      }

      if (state.defaultIcon instanceof Element) {
        state.defaultIcon.classList.remove("hidden");
      }

      if (state.successIcon instanceof Element) {
        state.successIcon.classList.add("hidden");
      }

      state.resetTimer = null;
    };

    const applyCopiedState = (
      button: HTMLButtonElement,
      state: CopyVisualState,
    ): void => {
      button.dataset.copied = "true";
      button.classList.add(
        "border-success/40",
        "bg-success/10",
        "text-success",
        "ring-1",
        "ring-success/30",
      );

      if (state.label instanceof HTMLElement) {
        state.label.textContent = "Copiado";
        state.label.classList.add("text-success");
      }

      if (state.actionIcon instanceof HTMLElement) {
        state.actionIcon.classList.add("opacity-100");
      }

      if (state.defaultIcon instanceof Element) {
        state.defaultIcon.classList.add("hidden");
      }

      if (state.successIcon instanceof Element) {
        state.successIcon.classList.remove("hidden");
      }

      if (state.resetTimer !== null) {
        window.clearTimeout(state.resetTimer);
      }

      state.resetTimer = window.setTimeout(() => {
        resetCopiedState(button, state);
      }, feedbackDurationMs);
    };

    const copyButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(
        "[data-contact-copy-button]",
      ),
    );

    copyButtons.forEach((button) => {
      if (button.dataset.copyBound === "true") {
        return;
      }

      button.dataset.copyBound = "true";

      const label = button.querySelector<HTMLElement>("[data-copy-label]");

      copyButtonStates.set(button, {
        defaultIcon: button.querySelector("[data-copy-icon-default]"),
        successIcon: button.querySelector("[data-copy-icon-success]"),
        actionIcon: button.querySelector<HTMLElement>("[data-copy-action]"),
        label,
        originalLabel: label?.textContent?.trim() ?? "",
        resetTimer: null,
      });

      button.addEventListener("click", async () => {
        const value = button.dataset.copyValue ?? "";

        if (value.trim().length === 0) {
          return;
        }

        const copied = await copyToClipboard(value);
        if (!copied) {
          return;
        }

        const state = copyButtonStates.get(button);
        if (!state) {
          return;
        }

        applyCopiedState(button, state);
      });
    });
  </script>
</BaseLayout>
