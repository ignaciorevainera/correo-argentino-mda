---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";

// Datos de ejemplo para las sucursales (mock)
// Normalmente esto vendría de una API o base de datos / archivo JSON
const sucursales = [
  {
    nis: "A1234",
    ubicacion: {
      lat: -34.6037,
      lng: -58.3816,
      nombre: "Sucursal Central - CABA",
    },
    region: "Centro",
    cantidad_pc: 15,
    servidores: 2,
    contacto: "011-4444-5555",
  },
  {
    nis: "B5678",
    ubicacion: { lat: -31.4201, lng: -64.1888, nombre: "Sucursal Córdoba" },
    region: "Centro",
    cantidad_pc: 8,
    servidores: 1,
    contacto: "0351-444-5555",
  },
  {
    nis: "C9012",
    ubicacion: { lat: -26.8241, lng: -65.2226, nombre: "Sucursal Tucumán" },
    region: "Norte",
    cantidad_pc: 5,
    servidores: 0,
    contacto: "0381-444-5555",
  },
  {
    nis: "D3456",
    ubicacion: { lat: -41.1335, lng: -71.3103, nombre: "Sucursal Bariloche" },
    region: "Sur",
    cantidad_pc: 4,
    servidores: 0,
    contacto: "0294-444-5555",
  },
];
---

<BaseLayout title="Sucursales y Oficinas">
  <!-- Hoja de estilos de Leaflet (requerida por la librería) -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <PageContainer width="wide" gap="lg" class="animate-fade-in">
    <!-- Page Header -->
    <section class="space-y-4">
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4"
      >
        <PageHeader
          title="Mapa de Sucursales"
          description="Visualización interactiva de la infraestructura instalada por sucursal. Vista general de cobertura territorial."
          class="max-w-2xl"
        />

        <div class="flex flex-col sm:flex-row gap-4 items-center">
          <!-- View Switcher -->
          <div class="tabs tabs-boxed bg-base-200/50 p-1">
            <button
              id="switch-map"
              class="tab tab-active gap-2 transition-all duration-300"
            >
              <Icon name="boxicons:map" class="size-4" />
              Vista Mapa
            </button>
            <button
              id="switch-list"
              class="tab gap-2 transition-all duration-300"
            >
              <Icon name="boxicons:list-ul" class="size-4" />
              Vista Directorio
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Contenedor de Vistas -->
    <div id="views-wrapper" class="relative min-h-[600px]">
      <!-- Vista Mapa -->
      <section
        id="view-map"
        class="bg-base-100 rounded-xl shadow-lg border border-base-content/10 overflow-hidden relative z-0 transition-all duration-500"
      >
        <div id="mapa-sucursales" class="h-150 w-full z-0 relative"></div>

      </section>

      <!-- Controles del Mapa -->
      <div 
        id="map-controls" 
        class="flex flex-wrap justify-center gap-3 mt-6"
      >
        <button
          id="toggle-polygons"
          class="btn btn-sm btn-outline border-base-content/20 shadow-sm gap-2 font-bold uppercase text-[10px] sm:text-xs transition-all duration-300"
        >
          <Icon name="boxicons:layers-alt" class="size-4 text-primary" />
          <span id="polygons-text">Ocultar Polígonos</span>
        </button>

        <button
          id="toggle-labels"
          class="btn btn-sm btn-outline border-base-content/20 shadow-sm gap-2 font-bold uppercase text-[10px] sm:text-xs transition-all duration-300"
        >
          <Icon name="boxicons:font-family" class="size-4 text-primary" />
          <span id="labels-text">Ocultar Letras</span>
        </button>

        <button
          id="toggle-markers"
          class="btn btn-sm btn-outline border-base-content/20 shadow-sm gap-2 font-bold uppercase text-[10px] sm:text-xs transition-all duration-300"
        >
          <Icon name="boxicons:location-pin" class="size-4 text-primary" />
          <span id="marker-toggle-text">Ocultar Sucursales</span>
        </button>
      </div>

      <!-- Vista Directorio (Hidden) -->
      <section
        id="view-list"
        class="hidden bg-base-100 rounded-xl shadow-lg border border-base-content/10 overflow-hidden animate-fade-in"
      >
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr class="bg-base-200/50">
                <th
                  class="py-4 px-6 text-xs uppercase tracking-wider opacity-70"
                  >Sucursal</th
                >
                <th
                  class="py-4 px-6 text-xs uppercase tracking-wider opacity-70"
                  >Identificador</th
                >
                <th
                  class="py-4 px-6 text-xs uppercase tracking-wider opacity-70"
                  >Región</th
                >
                <th
                  class="py-4 px-6 text-xs uppercase tracking-wider opacity-70"
                  >Infraestructura</th
                >
                <th
                  class="py-4 px-6 text-xs uppercase tracking-wider opacity-70"
                  >Contacto Directo</th
                >
              </tr>
            </thead>
            <tbody>
              {
                sucursales.map((sucursal) => (
                  <tr class="hover:bg-primary/5 transition-colors group">
                    <td class="py-4 px-6 font-bold text-base-content">
                      {sucursal.ubicacion.nombre}
                    </td>
                    <td class="py-4 px-6">
                      <span class="badge badge-outline badge-sm font-mono">
                        {sucursal.nis}
                      </span>
                    </td>
                    <td class="py-4 px-6">
                      <div class="flex items-center gap-2">
                        <div class="size-2 rounded-full bg-primary/40" />
                        {sucursal.region}
                      </div>
                    </td>
                    <td class="py-4 px-6">
                      <div class="flex flex-col gap-1 text-xs">
                        <span class="flex items-center gap-1.5 font-medium">
                          <Icon
                            name="boxicons:desktop"
                            class="size-3.5 text-primary"
                          />
                          {sucursal.cantidad_pc} PCs
                        </span>
                        <span class="flex items-center gap-1.5 font-medium">
                          <Icon
                            name="boxicons:server"
                            class="size-3.5 text-primary"
                          />
                          {sucursal.servidores} Servidores
                        </span>
                      </div>
                    </td>
                    <td class="py-4 px-6">
                      <a
                        href={`tel:${sucursal.contacto}`}
                        class="btn btn-ghost btn-xs gap-2 text-primary hover:bg-primary hover:text-white no-underline lowercase"
                      >
                        <Icon name="boxicons:phone" class="size-4" />
                        {sucursal.contacto}
                      </a>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <!-- Data para client-side (Astro Islands) -->
    <script is:inline define:vars={{ sucursales }}>
      // Inyectamos la variable desde el servidor hacia Astro Island
      window._SUCURSALES_DATA = sucursales;
    </script>

    <!-- Script de Leaflet (CDN sin requerir apiKey/paquetes) y lógica --->
    <script
      is:inline
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
      crossorigin=""></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const dataMap = window._SUCURSALES_DATA || [];

        // 1. Inicializar el mapa (Enfocamos el centro de Argentina, con un Zoom inicial bajo para ver panorámica)
        // Definimos límites para que no se pueda salir de la región de Argentina
        const bounds = [
          [-56.0, -74.0], // Sudoeste
          [-21.0, -53.0], // Noreste
        ];

        const map = L.map("mapa-sucursales", {
          maxBounds: bounds,
          maxBoundsViscosity: 1.0, // Evita que "rebote" y se salga de los límites
        }).setView([-38.5, -64.0], 4);

        // 2. Capa base Argenmap (IGN - Instituto Geográfico Nacional)
        L.tileLayer(
          "https://wms.ign.gob.ar/geoserver/gwc/service/tms/1.0.0/capabaseargenmap@EPSG%3A3857@png/{z}/{x}/{-y}.png",
          {
            maxZoom: 18,
            minZoom: 3,
            attribution:
              '&copy; <a href="https://www.ign.gob.ar/AreaServicios/Argenmap/IntroduccionV2" target="_blank">Instituto Geográfico Nacional</a> + <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>',
          },
        ).addTo(map);

        // Grupos para capas adicionales (separados por polígonos y etiquetas)
        const grupoPoligonos = L.layerGroup().addTo(map);
        const grupoEtiquetas = L.layerGroup().addTo(map);
        
        let polygonsVisible = true;
        let labelsVisible = true;

        // Botón de Toggle Polígonos
        const polyBtn = document.getElementById("toggle-polygons");
        const polyText = document.getElementById("polygons-text");
        if (polyBtn) {
          polyBtn.addEventListener("click", () => {
            if (polygonsVisible) {
              map.removeLayer(grupoPoligonos);
              polyText.textContent = "Mostrar Polígonos";
            } else {
              map.addLayer(grupoPoligonos);
              polyText.textContent = "Ocultar Polígonos";
            }
            polygonsVisible = !polygonsVisible;
            polyBtn.classList.toggle("btn-active");
          });
        }

        // Botón de Toggle Etiquetas
        const labelsBtn = document.getElementById("toggle-labels");
        const labelsText = document.getElementById("labels-text");
        if (labelsBtn) {
          labelsBtn.addEventListener("click", () => {
            if (labelsVisible) {
              map.removeLayer(grupoEtiquetas);
              labelsText.textContent = "Mostrar Letras";
            } else {
              map.addLayer(grupoEtiquetas);
              labelsText.textContent = "Ocultar Letras";
              // Forzamos recalcular la escala de las letras recién aparecidas
              setTimeout(updateLabelsScale, 0);
            }
            labelsVisible = !labelsVisible;
            labelsBtn.classList.toggle("btn-active");
          });
        }

        // Grupo para marcadores de sucursales
        const grupoSucursales = L.layerGroup().addTo(map);
        let markersVisible = true;
        const markerToggleBtn = document.getElementById("toggle-markers");
        const markerToggleText = document.getElementById("marker-toggle-text");

        if (markerToggleBtn) {
          markerToggleBtn.addEventListener("click", () => {
            if (markersVisible) {
              map.removeLayer(grupoSucursales);
              markerToggleText.textContent = "Mostrar Sucursales";
            } else {
              map.addLayer(grupoSucursales);
              markerToggleText.textContent = "Ocultar Sucursales";
            }
            markersVisible = !markersVisible;
            markerToggleBtn.classList.toggle("btn-active");
          });
        }

        // Lógica de escalado dinámico y visibilidad para letras superpuestas
        function updateLabelsScale() {
          const z = map.getZoom();
          let scale = 0;
          let opacity = 0;

          // Se empiezan a ver desde zoom 5 y crecen más sutilmente
          if (z >= 5) {
            // Bajamos el multiplicador y el tope máximo para un estilo más minimalista
            scale = Math.min(Math.max(0.45, (z - 5) * 0.2 + 0.45), 0.8);
            // Opacidad más alta y constante para que no se difuminen tanto
            opacity = z >= 6 ? 0.9 : 0.7;
          }

          document.querySelectorAll(".polygon-label").forEach((el) => {
            el.style.transform = `translate(-50%, -50%) scale(${scale})`;
            el.style.opacity = opacity;
            el.style.pointerEvents = scale > 0.3 ? "auto" : "none";
            // Ocultamos físicamente solo si el zoom es muy bajo
            el.style.visibility = z < 5 ? "hidden" : "visible";
          });
        }
        map.on("zoomend", updateLabelsScale);
        map.on("zoom", updateLabelsScale);

        // Ícono personalizado (Azul Correo)
        const sucursalMarkerIcon = L.divIcon({
          className: "bg-transparent", // Reset de estilos nativos de leaflet
          html: `
              <div class="relative group cursor-pointer animate-fade-in" style="margin-top: -10px; margin-left: -10px;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" 
                     class="w-10 h-10 transition-transform hover:scale-110 text-primary drop-shadow-lg"
                     style="color: #003B71; filter: drop-shadow(0 4px 4px rgba(0,0,0,0.4));">
                  <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                </svg>
              </div>
            `,
          iconSize: [40, 40],
          iconAnchor: [20, 40], // La punta (ancla central inferior)
          popupAnchor: [0, -38], // Popup se asoma un poco por encima del marcador
        });

        // 3. Pintar todas las Provincias desde el archivo GeoJSON local
        const provinceLetters = {
          "Ciudad Autónoma de Buenos Aires": "C",
          "Buenos Aires": "B",
          Catamarca: "K",
          Chaco: "H",
          Chubut: "U",
          Córdoba: "X",
          Corrientes: "W",
          "Entre Ríos": "E",
          Formosa: "P",
          Jujuy: "Y",
          "La Pampa": "L",
          "La Rioja": "F",
          Mendoza: "M",
          Misiones: "N",
          Neuquén: "Q",
          "Río Negro": "R",
          Salta: "A",
          "San Juan": "J",
          "San Luis": "D",
          "Santa Cruz": "Z",
          "Santa Fe": "S",
          "Santiago del Estero": "G",
          "Tierra del Fuego, Antártida e Islas del Atlántico Sur": "V",
          Tucumán: "T",
        };

        const labelOverrides = {
          "Santa Fe": [-30.8, -61.6],
          "Buenos Aires": [-36.8, -60.1],
        };

        fetch("/data/argentina_provincias.geojson")
          .then((res) => res.json())
          .then((geoData) => {
            L.geoJSON(geoData, {
              style: function (feature) {
                const name = feature.properties.nombre;
                // Alternar colores institucionales
                const isYellow = [
                  "Buenos Aires",
                  "Córdoba",
                  "La Pampa",
                  "Mendoza",
                  "La Rioja",
                  "Chubut",
                  "Formosa",
                  "Santiago del Estero",
                  "Misiones",
                  "Jujuy",
                  "Santa Cruz",
                ].includes(name);

                const color = isYellow ? "#FFCC00" : "#003B71";
                return {
                  color: color,
                  weight: 1.5,
                  fillColor: color,
                  fillOpacity:
                    name === "Ciudad Autónoma de Buenos Aires" ? 0.25 : 0.12,
                };
              },
              onEachFeature: function (feature, layer) {
                const name = feature.properties.nombre;
                layer.bindPopup(
                  `<div class='text-center p-1'><b style='color: ${provinceLetters[name] === "C" || provinceLetters[name] === "S" ? "#003B71" : "#FFCC00"};'>${name}</b><br/>Provincia de la República Argentina.</div>`,
                  { className: "custom-popup" },
                );

                // Añadir etiqueta de letra
                const letter = provinceLetters[name];
                if (letter) {
                  const centroid = feature.properties.centroide;
                  const pos = labelOverrides[name] || [
                    centroid.lat,
                    centroid.lon,
                  ];

                  const isBlue = [
                    "C",
                    "S",
                    "E",
                    "W",
                    "A",
                    "G",
                    "T",
                    "F",
                    "J",
                    "D",
                    "Q",
                    "R",
                    "V",
                  ].includes(letter);
                  const color = isBlue ? "#003B71" : "#FFCC00";
                  const shadow = isBlue
                    ? "rgba(255,255,255,0.9)"
                    : "rgba(0,0,0,0.5)";

                  // Tamaño dinámico según la importancia/tamaño de la provincia
                  let fontSize = "3.5rem";
                  if (letter === "C") fontSize = "2rem";
                  if (["B", "S", "X"].includes(letter)) fontSize = "4.2rem";

                  L.marker(pos, {
                    icon: L.divIcon({
                      className: "bg-transparent",
                      html: `<div class="polygon-label font-black text-[#003B71] opacity-80 pointer-events-none transition-all duration-300" 
                             style="transform: translate(-50%, -50%); text-shadow: 0 2px 8px ${shadow}; line-height: 1; color: ${color}; font-size: ${fontSize};">${letter}</div>`,
                      iconSize: [0, 0],
                    }),
                    interactive: false,
                  }).addTo(grupoEtiquetas);
                }
              },
            }).addTo(grupoPoligonos);

            // Forzar actualización de etiquetas después de cargar todo
            updateLabelsScale();
          })
          .catch((err) =>
            console.error("Error al cargar GeoJSON de provincias:", err),
          );

        // 8. Renderizar cada marcador y configurarle los Popups (Tooltip interactivo)
        dataMap.forEach((sucursal) => {
          const { lat, lng } = sucursal.ubicacion;

          // Contenido HTML avanzado dentro del popup de Leaflet (estilos base o inline, acá reutilizamos el de Tailwind)
          const popupContent = `
              <div class="px-1 py-1 min-w-[220px]">
                <div class="border-b border-gray-200 pb-2 mb-2">
                  <h3 class="font-bold text-gray-900 text-sm m-0 leading-tight">${sucursal.ubicacion.nombre}</h3>
                  <span class="inline-block mt-1.5 px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-black rounded uppercase tracking-wider">NIS: ${sucursal.nis}</span>
                </div>
                
                <div class="text-xs text-gray-700 space-y-1.5">
                  <div class="flex justify-between items-center bg-gray-50 px-2 py-1 rounded">
                    <span class="font-semibold text-gray-500">Región</span> 
                    <span class="font-bold text-gray-800">${sucursal.region}</span>
                  </div>
                  <div class="flex justify-between items-center px-2 py-0.5">
                    <span class="text-gray-500">Equipos PC</span> 
                    <span class="font-bold text-gray-700">${sucursal.cantidad_pc}</span>
                  </div>
                  <div class="flex justify-between items-center px-2 py-0.5">
                    <span class="text-gray-500">Servidores</span> 
                    <span class="font-bold text-gray-700">${sucursal.servidores}</span>
                  </div>
                  <div class="flex justify-between pt-1.5 mt-1.5 border-t border-gray-100 px-2">
                    <span class="text-gray-500">Contacto</span> 
                    <a href="tel:${sucursal.contacto}" class="text-blue-600 font-bold hover:underline">${sucursal.contacto}</a>
                  </div>
                </div>
              </div>
            `;

          // Agregar el marker
          const marker = L.marker([lat, lng], {
            icon: sucursalMarkerIcon,
          }).addTo(grupoSucursales);

          // Linkeamos el html
          marker.bindPopup(popupContent, {
            className: "custom-popup",
          });
        });
        // 9. Lógica de Cambio de Vista (Mapa / Directorio)
        const btnMap = document.getElementById("switch-map");
        const btnList = document.getElementById("switch-list");
        const viewMap = document.getElementById("view-map");
        const viewList = document.getElementById("view-list");
        const mapControls = document.getElementById("map-controls");

        if (btnMap && btnList && viewMap && viewList) {
          btnMap.addEventListener("click", () => {
            viewMap.classList.remove("hidden");
            viewList.classList.add("hidden");
            btnMap.classList.add("tab-active");
            btnList.classList.remove("tab-active");
            if (mapControls) mapControls.classList.remove("hidden");
            // Forzar a Leaflet a recalcular el tamaño al hacerse visible
            setTimeout(() => {
              map.invalidateSize();
            }, 100);
          });

          btnList.addEventListener("click", () => {
            viewMap.classList.add("hidden");
            viewList.classList.remove("hidden");
            btnMap.classList.remove("tab-active");
            btnList.classList.add("tab-active");
            if (mapControls) mapControls.classList.add("hidden");
          });
        }
      });
    </script>

    <style>
      /* Evitar que Leaflet se dibuje por encima de navbars, pero mantenga usabilidad (z-index) */
      .leaflet-container {
        z-index: 10;
        font-family: inherit;
      }

      /* Estilos estéticos sobreescribiendo las features nativas del tooltip de Leaflet */
      .custom-popup .leaflet-popup-content-wrapper {
        border-radius: 0.75rem;
        box-shadow:
          0 10px 15px -3px rgb(0 0 0 / 0.1),
          0 4px 6px -4px rgb(0 0 0 / 0.1);
      }

      .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </PageContainer>
</BaseLayout>
