---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Home Público">
  <section class="mx-auto flex w-full max-w-4xl flex-col gap-6">
    <h1 class="text-3xl font-bold text-secondary">Home Público</h1>

    <article class="card border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body gap-3">
        <h2 class="card-title">Design System</h2>
        <p class="text-sm text-base-content/70">
          Acceso interno para consultar la paleta, reglas y ejemplos de
          componentes.
        </p>
        <div class="card-actions justify-end">
          <a href="/design-system" class="btn btn-primary btn-sm">
            Abrir Design System
          </a>
        </div>
      </div>
    </article>
  </section>
</BaseLayout>
