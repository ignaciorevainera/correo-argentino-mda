---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import QuickAccessCard from "@components/ui/QuickAccessCard.astro";
import { Icon } from "astro-icon/components";

type BoxiconName = `boxicons:${string}`;

interface QuickAccessItem {
  href: string;
  title: string;
  description: string;
  icon: BoxiconName;
  iconTone: string;
}

const quickAccessItems: QuickAccessItem[] = [
  {
    href: "/titulos-tickets",
    title: "Títulos de tickets",
    description:
      "Tipifica tickets y copia títulos listos para la gestión diaria.",
    icon: "boxicons:list-ul-filled",
    iconTone: "bg-primary/10 text-primary",
  },
  {
    href: "/buscador-usuarios",
    title: "Buscador de usuarios",
    description: "Encuentra personal interno para validaciones y escalamiento.",
    icon: "boxicons:group-filled",
    iconTone: "bg-info/10 text-info",
  },
  {
    href: "/directorio-oficinas",
    title: "Directorio de oficinas",
    description:
      "Explora el mapa de cobertura y consulta el directorio maestro de oficinas.",
    icon: "boxicons:building-filled",
    iconTone: "bg-success/10 text-success",
  },
  {
    href: "/guia-soportes",
    title: "Guía de soportes",
    description:
      "Revisa derivaciones por tema para resolver casos con rapidez.",
    icon: "boxicons:buoy-filled",
    iconTone: "bg-warning/10 text-warning",
  },
  {
    href: "/contactos",
    title: "Contactos",
    description:
      "Consulta telefonos, correos y enlaces para escalamientos operativos.",
    icon: "boxicons:phone-filled",
    iconTone: "bg-secondary/10 text-secondary",
  },
  {
    href: "/inventario-equipos",
    title: "Inventario de equipos",
    description:
      "Gestión centralizada del parque operativo: terminales y cúbics destinadas a Mesa de Ayuda.",
    icon: "boxicons:desktop-filled",
    iconTone: "bg-primary/10 text-primary",
  },
  {
    href: "/enlaces-recursos",
    title: "Enlaces y recursos",
    description: "Centraliza accesos críticos para tareas de soporte N1 y N2.",
    icon: "boxicons:link-filled",
    iconTone: "bg-warning/10 text-warning",
  },
  {
    href: "/asignacion-autogestiones",
    title: "Asignación de autogestiones",
    description:
      "Distribución semiautomática de tickets de AG entrantes para el equipo.",
    icon: "boxicons:git-branch-filled",
    iconTone: "bg-info/10 text-info",
  },
  {
    href: "/catalogo-aplicativos",
    title: "Catálogo de aplicativos",
    description:
      "Descarga herramientas y utilitarios para la operatoria diaria.",
    icon: "boxicons:grid-circle-diagonal-right-filled",
    iconTone: "bg-success/10 text-success",
  },
];
---

<BaseLayout title="Dashboard | Portal Mesa de Ayuda">
  <PageContainer>
    <PageHeader
      title="¡Hola!"
      description="Bienvenido al panel principal. Desde aquí puedes entrar rápido a los módulos operativos del portal."
    />

    <section
      aria-labelledby="accesos-rapidos-heading"
      class="flex flex-col gap-4"
    >
      <h2
        id="accesos-rapidos-heading"
        class="text-xl font-semibold text-base-content"
      >
        Accesos rápidos
      </h2>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
      >
        {
          quickAccessItems.map((item) => (
            <QuickAccessCard
              href={item.href}
              title={item.title}
              description={item.description}
              icon={item.icon}
              iconTone={item.iconTone}
            />
          ))
        }
      </div>
    </section>
  </PageContainer>
</BaseLayout>
