---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
---

<BaseLayout title="Página no encontrada">
  <div
    class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4 gap-6"
  >
    <Icon
      name="boxicons:sad"
      size={224}
      class="text-base-content/20"
      aria-hidden="true"
    />
    <div>
      <span class="text-4xl font-black text-base-content tracking-tight">
        404 - Página no encontrada
      </span>
      <p class="text-xl text-base-content/70 max-w-xl mt-2">
        La ruta solicitada no existe o fue movida.
      </p>
    </div>
    <a href="/" class="btn btn-primary btn-lg"> Volver al inicio </a>
  </div>
</BaseLayout>
