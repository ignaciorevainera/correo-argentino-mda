---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import linksData from "../../data/enlaces_importantes.json";

type BoxiconName = `boxicons:${string}`;

interface ImportantLink {
  id: string;
  title: string;
  url: string;
  description?: string;
  alternatives?: LinkAlternative[];
}

interface LinkAlternative {
  id: string;
  title: string;
  url: string;
}

interface LinkCategory {
  id: string;
  title: string;
  iconName: BoxiconName;
  links: ImportantLink[];
}

interface CategoryTheme {
  icon: BoxiconName;
  iconContainerClass: string;
  headerClass: string;
}

const importantCategories: LinkCategory[] = linksData as LinkCategory[];

const getCategoryTheme = (iconName: BoxiconName): CategoryTheme => {
  const defaultTheme: CategoryTheme = {
    icon: "boxicons:link",
    iconContainerClass: "border-neutral/30 bg-neutral/20 text-neutral-content",
    headerClass: "bg-base-200/70",
  };

  const themeMap: Record<BoxiconName, CategoryTheme> = {
    "boxicons:star": {
      icon: "boxicons:star",
      iconContainerClass:
        "border-primary/40 bg-primary/20 text-primary-content",
      headerClass: "bg-primary/10",
    },
    "boxicons:buoy": {
      icon: "boxicons:buoy",
      iconContainerClass: "border-warning/40 bg-warning/20 text-warning",
      headerClass: "bg-warning/10",
    },
    "boxicons:file-detail": {
      icon: "boxicons:file-detail",
      iconContainerClass: "border-secondary/40 bg-secondary/20 text-secondary",
      headerClass: "bg-secondary/10",
    },
    "boxicons:server": {
      icon: "boxicons:server",
      iconContainerClass: "border-info/40 bg-info/20 text-info",
      headerClass: "bg-info/10",
    },
    "boxicons:spanner": {
      icon: "boxicons:spanner",
      iconContainerClass: "border-accent/40 bg-accent/20 text-accent",
      headerClass: "bg-accent/10",
    },
    "boxicons:folder": {
      icon: "boxicons:folder",
      iconContainerClass: "border-accent/40 bg-accent/20 text-accent",
      headerClass: "bg-accent/10",
    },
    "boxicons:chip": {
      icon: "boxicons:chip",
      iconContainerClass: "border-success/40 bg-success/20 text-success",
      headerClass: "bg-success/10",
    },
    "boxicons:mobile": {
      icon: "boxicons:mobile",
      iconContainerClass: "border-info/40 bg-info/20 text-info",
      headerClass: "bg-info/10",
    },
    "boxicons:group": {
      icon: "boxicons:group",
      iconContainerClass: "border-warning/40 bg-warning/20 text-warning",
      headerClass: "bg-warning/10",
    },
    "boxicons:building": {
      icon: "boxicons:building",
      iconContainerClass: "border-secondary/40 bg-secondary/20 text-secondary",
      headerClass: "bg-secondary/10",
    },
    "boxicons:link": {
      icon: "boxicons:link",
      iconContainerClass: "border-accent/40 bg-accent/20 text-accent",
      headerClass: "bg-accent/10",
    },
    "boxicons:check-shield": {
      icon: "boxicons:check-shield",
      iconContainerClass: "border-error/40 bg-error/20 text-error",
      headerClass: "bg-error/10",
    },
    "boxicons:calendar": {
      icon: "boxicons:calendar",
      iconContainerClass: "border-error/40 bg-error/20 text-error",
      headerClass: "bg-error/10",
    },
  };

  return themeMap[iconName] ?? defaultTheme;
};
---

<BaseLayout title="Enlaces importantes">
  <section class="flex flex-col gap-6">
    <header class="space-y-2">
      <h1 class="text-2xl font-semibold text-base-content">
        Enlaces importantes
      </h1>
      <p class="text-sm text-base-content/70 sm:text-base">
        Accesos clave para resolver tareas operativas de soporte con menos
        friccion.
      </p>
    </header>

    <div class="w-full max-w-md">
      <label class="input input-bordered w-full" for="links-search">
        <Icon
          name="boxicons:search"
          class="size-4 opacity-50"
          aria-hidden="true"
        />
        <input
          id="links-search"
          type="search"
          class="grow"
          placeholder="Buscar por nombre o URL"
          autocomplete="off"
          aria-label="Buscar enlace por nombre o URL"
        />
      </label>
    </div>

    <section class="space-y-3">
      <div
        id="links-empty-state"
        class="alert alert-warning hidden"
        role="status"
      >
        <Icon
          name="boxicons:alert-triangle"
          class="size-5"
          aria-hidden="true"
        />
        <span>No se encontraron resultados para la busqueda actual.</span>
      </div>

      <div class="grid grid-cols-1 gap-5 lg:grid-cols-2 xl:grid-cols-4">
        {
          importantCategories.map((category) => {
            const categoryTheme = getCategoryTheme(category.iconName);

            return (
              <article
                class="overflow-hidden rounded-xl border border-base-300 bg-base-100 shadow-sm"
                data-category-card
              >
                <header
                  class:list={[
                    "flex items-center gap-3 rounded-t-xl border-b border-base-300 p-3",
                    categoryTheme.headerClass,
                  ]}
                >
                  <span
                    class:list={[
                      "inline-flex size-9 shrink-0 items-center justify-center rounded-lg border",
                      categoryTheme.iconContainerClass,
                    ]}
                    aria-hidden="true"
                  >
                    <Icon name={categoryTheme.icon} class="size-4" />
                  </span>
                  <h2 class="text-sm font-semibold text-base-content">
                    {category.title}
                  </h2>
                </header>

                <div class="grid grid-cols-1 gap-3 bg-base-200/40 p-3">
                  {category.links.map((link) => {
                    const isUncPath = link.url.startsWith("\\\\");
                    const hasAlternatives =
                      Array.isArray(link.alternatives) &&
                      link.alternatives.length > 0;
                    const linkOptions: LinkAlternative[] = hasAlternatives
                      ? [
                          {
                            id: `${link.id}-principal`,
                            title: "Principal",
                            url: link.url,
                          },
                          ...link.alternatives!,
                        ]
                      : [];

                    return hasAlternatives ? (
                      <div
                        class="rounded-xl border border-base-300 bg-base-100/70 p-2.5"
                        data-link-group
                        data-link-group-id={link.id}
                      >
                        <p
                          class="mb-2 truncate px-1 text-sm font-semibold text-base-content"
                          data-highlight-target
                        >
                          {link.title}
                        </p>

                        <div class="grid grid-cols-1 gap-2">
                          {linkOptions.map((option) => {
                            const isOptionUncPath =
                              option.url.startsWith("\\\\");

                            return (
                              <div
                                class="tooltip tooltip-top tooltip-neutral block w-full text-left before:block before:max-w-xs before:truncate"
                                data-tip={option.url}
                                data-link-item
                                data-link-id={`${link.id}-${option.id}`}
                                data-link-group-id={link.id}
                                data-search={`${category.title} ${link.title} ${option.title} ${option.url}`}
                              >
                                <div class="group relative flex overflow-hidden rounded-lg border border-base-300 bg-base-100 focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-accent">
                                  <a
                                    href={isOptionUncPath ? "#" : option.url}
                                    target={
                                      isOptionUncPath ? "_self" : "_blank"
                                    }
                                    rel={
                                      isOptionUncPath
                                        ? undefined
                                        : "noopener noreferrer"
                                    }
                                    class="flex flex-1 items-center gap-3 p-3 text-left transition-colors hover:bg-base-200/60 focus-visible:bg-base-200/60"
                                    aria-label={
                                      isOptionUncPath
                                        ? `Copiar ruta ${option.title}`
                                        : `Abrir enlace ${option.title}`
                                    }
                                    data-link-anchor
                                    data-link-url={option.url}
                                    data-link-unc={
                                      isOptionUncPath ? "true" : "false"
                                    }
                                  >
                                    <span class="min-w-0 flex-1">
                                      <span class="flex items-center gap-2">
                                        <span
                                          class="truncate text-sm font-semibold text-base-content"
                                          data-highlight-target
                                        >
                                          {option.title}
                                        </span>
                                        <Icon
                                          name="boxicons:arrow-up-right-square"
                                          class="size-4 shrink-0 text-base-content/50 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100"
                                          aria-hidden="true"
                                        />
                                      </span>
                                    </span>
                                  </a>

                                  <div
                                    class="my-2 w-px shrink-0 bg-base-300"
                                    aria-hidden="true"
                                  />

                                  <button
                                    type="button"
                                    class="inline-flex w-12 shrink-0 items-center justify-center text-base-content/65 transition-colors hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-offset-0 focus-visible:outline-accent"
                                    data-copy-button
                                    data-copy-value={option.url}
                                    aria-label={`Copiar URL de ${option.title}`}
                                  >
                                    <span class="relative inline-flex size-4 items-center justify-center">
                                      <Icon
                                        name="boxicons:clipboard"
                                        class="absolute inset-0 m-auto size-4"
                                        data-copy-icon-default
                                        aria-hidden="true"
                                      />
                                      <Icon
                                        name="boxicons:check"
                                        class="absolute inset-0 m-auto hidden size-4 text-success"
                                        data-copy-icon-success
                                        aria-hidden="true"
                                      />
                                    </span>
                                  </button>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      </div>
                    ) : (
                      <div
                        class="tooltip tooltip-top tooltip-neutral block w-full text-left before:block before:max-w-xs before:truncate"
                        data-tip={link.url}
                        data-link-item
                        data-link-id={link.id}
                        data-search={`${category.title} ${link.title} ${link.url} ${link.description ?? ""}`}
                      >
                        <div class="group relative flex overflow-hidden rounded-lg border border-base-300 bg-base-100 focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-accent">
                          <a
                            href={isUncPath ? "#" : link.url}
                            target={isUncPath ? "_self" : "_blank"}
                            rel={isUncPath ? undefined : "noopener noreferrer"}
                            class:list={[
                              "flex flex-1 items-center gap-3 text-left transition-colors hover:bg-base-200/60 focus-visible:bg-base-200/60",
                              link.description ? "px-3 py-2" : "p-3",
                            ]}
                            aria-label={
                              isUncPath
                                ? `Copiar ruta ${link.title}`
                                : `Abrir enlace ${link.title}`
                            }
                            data-link-anchor
                            data-link-url={link.url}
                            data-link-unc={isUncPath ? "true" : "false"}
                          >
                            <span class="min-w-0 flex-1">
                              <span class="flex items-center gap-2">
                                <span
                                  class="truncate text-sm font-semibold text-base-content"
                                  data-highlight-target
                                >
                                  {link.title}
                                </span>
                                <Icon
                                  name="boxicons:arrow-up-right-square"
                                  class="size-4 shrink-0 text-base-content/50 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100"
                                  aria-hidden="true"
                                />
                              </span>
                              {link.description && (
                                <span
                                  class="mt-1 block truncate text-xs text-base-content/70"
                                  data-highlight-target
                                >
                                  {link.description}
                                </span>
                              )}
                            </span>
                          </a>

                          <div
                            class="my-2 w-px shrink-0 bg-base-300"
                            aria-hidden="true"
                          />

                          <button
                            type="button"
                            class="inline-flex w-12 shrink-0 items-center justify-center text-base-content/65 transition-colors hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-offset-0 focus-visible:outline-accent"
                            data-copy-button
                            data-copy-value={link.url}
                            aria-label={`Copiar URL de ${link.title}`}
                          >
                            <span class="relative inline-flex size-4 items-center justify-center">
                              <Icon
                                name="boxicons:clipboard"
                                class="absolute inset-0 m-auto size-4"
                                data-copy-icon-default
                                aria-hidden="true"
                              />
                              <Icon
                                name="boxicons:check"
                                class="absolute inset-0 m-auto hidden size-4 text-success"
                                data-copy-icon-success
                                aria-hidden="true"
                              />
                            </span>
                          </button>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </article>
            );
          })
        }
      </div>
    </section>
  </section>

  <script>
    interface LinkVisualState {
      defaultIcon: Element | null;
      successIcon: Element | null;
      resetTimer: number | null;
    }

    const fallbackCopyToClipboard = (value: string): boolean => {
      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.setAttribute("readonly", "");
      textarea.setAttribute("aria-hidden", "true");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      textarea.style.top = "0";
      textarea.style.opacity = "0";

      document.body.append(textarea);
      textarea.focus();
      textarea.select();

      let copied = false;

      try {
        const legacyCopyApi = document as unknown as {
          execCommand?: (commandId: string) => boolean;
        };
        copied =
          typeof legacyCopyApi.execCommand === "function"
            ? legacyCopyApi.execCommand("copy")
            : false;
      } catch {
        copied = false;
      }

      textarea.remove();
      return copied;
    };

    const copyToClipboard = async (value: string): Promise<boolean> => {
      const canUseClipboardApi =
        typeof navigator !== "undefined" &&
        typeof navigator.clipboard !== "undefined" &&
        typeof navigator.clipboard.writeText === "function";

      if (canUseClipboardApi) {
        try {
          await navigator.clipboard.writeText(value);
          return true;
        } catch {
          return fallbackCopyToClipboard(value);
        }
      }

      return fallbackCopyToClipboard(value);
    };

    const searchInput = document.querySelector("#links-search");
    const emptyState = document.querySelector("#links-empty-state");
    const categoryCards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-category-card]"),
    );
    const linkGroups = Array.from(
      document.querySelectorAll<HTMLElement>("[data-link-group]"),
    );

    const normalizeValue = (value: string): string =>
      value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    const escapeRegExp = (value: string): string =>
      value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const escapeHtml = (value: string): string =>
      value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const highlightText = (element: HTMLElement, query: string) => {
      const originalText =
        element.dataset.originalText ?? element.textContent ?? "";

      if (!element.dataset.originalText) {
        element.dataset.originalText = originalText;
      }

      if (query.length === 0) {
        element.textContent = originalText;
        return;
      }

      const matcher = new RegExp(`(${escapeRegExp(query)})`, "ig");

      if (!matcher.test(originalText)) {
        element.textContent = originalText;
        return;
      }

      matcher.lastIndex = 0;
      const highlighted = originalText
        .split(matcher)
        .map((chunk, index) =>
          index % 2 === 1
            ? `<mark class=\"rounded bg-warning/30 px-0.5 text-base-content\">${escapeHtml(chunk)}</mark>`
            : escapeHtml(chunk),
        )
        .join("");

      element.innerHTML = highlighted;
    };

    const itemStates = new Map<string, LinkVisualState>();

    const setCopiedState = (state: LinkVisualState) => {
      if (state.defaultIcon instanceof Element) {
        state.defaultIcon.classList.add("hidden");
      }

      if (state.successIcon instanceof Element) {
        state.successIcon.classList.remove("hidden");
      }

      if (state.resetTimer !== null) {
        window.clearTimeout(state.resetTimer);
      }

      state.resetTimer = window.setTimeout(() => {
        if (state.defaultIcon instanceof Element) {
          state.defaultIcon.classList.remove("hidden");
        }

        if (state.successIcon instanceof Element) {
          state.successIcon.classList.add("hidden");
        }

        state.resetTimer = null;
      }, 2000);
    };

    const executeCopy = async (
      itemId: string,
      value: string,
    ): Promise<void> => {
      if (value.trim().length === 0) {
        return;
      }

      const copied = await copyToClipboard(value);
      if (!copied) {
        return;
      }

      const state = itemStates.get(itemId);
      if (!state) {
        return;
      }

      setCopiedState(state);
    };

    const linkItems = Array.from(
      document.querySelectorAll<HTMLElement>("[data-link-item]"),
    );

    if (
      searchInput instanceof HTMLInputElement &&
      emptyState instanceof HTMLElement
    ) {
      const updateItems = () => {
        const rawSearchValue = searchInput.value.trim();
        const searchValue = normalizeValue(searchInput.value.trim());
        let visibleItems = 0;

        linkItems.forEach((item) => {
          const searchableContent = normalizeValue(item.dataset.search ?? "");
          const isVisible =
            searchValue.length === 0 || searchableContent.includes(searchValue);

          item.classList.toggle("hidden", !isVisible);
          if (isVisible) {
            visibleItems += 1;
          }
        });

        linkGroups.forEach((group) => {
          const groupId = group.dataset.linkGroupId;
          if (!groupId) {
            return;
          }

          const groupItems = linkItems.filter(
            (item) => item.dataset.linkGroupId === groupId,
          );
          const hasVisibleGroupItems = groupItems.some(
            (item) => !item.classList.contains("hidden"),
          );

          group.classList.toggle("hidden", !hasVisibleGroupItems);

          const groupTargets = Array.from(
            group.querySelectorAll<HTMLElement>("[data-highlight-target]"),
          );

          groupTargets.forEach((target) => {
            highlightText(target, hasVisibleGroupItems ? rawSearchValue : "");
          });
        });

        categoryCards.forEach((categoryCard) => {
          const categoryItems = Array.from(
            categoryCard.querySelectorAll<HTMLElement>("[data-link-item]"),
          );
          const hasVisibleCategoryItems = categoryItems.some(
            (item) => !item.classList.contains("hidden"),
          );

          categoryCard.classList.toggle("hidden", !hasVisibleCategoryItems);

          const categoryTargets = Array.from(
            categoryCard.querySelectorAll<HTMLElement>(
              "[data-highlight-target]",
            ),
          );

          categoryTargets.forEach((target) => {
            const parentItem = target.closest("[data-link-item]");
            if (parentItem instanceof HTMLElement) {
              const isParentVisible = !parentItem.classList.contains("hidden");
              highlightText(target, isParentVisible ? rawSearchValue : "");
              return;
            }

            const parentGroup = target.closest("[data-link-group]");
            if (parentGroup instanceof HTMLElement) {
              const isParentGroupVisible =
                !parentGroup.classList.contains("hidden");
              highlightText(target, isParentGroupVisible ? rawSearchValue : "");
              return;
            }

            highlightText(
              target,
              hasVisibleCategoryItems ? rawSearchValue : "",
            );
          });
        });

        emptyState.classList.toggle("hidden", visibleItems > 0);
      };

      searchInput.addEventListener("input", updateItems);
      updateItems();
    }

    linkItems.forEach((item) => {
      const itemId = item.dataset.linkId ?? "";
      if (itemId.length === 0 || item.dataset.linkBound === "true") {
        return;
      }

      const button =
        item.querySelector<HTMLButtonElement>("[data-copy-button]");
      const anchors = Array.from(
        item.querySelectorAll<HTMLAnchorElement>("[data-link-anchor]"),
      );

      if (!(button instanceof HTMLButtonElement) || anchors.length === 0) {
        return;
      }

      const defaultIcon = button.querySelector("[data-copy-icon-default]");
      const successIcon = button.querySelector("[data-copy-icon-success]");

      item.dataset.linkBound = "true";

      itemStates.set(itemId, {
        defaultIcon,
        successIcon,
        resetTimer: null,
      });

      button.addEventListener("click", async () => {
        const value = button.getAttribute("data-copy-value") ?? "";
        await executeCopy(itemId, value);
      });

      anchors.forEach((anchor) => {
        anchor.addEventListener("click", async (event) => {
          const isUncPath = anchor.dataset.linkUnc === "true";
          if (!isUncPath) {
            return;
          }

          event.preventDefault();
          const uncValue = anchor.dataset.linkUrl ?? "";
          await executeCopy(itemId, uncValue);
        });
      });
    });
  </script>
</BaseLayout>
