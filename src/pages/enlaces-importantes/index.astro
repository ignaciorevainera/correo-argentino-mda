---
import BaseLayout from "@layouts/BaseLayout.astro";
import ImportantLinksView from "./_components/ImportantLinksView.astro";
import linksData from "../../data/enlaces_importantes.json";
import type {
  CategoryTone,
  CategoryViewModel,
  RawLinkCategory,
} from "./_components/types";

const categoryTones: CategoryTone[] = [
  "primary",
  "secondary",
  "accent",
  "neutral",
  "success",
];

const rawCategories = linksData as RawLinkCategory[];

const importantCategories = rawCategories.map(
  (category, index): CategoryViewModel => ({
    id: category.id,
    category: category.title,
    icon: category.iconName,
    tone: categoryTones[index % categoryTones.length],
    links: category.links,
  }),
);
---

<BaseLayout title="Enlaces importantes | Portal Mesa de Ayuda">
  <ImportantLinksView categories={importantCategories} />
</BaseLayout>
