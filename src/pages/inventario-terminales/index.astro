---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import inventoryRows from "../../data/inventario_terminales.json";

type OsFamily = "windows" | "linux" | "legacy";
type BoxiconName = `boxicons:${string}`;

interface TerminalItem {
  hostname: string;
  ip: string;
  mac: string;
  manufacturer: string;
  model: string;
  ram: string;
  serial: string;
  osName: string;
  architecture: string;
  branch: string;
  province: string;
  region: string;
  nis: string;
  lastContactDate: string;
  lastContactTime: string;
  osFamily: OsFamily;
}

interface CsvTerminalRow {
  Hostname: string;
  Mac: string;
  "Ip-Dir": string;
  "Sist. Ope.": string;
  "OS. Tipo": string;
  Ram: string;
  Serial: string;
  manufacturer: string;
  Modelo: string;
  Sucursal: string;
  Provincia: string;
  Region: string;
  NIS: string;
  "Last-Contact": string;
}

const monthLabels = [
  "Ene",
  "Feb",
  "Mar",
  "Abr",
  "May",
  "Jun",
  "Jul",
  "Ago",
  "Sep",
  "Oct",
  "Nov",
  "Dic",
];

const toOsFamily = (osName: string): OsFamily => {
  const normalized = osName.toLowerCase();

  if (
    normalized.includes("ubuntu") ||
    normalized.includes("linux") ||
    normalized.includes("debian")
  ) {
    return "linux";
  }

  if (normalized.includes("windows")) {
    return "windows";
  }

  return "legacy";
};

const parseLastContact = (
  lastContact: string,
): { date: string; time: string } => {
  const parsedDate = new Date(lastContact.replace(" ", "T"));

  if (Number.isNaN(parsedDate.getTime())) {
    return { date: "--", time: "--" };
  }

  const day = String(parsedDate.getDate()).padStart(2, "0");
  const month = monthLabels[parsedDate.getMonth()];
  const year = parsedDate.getFullYear();
  const hours = String(parsedDate.getHours()).padStart(2, "0");
  const minutes = String(parsedDate.getMinutes()).padStart(2, "0");

  return {
    date: `${day} ${month} ${year}`,
    time: `${hours}:${minutes}`,
  };
};

const terminals: TerminalItem[] = (inventoryRows as CsvTerminalRow[])
  .slice(0, 50)
  .map((row) => {
    const lastContact = parseLastContact(row["Last-Contact"]);
    const architecture = row["OS. Tipo"]?.trim()
      ? `${row["OS. Tipo"].trim()} bits`
      : "--";

    return {
      hostname: row.Hostname?.trim() || "--",
      ip: row["Ip-Dir"]?.trim() || "--",
      mac: row.Mac?.trim() || "--",
      manufacturer: row.manufacturer?.trim() || "--",
      model: row.Modelo?.trim() || "--",
      ram: row.Ram?.trim() || "--",
      serial: row.Serial?.trim() || "--",
      osName: row["Sist. Ope."]?.trim() || "--",
      architecture,
      branch: row.Sucursal?.trim() || "--",
      province: row.Provincia?.trim() || "--",
      region: row.Region?.trim() || "--",
      nis: row.NIS?.trim() || "--",
      lastContactDate: lastContact.date,
      lastContactTime: lastContact.time,
      osFamily: toOsFamily(row["Sist. Ope."] || ""),
    };
  });

const osFamilyTone: Record<OsFamily, string> = {
  windows: "border-info/30 bg-info/15 text-info",
  linux: "border-success/30 bg-success/15 text-success",
  legacy: "border-warning/30 bg-warning/15 text-warning",
};

const osFamilyBadge: Record<OsFamily, string> = {
  windows: "badge-info",
  linux: "badge-success",
  legacy: "badge-warning",
};

const osFamilyLabel: Record<OsFamily, string> = {
  windows: "Windows",
  linux: "Linux",
  legacy: "Legacy",
};

const rowIcons: Record<
  "hardware" | "os" | "location" | "contact",
  BoxiconName
> = {
  hardware: "boxicons:chip",
  os: "boxicons:database",
  location: "boxicons:location-pin",
  contact: "boxicons:clock",
};

const terminalHeaderGridClass = "grid-cols-12 gap-4";
const terminalRowGridClass = "grid grid-cols-12 items-start gap-4";
---

<BaseLayout title="Inventario de terminales">
  <section class="flex flex-col gap-6">
    <div class="space-y-3">
      <PageHeader
        title="Inventario de Terminales"
        description="Vista consolidada del parque operativo para diagnostico rapido de red, hardware y estado de contacto."
      />
      <div class="w-full max-w-md">
        <SearchInput
          id="terminal-search"
          label="Buscar terminal por hostname, direccion IP, MAC o sucursal"
          placeholder="Buscar por hostname, IP, MAC o sucursal"
        />
      </div>
    </div>

    <section class="space-y-3">
      <div
        id="terminal-empty-state"
        class="alert alert-warning hidden"
        role="status"
      >
        <Icon
          name="boxicons:alert-triangle"
          class="size-5"
          aria-hidden="true"
        />
        <span>No se encontraron resultados para la busqueda actual.</span>
      </div>

      <DataTable
        ariaLabel="Inventario de terminales"
        minWidthClass="min-w-280"
        headerGridClass={terminalHeaderGridClass}
        rowGridClass={terminalRowGridClass}
      >
        <div slot="header" class="col-span-3">
          <DataTableHeaderCell sortKey="hostname" monospace>
            Hostname/Red
          </DataTableHeaderCell>
        </div>
        <div slot="header" class="col-span-3">
          <DataTableHeaderCell sortKey="hardware" monospace>
            Hardware
          </DataTableHeaderCell>
        </div>
        <div slot="header" class="col-span-2">
          <DataTableHeaderCell sortKey="os" monospace>
            Sistema operativo
          </DataTableHeaderCell>
        </div>
        <div slot="header" class="col-span-2">
          <DataTableHeaderCell sortKey="location" monospace>
            Ubicacion
          </DataTableHeaderCell>
        </div>
        <div slot="header" class="col-span-2">
          <DataTableHeaderCell align="right" monospace>
            Ultimo contacto
          </DataTableHeaderCell>
        </div>

        {
          terminals.map((terminal) => (
            <article
              data-table-row
              data-terminal-row
              data-hostname={terminal.hostname}
              data-ip={terminal.ip}
              data-mac={terminal.mac}
              data-branch={terminal.branch}
              data-sort-hostname={terminal.hostname}
              data-sort-hardware={`${terminal.manufacturer} ${terminal.model}`}
              data-sort-os={terminal.osName}
              data-sort-location={`${terminal.branch} ${terminal.province} ${terminal.region}`}
              class:list={[
                terminalRowGridClass,
                "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-300/50 last:border-b-0",
              ]}
            >
              <div class="col-span-3 min-w-0">
                <div class="flex min-w-0 items-center gap-3">
                  <span
                    class:list={[
                      "inline-flex size-9 shrink-0 items-center justify-center rounded-lg border",
                      osFamilyTone[terminal.osFamily],
                    ]}
                    aria-hidden="true"
                  >
                    <Icon name="boxicons:desktop" class="size-4" />
                  </span>
                  <div class="min-w-0 space-y-0.5">
                    <p
                      class="truncate text-sm font-medium text-base-content"
                      data-highlight-target
                    >
                      {terminal.hostname}
                    </p>
                    <p
                      class="truncate font-mono text-xs text-base-content/70"
                      data-highlight-target
                    >
                      {terminal.ip}
                    </p>
                    <p
                      class="truncate font-mono text-xs text-base-content/50"
                      data-highlight-target
                    >
                      {terminal.mac}
                    </p>
                  </div>
                </div>
              </div>

              <div class="col-span-3 min-w-0 space-y-1">
                <p class="flex min-w-0 items-center gap-2 text-sm text-base-content">
                  <Icon
                    name={rowIcons.hardware}
                    class="size-4 shrink-0 text-base-content/60"
                    aria-hidden="true"
                  />
                  <span class="truncate">
                    {terminal.manufacturer} {terminal.model}
                  </span>
                </p>
                <div class="pl-6">
                  <p class="truncate text-xs text-base-content/70">
                    RAM:{" "}
                    <span class="font-medium text-base-content">
                      {terminal.ram}
                    </span>
                  </p>
                  <p class="truncate font-mono text-xs text-base-content/50">
                    SN: {terminal.serial}
                  </p>
                </div>
              </div>

              <div class="col-span-2 min-w-0 space-y-1">
                <p class="flex min-w-0 items-center gap-2 text-sm text-base-content">
                  <Icon
                    name={rowIcons.os}
                    class="size-4 shrink-0 text-base-content/60"
                    aria-hidden="true"
                  />
                  <span class="truncate">{terminal.osName}</span>
                </p>
                <div class="flex min-w-0 items-center gap-2 pl-6">
                  <span
                    class:list={[
                      "badge badge-outline badge-sm h-4 px-2 text-xs text-base-content/70",
                      osFamilyBadge[terminal.osFamily],
                    ]}
                  >
                    {osFamilyLabel[terminal.osFamily]}
                  </span>
                  <span class="badge badge-outline badge-sm h-4 px-2 text-xs text-base-content/60">
                    {terminal.architecture}
                  </span>
                </div>
              </div>

              <div class="col-span-2 min-w-0 space-y-1">
                <p class="flex min-w-0 items-center gap-2 text-sm text-base-content">
                  <Icon
                    name={rowIcons.location}
                    class="size-4 shrink-0 text-base-content/60"
                    aria-hidden="true"
                  />
                  <span class="truncate" data-highlight-target>
                    {terminal.branch}
                  </span>
                </p>
                <p class="truncate pl-6 text-xs text-base-content/60">
                  {terminal.province}{" "}
                  <span class="text-base-content/35">•</span>{" "}
                  {terminal.region}
                </p>
                <div class="pl-6">
                  <span class="inline-block max-w-full truncate rounded-md border border-base-300 bg-base-200/70 px-2 py-0.5 font-mono text-xs text-base-content/70">
                    {terminal.nis}
                  </span>
                </div>
              </div>

              <div class="col-span-2 min-w-0">
                <div class="flex min-w-0 flex-col items-end gap-0.5 text-right">
                  <p class="flex min-w-0 items-center justify-end gap-1.5 text-sm font-medium text-base-content">
                    <Icon
                      name={rowIcons.contact}
                      class="size-4 shrink-0 text-base-content/60"
                      aria-hidden="true"
                    />
                    <span class="truncate">{terminal.lastContactDate}</span>
                  </p>
                  <p class="truncate font-mono text-xs text-base-content/60">
                    {terminal.lastContactTime}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </DataTable>
    </section>
  </section>

  <script>
    import {
      highlightSearchTargets,
      matchesSearchQuery,
    } from "@lib/clientSearch";

    const searchInput =
      document.querySelector<HTMLInputElement>("#terminal-search");
    const rows = Array.from(
      document.querySelectorAll<HTMLElement>("[data-terminal-row]"),
    );
    const emptyState =
      document.querySelector<HTMLElement>("#terminal-empty-state");

    if (
      searchInput instanceof HTMLInputElement &&
      emptyState instanceof HTMLElement
    ) {
      const updateRows = () => {
        const rawSearchValue = searchInput.value.trim();
        let visibleRows = 0;

        rows.forEach((row) => {
          const isVisible = matchesSearchQuery(rawSearchValue, [
            row.dataset.hostname,
            row.dataset.ip,
            row.dataset.mac,
            row.dataset.branch,
          ]);

          row.classList.toggle("hidden", !isVisible);
          highlightSearchTargets(row, isVisible ? rawSearchValue : "");

          if (isVisible) {
            visibleRows += 1;
          }
        });

        emptyState.classList.toggle("hidden", visibleRows > 0);
      };

      searchInput.addEventListener("input", updateRows);
      updateRows();
    }
  </script>
</BaseLayout>
