---
import { getCleanBase } from "@lib/baseUrl";
import { db } from "@db/index";
import {
  cubics,
  agents,
  cubicAssignments,
  operatorAttendance,
} from "@db/schema";
import { eq, asc, and } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { logAdminAction } from "@lib/auditLogger";
import SectionCard from "@components/ui/SectionCard.astro";
const cleanBase = getCleanBase();

const user = Astro.locals.user;

const { id } = Astro.params;
const isNew = false;
let successMsg = "";
let errorMsg = "";

if (!id || isNaN(Number(id))) {
  return Astro.redirect(`${cleanBase}inventario-terminales`);
}

const cubicId = Number(id);

const todayStr = new Date().toLocaleDateString("en-CA", {
  timeZone: "America/Argentina/Buenos_Aires",
});

function getInitials(name: string): string {
  if (!name) return "";
  if (name.includes(",")) {
    return name
      .split(",")
      .reverse()
      .map((n) => n.trim()[0])
      .join("")
      .substring(0, 3)
      .toUpperCase();
  }
  return name
    .split(/\s+/)
    .map((n) => n[0])
    .join("")
    .substring(0, 3)
    .toUpperCase();
}

function getShiftType(
  entradaReal: string | null | undefined,
  horarioDefault: string | null | undefined,
): "Diurno" | "Nocturno" {
  let timeStr = entradaReal || "";
  if (!timeStr && horarioDefault) {
    const parts = horarioDefault.split("-");
    if (parts[0]) {
      timeStr = parts[0].trim();
    }
  }

  if (timeStr) {
    const hourMatch = timeStr.match(/^(\d{1,2})/);
    if (hourMatch) {
      const hour = parseInt(hourMatch[1], 10);
      if (hour >= 6 && hour < 18) {
        return "Diurno";
      } else {
        return "Nocturno";
      }
    }
  }
  return "Diurno";
}

if (Astro.request.method === "POST") {
  try {
    const fd = await Astro.request.formData();

    const cubicData = {
      name: fd.get("name")?.toString().trim() ?? "",
      ip: fd.get("ip")?.toString().trim() || null,
    };

    if (!cubicData.name) {
      errorMsg = "El nombre de red es obligatorio.";
    } else {
      const [existing] = await db
        .select({ name: cubics.name })
        .from(cubics)
        .where(eq(cubics.id, cubicId));
      const oldName = existing?.name || "";
      await db.update(cubics).set(cubicData).where(eq(cubics.id, cubicId));

      await db
        .delete(cubicAssignments)
        .where(eq(cubicAssignments.cubicId, cubicId));

      const aAgentIds = fd.getAll("assign_agent_id").slice(0, 4);

      for (let i = 0; i < aAgentIds.length; i++) {
        const agentIdStr = aAgentIds[i]?.toString().trim();
        if (!agentIdStr) continue;

        const agentId = Number(agentIdStr);
        if (isNaN(agentId)) continue;

        const agentData = db
          .select({
            horarioDefault: agents.horarioDefault,
            entradaReal: operatorAttendance.entradaReal,
          })
          .from(agents)
          .leftJoin(
            operatorAttendance,
            and(
              eq(operatorAttendance.agentId, agents.id),
              eq(operatorAttendance.date, todayStr),
            ),
          )
          .where(eq(agents.id, agentId))
          .get();

        const shiftType = agentData
          ? getShiftType(agentData.entradaReal, agentData.horarioDefault)
          : "Diurno";
        const dbShift = shiftType === "Diurno" ? "morning" : "afternoon_night";

        try {
          await db.insert(cubicAssignments).values({
            cubicId,
            agentId,
            shift: dbShift,
          });
        } catch (e: any) {}
      }

      if (oldName && oldName !== cubicData.name) {
        await logAdminAction(
          user?.username || "Sistema",
          `Actualizó el ordenador de "${oldName}" a "${cubicData.name}"`,
        );
      } else {
        await logAdminAction(
          user?.username || "Sistema",
          `Actualizó el ordenador "${cubicData.name}"`,
        );
      }
      return Astro.redirect(
        `${cleanBase}inventario-terminales?toast_msg=${encodeURIComponent("Cubic actualizado con éxito.")}&toast_type=success`,
      );
    }
  } catch (e: any) {
    errorMsg = e.message?.includes("UNIQUE")
      ? "Ya existe un cubic con ese nombre de red."
      : "Error al guardar el cubic.";
  }
}

type CubicRecord = {
  id: number;
  name: string;
  ip: string | null;
  status: string;
  lastPing: string | null;
  assignments: {
    shift: string;
    agent: { id: number; name: string; avatarInitials: string | null };
  }[];
};

const result = await db.query.cubics.findFirst({
  where: eq(cubics.id, cubicId),
  with: {
    assignments: {
      with: {
        agent: true,
      },
    },
  },
});
if (!result) return Astro.redirect(`${cleanBase}inventario-terminales`);
const cubic = result as unknown as CubicRecord;

const pageTitle = `Editar: ${cubic.name}`;

const allAgents = await db
  .select({
    id: agents.id,
    name: agents.name,
    avatarInitials: agents.avatarInitials,
    horarioDefault: agents.horarioDefault,
    entradaReal: operatorAttendance.entradaReal,
  })
  .from(agents)
  .leftJoin(
    operatorAttendance,
    and(
      eq(operatorAttendance.agentId, agents.id),
      eq(operatorAttendance.date, todayStr),
    ),
  )
  .orderBy(asc(agents.name));

const agentShiftMap = new Map<number, "Diurno" | "Nocturno">();
for (const agent of allAgents) {
  const shiftType = getShiftType(agent.entradaReal, agent.horarioDefault);
  agentShiftMap.set(agent.id, shiftType);
}
---

<BaseLayout title={pageTitle}>
  <PageContainer width="xxl">
    <div class="flex items-center gap-2 text-sm text-base-content/60">
      <a
        href={`${cleanBase}inventario-terminales`}
        class="flex items-center gap-1.5 hover:text-base-content transition-colors"
      >
        <Icon name="boxicons:chevron-left" size={16} />
        Terminales
      </a>
      <span>/</span>
      <span class="text-base-content font-medium truncate">{pageTitle}</span>
    </div>

    <PageHeader
      title={pageTitle}
      description={`Estado: ${cubic.status} · IP: ${cubic.ip ?? "sin asignar"}`}
    />

    {
      errorMsg && (
        <script is:inline define:vars={{ errorMsg }}>
          window.showToast?.(errorMsg, "alert-error");
        </script>
      )
    }

    <form
      method="POST"
      id="cubic-form"
      onsubmit="return confirm('¿Estás seguro de que deseas aplicar estas modificaciones sobre el Cubic?');"
      class="space-y-4"
    >
      <SectionCard class="shadow-md">
          <h2
            class="flex items-center gap-2 text-sm font-semibold text-base-content"
          >
            <span
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:desktop-filled" size={15} />
            </span>
            Datos técnicos del equipo
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <FormField
              id="input-name"
              name="name"
              label="Nombre de red"
              required
              value={cubic.name}
              placeholder="b1842zacw2999.correo.local"
              autocomplete="off"
              inputClass="input-sm font-mono"
            />

            <FormField
              id="input-ip"
              name="ip"
              label="Dirección IP"
              value={cubic.ip ?? ""}
              placeholder="10.254.59.62"
              autocomplete="off"
              inputClass="input-sm font-mono"
              helpText="IPv4 asignada al equipo. Opcional."
            />
          </div>
      </SectionCard>

      <SectionCard class="shadow-md">
          <div class="flex items-center justify-between">
            <h2
              class="flex items-center gap-2 text-sm font-semibold text-base-content"
            >
              <span
                class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warning/10 text-warning"
              >
                <Icon name="boxicons:group-filled" size={15} />
              </span>
              Operadores asignados
            </h2>
            <button
              type="button"
              id="btn-add-assignment"
              class="btn btn-ghost btn-xs text-warning gap-1"
            >
              <Icon name="boxicons:plus" size={14} />
              Agregar
            </button>
          </div>

          <div
            id="assignments-container"
            class="grid grid-cols-1 md:grid-cols-2 gap-4"
          >
            {
              cubic.assignments.map((a) => (
                <div
                  class="assignment-row relative rounded-lg bg-base-200/50 p-4 border border-base-300"
                  data-mode="read"
                >
                  <div class="read-mode flex items-center justify-between w-full">
                    <div class="flex items-center gap-3">
                      <div class="avatar placeholder">
                        <div class="bg-secondary/10 text-secondary rounded-xl w-8 h-8 border border-secondary/20 flex items-center justify-center">
                          <span class="text-xs font-bold">
                            {getInitials(a.agent.name)}
                          </span>
                        </div>
                      </div>
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="font-bold text-base-content">
                            {a.agent.name}
                          </span>
                          <span class="flex items-center gap-1 text-xxs text-base-content/60 bg-base-300/40 px-2 py-0.5 rounded border border-base-300 select-none">
                            {agentShiftMap.get(a.agent.id) === "Diurno" ? (
                              <Icon
                                name="boxicons:sun"
                                size={12}
                                class="text-warning shrink-0"
                              />
                            ) : (
                              <Icon
                                name="boxicons:moon"
                                size={12}
                                class="text-info shrink-0"
                              />
                            )}
                            <span>
                              {agentShiftMap.get(a.agent.id) || "Diurno"}
                            </span>
                          </span>
                        </div>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <button
                        type="button"
                        class="btn btn-ghost btn-xs edit-row-btn text-warning"
                      >
                        <Icon name="boxicons:edit-alt" size={16} />
                        Editar
                      </button>
                      <button
                        type="button"
                        class="btn btn-ghost btn-xs text-error remove-row-btn"
                        aria-label="Quitar asignación"
                      >
                        <Icon name="boxicons:trash" size={16} />
                        Quitar
                      </button>
                    </div>
                  </div>

                  <div class="edit-mode space-y-3 w-full">
                    <div class="flex items-center justify-between">
                      <span class="text-xs font-bold text-base-content/50">
                        Modificar Asignación
                      </span>
                      <button
                        type="button"
                        class="btn btn-ghost btn-xs cancel-row-btn text-neutral"
                      >
                        Cancelar
                      </button>
                    </div>

                    <div class="grid grid-cols-1 gap-3">
                      <SelectField
                        id={`assign_agent_id-${a.agent.id}`}
                        name="assign_agent_id"
                        label="Operador"
                        required
                        selectClass="select-sm"
                        options={allAgents.map((ag) => ({
                          value: ag.id.toString(),
                          label: ag.name,
                        }))}
                        value={a.agent.id.toString()}
                      />
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
          {
            cubic.assignments.length === 0 && (
              <p
                id="no-assignments-msg"
                class="text-xs text-base-content/40 text-center py-1"
              >
                Sin operadores asignados.
              </p>
            )
          }
      </SectionCard>

      <div class="flex items-center justify-between gap-3 pt-1">
        <a
          href={`${cleanBase}inventario-terminales`}
          class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10"
        >
          <Icon name="boxicons:arrow-left-filled" size={16} />
          Volver al listado
        </a>
        <button type="submit" class="btn btn-secondary btn-sm gap-2">
          <Icon name="boxicons:save-filled" size={16} />
          Guardar cambios
        </button>
      </div>
    </form>
  </PageContainer>
</BaseLayout>

<template id="tpl-assignment-row">
  <div
    class="assignment-row relative rounded-lg bg-base-200/50 p-4 border border-base-300"
    data-mode="edit"
  >
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-bold text-base-content/50"
        >Nueva Asignación</span
      >
      <button
        type="button"
        class="btn btn-ghost btn-xs remove-row-btn text-error"
      >
        Quitar
      </button>
    </div>

    <div class="space-y-3">
      <SelectField
        id="tpl-assign_agent_id"
        name="assign_agent_id"
        label="Operador"
        required
        selectClass="select-sm"
      >
        <option value="" disabled selected>Seleccione un operador...</option>
        {
          allAgents.map((agent) => (
            <option value={agent.id}>{agent.name}</option>
          ))
        }
      </SelectField>
    </div>
  </div>
</template>

<style>
  .assignment-row[data-mode="read"] .read-mode {
    display: flex;
  }
  .assignment-row[data-mode="read"] .edit-mode {
    display: none;
  }
  .assignment-row[data-mode="edit"] .read-mode {
    display: none;
  }
  .assignment-row[data-mode="edit"] .edit-mode {
    display: block;
  }
</style>

<script>
  function initDynamicRows() {
    const container = document.getElementById("assignments-container")!;
    const tpl = document.getElementById(
      "tpl-assignment-row",
    ) as HTMLTemplateElement;
    const btnAdd = document.getElementById("btn-add-assignment")!;
    const noMsg = document.getElementById("no-assignments-msg");

    function updateAddButtonState() {
      const rows = container.querySelectorAll(".assignment-row");
      const rowCount = rows.length;
      if (rowCount >= 4) {
        btnAdd.setAttribute("disabled", "true");
        btnAdd.classList.add("btn-disabled");
      } else {
        btnAdd.removeAttribute("disabled");
        btnAdd.classList.remove("btn-disabled");
      }

      if (noMsg) {
        if (rowCount > 0) {
          noMsg.classList.add("hidden");
        } else {
          noMsg.classList.remove("hidden");
        }
      }
    }

    container.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const row = target.closest(".assignment-row") as HTMLElement;
      if (!row) return;

      if (target.closest(".edit-row-btn")) {
        row.setAttribute("data-mode", "edit");
      } else if (target.closest(".cancel-row-btn")) {
        row.setAttribute("data-mode", "read");
      } else if (target.closest(".remove-row-btn")) {
        row.remove();
        updateAddButtonState();
      }
    });

    btnAdd?.addEventListener("click", () => {
      const rowCount = container.querySelectorAll(".assignment-row").length;
      if (rowCount < 4) {
        container.appendChild(tpl.content.cloneNode(true));
        updateAddButtonState();
      }
    });

    updateAddButtonState();
  }

  initDynamicRows();
</script>
