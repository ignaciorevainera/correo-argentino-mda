---
import BaseLayout from "@layouts/BaseLayout.astro";
import CronogramaDashboard from "@components/cronograma/CronogramaDashboard.astro";
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { normalizeRole } from "@lib/rbac";
const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
const role = normalizeRole(user.role);
---

<BaseLayout>
  <PageContainer width="xl">
    <PageHeader
      description="Gestión integral de asistencia y modalidades del equipo MDA."
      data-crono-hide-on-maximize
    />

    <CronogramaDashboard userRole={role} />
  </PageContainer>
</BaseLayout>
