---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import QuickAccessCard from "@components/ui/QuickAccessCard.astro";

const supervisionTools = [
  {
    title: "Cronograma",
    description: "Gestión integral de asistencia y modalidades del equipo.",
    icon: "boxicons:calendar-filled",
    href: "/cronograma",
    iconTone: "bg-error/10 text-error",
  },
  {
    title: "Calidad de operadores",
    description:
      "Métricas y validaciones de la calidad de atención del equipo de operaciones.",
    icon: "boxicons:bar-chart-big-filled",
    href: "/calidad-operadores",
    iconTone: "bg-primary/10 text-primary",
  },
];
---

<BaseLayout title="Supervisión">
  <PageContainer>
    <PageHeader
      title="Supervisión"
      description="Panel centralizado para herramientas de gestión de personal y métricas del equipo."
    />

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        supervisionTools.map((tool) => (
          <QuickAccessCard
            href={tool.href}
            title={tool.title}
            description={tool.description}
            icon={tool.icon}
            iconTone={tool.iconTone}
          />
        ))
      }
    </div>
  </PageContainer>
</BaseLayout>
