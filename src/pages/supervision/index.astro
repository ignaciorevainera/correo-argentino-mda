---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import QuickAccessCard from "@components/ui/QuickAccessCard.astro";

const user = Astro.locals.user;
const role = user.role;

const isLocked = (href: string) => {
  if (href === "/supervision/cronograma" || href === "/supervision/asistencia") {
    return !["admin", "supervisor"].includes(role);
  }
  return false;
};

const supervisionTools = [
  {
    title: "Cronograma",
    description: "Gestión integral de asistencia y modalidades del equipo.",
    icon: "boxicons:calendar-filled",
    href: "/supervision/cronograma",
    iconTone: "bg-error/10 text-error",
  },
  {
    title: "Control de Asistencia",
    description: "Registro de login/logout real, eventualidades y cumplimiento diario.",
    icon: "boxicons:clock-filled",
    href: "/supervision/asistencia",
    iconTone: "bg-success/10 text-success",
  },
  {
    title: "Calidad de operadores",
    description:
      "Métricas y validaciones de la calidad de atención del equipo de operaciones.",
    icon: "boxicons:bar-chart-big-filled",
    href: "/supervision/calidad-operadores",
    iconTone: "bg-primary/10 text-primary",
  },
  {
    title: "Asignación de autogestiones",
    description:
      "Distribución semiautomática de tickets de AG entrantes para el equipo operativo.",
    icon: "boxicons:git-branch-filled",
    href: "/supervision/asignacion-autogestiones",
    iconTone: "bg-secondary/10 text-secondary",
  },
];
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      description="Panel centralizado para herramientas de gestión de personal y métricas del equipo."
    />

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        supervisionTools.map((tool) => (
          <QuickAccessCard
            href={tool.href}
            title={tool.title}
            description={tool.description}
            icon={tool.icon}
            iconTone={tool.iconTone}
            locked={isLocked(tool.href)}
          />
        ))
      }
    </div>
  </PageContainer>
</BaseLayout>
