---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { operators, operatorShifts } from "@db/schema";
import { eq, asc } from "drizzle-orm";

let flashMessage: { type: "success" | "error"; text: string } | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action") as string;

    if (action === "update_mode") {
      const operatorId = formData.get("operatorId") as string;
      const currentMode = formData.get("currentMode") === "home" ? "home" : "presencial";
      if (operatorId) {
        await db
          .update(operators)
          .set({ currentMode })
          .where(eq(operators.id, operatorId));

        flashMessage = {
          type: "success",
          text: `Modo de trabajo actualizado correctamente.`,
        };
      }
    } else if (action === "assign_manual") {
      const operatorId = formData.get("operatorId") as string;
      if (operatorId) {
        // Liberar al operador actualmente asignado
        await db
          .update(operators)
          .set({ status: "disponible" })
          .where(eq(operators.status, "asignado"));

        await db
          .update(operators)
          .set({
            status: "asignado",
            lastAutogestionAssignedAt: Date.now(),
          })
          .where(eq(operators.id, operatorId));

        const [op] = await db
          .select({ name: operators.name })
          .from(operators)
          .where(eq(operators.id, operatorId));

        flashMessage = {
          type: "success",
          text: `Autogestión asignada manualmente a ${op?.name ?? operatorId}.`,
        };
      }
    } else if (action === "assign_cyclic") {
      const availableOps = await db.query.operators.findMany({
        where: eq(operators.status, "disponible"),
        with: {
          shifts: true,
        },
        orderBy: [asc(operators.lastAutogestionAssignedAt)],
      });

      const now = new Date();
      const currentTime =
        now.getHours().toString().padStart(2, "0") +
        ":" +
        now.getMinutes().toString().padStart(2, "0");

      let nextOp = null;

      for (const op of availableOps) {
        const activeShift = op.shifts.find((s: { type: string; }) => s.type === op.currentMode);
        if (!activeShift) continue;

        const { shiftStart, shiftEnd, breakTime } = activeShift;

        if (currentTime >= shiftStart && currentTime <= shiftEnd) {
          const [bHour, bMin] = breakTime.split(":").map(Number);
          const breakEndHour = (bHour + 1).toString().padStart(2, "0");
          const breakEnd = `${breakEndHour}:${bMin.toString().padStart(2, "0")}`;

          const inBreak = currentTime >= breakTime && currentTime < breakEnd;

          if (!inBreak) {
            nextOp = op;
            break;
          }
        }
      }

      if (nextOp) {
        // Liberar al operador actualmente asignado
        await db
          .update(operators)
          .set({ status: "disponible" })
          .where(eq(operators.status, "asignado"));

        await db
          .update(operators)
          .set({
            status: "asignado",
            lastAutogestionAssignedAt: Date.now(),
          })
          .where(eq(operators.id, nextOp.id));

        flashMessage = {
          type: "success",
          text: `Autogestión asignada cíclicamente a ${nextOp.name}.`,
        };
      } else {
        flashMessage = {
          type: "error",
          text: "No hay operadores disponibles o dentro de horario operativo para asignar.",
        };
      }
    } else if (action === "update_status") {
      const operatorId = formData.get("operatorId") as string;
      const newStatus = formData.get("status") as string;
      if (operatorId && newStatus) {
        if (newStatus === "asignado") {
          // Si lo pasamos manualmente a asignado desde el select, liberamos al actual
          await db
            .update(operators)
            .set({ status: "disponible" })
            .where(eq(operators.status, "asignado"));
        }

        await db
          .update(operators)
          .set({ status: newStatus })
          .where(eq(operators.id, operatorId));

        flashMessage = {
          type: "success",
          text: `Estado actualizado correctamente.`,
        };
      }
    }
  } catch (e) {
    flashMessage = {
      type: "error",
      text: "Ocurrió un error al procesar la acción.",
    };
  }
}

const allOperators = await db.query.operators.findMany({
  with: {
    shifts: true,
  },
  orderBy: [asc(operators.name)],
});

const STATUSES = [
  "disponible",
  "asignado",
  "break",
  "reunion",
  "supervision",
  "licencia",
  "vacaciones",
] as const;

type OperatorStatus = (typeof STATUSES)[number];

const STATUS_LABELS: Record<OperatorStatus, string> = {
  disponible: "Disponible",
  asignado: "Asignado",
  break: "Break",
  reunion: "Reunión",
  supervision: "Supervisión",
  licencia: "Licencia",
  vacaciones: "Vacaciones",
};

const STATUS_GROUPS = [
  { label: "Operativos", statuses: ["disponible", "asignado"] as const },
  { label: "Pausas Cortas", statuses: ["break", "reunion", "supervision"] as const },
  { label: "Ausencias", statuses: ["licencia", "vacaciones"] as const },
];

const getBadgeColor = (status: string): string => {
  switch (status) {
    case "disponible":
      return "badge-success";
    case "asignado":
      return "badge-primary";
    case "break":
    case "reunion":
    case "supervision":
      return "badge-warning";
    case "licencia":
    case "vacaciones":
      return "badge-error";
    default:
      return "badge-neutral";
  }
};

const getSelectColor = (status: string): string => {
  return getBadgeColor(status).replace("badge-", "select-");
};

const disponiblesCount = allOperators.filter(
  (op) => op.status === "disponible",
).length;
const noDisponiblesList = allOperators.filter(
  (op) => op.status !== "disponible",
);
const noDisponiblesCount = noDisponiblesList.length;

const breakdown: Record<string, number> = {};
for (const s of STATUSES) {
  if (s !== "disponible") {
    breakdown[s] = 0;
  }
}
noDisponiblesList.forEach((op) => {
  if (breakdown[op.status] !== undefined) {
    breakdown[op.status]++;
  } else {
    breakdown[op.status] = 1;
  }
});

const breakdownBadge = (status: string): string => {
  return getBadgeColor(status).replace("badge-", "bg-");
};
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      description="Distribución equitativa y controlada de autogestiones entre operadores técnicos. Utiliza el botón de asignar próximo para rotar de manera circular."
    />

    {
      flashMessage && (
        <div
          class={`alert mb-6 shadow-md ${flashMessage.type === "success" ? "alert-success" : "alert-error"}`}
          role="alert"
        >
          <Icon
            name={
              flashMessage.type === "success"
                ? "boxicons:check-circle"
                : "boxicons:error-circle"
            }
            size={20}
          />
          <span>{flashMessage.text}</span>
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <!-- Card Disponibles -->
      <div
        class="card bg-base-100 border border-base-300 shadow-md overflow-hidden group hover:border-success/30 transition-all duration-300"
      >
        <div
          class="absolute -top-4 -right-4 p-4 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition-all duration-500 pointer-events-none"
        >
          <Icon name="boxicons:user-check" size={128} />
        </div>
        <div class="card-body p-6">
          <div class="flex items-center gap-3 mb-2">
            <div class="p-2 bg-success/10 rounded-lg text-success">
              <Icon name="boxicons:user-check" size={24} />
            </div>
            <h3
              class="font-bold text-xs uppercase tracking-widest text-base-content/50"
            >
              Disponibilidad Actual
            </h3>
          </div>
          <div class="flex items-baseline gap-2">
            <span
              class="text-5xl font-black text-success tracking-tight"
              id="stat-disponibles-count">{disponiblesCount}</span
            >
            <span
              class="text-base-content/40 font-bold uppercase text-xs tracking-wider"
              >operadores activos</span
            >
          </div>
          <div class="mt-6 flex flex-col gap-2">
            <div
              class="flex justify-between text-xs font-bold uppercase tracking-wider px-0.5"
            >
              <span class="text-base-content/40">Tasa de disponibilidad</span>
              <span class="text-success font-mono" id="stat-percentage"
                >{
                  allOperators.length > 0
                    ? Math.round(
                        (disponiblesCount / allOperators.length) * 100,
                      )
                    : 0
                }%</span
              >
            </div>
            <progress
              class="progress progress-success w-full h-2.5 bg-base-200"
              value={disponiblesCount}
              max={allOperators.length || 1}
              id="stat-progress"></progress>
          </div>
        </div>
      </div>

      <!-- Card No Disponibles -->
      <div
        class="card bg-base-100 border border-base-300 shadow-md overflow-hidden group hover:border-base-content/20 transition-all duration-300"
      >
        <div
          class="absolute -top-4 -right-4 p-4 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition-all duration-500 pointer-events-none"
        >
          <Icon name="boxicons:user-x" size={128} />
        </div>
        <div class="card-body p-6">
          <div class="flex items-center gap-3 mb-2">
            <div class="p-2 bg-base-content/5 rounded-lg text-base-content/50">
              <Icon name="boxicons:user-x" size={24} />
            </div>
            <h3
              class="font-bold text-xs uppercase tracking-widest text-base-content/50"
            >
              Fuera de Servicio
            </h3>
          </div>
          <div class="flex items-baseline gap-2">
            <span
              class="text-5xl font-black text-base-content/80 tracking-tight"
              id="stat-no-disponibles-count">{noDisponiblesCount}</span
            >
            <span
              class="text-base-content/40 font-bold uppercase text-xs tracking-wider"
              >en estados especiales</span
            >
          </div>

          <div class="mt-4 grid grid-cols-2 gap-2">
            {
              Object.entries(breakdown).map(([estado, count]) => (
                <div
                  class="flex items-center justify-between p-2 rounded-lg bg-base-200/50 border border-transparent hover:border-base-300 transition-all duration-200 data-[count='0']:opacity-40"
                  data-count={count}
                >
                  <div class="flex items-center gap-2 min-w-0">
                    <span
                      class={`size-2 rounded-full shrink-0 ${breakdownBadge(estado)}`}
                    />
                    <span class="text-xs font-bold truncate text-base-content/60 uppercase tracking-tight">
                      {STATUS_LABELS[estado as OperatorStatus] ?? estado}
                    </span>
                  </div>
                  <span class="text-xs font-mono font-bold text-base-content/90">
                    {count}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="mb-4 flex flex-wrap items-center gap-4">
      <div class="flex-1">
        <label class="label cursor-pointer justify-start gap-3">
          <input
            type="checkbox"
            id="toggle-disponibles"
            class="toggle toggle-primary"
          />
          <span class="label-text">Ver solo operadores disponibles</span>
        </label>
      </div>
      <form method="POST">
        <input type="hidden" name="action" value="assign_cyclic" />
        <button type="submit" class="btn btn-primary">
          <Icon name="boxicons:user-check" size={24} aria-hidden="true" />
          Asignar Siguiente (Cíclico)
        </button>
      </form>
    </div>

    <DataTable
      ariaLabel="Lista de operadores para asignación de autogestiones"
      headerGridClass="grid-cols-[1.5fr_1.2fr_0.8fr_minmax(140px,auto)_minmax(90px,auto)] gap-2 md:gap-4"
      rowGridClass="grid grid-cols-[1.5fr_1.2fr_0.8fr_minmax(140px,auto)_minmax(90px,auto)] items-center gap-2 md:gap-4"
    >
      <Fragment slot="header">
        <DataTableHeaderCell sortKey="nombre">Operador</DataTableHeaderCell>
        <DataTableHeaderCell>Horario / Modo</DataTableHeaderCell>
        <DataTableHeaderCell sortKey="estado">Estado</DataTableHeaderCell>
        <DataTableHeaderCell>Cambiar Estado</DataTableHeaderCell>
        <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
      </Fragment>

      {
        allOperators.map((op) => {
          const activeShift = op.shifts.find((s: { type: string; }) => s.type === op.currentMode);
          
          return (
          <div
            class={`group border-b border-base-300 px-4 py-1.5 transition-colors hover:bg-base-200/50 ${op.status === "asignado" ? "bg-primary/10 border-l-4 border-l-primary" : ""}`}
            data-table-row
            data-op-id={op.id}
            data-op-estado={op.status}
            data-sort-nombre={op.name}
            data-sort-estado={op.status}
          >
            {/* Nombre + ID */}
            <div class="flex min-w-0 flex-col">
              <span class="truncate text-xs font-semibold text-base-content">
                {op.name}
              </span>
              <span class="font-mono text-[10px] text-base-content/50">
                {op.id}
              </span>
            </div>

            {/* Horario y Modo */}
            <div class="flex flex-col gap-1 min-w-0">
              <div class="text-[11px] text-base-content/70 leading-normal">
                {activeShift ? (
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
                    <span class="flex items-center gap-1 font-medium">
                      <Icon
                        name="boxicons:clock-dashed-half-filled"
                        size={14}
                        class="opacity-60 shrink-0"
                      />
                      {activeShift.shiftStart} - {activeShift.shiftEnd}
                    </span>
                    <span class="flex items-center gap-1 opacity-70">
                      <Icon
                        name="boxicons:coffee"
                        size={12}
                        class="opacity-60 shrink-0"
                      />
                      {activeShift.breakTime}
                    </span>
                  </div>
                ) : (
                  <span class="text-base-content/40 italic">Sin horario</span>
                )}
              </div>
              
              <form method="POST" class="m-0">
                <input type="hidden" name="action" value="update_mode" />
                <input type="hidden" name="operatorId" value={op.id} />
                <div class="form-control">
                  <label class="label cursor-pointer justify-start gap-1 p-0">
                    <span class="label-text text-[10px] font-bold opacity-60 uppercase tracking-tight">Presencial</span>
                    <input 
                      type="checkbox" 
                      class="toggle toggle-xs toggle-primary shrink-0" 
                      name="currentMode"
                      value="home"
                      checked={op.currentMode === "home"}
                      onchange="this.form.submit()"
                    />
                    <span class="label-text text-[10px] font-bold opacity-60 uppercase tracking-tight">Home</span>
                  </label>
                </div>
              </form>
            </div>

            {/* Badge estado */}
            <div>
              <span
                class={`badge ${getBadgeColor(op.status)} badge-xs font-semibold uppercase text-[9px] tracking-wider py-1.5`}
              >
                {STATUS_LABELS[op.status as OperatorStatus] ?? op.status}
              </span>
            </div>

            {/* Select cambiar estado */}
            <div>
              <form method="POST" class="m-0">
                <input type="hidden" name="action" value="update_status" />
                <input type="hidden" name="operatorId" value={op.id} />
                <select
                  name="status"
                  class={`select select-bordered select-xs w-full max-w-[130px] font-medium text-xs ${getSelectColor(op.status)}`}
                  onchange="this.form.submit()"
                >
                  {STATUS_GROUPS.map((group) => (
                    <optgroup label={group.label} class="text-xs">
                      {group.statuses.map((s) => (
                        <option value={s} selected={op.status === s} class="text-xs text-base-content bg-base-100">
                          {STATUS_LABELS[s]}
                        </option>
                      ))}
                    </optgroup>
                  ))}
                </select>
              </form>
            </div>

            {/* Botón asignar manual */}
            <div class="flex items-center justify-end">
              <form method="POST" class="m-0">
                <input type="hidden" name="action" value="assign_manual" />
                <input type="hidden" name="operatorId" value={op.id} />
                <button
                  type="submit"
                  class="btn btn-secondary btn-xs btn-soft"
                  title={`Asignar autogestión a ${op.name}`}
                  disabled={!activeShift}
                >
                  Asignar
                </button>
              </form>
            </div>
          </div>
        )})
      }
    </DataTable>
  </PageContainer>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById(
      "toggle-disponibles",
    ) as HTMLInputElement | null;
    if (!toggle) return;

    const updateVisibility = () => {
      const soloDisponibles = toggle.checked;
      const rows =
        document.querySelectorAll<HTMLElement>("[data-op-estado]");
      rows.forEach((row) => {
        const estado = row.getAttribute("data-op-estado") || "";
        if (soloDisponibles && estado !== "disponible") {
          row.classList.add("hidden");
        } else {
          row.classList.remove("hidden");
        }
      });
    };

    toggle.addEventListener("change", updateVisibility);
  });
</script>
