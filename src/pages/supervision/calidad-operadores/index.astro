          <!-- Section 2 -->
          <div class="p-6">
            <div class="mb-6 flex items-center justify-between border-b border-base-300/50 pb-3">
              <h5 class="font-bold text-xs uppercase tracking-widest text-base-content/70">Gestión del Ticket</h5>
              <div class="flex items-baseline gap-1">
                <span class="text-xl font-black ${s2ScoreColor}">${call.section2.score}</span>
                <span class="text-xs font-bold text-base-content/30">/${call.section2.maxScore}</span>
              </div>
            </div>
            <ul class="space-y-3.5 text-sm">
              <li class="flex items-center justify-between group/item">
                <span class="text-base-content/70 font-medium group-hover/item:text-base-content transition-colors">Origen de la solicitud</span>
                <span class="leading-none ${call.section2.details.origen ? "text-success" : "text-error"}" title="${call.section2.details.origen ? "Cumple" : "No Cumple"}">${call.section2.details.origen ? ICON_CHECK : ICON_X}</span>
