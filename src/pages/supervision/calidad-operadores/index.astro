                <span class="leading-none ${call.section2.details.cierre ? "text-success" : "text-error"}" title="${call.section2.details.cierre ? "Cumple" : "No Cumple"}">${call.section2.details.cierre ? ICON_CHECK : ICON_X}</span>
              </li>
              <li class="flex items-center justify-between group/item">
