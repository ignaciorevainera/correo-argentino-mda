                <span class="leading-none ${call.section1.details.solicitud ? "text-success" : "text-error"}" title="${call.section1.details.solicitud ? "Cumple" : "No Cumple"}">${call.section1.details.solicitud ? ICON_CHECK : ICON_X}</span>
