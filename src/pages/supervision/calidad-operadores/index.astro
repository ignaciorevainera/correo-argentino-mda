                <span class="leading-none ${call.section2.details.descripcion ? "text-success" : "text-error"}" title="${call.section2.details.descripcion ? "Cumple" : "No Cumple"}">${call.section2.details.descripcion ? ICON_CHECK : ICON_X}</span>
              </li>
              <li class="flex items-center justify-between group/item">
                <span class="text-base-content/70 font-medium group-hover/item:text-base-content transition-colors">Exactitud en el ingreso de datos</span>
                <span class="leading-none ${call.section2.details.exactitud ? "text-success" : "text-error"}" title="${call.section2.details.exactitud ? "Cumple" : "No Cumple"}">${call.section2.details.exactitud ? ICON_CHECK : ICON_X}</span>
              </li>
