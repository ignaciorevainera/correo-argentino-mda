              <li class="flex items-center justify-between group/item">
                <span class="text-base-content/70 font-medium group-hover/item:text-base-content transition-colors">Lenguaje apropiado</span>
                <span class="leading-none ${call.section1.details.lenguaje ? "text-success" : "text-error"}" title="${call.section1.details.lenguaje ? "Cumple" : "No Cumple"}">${call.section1.details.lenguaje ? ICON_CHECK : ICON_X}</span>
