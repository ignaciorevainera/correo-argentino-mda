---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import { mockOperatorsQuality } from "@lib/mockQualityData";

const totalOperators = mockOperatorsQuality.length;
const avgScore = Math.round(
  mockOperatorsQuality.reduce((acc, op) => acc + op.averageScore, 0) /
    totalOperators,
);
const excellentOperators = mockOperatorsQuality.filter(
  (op) => op.averageScore >= 90,
).length;
const needsImprovement = mockOperatorsQuality.filter(
  (op) => op.averageScore < 80,
).length;

const allCalls = mockOperatorsQuality.flatMap((op) => op.calls);
const totalCalls = allCalls.length;
const avgSection1 = Math.round(
  allCalls.reduce((acc, c) => acc + c.section1.score, 0) / totalCalls,
);
const avgSection2 = Math.round(
  allCalls.reduce((acc, c) => acc + c.section2.score, 0) / totalCalls,
);
---

<BaseLayout title="Calidad de operadores">
  <PageContainer class="max-w-7xl mx-auto">
    <a href="/supervision" class="btn btn-ghost btn-sm mb-2 w-fit pl-2">
      <Icon name="boxicons:chevron-left" size={24} />
      Volver a Supervisión
    </a>

    <PageHeader
      title="Calidad de operadores"
      description="Evaluación de llamadas, métricas y validaciones de la calidad de atención del equipo de operaciones de Mesa de Ayuda."
    />

    <!-- Selector de Período -->
    <div
      class="mt-4 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between bg-base-200/50 p-4 rounded-xl border border-base-300 shadow-sm"
    >
      <div class="flex items-center gap-2 text-base-content/80 mb-3 sm:mb-0">
        <Icon name="boxicons:calendar" size={24} class="text-primary" />
        <span class="font-semibold">Período de evaluación:</span>
      </div>
      <div class="flex items-center gap-2">
        <button class="btn btn-sm btn-square btn-ghost" title="Mes anterior">
          <Icon name="boxicons:chevron-left" size={24} />
        </button>
        <select
          id="month-selector"
          class="select select-bordered select-sm w-full sm:w-48 bg-base-100 font-bold text-center"
        >
          <option value="05-2026">Mayo 2026</option>
          <option value="04-2026">Abril 2026</option>
          <option value="03-2026">Marzo 2026</option>
          <option value="02-2026">Febrero 2026</option>
        </select>
        <button
          class="btn btn-sm btn-square btn-ghost"
          title="Mes siguiente"
          disabled
        >
          <Icon name="boxicons:chevron-right" class="opacity-50" size={24} />
        </button>
      </div>
    </div>

    <div
      class="mt-2 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start relative"
    >
      <!-- Panel Izquierdo: Lista Navegable -->
      <aside
        class="lg:col-span-4 flex flex-col gap-4 lg:sticky lg:top-6 lg:h-[calc(100vh-8rem)]"
      >
        <div
          class="card border border-base-300 bg-base-100 shadow-sm flex-1 flex flex-col overflow-hidden"
        >
          <div
            class="p-4 border-b border-base-200 bg-base-200/30 flex flex-col gap-3"
          >
            <h2 class="font-bold text-base-content flex items-center gap-2">
              <Icon name="boxicons:group" class="text-primary" size={24} />
              Operadores Evaluados
            </h2>
            <div class="flex flex-col gap-2">
              <SearchInput
                id="operator-search"
                label="Buscar operador"
                placeholder="Buscar por nombre o legajo..."
              />
              <div class="flex gap-2">
                <select
                  id="operator-filter"
                  class="select select-bordered select-sm w-1/2 font-medium text-base-content/70"
                >
                  <option value="all">Estado: Todos</option>
                  <option value="Activo">Activos</option>
                  <option value="Vacaciones">Vacaciones</option>
                  <option value="Licencia">Licencia</option>
                </select>
                <select
                  id="operator-sort"
                  class="select select-bordered select-sm w-1/2 font-medium text-base-content/70"
                >
                  <option value="name">A-Z</option>
                  <option value="score-desc">Mayor Score</option>
                  <option value="score-asc">Menor Score</option>
                </select>
              </div>
            </div>
          </div>

          <div class="flex-1 overflow-y-auto p-2" id="operator-list">
            {
              mockOperatorsQuality.map((op) => (
                <button
                  class="operator-item group w-full text-left p-4 mb-2 rounded-xl bg-base-100 border border-base-200 border-l-4 border-l-transparent hover:border-l-secondary hover:shadow-sm transition-all flex items-center justify-between"
                  data-name={op.name.toLowerCase()}
                  data-id={op.id.toLowerCase()}
                  data-operator={JSON.stringify(op)}
                >
                  <div class="flex items-center gap-4">
                    <div class="relative">
                      <div class="flex size-10 items-center justify-center rounded-full bg-base-200 group-hover:bg-secondary group-hover:text-secondary-content text-base-content/70 font-bold transition-colors shadow-sm">
                        {op.name
                          .split(" ")
                          .map((n) => n[0])
                          .join("")
                          .substring(0, 2)}
                      </div>
                      <div
                        class={`absolute -bottom-1 -right-1 size-3.5 rounded-full border-2 border-base-100 ${op.status === "Activo" ? "bg-success" : "bg-warning"}`}
                      />
                    </div>
                    <div>
                      <div class="font-bold text-sm text-base-content group-hover:text-base-content transition-colors tracking-tight flex items-center gap-1">
                        {op.name}
                        {op.averageScore >= 90 && (
                          <Icon
                            name="boxicons:badge-check"
                            class="text-secondary"
                            size={24}
                            title="Insignia de Excelencia"
                          />
                        )}
                      </div>
                      <div class="font-mono text-xs uppercase text-base-content/50 mt-0.5">
                        {op.id}
                      </div>
                    </div>
                  </div>
                  <div
                    class={`text-sm font-black ${op.averageScore >= 90 ? "text-success" : op.averageScore >= 80 ? "text-warning" : "text-error"}`}
                  >
                    {op.averageScore}%
                  </div>
                </button>
              ))
            }
            <div
              id="no-results-msg"
              class="hidden py-8 text-center text-base-content/50"
            >
              <Icon
                name="boxicons:search"
                class="mx-auto mb-2 opacity-40"
                size={48}
              />
              <p class="text-sm font-medium">Sin resultados</p>
            </div>
          </div>
        </div>
      </aside>

      <!-- Panel Derecho: Información / Detalle -->
      <main class="lg:col-span-8 h-full">
        <!-- Estado 1: Información General (Default) -->
        <div id="general-info-panel" class="space-y-6 animate-fade-in">
          <!-- Stats Grid -->
          <!-- Asymmetric Editorial Stats Grid -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Hero Stat: Promedio General (Takes 2 cols/2 rows) -->
            <div
              class="col-span-2 row-span-2 bg-secondary text-secondary-content rounded-3xl p-8 flex flex-col justify-between shadow-lg relative overflow-hidden"
            >
              <!-- Subtle pattern overlay -->
              <div
                class="absolute inset-0 opacity-5"
                style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 24px 24px;"
              >
              </div>
              <div
                class="absolute -right-8 -top-8 opacity-10 transition-all duration-700"
              >
                <Icon name="boxicons:check-shield" size={256} />
              </div>
              <div class="flex justify-between items-start relative z-10">
                <h3
                  class="font-bold uppercase tracking-widest text-xs opacity-80"
                >
                  Calidad Global
                </h3>
                <Icon
                  name="boxicons:chart-bar-columns"
                  size={24}
                  class="opacity-80"
                />
              </div>
              <div class="mt-12 relative z-10">
                <div
                  class="text-7xl lg:text-8xl font-black tracking-tighter leading-none"
                >
                  {avgScore}<span class="ml-2 text-4xl lg:text-5xl opacity-70"
                    >%</span
                  >
                </div>
                <p
                  class="text-sm font-medium opacity-90 mt-4 max-w-xs leading-relaxed"
                >
                  Promedio general del equipo de Mesa de Ayuda en el período
                  seleccionado.
                </p>
              </div>
            </div>

            <!-- Evaluados -->
            <div
              class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm transition-all hover:shadow-md hover:border-base-300 flex flex-col justify-between"
            >
              <h3
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
              >
                <Icon name="boxicons:group" size={18} /> Evaluados
              </h3>
              <div>
                <div
                  class="text-4xl font-black text-base-content tracking-tight"
                >
                  {totalOperators}
                </div>
                <div class="text-xs font-medium text-base-content/50 mt-1">
                  Operadores activos
                </div>
              </div>
            </div>

            <!-- Llamadas Auditadas -->
            <div
              class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm transition-all hover:shadow-md hover:border-base-300 flex flex-col justify-between"
            >
              <h3
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
              >
                <Icon name="boxicons:phone-ring" size={18} /> Auditorías
              </h3>
              <div>
                <div
                  class="text-4xl font-black text-base-content tracking-tight"
                >
                  {totalCalls}
                </div>
                <div class="text-xs font-medium text-base-content/50 mt-1">
                  Llamadas aleatorias
                </div>
              </div>
            </div>

            <!-- Excelente -->
            <div
              class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm transition-all hover:shadow-md hover:border-success/30 flex flex-col justify-between"
            >
              <h3
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
              >
                <Icon name="boxicons:star" size={18} /> Excelencia
              </h3>
              <div>
                <div class="text-4xl font-black text-success tracking-tight">
                  {excellentOperators}
                </div>
                <div class="text-xs font-medium text-base-content/50 mt-1">
                  Operadores &gt; 90%
                </div>
              </div>
            </div>

            <!-- Bajo Rendimiento -->
            <div
              class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm transition-all hover:shadow-md hover:border-error/30 flex flex-col justify-between"
            >
              <h3
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
              >
                <Icon name="boxicons:alert-circle" size={18} /> Alerta
              </h3>
              <div>
                <div class="text-4xl font-black text-error tracking-tight">
                  {needsImprovement}
                </div>
                <div class="text-xs font-medium text-base-content/50 mt-1">
                  Operadores &lt; 80%
                </div>
              </div>
            </div>

            <!-- Promedio Interacción -->
            <div
              class="col-span-2 lg:col-span-2 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm transition-all hover:shadow-md hover:border-base-300 flex flex-col justify-between"
            >
              <h3
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
              >
                <Icon name="boxicons:discussion" size={18} /> Interacción
              </h3>
              <div>
                <div
                  class="text-4xl font-black text-base-content tracking-tight"
                >
                  {avgSection1}%
                </div>
                <div class="text-xs font-medium text-base-content/50 mt-1">
                  Trato al usuario y habilidades blandas
                </div>
              </div>
            </div>

            <!-- Promedio Gestión -->
            <div
              class="col-span-2 lg:col-span-2 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm transition-all hover:shadow-md hover:border-base-300 flex flex-col justify-between"
            >
              <h3
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
              >
                <Icon name="boxicons:task" size={18} /> Gestión
              </h3>
              <div>
                <div
                  class="text-4xl font-black text-base-content tracking-tight"
                >
                  {avgSection2}%
                </div>
                <div class="text-xs font-medium text-base-content/50 mt-1">
                  Eficiencia técnica y resolución de tickets
                </div>
              </div>
            </div>
          </div>

          <!-- Empty State CTA -->
          <div
            class="rounded-3xl bg-base-200/50 flex-1 min-h-64 flex flex-col items-center justify-center text-center p-8 mt-4 border border-base-300 shadow-inner"
          >
            <div
              class="rounded-full bg-base-100 p-6 shadow-sm mb-6 border border-base-200"
            >
              <Icon
                name="boxicons:cursor-click"
                size={48}
                class="text-secondary/40"
              />
            </div>
            <h3
              class="text-2xl font-black text-base-content tracking-tight mb-3"
            >
              Análisis Individual
            </h3>
            <p
              class="max-w-md text-sm text-base-content/60 font-medium leading-relaxed"
            >
              Seleccione un operador de la lista lateral para visualizar su
              rendimiento detallado y el desglose de cada llamada.
            </p>
          </div>
        </div>

        <!-- Estado 2: Detalle del Operador (Oculto por defecto) -->
        <div
          id="operator-details-panel"
          class="hidden space-y-6 animate-fade-in pb-8"
        >
          <div class="flex justify-between items-center mb-2 no-print">
            <button
              id="btn-back-to-summary"
              class="btn btn-sm btn-ghost w-fit pl-2 text-base-content/70 hover:text-base-content hover:bg-base-200"
            >
              <Icon name="boxicons:arrow-to-left" size={18} />
              Volver al resumen
            </button>
            <button
              class="btn btn-sm btn-outline text-secondary border-secondary/30 hover:bg-secondary hover:text-secondary-content"
              onclick="window.print()"
            >
              <Icon name="boxicons:printer" size={18} />
              Exportar Reporte
            </button>
          </div>

          <!-- Header del Detalle -->
          <div
            class="bg-base-100 border-l-4 border-l-secondary rounded-2xl p-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 shadow-md border-y border-r border-base-200 mt-2"
          >
            <div class="flex flex-col sm:flex-row sm:items-center gap-6">
              <div
                class="flex size-20 items-center justify-center rounded-2xl bg-base-200 text-base-content/60 text-3xl font-black shadow-inner border border-base-300"
                id="detail-avatar"
              >
                --
              </div>
              <div>
                <div
                  class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-1"
                >
                  Perfil del Operador
                </div>
                <h3
                  class="text-4xl font-black text-base-content tracking-tighter"
                  id="detail-name"
                >
                  --
                </h3>
                <div
                  class="mt-2 flex flex-wrap items-center gap-3 text-xs font-medium text-base-content/60"
                >
                  <span class="flex items-center gap-1"
                    ><Icon
                      name="boxicons:user-id-card"
                      size={18}
                      class="opacity-70"
                    />
                    <span id="detail-id" class="font-mono">--</span></span
                  >
                  <span class="opacity-30">•</span>
                  <span class="flex items-center gap-1"
                    ><Icon
                      name="boxicons:calendar"
                      size={18}
                      class="opacity-70"
                    />
                    <span id="detail-month">--</span></span
                  >
                  <span class="opacity-30">•</span>
                  <span
                    id="detail-status"
                    class="badge badge-sm font-bold border-2 bg-base-100"
                    >--</span
                  >
                </div>
              </div>
            </div>

            <div
              class="sm:text-right bg-base-200/50 p-4 rounded-2xl border border-base-200"
            >
              <div
                class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-1"
              >
                Score Mensual
              </div>
              <div
                class="text-5xl font-black tracking-tighter"
                id="detail-score"
              >
                --%
              </div>
            </div>
          </div>

          <!-- Insights y Tendencia -->
          <div class="grid sm:grid-cols-2 gap-6 mt-6">
            <!-- Tendencia -->
            <div
              class="bg-base-100 rounded-2xl border border-base-200 p-6 shadow-sm"
            >
              <h4
                class="font-bold uppercase tracking-wider text-xs text-base-content/70 flex items-center gap-2 mb-4"
              >
                <Icon name="boxicons:chart-line" size={18} />
                Tendencia (Últimos 6 meses)
              </h4>
              <div
                class="flex items-end justify-between h-20 gap-2"
                id="detail-history-chart"
              >
                <!-- dynamic bars -->
              </div>
            </div>

            <!-- Áreas de Mejora -->
            <div
              class="bg-base-100 rounded-2xl border border-warning/30 p-6 shadow-sm bg-warning/5"
            >
              <h4
                class="font-bold uppercase tracking-wider text-xs text-warning-content/70 flex items-center gap-2 mb-4"
              >
                <Icon
                  name="boxicons:alert-octagon"
                  size={24}
                  class="text-warning"
                />
                Áreas de Mejora Detectadas
              </h4>
              <ul
                class="space-y-2 text-sm font-medium text-base-content/80"
                id="detail-insights"
              >
                <!-- dynamic insights -->
              </ul>
            </div>
          </div>

          <!-- Section Titulo -->
          <div
            class="flex items-center justify-between border-b border-base-300 pb-2 mt-8"
          >
            <h4
              class="font-bold uppercase tracking-wider text-base-content/70 flex items-center gap-2"
            >
              <Icon name="boxicons:headphone" size={24} />
              Desglose de Llamadas
            </h4>
            <span
              class="text-xs font-medium text-base-content/50 badge badge-ghost"
              >4 Aleatorias</span
            >
          </div>

          <!-- Grid de Llamadas -->
          <div class="grid gap-6" id="detail-calls-container">
            <!-- Renderizado dinámico vía JS -->
          </div>
        </div>
      </main>
    </div>
  </PageContainer>
</BaseLayout>

<style>
  /* Animaciones útiles para las transiciones de estado */
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media print {
    body * {
      visibility: hidden;
    }
    #operator-details-panel,
    #operator-details-panel * {
      visibility: visible;
    }
    #operator-details-panel {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      margin: 0;
      padding: 0;
    }
    .no-print,
    .btn,
    button,
    select {
      display: none !important;
    }
    .call-card-details {
      display: grid !important;
    } /* Force expand all calls for print */
  }
</style>

<script>
  const ICON_CHECK = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="m10 15.586-3.293-3.293-1.414 1.414L10 18.414l9.707-9.707-1.414-1.414z"></path></svg>`;
  const ICON_X = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="m16.192 6.344-4.243 4.242-4.242-4.242-1.414 1.414L10.535 12l-4.242 4.242 1.414 1.414 4.242-4.242 4.243 4.242 1.414-1.414L13.364 12l4.242-4.242z"></path></svg>`;
  const ICON_ARROW = `<svg class="size-4 text-warning" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M10.707 17.707 16.414 12l-5.707-5.707-1.414 1.414L13.586 12l-4.293 4.293z"></path></svg>`;
  const ICON_STAR = `<svg class="size-4 text-success" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M21.947 9.179a1.001 1.001 0 0 0-.868-.676l-5.701-.453-2.467-5.461a.998.998 0 0 0-1.822-.001L8.622 8.05l-5.701.453a1 1 0 0 0-.619 1.713l4.214 4.107-1.29 5.71a1.001 1.001 0 0 0 1.451 1.054L12 18.26l5.324 2.827a1.002 1.002 0 0 0 1.45-1.054l-1.29-5.71 4.214-4.107a1 1 0 0 0 .249-1.037z"></path></svg>`;

  function renderCallCard(call: any, index: number) {
    const s1ScoreColor =
      call.section1.score >= 90
        ? "text-success"
        : call.section1.score >= 70
          ? "text-warning"
          : "text-error";
    const s2ScoreColor =
      call.section2.score >= 90
        ? "text-success"
        : call.section2.score >= 70
          ? "text-warning"
          : "text-error";
    const badgeClass =
      call.totalScore >= 90
        ? "badge-success"
        : call.totalScore >= 80
          ? "badge-warning"
          : "badge-error";

    return `
      <div class="call-card-container rounded-3xl border border-base-300 bg-base-100 overflow-hidden shadow-sm transition-all hover:shadow-lg relative group">
        
        <!-- Decoration Left Border -->
        <div class="absolute left-0 top-0 bottom-0 w-2 ${badgeClass.replace("badge-", "bg-")} opacity-80 group-hover:opacity-100 transition-opacity"></div>
        
        <!-- Card Header -->
        <div class="flex flex-wrap items-center justify-between border-b border-base-200 bg-base-100 p-6 pl-8">
          <div class="flex items-center gap-5">
            <div class="flex size-12 items-center justify-center rounded-2xl bg-base-200 font-black text-base-content/70 border border-base-300 shadow-inner">
              #${index + 1}
            </div>
            <div>
              <div class="font-mono text-lg font-black tracking-tight text-base-content">${call.callId}</div>
              <div class="text-xs font-medium text-base-content/50 mt-1 uppercase tracking-widest">Ticket: <span class="font-mono text-base-content/70">${call.ticketId}</span></div>
            </div>
          </div>
          <div class="flex items-center gap-8 mt-4 sm:mt-0">
            <div class="text-right">
              <div class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-1">Duración</div>
              <div class="text-base font-mono font-bold text-base-content/80">${call.duration}</div>
            </div>
            <div class="text-right">
              <div class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-1">Score Total</div>
              <div class="badge ${badgeClass} font-black shadow-sm text-sm py-3 px-3">
                ${call.totalScore}%
              </div>
            </div>
            <button 
              class="btn btn-circle btn-ghost btn-sm text-base-content/50 hover:text-base-content hover:bg-base-200 ml-2" 
              onclick="this.closest('.call-card-container').querySelector('.call-card-details').classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');"
              title="Expandir / Minimizar detalles"
            >
              <svg class="size-6 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M16.293 9.293 12 13.586 7.707 9.293l-1.414 1.414L12 16.414l5.707-5.707z"></path></svg>
            </button>
          </div>
        </div>
        
        <!-- Details Grid -->
        <div class="call-card-details hidden grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-base-200 bg-base-200/20">
          
          <!-- Section 1 -->
