    `;
  }

  function initQualityMasterDetail() {
    // Referencias a paneles
    const generalPanel = document.getElementById("general-info-panel");
    const detailsPanel = document.getElementById("operator-details-panel");

    // Referencias a elementos del detalle
    const dAvatar = document.getElementById("detail-avatar");
    const dName = document.getElementById("detail-name");
    const dId = document.getElementById("detail-id");
    const dMonth = document.getElementById("detail-month");
    const dStatus = document.getElementById("detail-status");
    const dScore = document.getElementById("detail-score");
    const callsContainer = document.getElementById("detail-calls-container");
    const btnBack = document.getElementById("btn-back-to-summary");

    // Lógica botón volver al resumen
    if (btnBack) {
      const newBtnBack = btnBack.cloneNode(true) as HTMLButtonElement;
      btnBack.parentNode?.replaceChild(newBtnBack, btnBack);

      newBtnBack.addEventListener("click", () => {
        if (generalPanel) generalPanel.classList.remove("hidden");
        if (detailsPanel) detailsPanel.classList.add("hidden");

        // Limpiar selección de la lista
        document.querySelectorAll(".operator-item").forEach((el) => {
          el.classList.remove("border-l-primary", "bg-primary/5", "shadow-md");
          el.classList.add("border-l-transparent");
        });
      });
    }

    // 1. Buscador y Filtro de la lista
    const searchInput = document.getElementById(
      "operator-search",
    ) as HTMLInputElement;
    const operatorFilter = document.getElementById(
      "operator-filter",
    ) as HTMLSelectElement;
    const operatorSort = document.getElementById(
      "operator-sort",
    ) as HTMLSelectElement;
    const operatorListContainer = document.getElementById("operator-list");
    const operatorItems = document.querySelectorAll(".operator-item");
    const noResultsMsg = document.getElementById("no-results-msg");

    const updateOperatorsList = () => {
      const term = searchInput?.value.toLowerCase() || "";
      const filter = operatorFilter?.value || "all";
      const sortValue = operatorSort?.value || "name";
      let hasVisibleItems = false;

      const itemsArray = Array.from(operatorItems) as HTMLElement[];

      itemsArray.sort((a, b) => {
        if (sortValue === "name") {
          return (a.getAttribute("data-name") || "").localeCompare(
            b.getAttribute("data-name") || "",
          );
        } else {
          const opA = JSON.parse(a.getAttribute("data-operator") || "{}");
          const opB = JSON.parse(b.getAttribute("data-operator") || "{}");
          return sortValue === "score-desc"
            ? opB.averageScore - opA.averageScore
            : opA.averageScore - opB.averageScore;
        }
      });

      itemsArray.forEach((item) => {
        const name = item.getAttribute("data-name") || "";
        const id = item.getAttribute("data-id") || "";
        const opDataStr = item.getAttribute("data-operator");
        let status = "";
        if (opDataStr) {
          try {
            status = JSON.parse(opDataStr).status;
          } catch (e) {}
        }

        const matchesSearch = name.includes(term) || id.includes(term);
        const matchesFilter = filter === "all" || status === filter;

        if (matchesSearch && matchesFilter) {
          item.classList.remove("hidden");
          hasVisibleItems = true;
        } else {
          item.classList.add("hidden");
        }

        // Re-append to sort visually
        if (operatorListContainer && noResultsMsg) {
          operatorListContainer.insertBefore(item, noResultsMsg);
        }
      });

      if (!hasVisibleItems && noResultsMsg) {
        noResultsMsg.classList.remove("hidden");
      } else if (noResultsMsg) {
        noResultsMsg.classList.add("hidden");
      }
    };

    // Lógica selector de mes (Simulación visual)
    const monthSelector = document.getElementById(
      "month-selector",
    ) as HTMLSelectElement;
    if (monthSelector) {
      const newMonthSelector = monthSelector.cloneNode(
        true,
      ) as HTMLSelectElement;
      monthSelector.parentNode?.replaceChild(newMonthSelector, monthSelector);

      newMonthSelector.addEventListener("change", (e) => {
        const select = e.target as HTMLSelectElement;

        // Simular un efecto de carga en la lista y las tarjetas
        document.querySelectorAll(".stat-value").forEach((el) => {
          el.classList.add("opacity-0");
          setTimeout(() => el.classList.remove("opacity-0"), 300);
        });

        operatorItems.forEach((item) => {
          item.classList.add("opacity-50", "pointer-events-none");
          setTimeout(() => {
            item.classList.remove("opacity-50", "pointer-events-none");
            // Resetear vista a panel general
            const gp = document.getElementById("general-info-panel");
            const dp = document.getElementById("operator-details-panel");
            if (gp) gp.classList.remove("hidden");
            if (dp) dp.classList.add("hidden");
            item.classList.remove(
              "active",
              "border-l-secondary",
              "bg-secondary/5",
              "shadow-md",
            );
            item.classList.add("border-l-transparent");
          }, 400);
        });
      });
    }

    if (searchInput) {
      const newSearchInput = searchInput.cloneNode(true) as HTMLInputElement;
      searchInput.parentNode?.replaceChild(newSearchInput, searchInput);
      newSearchInput.addEventListener("input", updateOperatorsList);
    }

    if (operatorFilter) {
      const newOperatorFilter = operatorFilter.cloneNode(
        true,
      ) as HTMLSelectElement;
      operatorFilter.parentNode?.replaceChild(
        newOperatorFilter,
        operatorFilter,
      );
      newOperatorFilter.addEventListener("change", updateOperatorsList);
    }

    if (operatorSort) {
      const newOperatorSort = operatorSort.cloneNode(true) as HTMLSelectElement;
      operatorSort.parentNode?.replaceChild(newOperatorSort, operatorSort);
      newOperatorSort.addEventListener("change", updateOperatorsList);
    }

    // 2. Lógica de selección Maestro-Detalle
    // Reemplazamos los botones para evitar listeners duplicados en caso de HMR
    operatorItems.forEach((item) => {
      const newItem = item.cloneNode(true) as HTMLButtonElement;
      item.parentNode?.replaceChild(newItem, item);

      newItem.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const operatorData = target.getAttribute("data-operator");
        if (!operatorData) return;

        try {
          const operator = JSON.parse(operatorData);

          // Actualizar estado visual de la lista
          document.querySelectorAll(".operator-item").forEach((el) => {
            el.classList.remove(
              "border-l-secondary",
              "bg-secondary/5",
              "shadow-md",
            );
            el.classList.add("border-l-transparent");
          });
          target.classList.remove("border-l-transparent");
          target.classList.add(
            "border-l-secondary",
            "bg-secondary/5",
            "shadow-md",
          );

          // Llenar datos de cabecera
          if (dAvatar)
            dAvatar.textContent = operator.name
              .split(" ")
              .map((n: string) => n[0])
              .join("")
              .substring(0, 2);
          if (dName) dName.textContent = operator.name;
          if (dMonth) dMonth.textContent = operator.month || "Mayo 2026";

          if (dStatus) {
            dStatus.textContent = operator.status;
            dStatus.className = `badge badge-sm font-bold border-2 bg-base-100 ${operator.status === "Activo" ? "border-success text-success" : "border-warning text-warning"}`;
          }

          if (dScore) {
            dScore.textContent = `${operator.averageScore}%`;
            dScore.className = `text-5xl font-black tracking-tighter ${operator.averageScore >= 90 ? "text-success" : operator.averageScore >= 80 ? "text-warning" : "text-error"}`;
          }

          // Render History Chart (SVG Line Chart)
          const historyContainer = document.getElementById(
            "detail-history-chart",
          );
          if (historyContainer && operator.history) {
            const points = operator.history;
            const width = 300;
            const height = 60;

            // Calculate coordinates (Y inverted since SVG 0,0 is top-left)
            // Using 0-100 scale for Y
            const coords = points.map((score: number, i: number) => {
              const x = (i / (points.length - 1)) * width;
              const y = height - (score / 100) * height;
              return { x, y, score };
            });

            const pathD = coords
              .map((c: any, i: number) =>
                i === 0 ? `M ${c.x},${c.y}` : `L ${c.x},${c.y}`,
              )
              .join(" ");

            historyContainer.className = "relative w-full h-16 mt-2 mb-4"; // Ensure absolute positioning context and height
            historyContainer.innerHTML = `
               <svg class="w-full h-full overflow-visible" viewBox="-4 -4 ${width + 8} ${height + 8}" preserveAspectRatio="none">
                 <path d="${pathD}" fill="none" stroke="currentColor" stroke-width="3" class="text-secondary drop-shadow-sm" stroke-linecap="round" stroke-linejoin="round" />
                 ${coords
                   .map(
                     (c: any, i: number) => `
                   <circle cx="${c.x}" cy="${c.y}" r="${i === points.length - 1 ? "5" : "4"}" fill="currentColor" class="${i === points.length - 1 ? "text-secondary" : "text-base-100"} stroke-secondary stroke-2 transition-all hover:r-6" />
                 `,
                   )
                   .join("")}
               </svg>
               <div class="absolute w-full flex justify-between -bottom-5 text-xs font-bold text-base-content/50">
                  ${points.map((p: number) => `<span>${p}%</span>`).join("")}
               </div>
             `;
          }

          // Render Insights
          const insightsContainer = document.getElementById("detail-insights");
          if (insightsContainer && operator.calls) {
            const failures: Record<string, number> = {};
            // Count failures
            operator.calls.forEach((c: any) => {
              Object.entries(c.section1.details).forEach(([key, val]) => {
                if (!val) failures[key] = (failures[key] || 0) + 1;
              });
              Object.entries(c.section2.details).forEach(([key, val]) => {
                if (!val) failures[key] = (failures[key] || 0) + 1;
              });
            });
            // Sort failures
            const sortedFailures = Object.entries(failures)
              .sort((a, b) => b[1] - a[1])
              .slice(0, 2);

            if (sortedFailures.length > 0) {
              insightsContainer.innerHTML = sortedFailures
                .map(
                  ([key, count]) => `
                 <li class="flex items-center gap-2">
                   ${ICON_ARROW}
                   <span>Falla frecuente en: <strong class="capitalize">${key}</strong> <span class="opacity-50">(${count} veces)</span></span>
                 </li>
               `,
                )
                .join("");
            } else {
              insightsContainer.innerHTML = `<li class="text-success flex items-center gap-2">${ICON_STAR} <span class="font-bold">¡Rendimiento impecable!</span> No se detectaron patrones de error frecuentes.</li>`;
            }
          }

          // Llenar contenedor de llamadas
          if (callsContainer) {
            callsContainer.innerHTML = operator.calls
              .map((call: any, index: number) => renderCallCard(call, index))
              .join("");
          }

          // Ocultar info general y mostrar el detalle
          if (generalPanel) generalPanel.classList.add("hidden");
          if (detailsPanel) {
            detailsPanel.classList.remove("hidden");
            // Hacer scroll hacia arriba en mobile
            if (window.innerWidth < 1024) {
              detailsPanel.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            }
          }
        } catch (err) {
          console.error("Error displaying operator details", err);
        }
      });
    });
  }

  // Inicializar al ejecutar script
  initQualityMasterDetail();

  // Compatibilidad con Astro View Transitions
  document.addEventListener("astro:page-load", initQualityMasterDetail);
</script>
