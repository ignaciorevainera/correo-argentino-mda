---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!["admin", "supervisor"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);

// Define current date string YYYY-MM-DD
const today = new Date();
const y = today.getFullYear();
const m = String(today.getMonth() + 1).padStart(2, "0");
const d = String(today.getDate()).padStart(2, "0");
const defaultDate = `${y}-${m}-${d}`;
---

<BaseLayout>
  <PageContainer width="xl">
    <a
      href={`${cleanBase}supervision`}
      class="btn btn-ghost btn-sm mb-2 w-fit pl-2 transition-colors duration-200"
    >
      <Icon name="boxicons:chevron-left" size={16} />
      Volver a Supervisión
    </a>

    <PageHeader
      title="Control de Asistencia"
      description="Control diario de horarios reales de login/logout, eventualidades y cumplimiento."
    />

    <div class="flex flex-col gap-6 w-full pb-24 animate-in fade-in duration-500">
      
      <!-- Filters bar -->
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-base-100 p-4 rounded-2xl border border-base-300 shadow-sm">
        <!-- Date Selector -->
        <div class="flex items-center gap-3">
          <div class="relative flex items-center gap-2 bg-base-200/50 px-4 py-2 rounded-xl border border-base-300 hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20">
            <Icon name="boxicons:calendar" size={18} class="text-base-content/40" />
            <span id="date-display" class="text-sm font-semibold tabular-nums text-base-content pointer-events-none">
              {defaultDate}
            </span>
            <input 
              type="date" 
              id="attendance-date"
              value={defaultDate}
              class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 opacity-0"
              title="Seleccionar fecha"
            />
          </div>
          <span class="text-xs text-base-content/50 uppercase font-black tracking-wider" id="day-of-week-label"></span>
        </div>

        <!-- Search, Sort and Export Actions -->
        <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
          <!-- Estadísticas -->
          <a 
            href={`${cleanBase}supervision/asistencia/estadisticas`} 
            class="btn btn-outline btn-sm border-base-300 text-base-content/75 hover:bg-base-200 rounded-xl px-3 w-10 h-10 flex items-center justify-center shrink-0"
            title="Ver estadísticas y reportes mensuales"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-base-content/75" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"></line>
              <line x1="12" y1="20" x2="12" y2="4"></line>
              <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
          </a>

          <!-- Exportar CSV -->
          <button 
            type="button" 
            id="export-csv-btn" 
            class="btn btn-outline btn-sm border-base-300 text-base-content/75 hover:bg-base-200 rounded-xl px-4 flex items-center gap-1.5 w-full sm:w-auto font-bold h-10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-base-content/75" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Exportar CSV
          </button>

          <!-- Sort Segmented Control -->
          <div class="flex items-center gap-1 bg-base-200 p-1 rounded-xl border border-base-300 select-none w-full sm:w-auto justify-center">
            <button 
              type="button" 
              id="sort-alpha-btn" 
              class="px-3 py-1.5 text-xs font-bold rounded-lg transition-all duration-200 flex items-center gap-1.5 bg-base-100 text-base-content shadow-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 16 4 4 4-4"></path>
                <path d="M7 20V4"></path>
                <path d="M15 4h5l-5 6h5"></path>
                <path d="M15 20h5l-5-6h5"></path>
              </svg>
              Alfabético
            </button>
            <button 
              type="button" 
              id="sort-sede-btn" 
              class="px-3 py-1.5 text-xs font-bold rounded-lg transition-all duration-200 flex items-center gap-1.5 text-base-content/60 hover:text-base-content"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect>
                <path d="M9 22v-4h6v4"></path>
                <path d="M8 6h.01"></path>
                <path d="M16 6h.01"></path>
                <path d="M8 10h.01"></path>
                <path d="M16 10h.01"></path>
                <path d="M12 14h.01"></path>
              </svg>
              Sede
            </button>
          </div>

          <!-- Search input -->
          <div class="relative w-full sm:w-64">
            <Icon name="boxicons:search" size={18} class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/30" />
            <input 
              type="text" 
              id="operator-search"
              placeholder="Buscar operador..." 
              class="w-full bg-base-100 border border-base-300 rounded-xl py-2 pl-10 pr-4 text-xs focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all outline-none h-10"
            />
          </div>
        </div>
      </div>

      <!-- Main attendance table -->
      <div class="bg-base-100 rounded-2xl border border-base-300 shadow-md overflow-hidden">
        <div class="overflow-x-auto min-h-[300px]">
          <table class="w-full text-xs text-left border-collapse" id="attendance-table">
            <thead class="bg-base-200/80 border-b border-base-300 font-bold uppercase tracking-wider text-base-content/60">
              <tr>
                <th class="py-3.5 px-4 w-[28%] min-w-[180px]">Operador</th>
                <th class="py-3.5 px-3 w-[18%] min-w-[150px]">Asistencia Real</th>
                <th class="py-3.5 px-3 w-[18%] min-w-[150px]">Ausencia / Eventualidad</th>
                <th class="py-3.5 px-3 w-[10%] min-w-[100px] text-center">Horario Estipulado</th>
                <th class="py-3.5 px-3 w-[8%] min-w-[80px] text-center">Entrada Real</th>
                <th class="py-3.5 px-3 w-[8%] min-w-[80px] text-center">Salida Real</th>
                <th class="py-3.5 px-3 w-[10%] min-w-[110px] text-center">Cumplimiento</th>
              </tr>
            </thead>
            <tbody id="attendance-table-body" class="divide-y divide-base-200">
              <!-- Dynamically populated rows -->
              <tr>
                <td colspan="8" class="py-12 text-center text-base-content/40">
                  <span class="loading loading-spinner loading-md"></span>
                  <p class="mt-2 font-medium">Cargando registros...</p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- Floating Save Toolbar -->
    <div id="save-toolbar" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-base-100/95 backdrop-blur-xl rounded-2xl shadow-[0_12px_40px_rgba(0,0,0,0.15)] border border-base-300 p-3.5 flex items-center justify-between gap-6 z-[100] transition-all duration-300 translate-y-32 opacity-0 pointer-events-none w-[90%] max-w-2xl">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20 animate-pulse">
          <Icon name="boxicons:save" size={18} />
        </div>
        <div>
          <h4 class="text-xs font-black text-base-content uppercase tracking-wider">Cambios sin guardar</h4>
          <p id="pending-count-text" class="text-[10px] text-base-content/60">0 modificaciones pendientes.</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button 
          type="button" 
          id="discard-btn" 
          class="btn btn-sm btn-outline border-base-300 text-base-content/60 hover:bg-base-200 rounded-lg px-4"
        >
          Descartar
        </button>
        <button 
          type="button" 
          id="save-btn" 
          class="btn btn-sm btn-primary rounded-lg px-5 shadow-lg shadow-primary/10 flex items-center gap-1.5"
        >
          <span id="save-btn-text">Guardar Cambios</span>
        </button>
      </div>
    </div>

    <!-- Toast notification container -->
    <div id="toast-container" class="toast toast-end toast-bottom z-[200]"></div>

  </PageContainer>
</BaseLayout>

<style is:global>
  /* Premium styles for input focus states and animations */
  .attendance-input {
    background-color: var(--color-base-200, #f3f4f6);
    border: 1px solid var(--color-base-300, #e5e7eb);
    border-radius: 0.5rem;
    padding: 0.35rem 0.5rem;
    outline: none;
    transition: all 0.15s ease-in-out;
  }
  .attendance-input:focus {
    border-color: var(--color-secondary, #3b82f6);
    background-color: var(--color-base-100, #ffffff);
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--color-secondary) 15%, transparent);
  }
  
  .time-input {
    font-family: monospace;
    font-size: 11.5px;
    letter-spacing: -0.02em;
    text-align: center;
    width: 68px;
    padding-left: 0.25rem;
    padding-right: 0.25rem;
  }

  .select-pill {
    font-weight: 700;
    cursor: pointer;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    padding-right: 2rem !important;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }

  /* Prevent option tags from inheriting colored or transparent backgrounds from parent selects */
  #attendance-table select option,
  .attendance-input option {
    background-color: var(--color-base-100, #ffffff) !important;
    color: var(--color-base-content, #1f2937) !important;
  }

  /* Accordion Chevron Rotation */
  .toggle-row-btn svg {
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .toggle-row-btn.is-active svg {
    transform: rotate(180deg);
  }

  /* Clickable Main Attendance Rows */
  .main-attendance-row {
    cursor: pointer;
  }

  /* Expandable Row Slide-Down Animation */
  .details-row-animate {
    animation: expandRow 0.28s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    transform-origin: top;
  }

  @keyframes expandRow {
    from {
      opacity: 0;
      transform: scaleY(0.97) translateY(-8px);
    }
    to {
      opacity: 1;
      transform: scaleY(1) translateY(0);
    }
  }
</style>

<script>
  let attendanceData = [];
  let renderedData = []; // Store current visible (filtered/sorted) operators for CSV export
  let pendingEdits = {}; // key: agentId, value: editObject
  let selectedDate = '';
  let currentSort = 'alpha'; // 'alpha' or 'sede'
  
  const dateInput = document.getElementById('attendance-date');
  const serverToday = dateInput.defaultValue || dateInput.value;
  const currentYear = parseInt(serverToday.substring(0, 4));
  const dateDisplay = document.getElementById('date-display');
  const dayOfWeekLabel = document.getElementById('day-of-week-label');
  const searchInput = document.getElementById('operator-search');
  const sortAlphaBtn = document.getElementById('sort-alpha-btn');
  const sortSedeBtn = document.getElementById('sort-sede-btn');
  const exportCsvBtn = document.getElementById('export-csv-btn');
  const tableBody = document.getElementById('attendance-table-body');
  const saveToolbar = document.getElementById('save-toolbar');
  const pendingCountText = document.getElementById('pending-count-text');
  const saveBtn = document.getElementById('save-btn');
  const discardBtn = document.getElementById('discard-btn');
  const toastContainer = document.getElementById('toast-container');

  const asistenciaOptions = [
    "HOME OFFICE",
    "PRESENCIAL MONTE GRANDE",
    "PRESENCIAL PARQUE PATRICIOS"
  ];

  const ausenciaOptions = [
    { value: "", label: "SIN EVENTUALIDAD" },
    { value: "Vacaciones", label: "Vacaciones" },
    { value: "Dia OFF", label: "Día OFF" },
    { value: "Dia Gremial", label: "Día Gremial" },
    { value: "Medico", label: "Médico" },
    { value: "Dia de Estudio", label: "Día de Estudio" },
    { value: "Licencia Maternidad", label: "Licencia Maternidad" },
    { value: "Licencia Fallecimiento", label: "Licencia Fallecimiento" },
    { value: "Licencia ART", label: "Licencia ART" },
    { value: "Ausente Justificado", label: "Ausente Justificado" },
    { value: "Tarde", label: "Tarde" },
    { value: "Licencia Anual", label: "Licencia Anual" },
    { value: "Ausente con Permiso", label: "Ausente con Permiso" }
  ];

  const complianceLabels = {
    "Cumplió": "Cumplió",
    "Incumplió": "Incumplió",
    "Llegada Tarde": "Llegada Tarde",
    "Retiro Anticipado": "Retiro Anticipado",
    "Tarde y Retiro Anticipado": "Tarde y R. Antic.",
    "Sin Registro": "Sin Registro"
  };

  const complianceClasses = {
    "Cumplió": "bg-success/15 text-success border border-success/30 font-bold",
    "Incumplió": "bg-error/15 text-error border border-error/30 font-bold animate-pulse",
    "Llegada Tarde": "bg-warning/15 text-warning border border-warning/30 font-bold",
    "Retiro Anticipado": "bg-warning/15 text-warning border border-warning/30 font-bold",
    "Tarde y Retiro Anticipado": "bg-error/15 text-error border border-error/30 font-bold animate-pulse",
    "Sin Registro": "bg-base-300/40 text-base-content/50 border border-base-300 font-bold"
  };

  function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `alert alert-${type} shadow-lg rounded-xl text-xs flex items-center gap-2 animate-in slide-in-from-bottom-5 duration-300`;
    
    toast.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-4 w-4" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span>${message}</span>
    `;
    
    toastContainer.appendChild(toast);
    setTimeout(() => {
      toast.classList.add('animate-out', 'fade-out', 'duration-300');
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  function getSpanishDayName(dateStr) {
    const days = ["Domingo", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado"];
    const date = new Date(dateStr + "T12:00:00");
    return days[date.getDay()];
  }

  // Parse shift strings (e.g. "08:00 - 17:00", "08 a 17")
  // Handle regular expressions cleanly
  function parseTimeRange(range) {
    if (!range || range.trim() === "" || range.trim() === "-") return null;
    const clean = range.toLowerCase().replace(/\s+/g, "");
    const match = clean.match(/^(\d{1,2})(?::(\d{2}))?(?:-|a)(\d{1,2})(?::(\d{2}))?$/);
    if (!match) return null;
    return {
      startH: parseInt(match[1]),
      startM: match[2] ? parseInt(match[2]) : 0,
      endH: parseInt(match[3]),
      endM: match[4] ? parseInt(match[4]) : 0
    };
  }

  // Calculate compliance on the fly
  function calculateCompliance(entrada, salida, estipulado) {
    if (!entrada && !salida) return "Sin Registro";
    if (!estipulado) return "Cumplió";
    
    const times = parseTimeRange(estipulado);
    if (!times) return "Cumplió";
    
    let late = false;
    let early = false;
    
    if (entrada) {
      const [eh, em] = entrada.split(":").map(Number);
      if (!isNaN(eh) && !isNaN(em)) {
        if (eh > times.startH || (eh === times.startH && em > times.startM)) {
          late = true;
        }
      }
    }
    
    if (salida) {
      const [sh, sm] = salida.split(":").map(Number);
      if (!isNaN(sh) && !isNaN(sm)) {
        if (sh < times.endH || (sh === times.endH && sm < times.endM)) {
          early = true;
        }
      }
    }
    
    if (late && early) return "Tarde y Retiro Anticipado";
    if (late) return "Llegada Tarde";
    if (early) return "Retiro Anticipado";
    return "Cumplió";
  }

  async function fetchAttendance(date) {
    try {
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="py-12 text-center text-base-content/40">
            <span class="loading loading-spinner loading-md"></span>
            <p class="mt-2 font-medium">Cargando registros...</p>
          </td>
        </tr>
      `;
      
      const response = await fetch(`${import.meta.env.BASE_URL || "/"}api/asistencia?date=${date}`);
      if (!response.ok) throw new Error("Failed to fetch");
      attendanceData = await response.json();
      
      pendingEdits = {};
      updateToolbar();
      renderTable();
    } catch (error) {
      console.error(error);
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="py-8 text-center text-error font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            Error al cargar los datos de asistencia.
          </td>
        </tr>
      `;
    }
  }

  const attendanceClasses = {
    "HOME OFFICE": ["bg-secondary/15", "text-secondary", "border-secondary/30"],
    "PRESENCIAL MONTE GRANDE": ["bg-primary/15", "text-amber-600", "dark:text-amber-400", "border-primary/30"],
    "PRESENCIAL PARQUE PATRICIOS": ["bg-purple-500/15", "text-purple-600", "dark:text-purple-400", "border-purple-500/30"]
  };

  const ausenciaClasses = {
    "": ["bg-base-200/50", "text-base-content/50", "border-base-300/40"],
    "Vacaciones": ["bg-emerald-500/15", "text-emerald-700", "dark:text-emerald-400", "border-emerald-500/30"],
    "Dia OFF": ["bg-slate-500/15", "text-slate-700", "dark:text-slate-400", "border-slate-500/30"],
    "Dia Gremial": ["bg-amber-500/15", "text-amber-700", "dark:text-amber-400", "border-amber-500/30"],
    "Medico": ["bg-orange-500/15", "text-orange-700", "dark:text-orange-400", "border-orange-500/30"],
    "Dia de Estudio": ["bg-yellow-500/15", "text-yellow-700", "dark:text-yellow-400", "border-yellow-500/30"],
    "Licencia Maternidad": ["bg-pink-500/15", "text-pink-700", "dark:text-pink-400", "border-pink-500/30"],
    "Licencia Fallecimiento": ["bg-violet-500/15", "text-violet-700", "dark:text-violet-400", "border-violet-500/30"],
    "Licencia ART": ["bg-cyan-500/15", "text-cyan-700", "dark:text-cyan-400", "border-cyan-500/30"],
    "Ausente Justificado": ["bg-green-600/15", "text-green-700", "dark:text-green-400", "border-green-600/30"],
    "Tarde": ["bg-rose-500/15", "text-rose-700", "dark:text-rose-400", "border-rose-500/30"],
    "Licencia Anual": ["bg-indigo-500/15", "text-indigo-700", "dark:text-indigo-400", "border-indigo-500/30"],
    "Ausente con Permiso": ["bg-sky-500/15", "text-sky-700", "dark:text-sky-400", "border-sky-500/30"]
  };

  function updateSelectColor(selectEl, field = 'asistencia') {
    const val = selectEl.value;
    if (field === 'asistencia') {
      selectEl.className = "attendance-input select-pill w-full max-w-[170px]";
      const classes = attendanceClasses[val];
      if (classes) classes.forEach(c => selectEl.classList.add(c));
    } else {
      selectEl.className = "attendance-input select-pill w-full max-w-[155px]";
      const classes = ausenciaClasses[val];
      if (classes) classes.forEach(c => selectEl.classList.add(c));
    }
  }

  function renderTable() {
    const query = searchInput.value.toLowerCase().trim();
    let filtered = attendanceData.filter(op => 
      op.nombre.toLowerCase().includes(query) || 
      (op.username && op.username.toLowerCase().includes(query))
    );

    // Sort logic
    if (currentSort === 'alpha') {
      filtered.sort((a, b) => a.nombre.localeCompare(b.nombre));
    } else if (currentSort === 'sede') {
      filtered.sort((a, b) => {
        const getSedeWeight = (op) => {
          const loc = (op.location || "").toLowerCase();
          if (loc.includes("parque patricios") || loc.includes("pp")) return 1;
          if (loc.includes("monte grande") || loc.includes("mg")) return 2;
          return 3;
        };

        const wA = getSedeWeight(a);
        const wB = getSedeWeight(b);
        if (wA !== wB) return wA - wB;
        return a.nombre.localeCompare(b.nombre);
      });
    }

    // Keep reference of active rows for CSV download
    renderedData = filtered;

    if (filtered.length === 0) {
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="py-12 text-center text-base-content/40">
            No se encontraron operadores registrados.
          </td>
        </tr>
      `;
      return;
    }

    const todayStr = serverToday;

    tableBody.innerHTML = filtered.map(op => {
      const edit = pendingEdits[op.agentId] || {};
      const asistencia = edit.asistencia !== undefined ? edit.asistencia : op.asistencia;
      const ausencia = edit.ausencia !== undefined ? edit.ausencia : op.ausencia;
      const entradaReal = edit.entradaReal !== undefined ? edit.entradaReal : op.entradaReal;
      const salidaReal = edit.salidaReal !== undefined ? edit.salidaReal : op.salidaReal;
      const cumplimientoForzado = edit.cumplimientoForzado !== undefined ? edit.cumplimientoForzado : op.cumplimientoForzado;
      
      let cumplimiento = edit.cumplimiento !== undefined ? edit.cumplimiento : op.cumplimiento;
      if (!cumplimientoForzado) {
        cumplimiento = calculateCompliance(entradaReal, salidaReal, op.horarioEstipulado);
      }

      const motivoLoguin = edit.motivoLoguin !== undefined ? edit.motivoLoguin : op.motivoLoguin;
      const detalle = edit.detalle !== undefined ? edit.detalle : op.detalle;

      const avatarInitials = op.nombre.split(", ").reverse().map(n => n[0]).join("").toUpperCase();

      const getAsistenciaClass = (val) => {
        const classes = attendanceClasses[val];
        return classes ? classes.join(" ") : "";
      };

      const getAusenciaClass = (val) => {
        const classes = ausenciaClasses[val];
        return classes ? classes.join(" ") : "bg-base-200/50 text-base-content/50 border border-base-300/40";
      };

      // Security checking for locks
      const isFutureDate = op.date > todayStr;
      const opYear = op.date ? parseInt(op.date.substring(0, 4)) : NaN;
      const isClosedYear = opYear !== currentYear;
      const isLocked = isFutureDate || isClosedYear;
      const disabledAttr = isLocked ? "disabled" : "";

      // Visual coloring based strictly on sede (cronograma)
      let rowBgClass = "hover:bg-base-200/40";
      let detailsCellBgClass = "bg-base-200/40";
      
      const loc = (op.location || "").toLowerCase();
      
      if (loc.includes("parque patricios") || loc.includes("pp")) {
        rowBgClass = "bg-purple-500/5 hover:bg-purple-500/10 dark:bg-purple-950/15 dark:hover:bg-purple-950/25";
        detailsCellBgClass = "bg-purple-500/10 dark:bg-purple-950/25";
      } else if (loc.includes("monte grande") || loc.includes("mg")) {
        rowBgClass = "bg-amber-500/5 hover:bg-amber-500/10 dark:bg-amber-950/10 dark:hover:bg-amber-950/20";
        detailsCellBgClass = "bg-amber-500/10 dark:bg-amber-950/15";
      }

      if (isLocked) {
        rowBgClass = "bg-base-200/30 text-base-content/55 opacity-75";
      }

      return `
        <tr class="main-attendance-row transition-colors ${rowBgClass}" data-agent-id="${op.agentId}">
          <!-- Operator with Accordion Toggle -->
          <td class="py-3 px-4 font-medium operator-cell">
            <div class="flex items-center gap-3 select-none">
              <button type="button" class="btn btn-ghost btn-xs btn-circle toggle-row-btn text-base-content/50 hover:text-base-content" data-agent-id="${op.agentId}">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="avatar placeholder">
                <div class="bg-secondary/10 text-secondary rounded-xl w-8 h-8 border border-secondary/20 flex items-center justify-center">
                  <span class="text-xs font-bold">${avatarInitials}</span>
                </div>
              </div>
              <div>
                <div class="flex items-center gap-1.5">
                  <p class="font-bold text-base-content leading-tight">${op.nombre}</p>
                  ${isFutureDate ? `
                    <span class="bg-neutral/15 dark:bg-neutral/30 text-neutral-content dark:text-neutral-content/80 text-[8px] font-black uppercase px-1.5 py-0.5 rounded flex items-center gap-0.5 select-none" title="Fecha futura, edición deshabilitada">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      Futuro
                    </span>
                  ` : ''}
                  ${isClosedYear ? `
                    <span class="bg-warning/20 dark:bg-warning/30 text-warning-content dark:text-warning/80 text-[8px] font-black uppercase px-1.5 py-0.5 rounded flex items-center gap-0.5 select-none" title="Año cerrado en el historial anual, edición deshabilitada">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      Cerrado
                    </span>
                  ` : ''}
                </div>
                <p class="text-[10px] text-base-content/50">${op.username || `ID: ${op.agentId}`} | ${op.location}</p>
              </div>
            </div>
          </td>

          <!-- Asistencia Real -->
          <td class="py-3 px-3">
            <select class="attendance-input select-pill w-full max-w-[170px] ${getAsistenciaClass(asistencia)}" data-field="asistencia" ${disabledAttr}>
              ${asistenciaOptions.map(opt => `
                <option value="${opt}" ${asistencia === opt ? 'selected' : ''}>${opt}</option>
              `).join('')}
            </select>
          </td>

          <!-- Ausencia -->
          <td class="py-3 px-3">
            <select class="attendance-input select-pill w-full max-w-[155px] ${getAusenciaClass(ausencia)}" data-field="ausencia" ${disabledAttr}>
              ${ausenciaOptions.map(opt => `
                <option value="${opt.value}" ${ausencia === opt.value ? 'selected' : ''}>${opt.label}</option>
              `).join('')}
            </select>
          </td>

          <!-- Horario Estipulado -->
          <td class="py-3 px-3 text-center">
            <span class="px-2.5 py-1 bg-base-200 text-base-content/75 rounded-md font-mono text-[10px] border border-base-300 font-semibold select-none whitespace-nowrap">
              ${op.horarioEstipulado || 'Franco'}
            </span>
          </td>

          <!-- Entrada Real -->
          <td class="py-3 px-3 text-center">
            <input 
              type="text" 
              class="attendance-input time-input" 
              value="${entradaReal}" 
              placeholder="HH:MM" 
              maxlength="5"
              data-field="entradaReal"
              ${disabledAttr}
            />
          </td>

          <!-- Salida Real -->
          <td class="py-3 px-3 text-center">
            <input 
              type="text" 
              class="attendance-input time-input" 
              value="${salidaReal}" 
              placeholder="HH:MM" 
              maxlength="5"
              data-field="salidaReal"
              ${disabledAttr}
            />
          </td>

          <!-- Cumplimiento -->
          <td class="py-3 px-3 text-center">
            <div class="flex flex-col gap-1 items-center justify-center">
              <span class="badge badge-sm py-2 px-3 rounded-lg text-[9px] whitespace-nowrap ${complianceClasses[cumplimiento] || 'badge-ghost'}" id="badge-cump-${op.agentId}">
                ${complianceLabels[cumplimiento] || cumplimiento}
              </span>
              <select class="select select-ghost select-xs text-[8px] font-black text-base-content/40 hover:text-base-content p-0 h-auto min-h-0 uppercase w-[120px] text-center" data-field="cumplimiento" ${disabledAttr}>
                <option value="" ${!cumplimientoForzado ? 'selected' : ''}>⚙️ AUTOMÁTICO</option>
                <option value="Cumplió" ${cumplimientoForzado && cumplimiento === 'Cumplió' ? 'selected' : ''}>Cumplió</option>
                <option value="Incumplió" ${cumplimientoForzado && cumplimiento === 'Incumplió' ? 'selected' : ''}>Incumplió</option>
                <option value="Llegada Tarde" ${cumplimientoForzado && cumplimiento === 'Llegada Tarde' ? 'selected' : ''}>Llegada Tarde</option>
                <option value="Retiro Anticipado" ${cumplimientoForzado && cumplimiento === 'Retiro Anticipado' ? 'selected' : ''}>Retiro Anticipado</option>
                <option value="Tarde y Retiro Anticipado" ${cumplimientoForzado && cumplimiento === 'Tarde y Retiro Anticipado' ? 'selected' : ''}>Tarde y R.Antic.</option>
              </select>
            </div>
          </td>
        </tr>

        <!-- Expanded details row -->
        <tr class="hidden" id="details-row-${op.agentId}">
          <td colspan="7" class="px-6 py-4 border-t border-base-200 border-b-2 border-base-300 ${detailsCellBgClass}">
            <div class="max-w-4xl w-full details-row-animate">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Motivo Login -->
                <div class="flex flex-col gap-1.5 md:col-span-1">
                  <label class="text-[10px] font-bold text-base-content/60 uppercase tracking-wider flex items-center gap-1.5 select-none">
                    🔑 Motivo Login
                  </label>
                  <input 
                    type="text" 
                    class="attendance-input text-xs w-full bg-base-100" 
                    value="${motivoLoguin}" 
                    placeholder="Ej: Problemas de conexión, VPN caída..." 
                    data-field="motivoLoguin"
                    ${disabledAttr}
                  />
                </div>

                <!-- Detalle / Comentario -->
                <div class="flex flex-col gap-1.5 md:col-span-2">
                  <label class="text-[10px] font-bold text-base-content/60 uppercase tracking-wider flex items-center gap-1.5 select-none">
                    📝 Detalle / Comentario (RRHH o Supervisor)
                  </label>
                  <textarea 
                    class="attendance-input text-xs w-full h-11 min-h-[44px] max-h-[160px] bg-base-100 py-1.5 px-3 resize-y leading-normal" 
                    placeholder="Escribe notas adicionales, justificaciones de demoras o comentarios para Recursos Humanos..." 
                    data-field="detalle"
                    ${disabledAttr}
                  >${detalle}</textarea>
                </div>
              </div>
            </div>
          </td>
        </tr>
      `;
    }).join('');

    // Attach event listeners to all main rows
    tableBody.querySelectorAll('tr[data-agent-id]').forEach(row => {
      const agentId = parseInt(row.dataset.agentId);
      const op = attendanceData.find(a => a.agentId === agentId);
      
      const detailsRow = document.getElementById(`details-row-${agentId}`);
      const toggleRowBtn = row.querySelector('.toggle-row-btn');

      const selectAsistencia = row.querySelector('[data-field="asistencia"]');
      const selectAusencia = row.querySelector('[data-field="ausencia"]');
      const inputEntrada = row.querySelector('[data-field="entradaReal"]');
      const inputSalida = row.querySelector('[data-field="salidaReal"]');
      const selectCumplimiento = row.querySelector('[data-field="cumplimiento"]');
      
      // Fetch inputs from the sibling details row
      const inputMotivo = detailsRow.querySelector('[data-field="motivoLoguin"]');
      const inputDetalle = detailsRow.querySelector('[data-field="detalle"]');

      // Expand/collapse logic
      const toggleDetails = () => {
        const isHidden = detailsRow.classList.contains('hidden');
        if (isHidden) {
          detailsRow.classList.remove('hidden');
          toggleRowBtn.classList.add('is-active');
        } else {
          detailsRow.classList.add('hidden');
          toggleRowBtn.classList.remove('is-active');
        }
      };

      toggleRowBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleDetails();
      });

      row.addEventListener('click', (e) => {
        // Toggle only if the user clicked inside the row but not on inputs/selects/buttons/avatars
        if (
          e.target.closest('select') ||
          e.target.closest('input') ||
          e.target.closest('button') ||
          e.target.closest('.avatar')
        ) {
          return;
        }
        toggleDetails();
      });

      const handleEdit = (field, value) => {
        if (!pendingEdits[agentId]) {
          pendingEdits[agentId] = { agentId };
        }
        
        pendingEdits[agentId][field] = value;
        
        // Auto-recalculate compliance if needed
        if (field === 'entradaReal' || field === 'salidaReal' || field === 'cumplimiento') {
          const edit = pendingEdits[agentId];
          const curEntrada = edit.entradaReal !== undefined ? edit.entradaReal : op.entradaReal;
          const curSalida = edit.salidaReal !== undefined ? edit.salidaReal : op.salidaReal;
          
          if (field === 'cumplimiento') {
            if (value === "") {
              // Revert to automatic calculation
              edit.cumplimientoForzado = false;
              edit.cumplimiento = calculateCompliance(curEntrada, curSalida, op.horarioEstipulado);
            } else {
              // Forced manual compliance
              edit.cumplimientoForzado = true;
              edit.cumplimiento = value;
            }
          } else {
            // Recalculate if not forced
            const curForced = edit.cumplimientoForzado !== undefined ? edit.cumplimientoForzado : op.cumplimientoForzado;
            if (!curForced) {
              edit.cumplimiento = calculateCompliance(curEntrada, curSalida, op.horarioEstipulado);
            }
          }
          
          // Update the badge in the DOM immediately
          const badge = document.getElementById(`badge-cump-${agentId}`);
          if (badge) {
            const finalCump = edit.cumplimiento;
            badge.textContent = complianceLabels[finalCump] || finalCump;
            badge.className = `badge badge-sm py-2 px-3 rounded-lg text-[9px] whitespace-nowrap ${complianceClasses[finalCump] || 'badge-ghost'}`;
          }
        }

        // Clean up edit properties if they match the original data
        const edit = pendingEdits[agentId];
        let changed = false;
        
        const fieldsToCheck = ['asistencia', 'ausencia', 'entradaReal', 'salidaReal', 'cumplimiento', 'cumplimientoForzado', 'motivoLoguin', 'detalle'];
        fieldsToCheck.forEach(f => {
          if (edit[f] !== undefined && edit[f] !== op[f]) {
            changed = true;
          }
        });

        if (!changed) {
          delete pendingEdits[agentId];
        }

        updateToolbar();
      };

      selectAsistencia.addEventListener('change', (e) => {
        handleEdit('asistencia', e.target.value);
        updateSelectColor(e.target, 'asistencia');
      });
      selectAusencia.addEventListener('change', (e) => {
        handleEdit('ausencia', e.target.value);
        updateSelectColor(e.target, 'ausencia');
      });
      inputMotivo.addEventListener('input', (e) => handleEdit('motivoLoguin', e.target.value));
      inputDetalle.addEventListener('input', (e) => handleEdit('detalle', e.target.value));

      // Handle custom input formatting for HH:MM
      const formatTimeInput = (input, field) => {
        let val = input.value.replace(/[^0-9]/g, "");
        if (val.length >= 2) {
          val = val.slice(0, 2) + ":" + val.slice(2, 4);
        }
        input.value = val;
        handleEdit(field, val);
      };

      inputEntrada.addEventListener('input', () => formatTimeInput(inputEntrada, 'entradaReal'));
      inputSalida.addEventListener('input', () => formatTimeInput(inputSalida, 'salidaReal'));
      
      selectCumplimiento.addEventListener('change', (e) => handleEdit('cumplimiento', e.target.value));
    });
  }

  function updateToolbar() {
    const editCount = Object.keys(pendingEdits).length;
    if (editCount > 0) {
      pendingCountText.textContent = `${editCount} operador(es) con modificaciones pendientes.`;
      saveToolbar.classList.remove('translate-y-32', 'opacity-0', 'pointer-events-none');
    } else {
      saveToolbar.classList.add('translate-y-32', 'opacity-0', 'pointer-events-none');
    }
  }

  // Event listener for date input
  dateInput.addEventListener('change', (e) => {
    selectedDate = e.target.value;
    dateDisplay.textContent = selectedDate;
    dayOfWeekLabel.textContent = getSpanishDayName(selectedDate);
    fetchAttendance(selectedDate);
  });

  dateInput.addEventListener('click', () => {
    try {
      dateInput.showPicker();
    } catch (err) {
      console.warn("dateInput.showPicker() is not supported by this browser.", err);
    }
  });

  // Search filter
  searchInput.addEventListener('input', renderTable);

  // Sort actions
  const updateSortUI = () => {
    if (currentSort === 'alpha') {
      sortAlphaBtn.className = "px-3 py-1.5 text-xs font-bold rounded-lg transition-all duration-200 flex items-center gap-1.5 bg-base-100 text-base-content shadow-sm";
      sortSedeBtn.className = "px-3 py-1.5 text-xs font-bold rounded-lg transition-all duration-200 flex items-center gap-1.5 text-base-content/60 hover:text-base-content";
    } else {
      sortAlphaBtn.className = "px-3 py-1.5 text-xs font-bold rounded-lg transition-all duration-200 flex items-center gap-1.5 text-base-content/60 hover:text-base-content";
      sortSedeBtn.className = "px-3 py-1.5 text-xs font-bold rounded-lg transition-all duration-200 flex items-center gap-1.5 bg-base-100 text-base-content shadow-sm";
    }
  };

  sortAlphaBtn.addEventListener('click', () => {
    currentSort = 'alpha';
    updateSortUI();
    renderTable();
  });

  sortSedeBtn.addEventListener('click', () => {
    currentSort = 'sede';
    updateSortUI();
    renderTable();
  });

  // Sanitizer for CSV export cells
  function cleanCsvCell(value) {
    if (value === null || value === undefined) return '""';
    let str = String(value);
    // Replace newlines with single space
    str = str.replace(/\r?\n|\r/g, " ");
    // Escape double quotes by doubling them
    str = str.replace(/"/g, '""');
    return `"${str}"`;
  }

  // Export visible table rows to CSV
  exportCsvBtn.addEventListener('click', () => {
    if (renderedData.length === 0) {
      showToast("No hay datos cargados para exportar.", "error");
      return;
    }

    const headers = [
      "Fecha",
      "Operador",
      "Sede",
      "Asistencia Real",
      "Ausencia/Eventualidad",
      "Horario Estipulado",
      "Entrada Real",
      "Salida Real",
      "Cumplimiento",
      "Motivo Login",
      "Detalle/Comentario"
    ];

    let csvRows = [];
    csvRows.push(headers.join(","));

    renderedData.forEach(op => {
      const row = [
        op.date,
        op.nombre,
        op.location,
        op.asistencia,
        op.ausencia || "NINGUNA",
        op.horarioEstipulado || "Franco",
        op.entradaReal || "--:--",
        op.salidaReal || "--:--",
        op.cumplimiento,
        op.motivoLoguin || "",
        op.detalle || ""
      ];

      const cleanRow = row.map(val => cleanCsvCell(val));
      csvRows.push(cleanRow.join(","));
    });

    // Add BOM for Microsoft Excel compatibility
    const csvContent = "\uFEFF" + csvRows.join("\n");
    const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);

    const link = document.createElement("a");
    link.setAttribute("href", url);

    const filename = `asistencia_${selectedDate}.csv`;

    link.setAttribute("download", filename);
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    showToast("Archivo CSV descargado correctamente.", "success");
  });

  // Discard edits
  discardBtn.addEventListener('click', () => {
    pendingEdits = {};
    updateToolbar();
    renderTable();
    showToast("Cambios descartados.", "info");
  });

  // Save edits
  saveBtn.addEventListener('click', async () => {
    const editCount = Object.keys(pendingEdits).length;
    if (editCount === 0) return;

    saveBtn.disabled = true;
    discardBtn.disabled = true;
    const originalText = saveBtn.innerHTML;
    saveBtn.innerHTML = `<span class="loading loading-spinner loading-xs"></span> Guardando...`;

    try {
      const editsArray = Object.values(pendingEdits);
      const response = await fetch(`${import.meta.env.BASE_URL || "/"}api/asistencia`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          date: selectedDate,
          edits: editsArray
        })
      });

      const responseData = await response.json();
      if (!response.ok) throw new Error(responseData.error || "Failed to save");

      showToast(`¡Se guardaron los cambios de ${editCount} operador(es) correctamente!`, "success");
      pendingEdits = {};
      updateToolbar();
      await fetchAttendance(selectedDate);
    } catch (error) {
      console.error(error);
      showToast(error.message || "Hubo un error al guardar los cambios en la base de datos.", "error");
    } finally {
      saveBtn.disabled = false;
      discardBtn.disabled = false;
      saveBtn.innerHTML = originalText;
    }
  });

  // Initialize
  selectedDate = dateInput.value;
  dateDisplay.textContent = selectedDate;
  dayOfWeekLabel.textContent = getSpanishDayName(selectedDate);
  fetchAttendance(selectedDate);
</script>
