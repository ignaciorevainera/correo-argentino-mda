---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { resourceCategories, resourceLinks } from "@db/schema";
import { eq } from "drizzle-orm";
import { logAdminFromAstro } from "@lib/auditLogger";
import { processIconUpload } from "@lib/iconUpload";
import { encrypt } from "@lib/encryption";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import { resolveUrl } from "@lib/url";
import { redirectWithToast } from "@lib/api/redirectWithToast";
import { toastResponse } from "@lib/api/toastResponse";
import ActionCancelButton from "@components/ui/ActionCancelButton.astro";
import ActionConfirmButton from "@components/ui/ActionConfirmButton.astro";
import SectionCard from "@components/ui/SectionCard.astro";
import FormLegend from "@components/ui/forms/FormLegend.astro";

const { id } = Astro.params;
let errorMsg = "";
let link = {
  id: "",
  categoryId: "",
  title: "",
  url: "",
  subtitle: "",
  iconPath: "",
  deprecated: false,
  credentialUsername: "",
  credentialPassword: "",
};

const categories = await db.select().from(resourceCategories);

if (!id || isNaN(Number(id))) {
  return Astro.redirect(resolveUrl("/admin/recursos"));
}

const numericId = Number(id);
const existingLink = await db.query.resourceLinks.findFirst({
  where: eq(resourceLinks.id, numericId),
});
if (existingLink) {
  link = {
    ...existingLink,
    id: String(existingLink.id),
    categoryId: String(existingLink.categoryId),
    subtitle: existingLink.subtitle || "",
    iconPath: existingLink.iconPath || "",
    deprecated: existingLink.deprecated || false,
    credentialUsername: existingLink.credentialUsername || "",
    credentialPassword: existingLink.credentialPassword || "",
  };
} else {
  return Astro.redirect(resolveUrl("/admin/recursos"));
}

let formSnapshot = null;

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  try {
    const formData = await Astro.request.formData();
    formSnapshot = formData;

    const title = formData.get("title")?.toString().trim();
    const url = formData.get("url")?.toString().trim();
    const categoryIdRaw = formData.get("categoryId")?.toString();
    const categoryId = categoryIdRaw && !isNaN(Number(categoryIdRaw)) ? Number(categoryIdRaw) : null;
    const subtitle = formData.get("subtitle")?.toString().trim() || null;
    const deprecated = formData.get("deprecated") === "on";
    const deleteCredentials = formData.get("deleteCredentials") === "on";

    let credentialUsername = null;
    let credentialPassword = null;

    if (!deleteCredentials) {
      credentialUsername = formData.get("credentialUsername")?.toString().trim() || null;
      const rawPassword = formData.get("credentialPassword")?.toString().trim() || "";
      credentialPassword = rawPassword ? encrypt(rawPassword) : (link.credentialPassword || null);
    }

    let iconPath = link.iconPath || null;

    const newIconPath = await processIconUpload({
      iconFile: formData.get("iconFile") as File | null,
      currentIconPath: link.iconPath || null,
    });
    if (newIconPath) {
      iconPath = newIconPath;
    }

    if (!title || !url || categoryId === null) {
      throw new Error("El título, la url y la categoría son obligatorios.");
    }

    if (id) {
      const oldTitle = link.title;
      await db
        .update(resourceLinks)
        .set({
          categoryId: categoryId,
          title,
          url,
          subtitle,
          iconPath,
          deprecated,
          credentialUsername,
          credentialPassword,
        })
        .where(eq(resourceLinks.id, numericId));
      if (oldTitle && oldTitle !== title) {
        await logAdminFromAstro(Astro.locals, `Actualizó el enlace de "${oldTitle}" a "${title}"`);
      } else {
        await logAdminFromAstro(Astro.locals, `Actualizó el enlace "${title}"`);
      }
    }

    const successMsg = "Enlace actualizado con éxito.";
    if (isAjax) {
      return toastResponse({ success: true, message: successMsg, redirectUrl: resolveUrl("/admin/recursos") });
    }
    return redirectWithToast("/admin/recursos", successMsg);
  } catch (error: any) {
    errorMsg = error.message || "Error al guardar el enlace.";
    if (isAjax) {
      return toastResponse({ success: false, error: errorMsg });
    }
    if (formSnapshot) {
      link.title = formSnapshot.get("title")?.toString() || "";
      link.url = formSnapshot.get("url")?.toString() || "";
      link.categoryId = formSnapshot.get("categoryId")?.toString() || "";
      link.subtitle = formSnapshot.get("subtitle")?.toString() || "";
      link.deprecated = formSnapshot.get("deprecated") === "on";
      link.credentialUsername = formSnapshot.get("credentialUsername")?.toString() || "";
    }
  }
}
---

<BaseLayout title="Editar Enlace">
  <PageContainer>
    <div class="max-w-2xl mx-auto py-4 sm:py-8">
      <div class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
        <a
          href={resolveUrl("/admin/recursos")}
          class="flex items-center gap-1.5 hover:text-base-content transition-colors"
        >
          <Icon name="boxicons:chevron-left" size={16} />
          Recursos
        </a>
        <span>/</span>
        <span class="text-base-content font-medium truncate">Editar enlace</span>
      </div>

      <PageHeader
        title="Editar Enlace"
        description="Configuración del acceso directo para operadores."
      />

      {
        errorMsg && (
          <script is:inline define:vars={{ errorMsg }}>
            window.addEventListener('load', () => window.showToast?.(errorMsg, "alert-error"));
          </script>
        )
      }

      <SectionCard>
        <div class="p-6 sm:p-8">
          <form method="POST" enctype="multipart/form-data" class="space-y-5" data-async-form>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-5">
              <FormField
                id="input-title"
                name="title"
                label="Título del Enlace"
                required
                value={link.title}
                placeholder="Ej: Portal de Autogestión"
              />

              <SelectField
                id="select-categoryId"
                name="categoryId"
                label="Categoría"
                required
                selectClass="font-medium"
              >
                {
                  categories.map((cat) => (
                    <option
                      value={cat.id}
                      selected={link.categoryId ? Number(cat.id) === Number(link.categoryId) : false}
                    >
                      {cat.title}
                    </option>
                  ))
                }
              </SelectField>

              <FormField
                id="input-url"
                type="url"
                name="url"
                label="URL de Destino"
                required
                value={link.url}
                placeholder="https://..."
                inputClass="font-mono text-sm"
                class="sm:col-span-2"
              />

              <FormField
                id="input-subtitle"
                name="subtitle"
                label="Subtítulo Descriptivo"
                value={link.subtitle}
                placeholder="Breve explicación del propósito del enlace"
                helpText="(Opcional)"
                class="sm:col-span-2"
              />

              <FormField
                id="input-credentialUsername"
                name="credentialUsername"
                label="Usuario (Credenciales)"
                value={link.credentialUsername}
                placeholder="Ej: admin_soti"
                helpText="(Opcional)"
              />

              <FormField
                id="input-credentialPassword"
                type="password"
                name="credentialPassword"
                label="Contraseña (Credenciales)"
                placeholder="••••••••"
                helpText="(Opcional, dejar vacío para no modificar)"
              />

              {
                (link.credentialUsername || link.credentialPassword) && (
                  <div class="sm:col-span-2 flex items-center gap-3 bg-error/10 border border-error/20 rounded-lg p-3">
                    <input
                      id="checkbox-deleteCredentials"
                      type="checkbox"
                      name="deleteCredentials"
                      class="checkbox checkbox-error"
                    />
                    <label for="checkbox-deleteCredentials" class="label cursor-pointer flex flex-col items-start p-0">
                      <span class="label-text font-semibold text-error">Eliminar credenciales guardadas</span>
                      <span class="label-text-alt text-base-content/60">Marcar para borrar el usuario y la contraseña almacenados para este enlace.</span>
                    </label>
                  </div>
                )
              }

              <div class="sm:col-span-2 flex items-center gap-3">
                <input
                  id="checkbox-deprecated"
                  type="checkbox"
                  name="deprecated"
                  class="toggle toggle-primary"
                  checked={link.deprecated}
                />
                <label for="checkbox-deprecated" class="label cursor-pointer flex flex-col items-start">
                  <span class="label-text font-semibold">Marcar como Obsoleto</span>
                  <span class="label-text-alt text-base-content/60">Los enlaces obsoletos se verán atenuados y etiquetados como "Obsoleto".</span>
                </label>
              </div>
            </div>

            <FormField
              type="file"
              id="input-icon-file"
              name="iconFile"
              label="Ícono"
              accept="image/png, image/jpeg, image/svg+xml, .ico"
              helpText="(Opcional, .png, .jpg, .svg, .ico)"
            >
              {
                link.iconPath && (
                  <div slot="preview" class="w-12 h-12 shrink-0 rounded-box border border-base-300 bg-base-200 flex items-center justify-center overflow-hidden p-1">
                    <img
                      src={resolveUrl(`api/icons/${link.iconPath}`)}
                      alt="Preview del ícono"
                      class="w-full h-full object-contain"
                    />
                  </div>
                )
              }
            </FormField>

            <div class="flex justify-end gap-3 pt-6 mt-2 border-t border-base-200">
              <ActionCancelButton
                href={resolveUrl("/admin/recursos")}
                label="Cancelar"
              />
              <ActionConfirmButton
                type="submit"
                color="btn-primary"
                label="Guardar Enlace"
                icon="boxicons:save"
              />
            </div>
          </form>
        </div>
      </SectionCard>
    </div>
  </PageContainer>
  <AsyncFormScript />
</BaseLayout>
