---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { resourceCategories } from "@db/schema";
import { eq } from "drizzle-orm";
import { logAdminAction } from "@lib/auditLogger";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import { resolveUrl } from "@lib/url";
import SectionCard from "@components/ui/SectionCard.astro";
import FormLegend from "@components/ui/forms/FormLegend.astro";

const { id } = Astro.params;
let errorMsg = "";
let category = { id: "", title: "", iconName: "", tone: "primary" };

if (!id || isNaN(Number(id))) {
  return Astro.redirect(resolveUrl("/admin/recursos"));
}

const numericId = Number(id);
const existingCategory = await db.query.resourceCategories.findFirst({
  where: eq(resourceCategories.id, numericId),
});
if (existingCategory) {
  if (
    existingCategory.title.toLowerCase() === "sin categoría" ||
    existingCategory.title.toLowerCase() === "sin categoria"
  ) {
    return Astro.redirect(
      resolveUrl(
        `/admin/recursos?toast_msg=${encodeURIComponent("No se puede modificar la categoría por defecto")}&toast_type=warning`,
      ),
    );
  }
  category = existingCategory as any;
} else {
  return Astro.redirect(resolveUrl("/admin/recursos"));
}

const PREDEFINED_ICONS = [
  { value: "boxicons:star-filled", label: "Estrella (Destacados)" },
  { value: "boxicons:file-detail-filled", label: "Documento (Normativas)" },
  { value: "boxicons:group-filled", label: "Grupo (Usuarios / RRHH)" },
  { value: "boxicons:building-filled", label: "Edificio (Intranet)" },
  { value: "boxicons:chip-filled", label: "Microchip (Hardware)" },
  { value: "boxicons:spanner-filled", label: "Llave (Herramientas)" },
  { value: "boxicons:check-shield-filled", label: "Escudo (Seguridad / VPN)" },
  { value: "boxicons:link-filled", label: "Enlace (Portales / Accesos)" },
  { value: "boxicons:help-circle-filled", label: "Ayuda (Soporte / FAQ)" },
  { value: "boxicons:calendar-filled", label: "Calendario (Cronograma)" },
];

const currentIcon = category.iconName || "boxicons:star-filled";
const iconExistsInPredefined = PREDEFINED_ICONS.some(
  (icon) => icon.value === currentIcon,
);
const iconsList = [...PREDEFINED_ICONS];
if (category.iconName && !iconExistsInPredefined) {
  iconsList.push({
    value: category.iconName,
    label: `Personalizado (${category.iconName})`,
  });
}

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  try {
    const formData = await Astro.request.formData();
    const title = formData.get("title")?.toString().trim();
    const iconName = formData.get("iconName")?.toString().trim();

    if (!title || !iconName) {
      throw new Error("El título y el icono son obligatorios.");
    }

    const tone = formData.get("tone")?.toString().trim() || "primary";

    if (id) {
      const numericId = Number(id);
      const oldTitle = category.title;
      await db
        .update(resourceCategories)
        .set({
          title,
          iconName,
          tone,
        })
        .where(eq(resourceCategories.id, numericId));
      if (oldTitle && oldTitle !== title) {
        await logAdminAction(
          Astro.locals.user?.username || "Sistema",
          `Actualizó la categoría de recursos de "${oldTitle}" a "${title}"`,
        );
      } else {
        await logAdminAction(
          Astro.locals.user?.username || "Sistema",
          `Actualizó la categoría de recursos "${title}"`,
        );
      }
    }

    const successMsg = "Categoría actualizada con éxito.";
    if (isAjax) {
      return new Response(JSON.stringify({ success: true, message: successMsg, redirectUrl: resolveUrl("/admin/recursos") }), { status: 200, headers: { "Content-Type": "application/json" } });
    }
    return Astro.redirect(
      resolveUrl(
        `/admin/recursos?toast_msg=${encodeURIComponent(successMsg)}&toast_type=success`,
      ),
    );
  } catch (error: any) {
    errorMsg = error.message || "Error al guardar la categoría.";
    if (isAjax) {
      return new Response(JSON.stringify({ success: false, error: errorMsg }), { status: 400, headers: { "Content-Type": "application/json" } });
    }
  }
}
---

<BaseLayout title="Editar categoría">
  <PageContainer>
    <div class="max-w-2xl mx-auto py-4 sm:py-8">
      <div class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
        <a
          href={resolveUrl("/admin/recursos")}
          class="flex items-center gap-1.5 hover:text-base-content transition-colors"
        >
          <Icon name="boxicons:chevron-left" size={16} />
          Recursos
        </a>
        <span>/</span>
        <span class="text-base-content font-medium truncate">Editar categoría</span>
      </div>

      <PageHeader
        title="Editar categoría"
        description="Definí cómo se agruparán y visualizarán los enlaces."
      />

      {
        errorMsg && (
          <script is:inline define:vars={{ errorMsg }}>
            const triggerToast = () => {
              if (window.showToast) {
                window.showToast(errorMsg, "alert-error");
              } else {
                setTimeout(triggerToast, 100);
              }
            };
            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", triggerToast);
            } else {
              triggerToast();
            }
          </script>
        )
      }

      <SectionCard>
        <div class="p-6 sm:p-8">

          <form method="POST" class="space-y-5" data-async-form>
            <div class="grid grid-cols-1 gap-y-5">
              <FormField
                id="input-title"
                name="title"
                label="Título de la Categoría"
                required
                value={category.title}
                placeholder="Ej: Sistemas operativos"
                inputClass="font-medium"
              />

              <SelectField
                id="select-iconName"
                name="iconName"
                label="Ícono Visual"
                selectClass="font-medium"
                options={iconsList}
                value={currentIcon}
              />

              <fieldset class="fieldset">
                <FormLegend class="mb-2"
                  >Color de Identificación (Tono)</FormLegend
                >
                <div
                  class="flex flex-col gap-2.5 bg-base-200/50 p-4 rounded-xl border border-base-300 w-full"
                >
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="primary"
                      class="radio radio-primary radio-sm"
                      checked={category.tone === "primary" || !category.tone}
                    />
                    <span class="text-sm font-medium">Amarillo (Principal)</span
                    >
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="secondary"
                      class="radio radio-secondary radio-sm"
                      checked={category.tone === "secondary"}
                    />
                    <span class="text-sm font-medium">Azul (Secundario)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="accent"
                      class="radio radio-accent radio-sm"
                      checked={category.tone === "accent"}
                    />
                    <span class="text-sm font-medium">Celeste (Acento)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="success"
                      class="radio radio-success radio-sm"
                      checked={category.tone === "success"}
                    />
                    <span class="text-sm font-medium">Verde (Éxito)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="info"
                      class="radio radio-info radio-sm"
                      checked={category.tone === "info"}
                    />
                    <span class="text-sm font-medium">Azul claro (Info)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="warning"
                      class="radio radio-warning radio-sm"
                      checked={category.tone === "warning"}
                    />
                    <span class="text-sm font-medium">Naranja (Alerta)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="error"
                      class="radio radio-error radio-sm"
                      checked={category.tone === "error"}
                    />
                    <span class="text-sm font-medium">Rojo (Error)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="neutral"
                      class="radio radio-neutral radio-sm"
                      checked={category.tone === "neutral"}
                    />
                    <span class="text-sm font-medium">Gris (Neutral)</span>
                  </label>
                </div>
              </fieldset>
            </div>

            <div
              class="flex justify-end gap-3 pt-6 mt-2 border-t border-base-200"
            >
              <a href={resolveUrl("/admin/recursos")} class="btn btn-ghost"
                >Cancelar</a
              >
              <button type="submit" class="btn btn-primary gap-2">
                <Icon name="boxicons:save" size={18} />
                Guardar Categoría
              </button>
            </div>
          </form>
        </div>
      </SectionCard>
    </div>
  </PageContainer>
  <AsyncFormScript />
</BaseLayout>
