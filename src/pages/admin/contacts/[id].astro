---
import { db } from "@db/index";
import { providerContacts, contactCategories } from "@db/schema";
import { eq, asc } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { logAdminAction } from "@lib/auditLogger";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!user || !["admin", "supervisor"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);

const { id } = Astro.params;
const isNew = id === "new";

let successMsg = "";
let errorMsg = "";

// Cargar categorías para el selector
const allCategories = await db
  .select()
  .from(contactCategories)
  .orderBy(asc(contactCategories.title));

let contact: typeof providerContacts.$inferSelect | null = null;

if (!isNew) {
  const [result] = await db
    .select()
    .from(providerContacts)
    .where(eq(providerContacts.id, Number(id)));

  if (!result) return Astro.redirect(`${cleanBase}admin/contacts`);
  contact = result;
}

if (Astro.request.method === "POST") {
  try {
    const fd = await Astro.request.formData();

    const categoryId = fd.get("categoryId")?.toString() || null;
    const provider = fd.get("provider")?.toString().trim() ?? "";
    const service = fd.get("service")?.toString().trim() ?? "";

    // Procesar phones
    const phones =
      fd
        .get("phones")
        ?.toString()
        .split("\n")
        .map((s) => s.trim())
        .filter(Boolean) ?? [];

    // Procesar emails
    const emails =
      fd
        .get("emails")
        ?.toString()
        .split("\n")
        .map((s) => s.trim())
        .filter(Boolean) ?? [];

    // Procesar urls (como objetos {label, url})
    const urls =
      fd
        .get("urls")
        ?.toString()
        .split("\n")
        .map((s) => s.trim())
        .filter(Boolean)
        .map((line) => {
          const parts = line.split(",");
          if (parts.length >= 2) {
            const label = parts[0].trim();
            const url = parts.slice(1).join(",").trim();
            return { label, url };
          }
          return { label: "Enlace", url: line };
        }) ?? [];

    if (!provider || !service) {
      errorMsg = "Proveedor y servicio son obligatorios.";
    } else {
      if (isNew) {
        await db.insert(providerContacts).values({
          categoryId,
          provider,
          service,
          phones,
          emails,
          urls,
        });
        await logAdminAction(user?.username || 'Sistema', `Creó el contacto "${provider} - ${service}"`);
      } else {
        await db
          .update(providerContacts)
          .set({
            categoryId,
            provider,
            service,
            phones,
            emails,
            urls,
          })
          .where(eq(providerContacts.id, Number(id)));
        const oldName = contact ? `${contact.provider} - ${contact.service}` : "";
        const newName = `${provider} - ${service}`;
        if (oldName && oldName !== newName) {
          await logAdminAction(user?.username || 'Sistema', `Actualizó el contacto ID ${id} (de "${oldName}" a "${newName}")`);
        } else {
          await logAdminAction(user?.username || 'Sistema', `Actualizó el contacto "${newName}" (ID ${id})`);
        }
      }

      const toastMessage = isNew ? "Contacto creado con éxito." : "Contacto actualizado con éxito.";
      return Astro.redirect(
        `${cleanBase}admin/contacts?toast_msg=${encodeURIComponent(toastMessage)}&toast_type=success`
      );
    }
  } catch (e: any) {
    errorMsg = "Error al guardar el contacto.";
  }
}

const pageTitle = isNew ? "Nuevo contacto" : `Editar: ${contact!.provider}`;

// Convertir arrays a formato multilínea para el textarea
const phonesText = contact?.phones?.join("\n") ?? "";
const emailsText = contact?.emails?.join("\n") ?? "";
const urlsText =
  contact?.urls
    ?.map((u) => (u.label ? `${u.label}, ${u.url}` : u.url))
    .join("\n") ?? "";
---

<BaseLayout title={pageTitle}>
  <PageContainer>
    {/* ── Breadcrumb / Volver ── */}
    <div class="flex items-center gap-2 text-sm text-base-content/60">
      <a
        href={`${cleanBase}admin/contacts`}
        class="flex items-center gap-1.5 hover:text-base-content transition-colors"
      >
        <Icon name="boxicons:chevron-left" size={16} />
        Gestión de contactos
      </a>
      <span>/</span>
      <span class="text-base-content font-medium truncate">{pageTitle}</span>
    </div>

    <PageHeader
      title={pageTitle}
      description={isNew
        ? "Completá los datos para registrar un nuevo contacto útil."
        : `ID de contacto: ${contact!.id}`}
    />

    {/* Feedback */}
    {
      errorMsg && (
        <script is:inline define:vars={{ errorMsg }}>
          window.showToast?.(errorMsg, "alert-error");
        </script>
      )
    }
    {
      successMsg && (
        <script is:inline define:vars={{ successMsg }}>
          window.showToast?.(successMsg, "alert-success");
        </script>
      )
    }

    <form
      method="POST"
      id="contact-form"
      onsubmit="return confirm('¿Estás seguro de que deseas guardar estas modificaciones?');"
      class="space-y-4"
    >
      <section class="card bg-base-100 border border-base-300 shadow-md">
        <div class="card-body gap-4 p-5">
          <h2
            class="flex items-center gap-2 text-sm font-semibold text-base-content"
          >
            <span
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:phone-filled" size={15} />
            </span>
            Datos del contacto
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-3">
              <FormField
                id="input-provider"
                name="provider"
                label="Proveedor"
                required
                value={contact?.provider ?? ""}
                placeholder="ej: CORASA"
                autocomplete="off"
                inputClass="input-sm font-semibold"
              />

              <FormField
                id="input-service"
                name="service"
                label="Servicio"
                required
                value={contact?.service ?? ""}
                placeholder="ej: Mesa de Ayuda"
                autocomplete="off"
                inputClass="input-sm"
              />

              <SelectField
                id="select-categoryId"
                name="categoryId"
                label="Categoría"
                selectClass="select-sm"
              >
                <option value="" selected={!contact?.categoryId}>
                  Ninguna
                </option>
                {
                  allCategories.map((cat) => (
                    <option
                      value={cat.id}
                      selected={contact?.categoryId === cat.id}
                    >
                      {cat.title}
                    </option>
                  ))
                }
              </SelectField>
            </div>

            <div class="space-y-3">
              <fieldset class="fieldset gap-1 font-mono">
                <legend class="fieldset-legend text-xs"
                  >Teléfonos (uno por línea)</legend
                >
                <textarea
                  name="phones"
                  rows={2}
                  class="textarea textarea-sm w-full text-xs font-mono"
                  placeholder="ej: 6316-1111
0810-777-7787"
                  >{phonesText}</textarea
                >
              </fieldset>

              <fieldset class="fieldset gap-1 font-mono">
                <legend class="fieldset-legend text-xs"
                  >Correos electrónicos (uno por línea)</legend
                >
                <textarea
                  name="emails"
                  rows={2}
                  class="textarea textarea-sm w-full text-xs font-mono"
                  placeholder="ej: soporte@correo.com.ar">{emailsText}</textarea
                >
              </fieldset>

              <fieldset class="fieldset gap-1 font-mono">
                <legend class="fieldset-legend text-xs"
                  >Enlaces web (uno por línea como: Etiqueta, URL)</legend
                >
                <textarea
                  name="urls"
                  rows={2}
                  class="textarea textarea-sm w-full text-xs font-mono"
                  placeholder="ej: Portal, http://sm.correo.local
http://www.google.com"
                  >{urlsText}</textarea
                >
              </fieldset>
            </div>
          </div>
        </div>
      </section>

      {/* ── Acciones ── */}
      <div class="flex items-center justify-between gap-3 pt-1">
        <a
          href={`${cleanBase}admin/contacts`}
          class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10"
        >
          <Icon name="boxicons:arrow-left-filled" size={16} />
          Volver al listado
        </a>
        <button type="submit" class="btn btn-secondary btn-sm gap-2">
          <Icon name="boxicons:save-filled" size={16} />
          {isNew ? "Crear contacto" : "Guardar cambios"}
        </button>
      </div>
    </form>
  </PageContainer>
</BaseLayout>
