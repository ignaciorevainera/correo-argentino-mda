---
import BaseLayout from "@layouts/BaseLayout.astro";
import AdminOperadoresContent from "@components/admin/operadores/AdminOperadoresContent.astro";
import AdminOperadoresSkeleton from "@components/admin/operadores/AdminOperadoresSkeleton.astro";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!user || !["admin", "supervisor", "team_leader"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);
---

<BaseLayout>
  <AdminOperadoresContent server:defer>
    <AdminOperadoresSkeleton slot="fallback" />
  </AdminOperadoresContent>
</BaseLayout>
