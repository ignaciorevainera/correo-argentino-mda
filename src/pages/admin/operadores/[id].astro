---
import { db } from "@db/index";
import { agents, workLocations, schedules } from "@db/schema";
import { eq } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";
import { getDisponibilidadHoy } from "@/lib/disponibilidad";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (user.role !== "admin") return Astro.redirect(`${cleanBase}login`);

const { id } = Astro.params;
const isNew = id === "nuevo";
let successMsg = "";
let errorMsg = "";

const daysOfWeek = [
  "Lunes",
  "Martes",
  "Miércoles",
  "Jueves",
  "Viernes",
  "Sábado",
  "Domingo",
];

const dayNameMapping: Record<string, string> = {
  "Lunes": "Lunes",
  "Martes": "Martes",
  "Miércoles": "Miercoles",
  "Jueves": "Jueves",
  "Viernes": "Viernes",
  "Sábado": "Sabado",
  "Domingo": "Domingo",
  "Miercoles": "Miércoles",
  "Sabado": "Sábado"
};

const allLocations = await db
  .select({ id: workLocations.id, name: workLocations.name })
  .from(workLocations)
  .orderBy(workLocations.name);

if (Astro.request.method === "POST") {
  try {
    const fd = await Astro.request.formData();

    const name = fd.get("name")?.toString().trim() ?? "";
    const username = fd.get("id")?.toString().trim() || null; // 'id' field in form represents username
    const locationId = fd.get("locationId")?.toString().trim() || "";

    const loc = allLocations.find((l) => l.id === locationId);
    const locationName = loc ? loc.name : "Monte Grande";

    if (!name) {
      errorMsg = "El nombre completo es obligatorio.";
    } else if (isNew && !username) {
      errorMsg = "El ID de usuario es obligatorio.";
    } else {
      // Reconstruct the weekly schedule schemas based on form values for each day
      const newEsquemaSemanal: Record<string, string> = {};
      const newEsquemaHorario: Record<string, string> = {};
      const newEsquemaBreakInicio: Record<string, string> = {};
      const newEsquemaBreakFin: Record<string, string> = {};

      for (const day of daysOfWeek) {
        const cronoDay = dayNameMapping[day] || day;

        const homeStart = fd.get(`home_${day}_start`)?.toString().trim() || "";
        const homeEnd = fd.get(`home_${day}_end`)?.toString().trim() || "";
        const homeBreak = fd.get(`home_${day}_break`)?.toString().trim() || "";

        const presStart = fd.get(`presencial_${day}_start`)?.toString().trim() || "";
        const presEnd = fd.get(`presencial_${day}_end`)?.toString().trim() || "";
        const presBreak = fd.get(`presencial_${day}_break`)?.toString().trim() || "";

        if (presStart || presEnd) {
          newEsquemaSemanal[cronoDay] = "Presencial";
          newEsquemaHorario[cronoDay] = `${presStart || "08:00"} - ${presEnd || "17:00"}`;
          if (presBreak) {
            newEsquemaBreakInicio[cronoDay] = presBreak;
            const [h, m] = presBreak.split(":").map(Number);
            const endHour = (h + 1) % 24;
            newEsquemaBreakFin[cronoDay] = `${String(endHour).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
          } else {
            newEsquemaBreakInicio[cronoDay] = "";
            newEsquemaBreakFin[cronoDay] = "";
          }
        } else if (homeStart || homeEnd) {
          newEsquemaSemanal[cronoDay] = "Home Office";
          newEsquemaHorario[cronoDay] = `${homeStart || "08:00"} - ${homeEnd || "17:00"}`;
          if (homeBreak) {
            newEsquemaBreakInicio[cronoDay] = homeBreak;
            const [h, m] = homeBreak.split(":").map(Number);
            const endHour = (h + 1) % 24;
            newEsquemaBreakFin[cronoDay] = `${String(endHour).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
          } else {
            newEsquemaBreakInicio[cronoDay] = "";
            newEsquemaBreakFin[cronoDay] = "";
          }
        } else {
          newEsquemaSemanal[cronoDay] = "Franco";
          newEsquemaHorario[cronoDay] = "";
          newEsquemaBreakInicio[cronoDay] = "";
          newEsquemaBreakFin[cronoDay] = "";
        }
      }

      const initials = name
        .split(/\s+/)
        .map((p) => p[0])
        .join("")
        .substring(0, 2)
        .toUpperCase();

      if (isNew) {
        // Insert new agent
        const [inserted] = await db.insert(agents).values({
          name,
          username,
          avatarInitials: initials,
          location: locationName,
          horarioDefault: "08:00 - 17:00",
          esquemaSemanal: newEsquemaSemanal,
          esquemaHorario: newEsquemaHorario,
          esquemaBreakInicio: newEsquemaBreakInicio,
          esquemaBreakFin: newEsquemaBreakFin,
        }).returning({ id: agents.id, name: agents.name });

        // Populate monthly schedules table with "Franco" or weekly schema defaults for today and upcoming dates
        const uniqueDates = await db
          .selectDistinct({ date: schedules.date })
          .from(schedules);

        if (uniqueDates.length > 0) {
          const inserts = uniqueDates.map((d) => {
            const dateObj = new Date(d.date + "T12:00:00");
            const dayNamesList = ["Domingo", "Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado"];
            const dateDayName = dayNamesList[dateObj.getDay()];
            
            const status = newEsquemaSemanal[dateDayName] || "Franco";
            const horario = newEsquemaHorario[dateDayName] || "";
            const bInicio = newEsquemaBreakInicio[dateDayName] || "";
            const bFin = newEsquemaBreakFin[dateDayName] || "";

            return {
              agentName: name,
              date: d.date,
              status,
              comment: "",
              horario,
              breakInicio: bInicio,
              breakFin: bFin,
              entradaReal: "",
              salidaReal: "",
            };
          });
          await db.insert(schedules).values(inserts);
        }

        return Astro.redirect(`${cleanBase}admin/operadores`);
      } else {
        const agentId = Number(id);
        const [original] = await db.select({ name: agents.name }).from(agents).where(eq(agents.id, agentId));

        await db
          .update(agents)
          .set({
            name,
            username,
            avatarInitials: initials,
            location: locationName,
            esquemaSemanal: newEsquemaSemanal,
            esquemaHorario: newEsquemaHorario,
            esquemaBreakInicio: newEsquemaBreakInicio,
            esquemaBreakFin: newEsquemaBreakFin,
          })
          .where(eq(agents.id, agentId));

        // Cascade rename to schedules table if the name was updated
        if (original && original.name !== name) {
          await db
            .update(schedules)
            .set({ agentName: name })
            .where(eq(schedules.agentName, original.name));
        }

        successMsg = "Operador y horarios actualizados con éxito.";
      }
    }
  } catch (e: any) {
    console.error("POST Admin Operator Error:", e);
    errorMsg = e.message.includes("UNIQUE")
      ? "Ya existe un operador con ese nombre o ID de usuario."
      : "Error al guardar el operador.";
  }
}

type OperatorRecord = {
  id: string;
  name: string;
  username: string;
  status: string;
  location: string;
  locationId: string | null;
};

let operator: OperatorRecord | null = null;
let operatorSchedulesData: Record<string, Record<string, any>> = {};

if (!isNew) {
  const agentId = Number(id);
  const [result] = await db.select().from(agents).where(eq(agents.id, agentId));

  if (!result) return Astro.redirect(`${cleanBase}admin/operadores`);

  // Calculate live availability to map old status
  const availList = await getDisponibilidadHoy();
  const currentAvail = availList.find((a) => a.agentId === agentId);

  operator = {
    id: String(result.id),
    name: result.name,
    username: result.username || "",
    status: currentAvail?.disponible ? "disponible" : (currentAvail?.motivo || "Franco"),
    location: result.location,
    locationId: allLocations.find((l) => l.name === result.location)?.id || null,
  };

  const esquemaSemanal = (result.esquemaSemanal as Record<string, string>) || {};
  const esquemaHorario = (result.esquemaHorario as Record<string, string>) || {};
  const esquemaBreakInicio = (result.esquemaBreakInicio as Record<string, string>) || {};

  for (const day of daysOfWeek) {
    const cronoDay = dayNameMapping[day] || day;
    const status = esquemaSemanal[cronoDay] || "Franco";
    const horario = esquemaHorario[cronoDay] || "";
    const breakInicio = esquemaBreakInicio[cronoDay] || "";

    const [start, end] = horario.split(" - ");

    operatorSchedulesData[day] = {};

    if (status === "Home Office") {
      operatorSchedulesData[day]["home"] = {
        shiftStart: start || "",
        shiftEnd: end || "",
        breakTime: breakInicio || "",
      };
    } else if (status === "Presencial" || status === "Horas Extras") {
      operatorSchedulesData[day]["presencial"] = {
        shiftStart: start || "",
        shiftEnd: end || "",
        breakTime: breakInicio || "",
      };
    }
  }
}

const pageTitle = isNew ? "Nuevo operador" : `Editar: ${operator!.name}`;
---

<BaseLayout title={pageTitle}>
  <PageContainer>
    <div class="flex items-center gap-2 text-sm text-base-content/60">
      <a
        href={`${cleanBase}admin/operadores`}
        class="flex items-center gap-1.5 hover:text-base-content transition-colors"
      >
        <Icon name="boxicons:chevron-left" size={16} />
        Gestión de operadores
      </a>
      <span>/</span>
      <span class="text-base-content font-medium truncate">{pageTitle}</span>
    </div>

    <PageHeader
      title={pageTitle}
      description={isNew
        ? "Completá los datos y horarios para registrar un nuevo operador."
        : `ID de base de datos: ${operator!.id}`}
    />

    {
      errorMsg && (
        <div role="alert" class="alert alert-error alert-soft text-sm">
          <Icon
            name="boxicons:alert-circle-filled"
            size={18}
            class="shrink-0"
          />
          <span>{errorMsg}</span>
        </div>
      )
    }
    {
      successMsg && (
        <div role="alert" class="alert alert-success alert-soft text-sm">
          <Icon
            name="boxicons:check-circle-filled"
            size={18}
            class="shrink-0"
          />
          <span>{successMsg}</span>
        </div>
      )
    }

    <form method="POST" id="operator-form" class="space-y-4">
      <section class="card bg-base-100 border border-base-300 shadow-md">
        <div class="card-body gap-4 p-5">
          <h2
            class="flex items-center gap-2 text-sm font-semibold text-base-content"
          >
            <span
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:user-id-card-filled" size={15} />
            </span>
            Datos del operador
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs">ID de usuario *</legend>
              <input
                type="text"
                name="id"
                required
                value={operator?.username ?? ""}
                placeholder="ej: jperez"
                autocomplete="off"
                readonly={!isNew}
                class:list={[
                  "input input-sm w-full font-mono",
                  !isNew && "input-disabled bg-base-200 cursor-not-allowed",
                ]}
              />
              {
                isNew && (
                  <p class="text-xs text-base-content/50 mt-1">
                    Identificador único de usuario del operador.
                  </p>
                )
              }
            </fieldset>

            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs">Nombre completo *</legend>
              <input
                type="text"
                name="name"
                required
                value={operator?.name ?? ""}
                placeholder="ej: Juan Pérez"
                autocomplete="off"
                class="input input-sm w-full"
              />
            </fieldset>

            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs"
                >Ubicación presencial</legend
              >
              <select name="locationId" class="select select-sm w-full">
                <option value="" selected={!isNew && !operator?.locationId}>
                  Sin asignar
                </option>
                {
                  allLocations.map((loc) => (
                    <option
                      value={loc.id}
                      selected={
                        isNew
                          ? loc.id === "MGR"
                          : operator?.locationId === loc.id
                      }
                    >
                      {loc.name}
                    </option>
                  ))
                }
              </select>
            </fieldset>

            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs">Estado</legend>
              <input
                type="text"
                readonly
                value={isNew ? "Disponible" : (operator?.status === "disponible" ? "Activo (en servicio)" : `No disponible / Excepción`)}
                class="input input-sm w-full input-disabled bg-base-200 cursor-not-allowed"
              />
              <p class="text-[10px] text-base-content/50 mt-1">
                El estado de disponibilidad se calcula automáticamente basado en la matriz de horarios y Cronograma.
              </p>
            </fieldset>
          </div>
        </div>
      </section>

      <section class="card bg-base-100 border border-base-300 shadow-md">
        <div class="card-body gap-4 p-5">
          <h2
            class="flex items-center gap-2 text-sm font-semibold text-base-content"
          >
            <span
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:calendar" size={15} />
            </span>
            Matriz de Horarios (Esquema Semanal)
          </h2>
          <div class="space-y-2">
            {
              daysOfWeek.map((day) => (
                <div class="collapse collapse-arrow border border-base-300 bg-base-100 rounded-box">
                  <input type="checkbox" />
                  <div class="collapse-title text-sm font-medium">{day}</div>
                  <div class="collapse-content">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="space-y-3">
                        <h3 class="text-xs font-semibold uppercase text-base-content/70 flex items-center gap-1">
                          <span>🏠</span> Home Office
                        </h3>
                        <div class="grid grid-cols-3 gap-2">
                          <fieldset class="fieldset gap-1">
                            <legend class="fieldset-legend text-[10px]">
                              Entrada
                            </legend>
                            <input
                              type="time"
                              name={`home_${day}_start`}
                              value={
                                operatorSchedulesData[day]?.home?.shiftStart ||
                                ""
                              }
                              class="input input-sm w-full"
                            />
                          </fieldset>
                          <fieldset class="fieldset gap-1">
                            <legend class="fieldset-legend text-[10px]">
                              Salida
                            </legend>
                            <input
                              type="time"
                              name={`home_${day}_end`}
                              value={
                                operatorSchedulesData[day]?.home?.shiftEnd || ""
                              }
                              class="input input-sm w-full"
                            />
                          </fieldset>
                          <fieldset class="fieldset gap-1">
                            <legend class="fieldset-legend text-[10px]">
                              Break
                            </legend>
                            <input
                              type="time"
                              name={`home_${day}_break`}
                              value={
                                operatorSchedulesData[day]?.home?.breakTime ||
                                ""
                              }
                              class="input input-sm w-full"
                            />
                          </fieldset>
                        </div>
                      </div>
                      <div class="space-y-3">
                        <h3 class="text-xs font-semibold uppercase text-base-content/70 flex items-center gap-1">
                          <span>🏢</span> Presencial
                        </h3>
                        <div class="grid grid-cols-3 gap-2">
                          <fieldset class="fieldset gap-1">
                            <legend class="fieldset-legend text-[10px]">
                              Entrada
                            </legend>
                            <input
                              type="time"
                              name={`presencial_${day}_start`}
                              value={
                                operatorSchedulesData[day]?.presencial
                                  ?.shiftStart || ""
                              }
                              class="input input-sm w-full"
                            />
                          </fieldset>
                          <fieldset class="fieldset gap-1">
                            <legend class="fieldset-legend text-[10px]">
                              Salida
                            </legend>
                            <input
                              type="time"
                              name={`presencial_${day}_end`}
                              value={
                                operatorSchedulesData[day]?.presencial
                                  ?.shiftEnd || ""
                              }
                              class="input input-sm w-full"
                            />
                          </fieldset>
                          <fieldset class="fieldset gap-1">
                            <legend class="fieldset-legend text-[10px]">
                              Break
                            </legend>
                            <input
                              type="time"
                              name={`presencial_${day}_break`}
                              value={
                                operatorSchedulesData[day]?.presencial
                                  ?.breakTime || ""
                              }
                              class="input input-sm w-full"
                            />
                          </fieldset>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <div class="flex items-center justify-between gap-3 pt-1">
        <a
          href={`${cleanBase}admin/operadores`}
          class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10"
        >
          <Icon name="boxicons:arrow-left-filled" size={16} />
          Volver al listado
        </a>
        <button type="submit" class="btn btn-primary btn-sm gap-2">
          <Icon name="boxicons:save-filled" size={16} />
          {isNew ? "Crear operador" : "Guardar cambios"}
        </button>
      </div>
    </form>
  </PageContainer>
</BaseLayout>
