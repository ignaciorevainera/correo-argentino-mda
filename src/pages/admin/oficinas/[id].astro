---
import { db } from "@db/index";
import {
  offices,
  contacts,
  officeContacts,
  officeAssets,
  provinces,
  regions,
} from "@db/schema";
import { eq, and, isNull } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";
import { logAdminAction } from "@lib/auditLogger";
import OfficeForm from "@components/admin/OfficeForm.astro";
import { officeFormSchema } from "@lib/validations";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!["admin", "supervisor", "team_leader"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);

const { id } = Astro.params;
const isNew = id === "new";
let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  try {
    const fd = await Astro.request.formData();

    const rawType = fd.get("type")?.toString() ?? "TELEGRAFIA";
    let type = rawType;
    let officeType = null;

    if (rawType === "SUCURSAL_AUTOMATIZADA") {
      type = "SUCURSAL";
      officeType = "AUTOMATIZADA";
    } else if (rawType === "SUCURSAL_NO_AUTOMATIZADA") {
      type = "SUCURSAL";
      officeType = "NO_AUTOMATIZADA";
    }

    const valStr = (key: string) => {
      const val = fd.get(key)?.toString().trim();
      return val ? val : null;
    };

    const rawData = {
      code: valStr("code") ?? "",
      name: valStr("name") ?? "",
      type: type,
      officeType: officeType,
      provinceCode: valStr("provinceCode") ?? "",
      address: valStr("address"),
      locality: valStr("locality"),
      county: valStr("county"),
      zone: valStr("zone"),
      email: valStr("email"),
      notes: valStr("notes"),
      parentNis: valStr("parentNis"),
      enRed: fd.get("enRed") === "on",
      paqarAdmision: fd.get("paqarAdmision") === "on",
      paqarEntrega: fd.get("paqarEntrega") === "on",
      payroll: fd.get("payroll") === "on",
      taxExempt: fd.get("taxExempt") === "on",
      division: valStr("division"),
      company: valStr("company"),
      warehouse: valStr("warehouse"),
      profitCenter: valStr("profitCenter"),
      cctAdminOffice: valStr("cctAdminOffice"),
      ccCommercial: valStr("ccCommercial"),
      ccCommercialCorp: valStr("ccCommercialCorp"),
      ccElectoral: valStr("ccElectoral"),
      ccNetworkMgmt: valStr("ccNetworkMgmt"),
      ccOperations: valStr("ccOperations"),
      ccOperational: valStr("ccOperational"),
      ccHr: valStr("ccHr"),
      ccSecurity: valStr("ccSecurity"),
      ccAdmin: valStr("ccAdmin"),
      ccAdmission: valStr("ccAdmission"),
      ccCtp: valStr("ccCtp"),
      ccCtt: valStr("ccCtt"),
      ccTransport: valStr("ccTransport"),
      ccLogistics: valStr("ccLogistics"),
      posAutoAuto: valStr("posAutoAuto"),
      posCurrentAccount: valStr("posCurrentAccount"),
      posManual: valStr("posManual"),
      posManualAuto: valStr("posManualAuto"),
      posPlantaMg: valStr("posPlantaMg"),
      posVirtual: valStr("posVirtual"),
      posAutoAuto2: valStr("posAutoAuto2"),
      posSapTerminal: valStr("posSapTerminal"),
    };

    const parsed = officeFormSchema.safeParse(rawData);

    if (!parsed.success) {
      errorMsg = parsed.error.issues.map((i) => i.message).join(", ");
    } else {
      const officeData = parsed.data;
      let officeId: number;

      let oldName = "";
      if (isNew) {
        const [created] = await db
          .insert(offices)
          .values(officeData)
          .returning({ id: offices.id });
        officeId = created.id;
      } else {
        officeId = Number(id);
        const [existing] = await db
          .select({ name: offices.name })
          .from(offices)
          .where(eq(offices.id, officeId));
        oldName = existing?.name || "";
        await db
          .update(offices)
          .set(officeData)
          .where(eq(offices.id, officeId));
      }

      await db.delete(officeAssets).where(eq(officeAssets.officeId, officeId));

      const assetTypes = fd.getAll("asset_type");
      const assetHostnames = fd.getAll("asset_hostname");
      const assetIps = fd.getAll("asset_ip");

      for (let i = 0; i < assetTypes.length; i++) {
        const aType = assetTypes[i]?.toString().trim();
        if (!aType) continue;
        await db.insert(officeAssets).values({
          officeId,
          type: aType,
          hostname: assetHostnames[i]?.toString().trim() || null,
          ip: assetIps[i]?.toString().trim() || null,
        });
      }

      await db
        .delete(officeContacts)
        .where(eq(officeContacts.officeId, officeId));

      const cIds = fd.getAll("contact_id");
      const cNames = fd.getAll("contact_name");
      const cPhones = fd.getAll("contact_phone");
      const cRoles = fd.getAll("contact_role");
      const cTimeSlots = fd.getAll("contact_timeslot");

      for (let i = 0; i < cNames.length; i++) {
        const cIdStr = cIds[i]?.toString().trim();
        const cName = cNames[i]?.toString().trim();
        if (!cName) continue;
        const cPhone = cPhones[i]?.toString().trim() || null;

        let contactId: number;
        if (cIdStr) {
          contactId = Number(cIdStr);
          await db
            .update(contacts)
            .set({ name: cName, phone: cPhone })
            .where(eq(contacts.id, contactId));
        } else {
          let existing;
          if (cPhone) {
            [existing] = await db
              .select()
              .from(contacts)
              .where(and(eq(contacts.name, cName), eq(contacts.phone, cPhone)));
          } else {
            [existing] = await db
              .select()
              .from(contacts)
              .where(and(eq(contacts.name, cName), isNull(contacts.phone)));
          }

          if (existing) {
            contactId = existing.id;
          } else {
            const [created] = await db
              .insert(contacts)
              .values({ name: cName, phone: cPhone })
              .returning({ id: contacts.id });
            contactId = created.id;
          }
        }

        try {
          await db.insert(officeContacts).values({
            officeId,
            contactId,
            role: cRoles[i]?.toString().trim() || null,
            timeSlot: cTimeSlots[i]?.toString().trim() || null,
          });
        } catch (e: any) {}
      }

      if (isNew) {
        await logAdminAction(user?.username || 'Sistema', `Creó la oficina "${officeData.name}" (${officeData.code})`);
        return Astro.redirect(`${cleanBase}admin/oficinas?toast_msg=${encodeURIComponent("Oficina creada con éxito.")}&toast_type=success`);
      }
      if (oldName && oldName !== officeData.name) {
        await logAdminAction(user?.username || 'Sistema', `Actualizó la oficina NIS ${officeData.code} (de "${oldName}" a "${officeData.name}")`);
      } else {
        await logAdminAction(user?.username || 'Sistema', `Actualizó la oficina "${officeData.name}" (NIS ${officeData.code})`);
      }
      return Astro.redirect(`${cleanBase}admin/oficinas?toast_msg=${encodeURIComponent("Oficina actualizada con éxito.")}&toast_type=success`);
    }
  } catch (e: any) {
    errorMsg = e.message?.includes("UNIQUE")
      ? "Ya existe una oficina con ese código."
      : "Error al guardar la oficina.";
  }
}

type OfficeRecord = {
  id: number;
  code: string;
  name: string;
  type: string;
  officeType?: string | null;
  provinceCode: string;
  address: string | null;
  locality?: string | null;
  county?: string | null;
  zone?: string | null;
  email: string | null;
  notes: string | null;
  parentNis: string | null;
  enRed?: boolean | null;
  paqarAdmision?: boolean | null;
  paqarEntrega?: boolean | null;
  payroll?: boolean | null;
  taxExempt?: boolean | null;
  division?: string | null;
  company?: string | null;
  warehouse?: string | null;
  profitCenter?: string | null;
  cctAdminOffice?: string | null;
  ccCommercial?: string | null;
  ccCommercialCorp?: string | null;
  ccElectoral?: string | null;
  ccNetworkMgmt?: string | null;
  ccOperations?: string | null;
  ccOperational?: string | null;
  ccHr?: string | null;
  ccSecurity?: string | null;
  ccAdmin?: string | null;
  ccAdmission?: string | null;
  ccCtp?: string | null;
  ccCtt?: string | null;
  ccTransport?: string | null;
  ccLogistics?: string | null;
  posAutoAuto?: string | null;
  posCurrentAccount?: string | null;
  posManual?: string | null;
  posManualAuto?: string | null;
  posPlantaMg?: string | null;
  posVirtual?: string | null;
  posAutoAuto2?: string | null;
  posSapTerminal?: string | null;
  contacts: {
    role: string | null;
    timeSlot: string | null;
    contact: { id: number; name: string; phone: string | null };
  }[];
  assets: {
    id: number;
    type: string;
    hostname: string | null;
    ip: string | null;
  }[];
};

let office: OfficeRecord | null = null;

if (!isNew) {
  const result = await db.query.offices.findFirst({
    where: eq(offices.id, Number(id)),
    with: {
      assets: true,
      contacts: { with: { contact: true } },
    },
  });
  if (!result) return Astro.redirect(`${cleanBase}admin/oficinas`);
  office = result as unknown as OfficeRecord;
}

const allProvincesWithRegion = await db
  .select({
    code: provinces.code,
    name: provinces.name,
    regionId: provinces.regionId,
    regionName: regions.name,
  })
  .from(provinces)
  .leftJoin(regions, eq(provinces.regionId, regions.id))
  .orderBy(regions.name, provinces.name);

const groupedProvinces = Array.from(
  allProvincesWithRegion.reduce((map, p) => {
    const rName = p.regionName ?? "Sin región";
    if (!map.has(rName)) map.set(rName, []);
    map.get(rName)!.push({ code: p.code, name: p.name });
    return map;
  }, new Map<string, { code: string; name: string }[]>()),
).map(([regionName, provs]) => ({ regionName, provinces: provs }));

const pageTitle = isNew ? "Nueva sucursal" : `Editar: ${office!.name}`;

const officeTypes = [
  { value: "telegrafia", label: "Telegrafía" },
  { value: "comercial", label: "Comercial" },
  { value: "distribucion", label: "Distribución" },
  { value: "paqueteria", label: "Paquetería" },
];

const assetTypeOptions = [
  { value: "server", label: "Servidor" },
  { value: "client", label: "Cliente" },
  { value: "printer", label: "Impresora" },
];
---

<BaseLayout title={`${pageTitle}`}>
  <PageContainer>
    {/* ── Breadcrumb / Volver ── */}
    <div class="flex items-center gap-2 text-sm text-base-content/60">
      <a
        href={`${cleanBase}admin/oficinas`}
        class="flex items-center gap-1.5 hover:text-base-content transition-colors"
      >
        <Icon name="boxicons:chevron-left" size={16} />
        Oficinas
      </a>
      <span>/</span>
      <span class="text-base-content font-medium truncate">{pageTitle}</span>
    </div>

    <PageHeader
      title={pageTitle}
      description={isNew
        ? "Completá los datos para registrar una nueva sucursal."
        : `Código ${office!.code} · ${office!.type}`}
    />

    {/* Feedback */}
    {
      errorMsg && (
        <script is:inline define:vars={{ errorMsg }}>
          window.showToast?.(errorMsg, "alert-error");
        </script>
      )
    }
    {
      successMsg && (
        <script is:inline define:vars={{ successMsg }}>
          window.showToast?.(successMsg, "alert-success");
        </script>
      )
    }

    <OfficeForm office={office} groupedProvinces={groupedProvinces} isNew={isNew} />
  </PageContainer>
</BaseLayout>
