---
import { db } from "@db/index";
import { cubics } from "@db/schema";
import { eq } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import { logAdminAction } from "@lib/auditLogger";
import AdminCubicsContent from "@components/admin/cubics/AdminCubicsContent.astro";
import AdminCubicsSkeleton from "@components/admin/cubics/AdminCubicsSkeleton.astro";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!user || !["admin", "supervisor", "team_leader"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "delete_cubic") {
    const cubicId = Number(formData.get("cubicId"));
    if (cubicId) {
      try {
        const [deleted] = await db
          .delete(cubics)
          .where(eq(cubics.id, cubicId))
          .returning({ name: cubics.name });

        if (deleted) {
          const successMsg = `Ordenador "${deleted.name}" dado de baja con éxito.`;
          await logAdminAction(Astro.locals.user?.username || 'Sistema', `Eliminó el ordenador "${deleted.name}"`);
          return Astro.redirect(`${cleanBase}admin/inventario-terminales?toast_msg=${encodeURIComponent(successMsg)}&toast_type=success`);
        } else {
          return Astro.redirect(`${cleanBase}admin/inventario-terminales?toast_msg=${encodeURIComponent("El ordenador indicado no existe.")}&toast_type=error`);
        }
      } catch (e) {
        return Astro.redirect(`${cleanBase}admin/inventario-terminales?toast_msg=${encodeURIComponent("Error al eliminar el ordenador.")}&toast_type=error`);
      }
    }
  }
}
---

<BaseLayout>
  <AdminCubicsContent server:defer>
    <AdminCubicsSkeleton slot="fallback" />
  </AdminCubicsContent>
</BaseLayout>
