---
import { db } from "@db/index";
import { offices, provinces, regions } from "@db/schema";
import { eq, asc, sql } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchInput from "@components/ui/SearchInput.astro";

import { Icon } from "astro-icon/components";

let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "delete_office") {
    const officeId = Number(formData.get("officeId"));
    if (officeId) {
      try {
        const [deleted] = await db
          .delete(offices)
          .where(eq(offices.id, officeId))
          .returning({ code: offices.code, name: offices.name });

        if (deleted) {
          successMsg = `Oficina "${deleted.name}" (${deleted.code}) eliminada con éxito.`;
        } else {
          errorMsg = "La oficina indicada no existe.";
        }
      } catch (e) {
        errorMsg = "Error al eliminar la oficina.";
      }
    }
  }
}

const allOfficesRaw = await db
  .select({
    id: offices.id,
    code: offices.code,
    name: offices.name,
    type: offices.type,
    officeType: offices.officeType,
    provinceCode: offices.provinceCode,
    address: offices.address,
    email: offices.email,
    notes: offices.notes,
    zone: offices.zone,
    paqarAdmision: offices.paqarAdmision,
    paqarEntrega: offices.paqarEntrega,
    provinceName: provinces.name,
    regionName: regions.name,
  })
  .from(offices)
  .leftJoin(provinces, eq(offices.provinceCode, provinces.code))
  .leftJoin(regions, eq(provinces.regionId, regions.id))
  .orderBy(asc(offices.code), asc(offices.name));

const allOffices = allOfficesRaw.map((o) => {
  let mappedType = o.type;
  if (o.type === "SUCURSAL") {
    mappedType =
      o.officeType === "AUTOMATIZADA"
        ? "SUCURSAL_AUTOMATIZADA"
        : "SUCURSAL_NO_AUTOMATIZADA";
  }
  return {
    ...o,
    mappedType,
    provinceName: o.provinceName ?? "",
    regionName: o.regionName ?? "",
    zone: o.zone ?? "",
    paqarAdmision: o.paqarAdmision ?? false,
    paqarEntrega: o.paqarEntrega ?? false,
  };
});

const provincesByRegion: Record<string, { code: string; name: string }[]> = {};
for (const o of allOfficesRaw) {
  const rName = o.regionName ?? "Sin región";
  if (!provincesByRegion[rName]) provincesByRegion[rName] = [];
  if (!provincesByRegion[rName].find((x) => x.code === o.provinceCode)) {
    provincesByRegion[rName].push({
      code: o.provinceCode,
      name: o.provinceName ?? "",
    });
  }
}
Object.values(provincesByRegion).forEach((provs) =>
  provs.sort((a, b) =>
    a.name.localeCompare(b.name, "es", { sensitivity: "base" }),
  ),
);

const uniqueRegions = [
  ...new Set(allOffices.map((o) => o.regionName).filter(Boolean)),
].sort((a, b) => a.localeCompare(b, "es", { sensitivity: "base" }));

const uniqueZones = [
  ...new Set(allOffices.map((o) => o.zone).filter(Boolean)),
].sort((a, b) => a.localeCompare(b, "es", { numeric: true }));

const rawCounts = await db
  .select({
    type: offices.type,
    officeType: offices.officeType,
    count: sql<number>`count(*)`,
  })
  .from(offices)
  .groupBy(offices.type, offices.officeType);

const processedCounts: { type: string; count: number }[] = [];
let sucursalAutoCount = 0;
let sucursalNoAutoCount = 0;

for (const row of rawCounts) {
  if (!row.type) continue;
  if (row.type === "SUCURSAL") {
    if (row.officeType === "AUTOMATIZADA") {
      sucursalAutoCount += row.count;
    } else {
      sucursalNoAutoCount += row.count;
    }
  } else {
    const existing = processedCounts.find((p) => p.type === row.type);
    if (existing) {
      existing.count += row.count;
    } else {
      processedCounts.push({ type: row.type, count: row.count });
    }
  }
}

if (sucursalAutoCount > 0)
  processedCounts.push({ type: "SUCURSAL_AUTOMATIZADA", count: sucursalAutoCount });
if (sucursalNoAutoCount > 0)
  processedCounts.push({ type: "SUCURSAL_NO_AUTOMATIZADA", count: sucursalNoAutoCount });

const officeCountByType = processedCounts.reduce(
  (acc, row) => {
    acc.all += row.count;
    acc[row.type] = row.count;
    return acc;
  },
  { all: 0 } as Record<string, number>,
);

const officeTypeLabelByType: Record<string, string> = {
  ADMINISTRACION: "Administración",
  AGENCIA: "Agencia",
  CDD: "CDD",
  CDP: "CDP",
  CTP: "CTP",
  "CORREO COLABORATIVO": "Colaborativo",
  ESPECIALES: "Especiales",
  ESTAFETA: "Estafeta",
  GENERAL: "General",
  SUCURSAL_AUTOMATIZADA: "Sucursal Automatizada",
  SUCURSAL_NO_AUTOMATIZADA: "Sucursal No Automatizada",
  TELEGRAFIA: "Telegrafía",
  "UNIDAD POSTAL": "Unidad Postal",
};

function formatTypeLabel(type: string): string {
  if (type.toLowerCase() === "cdd") return "CDD";
  if (type.toLowerCase() === "ctp") return "CTP";
  return (
    type.charAt(0).toUpperCase() +
    type.slice(1).toLowerCase().replace(/_/g, " ")
  );
}

processedCounts.forEach((row) => {
  if (row.type && !officeTypeLabelByType[row.type]) {
    officeTypeLabelByType[row.type] = formatTypeLabel(row.type);
  }
});

const officeTypeTabs = [
  { value: "all", label: "Todas", count: officeCountByType.all },
  ...processedCounts
    .sort((a, b) => b.count - a.count)
    .map((row) => ({
      value: row.type,
      label: officeTypeLabelByType[row.type] || formatTypeLabel(row.type),
      count: row.count,
    })),
];

const defaultChipClass =
  "office-type-chip bg-base-300 text-base-content border-base-400";
const officeTypeChipClassByType: Record<string, string> = {
  ADMINISTRACION: "office-type-chip office-type-chip-administracion",
  AGENCIA: "office-type-chip office-type-chip-agencia",
  CDD: "office-type-chip office-type-chip-cdd",
  CDP: "office-type-chip office-type-chip-cdp",
  CTP: "office-type-chip office-type-chip-ctp",
  "CORREO COLABORATIVO":
    "office-type-chip office-type-chip-correo-colaborativo",
  ESPECIALES: "office-type-chip office-type-chip-especiales",
  ESTAFETA: "office-type-chip office-type-chip-estafeta",
  GENERAL: "office-type-chip office-type-chip-general",
  SUCURSAL_AUTOMATIZADA:
    "office-type-chip office-type-chip-sucursal-automatizada",
  SUCURSAL_NO_AUTOMATIZADA:
    "office-type-chip office-type-chip-sucursal-no-automatizada",
  TELEGRAFIA: "office-type-chip office-type-chip-telegrafia",
  "UNIDAD POSTAL": "office-type-chip office-type-chip-unidad-postal",
};

const headerGridClass = "grid-cols-[100px_1fr_160px_1fr_140px] gap-4";
const rowGridClass =
  "grid grid-cols-[100px_1fr_160px_1fr_140px] items-center gap-4";
const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      description="Administración del directorio operativo de oficinas, contactos y activos tecnológicos."
    />

    {errorMsg && (
      <div role="alert" class="alert alert-error alert-soft text-sm">
        <Icon name="boxicons:alert-circle-filled" size={20} class="shrink-0" />
        <span>{errorMsg}</span>
      </div>
    )}
    {successMsg && (
      <div role="alert" class="alert alert-success alert-soft text-sm">
        <Icon name="boxicons:check-circle-filled" size={20} class="shrink-0" />
        <span>{successMsg}</span>
      </div>
    )}

    {/* ── Filtros ── */}
    <div
      class="flex flex-col gap-4 rounded-box border border-base-300 bg-base-100 p-4 shadow-md"
      aria-label="Filtros de oficinas"
    >
      {/* Tabs por tipo */}
      <div
        id="admin-office-type-tabs"
        class="tabs tabs-box gap-1.5 flex-wrap bg-base-200/50 p-2"
        role="tablist"
      >
        {officeTypeTabs.map((tab) => (
          <button
            type="button"
            role="tab"
            data-admin-type-tab={tab.value}
            aria-selected={tab.value === "all" ? "true" : "false"}
            class:list={[
              "tab transition-all duration-200 flex items-center gap-2",
              tab.value === "all" ? "tab-active" : "",
            ]}
          >
            <span>{tab.label}</span>
            {tab.count !== undefined && (
              <span class="badge badge-sm bg-base-200 text-current border-none">
                {tab.count}
              </span>
            )}
          </button>
        ))}
      </div>

      {/* Fila de selects + búsqueda + acción */}
      <div class="flex flex-wrap items-center gap-3 w-full">
        <select
          id="admin-office-region-filter"
          class="select border-base-300 flex-1 min-w-40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          aria-label="Filtrar por región"
        >
          <option value="all">Regiones (Todas)</option>
          {uniqueRegions.map((region) => (
            <option value={region}>{region}</option>
          ))}
        </select>

        <select
          id="admin-office-province-filter"
          class="select border-base-300 flex-1 min-w-40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          aria-label="Filtrar por provincia"
          disabled
        >
          <option value="all">Provincias (Todas)</option>
        </select>

        <select
          id="admin-office-zone-filter"
          class="select border-base-300 flex-1 min-w-40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          aria-label="Filtrar por zona"
        >
          <option value="all">Zonas (Todas)</option>
          {uniqueZones.map((zone) => (
            <option value={zone}>{zone}</option>
          ))}
        </select>

        <select
          id="admin-office-paqar-filter"
          class="select border-base-300 flex-1 min-w-40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          aria-label="Filtrar por servicios Paq.AR"
        >
          <option value="all">Paq.AR (Todos)</option>
          <option value="admision">Admite Paq.AR</option>
          <option value="entrega">Entrega Paq.AR</option>
          <option value="ambos">Admite y Entrega</option>
        </select>

        <div class="flex-2 min-w-70 flex gap-2">
          <SearchInput
            id="admin-office-search"
            label="Buscar oficina por nombre, código o dirección"
            placeholder="Buscar por código, nombre o dirección"
            class="flex-1"
          />
          <button
            id="admin-office-clear-filters"
            type="button"
            class="btn btn-soft text-base-content/70 hover:text-base-content hidden"
            aria-label="Limpiar filtros"
            title="Limpiar todos los filtros"
          >
            Limpiar
          </button>
        </div>
      </div>
    </div>

    {/* ── Toolbar superior ── */}
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <h2 class="text-lg font-semibold text-base-content">
          Oficinas registradas
        </h2>
        {allOffices.length > 0 && (
          <span
            id="office-count-badge"
            class="badge badge-neutral badge-sm font-mono"
          >
            {allOffices.length}
          </span>
        )}
      </div>
      <a
        href={`${cleanBase}admin/offices/new`}
        class="btn btn-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        <Icon name="boxicons:plus" size={18} />
        Nueva sucursal
      </a>
    </div>

    {/* ── Tabla ── */}
    <DataTable
      ariaLabel="Listado de oficinas registradas"
      minWidthClass="min-w-200"
      headerGridClass={headerGridClass}
      rowGridClass={rowGridClass}
    >
      <div slot="header">
        <DataTableHeaderCell sortKey="code">Código</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="name">Nombre</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="type">Tipo</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="region">Provincia / Región</DataTableHeaderCell>
      </div>
      <div slot="header" class="text-right">
        <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
      </div>

      {allOffices.length === 0 ? (
        <div class="flex flex-col items-center gap-3 py-16 text-base-content/50">
          <div class="rounded-full bg-base-200 p-4">
            <Icon
              name="boxicons:building-filled"
              size={32}
              class="opacity-30"
              aria-hidden="true"
            />
          </div>
          <div class="space-y-1 text-center">
            <p class="text-sm font-semibold">No hay oficinas registradas</p>
            <p class="text-xs">
              Comenzá cargando la primera oficina desde el botón superior.
            </p>
          </div>
        </div>
      ) : (
        <>
          {allOffices.map((office) => (
            <article
              data-table-row
              data-sort-code={office.code}
              data-sort-name={office.name}
              data-sort-type={office.mappedType}
              data-sort-region={office.regionName}
              data-sort-province-code={office.provinceCode}
              data-sort-zone={office.zone}
              data-paqar-admision={office.paqarAdmision ? "true" : "false"}
              data-paqar-entrega={office.paqarEntrega ? "true" : "false"}
              data-search-text={`${office.code} ${office.name} ${office.address ?? ""} ${office.regionName} ${office.provinceName} ${officeTypeLabelByType[office.mappedType] ?? office.mappedType}`.toLowerCase()}
              class:list={[
                rowGridClass,
                "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-200/50 last:border-b-0",
              ]}
            >
              {/* Código */}
              <div>
                <span
                  data-highlight-target
                  class:list={[
                    "inline-flex px-2 py-1 font-mono text-sm font-semibold",
                    officeTypeChipClassByType[office.mappedType] || defaultChipClass,
                  ]}
                >
                  {office.code}
                </span>
              </div>

              {/* Nombre + Dirección */}
              <div class="min-w-0">
                <p
                  data-highlight-target
                  class="truncate text-sm font-semibold text-base-content"
                >
                  {office.name}
                </p>
                {office.address && (
                  <p
                    data-highlight-target
                    class="mt-0.5 truncate text-xs text-base-content/50"
                  >
                    {office.address}
                  </p>
                )}
              </div>

              {/* Tipo */}
              <div class="min-w-0">
                <span
                  data-highlight-target
                  class:list={[
                    "inline-flex px-2 py-1 text-xs font-bold uppercase tracking-wide",
                    officeTypeChipClassByType[office.mappedType] || defaultChipClass,
                  ]}
                >
                  {officeTypeLabelByType[office.mappedType] ?? office.mappedType}
                </span>
              </div>

              {/* Provincia / Región */}
              <div class="min-w-0">
                <span
                  data-highlight-target
                  class="truncate text-sm text-base-content/70"
                >
                  {office.provinceName || (
                    <span class="text-base-content/30">&mdash;</span>
                  )}
                </span>
                {office.regionName && (
                  <p class="mt-0.5 truncate text-xs text-base-content/50">
                    {office.regionName}
                  </p>
                )}
              </div>

              {/* Acciones */}
              <div class="flex items-center justify-end gap-1">
                <a
                  href={`${cleanBase}admin/offices/${office.id}`}
                  class="btn btn-sm btn-ghost h-7 px-2 text-base-content/60 hover:text-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                  aria-label={`Editar ${office.name}`}
                >
                  <Icon name="boxicons:pencil-filled" size={14} />
                  <span class="hidden sm:inline">Editar</span>
                </a>

                <form
                  method="POST"
                  class="inline"
                  onsubmit="return confirm('¿Estás seguro de que querés eliminar esta oficina? Se borrarán también sus contactos y activos vinculados.')"
                >
                  <input type="hidden" name="action" value="delete_office" />
                  <input type="hidden" name="officeId" value={office.id} />
                  <button
                    type="submit"
                    class="btn btn-ghost btn-sm h-7 rounded-lg px-2 text-base-content/60 hover:text-error hover:bg-error/10 transition-all duration-200"
                    aria-label={`Eliminar ${office.name}`}
                  >
                    <Icon name="boxicons:trash-filled" size={14} />
                    <span class="hidden sm:inline">Eliminar</span>
                  </button>
                </form>
              </div>
            </article>
          ))}
        </>
      )}
    </DataTable>

    <script is:inline define:vars={{ provincesByRegion }}>
      window._ADMIN_PROVINCES_BY_REGION = provincesByRegion;
    </script>
    <script>
      import {
        matchesSearchQuery,
        highlightSearchTargets,
      } from "@lib/clientSearch";

      const searchInput = document.querySelector<HTMLInputElement>(
        "#admin-office-search",
      );
      const typeTabs = document.querySelectorAll<HTMLElement>(
        "#admin-office-type-tabs [data-admin-type-tab]",
      );
      const regionFilter = document.querySelector<HTMLSelectElement>(
        "#admin-office-region-filter",
      );
      const provinceFilter = document.querySelector<HTMLSelectElement>(
        "#admin-office-province-filter",
      );
      const zoneFilter = document.querySelector<HTMLSelectElement>(
        "#admin-office-zone-filter",
      );
      const paqarFilter = document.querySelector<HTMLSelectElement>(
        "#admin-office-paqar-filter",
      );
      const clearBtn = document.querySelector<HTMLButtonElement>(
        "#admin-office-clear-filters",
      );
      const rows =
        document.querySelectorAll<HTMLElement>("[data-table-row]");
      const countBadge =
        document.querySelector<HTMLElement>("#office-count-badge");

      let activeType = "all";

      function updateClearButton() {
        const hasFilters =
          activeType !== "all" ||
          (regionFilter?.value ?? "all") !== "all" ||
          (provinceFilter?.value ?? "all") !== "all" ||
          (zoneFilter?.value ?? "all") !== "all" ||
          (paqarFilter?.value ?? "all") !== "all" ||
          (searchInput?.value.trim() ?? "") !== "";

        clearBtn?.classList.toggle("hidden", !hasFilters);
      }

      function applyFilters() {
        const query = searchInput?.value.trim() || "";
        const regionValue = regionFilter?.value || "all";
        const provinceValue = provinceFilter?.value || "all";
        const zoneValue = zoneFilter?.value || "all";
        const paqarValue = paqarFilter?.value || "all";
        let visibleCount = 0;

        rows.forEach((row) => {
          const searchText = row.dataset.searchText || "";
          const rowType = row.dataset.sortType || "";
          const rowRegion = row.dataset.sortRegion || "";
          const rowProvinceCode = row.dataset.sortProvinceCode || "";
          const rowZone = row.dataset.sortZone || "";
          const rowPaqarAdmision = row.dataset.paqarAdmision === "true";
          const rowPaqarEntrega = row.dataset.paqarEntrega === "true";

          const matchSearch = matchesSearchQuery(query, [searchText]);
          const matchType = activeType === "all" || rowType === activeType;
          const matchRegion =
            regionValue === "all" || rowRegion === regionValue;
          const matchProvince =
            provinceValue === "all" || rowProvinceCode === provinceValue;
          const matchZone = zoneValue === "all" || rowZone === zoneValue;

          let matchPaqar = true;
          if (paqarValue === "admision") matchPaqar = rowPaqarAdmision;
          else if (paqarValue === "entrega") matchPaqar = rowPaqarEntrega;
          else if (paqarValue === "ambos")
            matchPaqar = rowPaqarAdmision && rowPaqarEntrega;

          const isVisible =
            matchSearch &&
            matchType &&
            matchRegion &&
            matchProvince &&
            matchZone &&
            matchPaqar;

          row.classList.toggle("hidden", !isVisible);
          highlightSearchTargets(row, isVisible ? query : "");

          if (isVisible) visibleCount++;
        });

        if (countBadge) countBadge.textContent = visibleCount.toString();
        updateClearButton();
      }

      typeTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          activeType = (tab as HTMLElement).dataset.adminTypeTab || "all";
          typeTabs.forEach((t) => {
            const isActive = (t as HTMLElement).dataset.adminTypeTab === activeType;
            t.setAttribute("aria-selected", isActive ? "true" : "false");
            t.classList.toggle("tab-active", isActive);
          });
          applyFilters();
        });
      });

      searchInput?.addEventListener("input", applyFilters);
      zoneFilter?.addEventListener("change", applyFilters);
      paqarFilter?.addEventListener("change", applyFilters);

      const provincesData = (window as any)._ADMIN_PROVINCES_BY_REGION as
        | Record<string, { code: string; name: string }[]>
        | undefined;

      regionFilter?.addEventListener("change", () => {
        const selectedRegion = regionFilter.value;

        if (provinceFilter) {
          provinceFilter.innerHTML =
            '<option value="all">Provincias (Todas)</option>';

          if (selectedRegion !== "all" && provincesData?.[selectedRegion]) {
            for (const p of provincesData[selectedRegion]) {
              const opt = document.createElement("option");
              opt.value = p.code;
              opt.textContent = p.name;
              provinceFilter.appendChild(opt);
            }
            provinceFilter.disabled = false;
          } else {
            provinceFilter.disabled = true;
          }
          provinceFilter.value = "all";
        }

        applyFilters();
      });

      provinceFilter?.addEventListener("change", applyFilters);

      clearBtn?.addEventListener("click", () => {
        activeType = "all";
        typeTabs.forEach((tab) => {
          const isAll = (tab as HTMLElement).dataset.adminTypeTab === "all";
          tab.setAttribute("aria-selected", isAll ? "true" : "false");
          tab.classList.toggle("tab-active", isAll);
        });
        if (regionFilter) regionFilter.value = "all";
        if (provinceFilter) {
          provinceFilter.innerHTML =
            '<option value="all">Provincias (Todas)</option>';
          provinceFilter.disabled = true;
          provinceFilter.value = "all";
        }
        if (zoneFilter) zoneFilter.value = "all";
        if (paqarFilter) paqarFilter.value = "all";
        if (searchInput) searchInput.value = "";
        applyFilters();
      });
    </script>
  </PageContainer>
</BaseLayout>

<style is:global>
  .office-type-chip {
    border-width: 1px;
    box-shadow: inset 0 0 0 1px rgb(0 0 0 / 0.04);
    border-radius: 0.5rem;
  }

  .office-type-chip-administracion { background-color: var(--color-indigo-100, #e0e7ff); border-color: var(--color-indigo-300, #a5b4fc); color: var(--color-indigo-900, #1e1b4b); }
