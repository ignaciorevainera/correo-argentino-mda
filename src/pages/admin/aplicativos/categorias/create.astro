---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { applicationCategories } from "@db/schema";
import { logAdminFromAstro } from "@lib/auditLogger";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import { resolveUrl } from "@lib/url";
import { redirectWithToast } from "@lib/api/redirectWithToast";
import { toastResponse } from "@lib/api/toastResponse";
import SectionCard from "@components/ui/SectionCard.astro";

let errorMsg = "";

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  try {
    const formData = await Astro.request.formData();
    const title = formData.get("title")?.toString().trim();

    if (!title) {
      throw new Error("El título es obligatorio.");
    }

    if (title.toLowerCase() === "sin categoría" || title.toLowerCase() === "sin categoria") {
      throw new Error("No se puede crear una categoría con este nombre reservado.");
    }

    await db.insert(applicationCategories).values({
      title,
    });
    await logAdminFromAstro(Astro.locals, `Creó la categoría de aplicativos "${title}"`);

    if (isAjax) {
      return toastResponse({ success: true, message: "Categoría creada con éxito.", redirectUrl: resolveUrl("/admin/aplicativos") });
    }

    return redirectWithToast("/admin/aplicativos", "Categoría creada con éxito.");
  } catch (error: any) {
    console.error("DEBUG ERROR CREATE CATEGORIA APLICATIVOS:", error);
    if (isAjax) {
      return toastResponse({ success: false, error: error.message || "Error al guardar la categoría." });
    }
    errorMsg = error.message || "Error al guardar la categoría.";
  }
}
---

<BaseLayout title="Nueva categoría de aplicativos">
  <PageContainer>
    <div class="max-w-2xl mx-auto py-4 sm:py-8">
      <div class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
        <a
          href={resolveUrl("/admin/aplicativos")}
          class="flex items-center gap-1.5 hover:text-base-content transition-colors"
        >
          <Icon name="boxicons:chevron-left" size={16} />
          Aplicativos
        </a>
        <span>/</span>
        <span class="text-base-content font-medium truncate">Nueva categoría</span>
      </div>

      <PageHeader
        title="Nueva categoría de aplicativos"
        description="Definí cómo se agruparán los aplicativos en la intranet."
      />

      {
        errorMsg && (
              <script is:inline define:vars={{ errorMsg }}>
                window.addEventListener('load', () => window.showToast?.(errorMsg, "alert-error"));
              </script>
            )
      }

      <SectionCard>
        <div class="p-6 sm:p-8">

          <form method="POST" class="space-y-5" data-async-form>
            <div class="grid grid-cols-1 gap-y-5">
              <FormField
                id="input-title"
                name="title"
                label="Título de la Categoría"
                required
                value=""
                placeholder="Ej: Herramientas de Red"
                inputClass="font-medium"
                autofocus
              />
            </div>

            <div
              class="flex justify-end gap-3 pt-6 mt-2 border-t border-base-200"
            >
              <a href={resolveUrl("/admin/aplicativos")} class="btn btn-ghost"
                >Cancelar</a
              >
              <button type="submit" class="btn btn-primary gap-2">
                <Icon name="boxicons:save" size={18} />
                Guardar Categoría
              </button>
            </div>
          </form>
        </div>
      </SectionCard>
    </div>
  </PageContainer>
  <AsyncFormScript />
</BaseLayout>
