---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import FormTextarea from "@components/ui/forms/FormTextarea.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { applications, applicationCategories } from "@db/schema";
import { eq } from "drizzle-orm";
import { logAdminAction } from "@lib/auditLogger";
import { processIconUpload } from "@lib/iconUpload";
import { encryptData, decryptData } from "@lib/encryption";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import { getAppsDir, ensureDir, getPdfsDir } from "@lib/storage";
import { resolveUrl } from "@lib/url";
import SectionCard from "@components/ui/SectionCard.astro";
import FormLegend from "@components/ui/forms/FormLegend.astro";

const { id } = Astro.params;

let errorMsg = "";
let app = {
  id: 0,
  title: "",
  categoryId: "",
  description: "",
  version: "",
  filePath: "",
  iconPath: "",
  metadata: [] as Array<{ label: string; value: string }>,
  instructionPdfPath: "",
};

const categories = await db.select().from(applicationCategories);

if (!id || isNaN(Number(id))) {
  return Astro.redirect(resolveUrl("/admin/aplicativos"));
}

const numericId = Number(id);

const existing = await db.query.applications.findFirst({
  where: eq(applications.id, numericId),
});

let decryptedMetadata: Array<{ label: string; value: string }> = [];
if (existing && existing.metadata) {
  try {
    const jsonStr = decryptData(existing.metadata);
    decryptedMetadata = JSON.parse(jsonStr);
  } catch (err) {
    console.error("Error al desencriptar metadatos:", err);
  }
}

if (existing) {
  app = {
    id: existing.id,
    title: existing.title,
    categoryId: existing.categoryId ? String(existing.categoryId) : "",
    description: existing.description || "",
    version: existing.version || "",
    filePath: existing.filePath || "",
    iconPath: existing.iconPath || "",
    metadata: decryptedMetadata,
    instructionPdfPath: existing.instructionPdfPath || "",
  };
} else {
  return Astro.redirect(resolveUrl("/admin/aplicativos"));
}

let formUploadType = "";
let formExternalUrl = "";
let formSnapshot: FormData | null = null;

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  try {
    const formData = await Astro.request.formData();
    formSnapshot = formData;

    const title = formData.get("title")?.toString().trim();
    const categoryIdRaw = formData.get("categoryId")?.toString().trim();
    const categoryId = categoryIdRaw && !isNaN(Number(categoryIdRaw)) ? Number(categoryIdRaw) : null;
    const description = formData.get("description")?.toString().trim() || null;
    const version = formData.get("version")?.toString().trim() || null;
    const uploadType = formData.get("uploadType")?.toString() as
      | "local"
      | "external"
      | null;

    if (!title) {
      throw new Error("El título es obligatorio.");
    }
    if (title.length > 50) {
      throw new Error("El título no puede superar los 50 caracteres.");
    }
    if (description && description.length > 150) {
      throw new Error("La descripción no puede superar los 150 caracteres.");
    }

    let filePath = app.filePath || null;
    let iconPath = app.iconPath || null;

    if (uploadType === "external") {
      const externalUrl =
        formData.get("externalUrl")?.toString().trim() || null;
      if (externalUrl) {
        filePath = externalUrl;
      }
    } else {
      const file = formData.get("file") as File | null;

      if (file && file.size > 0 && file.name) {
        const fs = await import("node:fs");
        const path = await import("node:path");

        const appsDir = getAppsDir();
        ensureDir(appsDir);

        const ext = path.extname(file.name);
        const baseName = path
          .basename(file.name, ext)
          .replace(/[^a-zA-Z0-9_\-\.]/g, "_")
          .replace(/_+/g, "_");
        const safeFileName = `${Date.now()}_${baseName}${ext}`;

        try {
          const buffer = Buffer.from(await file.arrayBuffer());
          fs.writeFileSync(path.join(appsDir, safeFileName), buffer);
        } catch (writeError: any) {
          console.error(
            `[aplicativos] Error al escribir el archivo "${safeFileName}": ${writeError.message}`,
          );
          throw new Error(
            `No se pudo guardar el archivo en el servidor. Verificá los permisos de la carpeta de almacenamiento.`,
          );
        }

        if (app.filePath && !app.filePath.startsWith("http")) {
          const downloadPrefix = resolveUrl("api/download/");
          const oldFileName = app.filePath.startsWith(downloadPrefix)
            ? app.filePath.slice(downloadPrefix.length)
            : null;

          if (oldFileName) {
            try {
              const oldAbsPath = path.join(appsDir, oldFileName);
              if (fs.existsSync(oldAbsPath)) {
                fs.unlinkSync(oldAbsPath);
              }
            } catch {}
          }
        }

        filePath = `${resolveUrl("api/download/")}${safeFileName}`;
      }
    }

    const newIconPath = await processIconUpload({
      iconFile: formData.get("icon") as File | null,
      currentIconPath: app.iconPath || null,
    });
    if (newIconPath) {
      iconPath = newIconPath;
    }

    // Procesar metadatos
    const metadataRaw = formData.get("metadata")?.toString().trim();
    let metadataEncrypted = null;
    if (metadataRaw) {
      try {
        const parsed = JSON.parse(metadataRaw);
        if (Array.isArray(parsed) && parsed.length > 0) {
          metadataEncrypted = encryptData(metadataRaw);
        }
      } catch (e) {
        console.error("Error al parsear o encriptar metadatos:", e);
      }
    }

    // Procesar PDF de instructivo
    const instructionPdfFile = formData.get("instructionPdf") as File | null;
    let instructionPdfPath = app.instructionPdfPath || null;

    if (
      instructionPdfFile &&
      instructionPdfFile.size > 0 &&
      instructionPdfFile.name
    ) {
      const fs = await import("node:fs");
      const path = await import("node:path");

      const pdfsDir = getPdfsDir();
      ensureDir(pdfsDir);

      const ext = path.extname(instructionPdfFile.name);
      if (ext.toLowerCase() !== ".pdf") {
        throw new Error("El instructivo adjunto debe ser un archivo PDF.");
      }

      const baseName = path
        .basename(instructionPdfFile.name, ext)
        .replace(/[^a-zA-Z0-9_\-\.]/g, "_")
        .replace(/_+/g, "_");
      const safeFileName = `${Date.now()}_${baseName}${ext}`;

      try {
        const buffer = Buffer.from(await instructionPdfFile.arrayBuffer());
        fs.writeFileSync(path.join(pdfsDir, safeFileName), buffer);

        // Si existía un archivo viejo, borrarlo
        if (app.instructionPdfPath) {
          const oldAbsPath = path.join(
            pdfsDir,
            app.instructionPdfPath,
          );
          if (fs.existsSync(oldAbsPath)) {
            fs.unlinkSync(oldAbsPath);
          }
        }

        instructionPdfPath = safeFileName;
      } catch (writeError: any) {
        console.error(
          `[aplicativos] Error al escribir PDF privado: ${writeError.message}`,
        );
        throw new Error(`No se pudo guardar el archivo PDF en el servidor.`);
      }
    }

    const oldTitle = app.title;
    await db
      .update(applications)
      .set({
        title,
        categoryId,
        description,
        version,
        filePath,
        iconPath,
        metadata: metadataEncrypted,
        instructionPdfPath,
      })
      .where(eq(applications.id, app.id));
    if (oldTitle && oldTitle !== title) {
      await logAdminAction(
        Astro.locals.user?.username || "Sistema",
        `Actualizó el aplicativo de "${oldTitle}" a "${title}"`,
      );
    } else {
      await logAdminAction(
        Astro.locals.user?.username || "Sistema",
        `Actualizó el aplicativo "${title}"`,
      );
    }

    if (isAjax) {
      return new Response(
        JSON.stringify({
          success: true,
          message: "Aplicativo actualizado con éxito.",
          redirectUrl: resolveUrl("/admin/aplicativos"),
        }),
        { status: 200, headers: { "Content-Type": "application/json" } },
      );
    }

    return Astro.redirect(
      resolveUrl(
        `/admin/aplicativos?toast_msg=${encodeURIComponent("Aplicativo actualizado con éxito.")}&toast_type=success`,
      ),
    );
  } catch (error: any) {
    if (isAjax) {
      return new Response(JSON.stringify({ success: false, error: error.message || "Error al guardar el aplicativo." }), {
        status: 400,
        headers: { "Content-Type": "application/json" },
      });
    }
    errorMsg = error.message || "Error al guardar el aplicativo.";
    if (formSnapshot) {
      app.title = formSnapshot.get("title")?.toString() || "";
      app.categoryId = formSnapshot.get("categoryId")?.toString() || "";
      app.description = formSnapshot.get("description")?.toString() || "";
      app.version = formSnapshot.get("version")?.toString() || "";
      formUploadType = formSnapshot.get("uploadType")?.toString() || "";
      formExternalUrl = formSnapshot.get("externalUrl")?.toString() || "";

      const formMeta = formSnapshot.get("metadata")?.toString() || "[]";
      try {
        app.metadata = JSON.parse(formMeta);
      } catch {
        app.metadata = [];
      }
    }
  }
}

const isExternal = formUploadType
  ? formUploadType === "external"
  : /^https?:\/\//i.test(app.filePath);
---

<BaseLayout title="Editar aplicativo">
  <PageContainer>
    <div class="max-w-2xl mx-auto py-4 sm:py-8">
      <div class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
        <a
          href={resolveUrl("/admin/aplicativos")}
          class="flex items-center gap-1.5 hover:text-base-content transition-colors"
        >
          <Icon name="boxicons:chevron-left" size={16} />
          Aplicativos
        </a>
        <span>/</span>
        <span class="text-base-content font-medium truncate">Editar aplicativo</span>
      </div>

      <PageHeader
        title="Editar aplicativo"
        description="Modificá los datos del aplicativo seleccionado."
      />

      {
        errorMsg && (
          <script is:inline define:vars={{ errorMsg }}>
            const triggerToast = () => {
              if (window.showToast) {
                window.showToast(errorMsg, "alert-error");
              } else {
                setTimeout(triggerToast, 100);
              }
            };
            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", triggerToast);
            } else {
              triggerToast();
            }
          </script>
        )
      }

      <SectionCard>
        <div class="p-6 sm:p-8">
          <form method="POST" enctype="multipart/form-data" class="space-y-5" data-async-form>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-5">
              <FormField
                id="input-title"
                name="title"
                label="Título"
                required
                value={app.title}
                placeholder="Ej: ShareX"
                maxlength={50}
              />

              <SelectField
                id="select-categoryId"
                name="categoryId"
                label="Categoría"
                selectClass="font-medium"
              >
                <option value="" selected={!app.categoryId}>
                  Sin categoría
                </option>
                {
                  categories.map((cat) => (
                    <option value={cat.id} selected={Number(cat.id) === Number(app.categoryId)}>
                      {cat.title}
                    </option>
                  ))
                }
              </SelectField>

              <FormField
                id="input-version"
                name="version"
                label="Versión"
                value={app.version}
                placeholder="Ej: 1.2.0"
                inputClass="font-mono text-sm"
                helpText="(Opcional)"
              />
            </div>

            <FormField
              type="file"
              id="input-icon"
              name="icon"
              label="Ícono"
              accept="image/png, image/jpeg, image/svg+xml, .ico"
              helpText="(Opcional, .png, .jpg, .svg, .ico)"
            >
              {
                app.iconPath && (
                  <div slot="preview" class="w-12 h-12 shrink-0 rounded-box border border-base-300 bg-base-200 flex items-center justify-center overflow-hidden p-1">
                    <img
                      src={resolveUrl(`api/icons/${app.iconPath}`)}
                      alt="Preview del ícono"
                      class="w-full h-full object-contain"
                    />
                  </div>
                )
              }
            </FormField>

            <fieldset class="fieldset">
              <FormLegend class="mb-2">
                Origen del archivo
              </FormLegend>
              <div
                class="flex gap-1 rounded-lg bg-base-200/60 p-1"
                role="radiogroup"
                aria-label="Tipo de subida"
              >
                <label
                  class:list={[
                    "flex-1 flex items-center justify-center gap-2 cursor-pointer rounded-md px-3 py-2 text-sm font-medium transition-all duration-200",
                    !isExternal
                      ? "bg-base-100 shadow-sm text-base-content"
                      : "text-base-content/50 hover:text-base-content/80",
                  ]}
                >
                  <input
                    type="radio"
                    name="uploadType"
                    value="local"
                    checked={!isExternal}
                    class="hidden"
                    id="radio-local"
                  />
                  <Icon
                    name="boxicons:arrow-in-up-square-half-filled"
                    size={16}
                    class="shrink-0"
                  />
                  Archivo local
                </label>
                <label
                  class:list={[
                    "flex-1 flex items-center justify-center gap-2 cursor-pointer rounded-md px-3 py-2 text-sm font-medium transition-all duration-200",
                    isExternal
                      ? "bg-base-100 shadow-sm text-base-content"
                      : "text-base-content/50 hover:text-base-content/80",
                  ]}
                >
                  <input
                    type="radio"
                    name="uploadType"
                    value="external"
                    checked={isExternal}
                    class="hidden"
                    id="radio-external"
                  />
                  <Icon
                    name="boxicons:arrow-out-up-right-square-filled"
                    size={16}
                    class="shrink-0"
                  />
                  Enlace externo
                </label>
              </div>
            </fieldset>

            <div id="localUploadGroup" class:list={[isExternal && "hidden"]}>
              <FormField
                type="file"
                id="input-file"
                name="file"
                label="Archivo"
                accept=".zip,.exe,.msi,.rar"
                helpText="Formatos: .zip, .exe, .msi, .rar"
              />
            </div>

            <div id="externalUrlGroup" class:list={[!isExternal && "hidden"]}>
              <FormField
                id="input-externalUrl"
                name="externalUrl"
                label="URL externa"
                type="url"
                value={formExternalUrl || (/^https?:\/\//i.test(app.filePath) ? app.filePath : "")}
                placeholder="https://ejemplo.com/descarga/archivo.zip"
                inputClass="font-mono"
              />
            </div>

            {
              app.filePath && (
                <div class="flex items-center gap-3 rounded-lg bg-success/10 border border-success/20 px-4 py-3">
                  <Icon
                    name={
                      isExternal
                        ? "boxicons:arrow-out-up-right-square-filled"
                        : "boxicons:file-filled"
                    }
                    size={20}
                    class="text-success shrink-0"
                  />
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-base-content">
                      {isExternal ? "Enlace actual" : "Archivo actual cargado"}
                    </p>
                    <p class="text-xs text-base-content/60 font-mono truncate">
                      {app.filePath}
                    </p>
                  </div>
                  <a
                    href={app.filePath}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-ghost btn-xs gap-1"
                  >
                    <Icon
                      name={
                        isExternal
                          ? "boxicons:arrow-to-right"
                          : "boxicons:arrow-in-down-square-half-filled"
                      }
                      size={14}
                    />
                    {isExternal ? "Abrir" : "Descargar"}
                  </a>
                </div>
              )
            }

            <FormField
              type="file"
              id="input-instruction-pdf"
              name="instructionPdf"
              label="Instructivo PDF"
              accept=".pdf"
              helpText="(Opcional, archivo .pdf confidencial)"
            />

            {
              app.instructionPdfPath && (
                <div class="flex items-center gap-3 rounded-lg bg-info/10 border border-info/20 px-4 py-3">
                  <Icon
                    name="boxicons:file-detail-filled"
                    size={20}
                    class="text-info shrink-0"
                  />
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-base-content">
                      Instructivo PDF actual cargado
                    </p>
                    <p class="text-xs text-base-content/60 font-mono truncate">
                      {app.instructionPdfPath}
                    </p>
                  </div>
                  <a
                    href={resolveUrl(`api/aplicativos/pdf/${app.id}`)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-ghost btn-xs gap-1"
                  >
                    <Icon
                      name="boxicons:arrow-in-down-square-half-filled"
                      size={14}
                    />
                    Descargar
                  </a>
                </div>
              )
            }

            <fieldset
              class="fieldset border border-base-300 rounded-box p-4 bg-base-200/30"
            >
              <FormLegend class="px-2">
                Credenciales / Metadatos Sensibles
              </FormLegend>
              <p class="text-xs text-base-content/60 mb-3 px-2">
                Agregá credenciales o información confidencial (ej. Entorno:
                Contraseña). Se almacenarán cifradas.
              </p>

              <div id="metadata-rows" class="space-y-3 px-2">
                <!-- Se poblará dinámicamente con JS -->
              </div>

              <div>
                <button
                  type="button"
                  id="btn-add-meta"
                  class="btn btn-sm btn-outline gap-2 mt-4 ml-2"
                >
                  <Icon name="boxicons:plus" size={16} />
                  Agregar credencial
                </button>
              </div>

              <input
                type="hidden"
                name="metadata"
                id="input-metadata-json"
                value={JSON.stringify(app.metadata || [])}
              />
            </fieldset>

            <FormTextarea
              id="input-description"
              name="description"
              label="Descripción (Opcional)"
              value={app.description}
              placeholder="Breve descripción del aplicativo y su uso operativo."
              rows={3}
              maxlength={150}
            />

            <div
              class="flex justify-end gap-3 pt-6 mt-2 border-t border-base-200"
            >
              <a href={resolveUrl("/admin/aplicativos")} class="btn btn-ghost"
                >Cancelar</a
              >
              <button type="submit" class="btn btn-primary gap-2">
                <Icon name="boxicons:save" size={18} />
                Guardar aplicativo
              </button>
            </div>
          </form>
        </div>
      </SectionCard>
    </div>
  </PageContainer>
  <AsyncFormScript />
</BaseLayout>

<script>
  const radios = document.querySelectorAll<HTMLInputElement>(
    'input[name="uploadType"]',
  );
  const localGroup = document.getElementById("localUploadGroup");
  const externalGroup = document.getElementById("externalUrlGroup");

  function syncGroups() {
    const selected = document.querySelector<HTMLInputElement>(
      'input[name="uploadType"]:checked',
    );
    if (!selected || !localGroup || !externalGroup) return;

    const isExternal = selected.value === "external";

    localGroup.classList.toggle("hidden", isExternal);
    externalGroup.classList.toggle("hidden", !isExternal);

    radios.forEach((radio) => {
      const label = radio.closest("label");
      if (!label) return;
      if (radio.checked) {
        label.classList.add("bg-base-100", "shadow-sm", "text-base-content");
        label.classList.remove(
          "text-base-content/50",
          "hover:text-base-content/80",
        );
      } else {
        label.classList.remove("bg-base-100", "shadow-sm", "text-base-content");
        label.classList.add(
          "text-base-content/50",
          "hover:text-base-content/80",
        );
      }
    });
  }

  radios.forEach((radio) => radio.addEventListener("change", syncGroups));

  // Manejo de Metadatos Dinámicos
  const metadataRowsContainer = document.getElementById("metadata-rows");
  const btnAddMeta = document.getElementById("btn-add-meta");
  const form = document.querySelector("form");
  const metadataJsonInput = document.getElementById(
    "input-metadata-json",
  ) as HTMLInputElement | null;

  function createMetaRow(label = "", value = "") {
    const row = document.createElement("div");
    row.className = "flex items-center gap-2 app-meta-row";
    row.innerHTML = `
      <input
        type="text"
        placeholder="Entorno / Clave (ej: Debian, MySQL)"
        class="input input-bordered input-sm flex-1 font-semibold"
        value="${label.replace(/"/g, "&quot;")}"
        required
      />
      <input
        type="text"
        placeholder="Valor / Contraseña"
        class="input input-bordered input-sm flex-1 font-mono"
        value="${value.replace(/"/g, "&quot;")}"
        required
      />
      <button type="button" class="btn btn-sm btn-circle btn-ghost text-error btn-remove-meta" title="Eliminar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M5 20a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8H5v12zM18 9v11a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V9h12zM9 5h6V4H9v1zM8 3h8v3H8V3z"/></svg>
      </button>
    `;

    row.querySelector(".btn-remove-meta")?.addEventListener("click", () => {
      row.remove();
    });

    metadataRowsContainer?.appendChild(row);
  }

  btnAddMeta?.addEventListener("click", () => {
    createMetaRow();
  });

  // Renderizar metadatos iniciales
  if (metadataJsonInput) {
    try {
      const initialMetadata = JSON.parse(metadataJsonInput.value || "[]");
      if (Array.isArray(initialMetadata)) {
        initialMetadata.forEach((meta: any) => {
          if (meta && typeof meta === "object" && meta.label) {
            createMetaRow(meta.label, meta.value || "");
          }
        });
      }
    } catch (e) {
      console.error("Error al parsear metadatos iniciales:", e);
    }
  }

  // Antes del submit del formulario, serializar a JSON
  form?.addEventListener("submit", () => {
    const rows = document.querySelectorAll(".app-meta-row");
    const metaArray: Array<{ label: string; value: string }> = [];

    rows.forEach((row) => {
      const inputs = row.querySelectorAll("input");
      const keyInput = inputs[0];
      const valInput = inputs[1];

      if (keyInput && valInput) {
        const label = keyInput.value.trim();
        const value = valInput.value.trim();
        if (label || value) {
          metaArray.push({ label, value });
        }
      }
    });

    if (metadataJsonInput) {
      metadataJsonInput.value = JSON.stringify(metaArray);
    }
  });
</script>
