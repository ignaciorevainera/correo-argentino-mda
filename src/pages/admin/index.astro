---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import QuickAccessCard from "@components/ui/QuickAccessCard.astro";
import { Icon } from "astro-icon/components";

const user = Astro.locals.user;

interface AdminModule {
  title: string;
  description: string;
  icon: string;
  iconTone: string;
  href?: string;
  active: boolean;
}

const adminModules: AdminModule[] = [
  {
    title: "Usuarios y accesos",
    description:
      "Gestión de cuentas, roles y permisos de los operadores del portal.",
    icon: "boxicons:group-filled",
    iconTone: "bg-secondary/10 text-secondary",
    href: "/admin/users",
    active: true,
  },
  {
    title: "Títulos de tickets",
    description:
      "Administración del catálogo de tipificaciones para tickets operativos.",
    icon: "boxicons:list-ul-filled",
    iconTone: "bg-primary/10 text-primary",
    active: false,
  },
  {
    title: "Directorio de oficinas",
    description:
      "Gestión centralizada del directorio operativo de oficinas y sus datos técnicos.",
    icon: "boxicons:building-filled",
    iconTone: "bg-success/10 text-success",
    href: "/admin/offices",
    active: true,
  },
  {
    title: "Contactos útiles",
    description:
      "Gestión de contactos corporativos de proveedores, teléfonos, correos y enlaces.",
    icon: "boxicons:phone-filled",
    iconTone: "bg-primary/10 text-primary",
    href: "/admin/contacts",
    active: true,
  },
  {
    title: "Enlaces y recursos",
    description:
      "Administración de las categorías y enlaces de interés general del portal.",
    icon: "boxicons:link-filled",
    iconTone: "bg-accent/10 text-accent",
    href: "/admin/recursos",
    active: true,
  },
  {
    title: "Inventario Cubics",
    description:
      "Administración del inventario de terminales y equipos del parque operativo.",
    icon: "boxicons:desktop-filled",
    iconTone: "bg-info/10 text-info",
    href: "/admin/cubics",
    active: true,
  },
  {
    title: "Catálogo de aplicativos",
    description:
      "Gestión de los aplicativos disponibles para descarga y distribución interna.",
    icon: "boxicons:grid-circle-diagonal-right-filled",
    iconTone: "bg-accent/10 text-accent",
    active: false,
  },
  {
    title: "Plantilla de operadores",
    description:
      "Configuración de turnos, modalidades y estructura del equipo de operaciones.",
    icon: "boxicons:user-id-card-filled",
    iconTone: "bg-warning/10 text-warning",
    href: "/admin/operadores",
    active: true,
  },
  {
    title: "Alertas globales",
    description:
      "Publicación y gestión de avisos críticos visibles para todos los operadores.",
    icon: "boxicons:bell-ring-filled",
    iconTone: "bg-error/10 text-error",
    active: false,
  },
  {
    title: "Logs de auditoría",
    description:
      "Registro inmutable de acciones y eventos del sistema para trazabilidad.",
    icon: "boxicons:note-book-filled",
    iconTone: "bg-neutral/10 text-neutral",
    active: false,
  },
];

const activeModules = adminModules.filter((m) => m.active);
const inactiveModules = adminModules.filter((m) => !m.active);

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith('/') ? base : base + '/';

const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith('/') ? path.slice(1) : path;
  return `${cleanBase}${cleanPath}`;
};
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      description={`Estación de mando centralizada del portal. Bienvenido, ${user.username}.`}
    />

    {
      activeModules.length > 0 && (
        <section aria-labelledby="modulos-activos-heading" class="flex flex-col gap-4">
          <h2
            id="modulos-activos-heading"
            class="text-xl font-semibold text-base-content"
          >
            Módulos activos
          </h2>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {activeModules.map((mod) => (
              <QuickAccessCard
                href={resolveUrl(mod.href!)}
                title={mod.title}
                description={mod.description}
                icon={mod.icon}
                iconTone={mod.iconTone}
              />
            ))}
          </div>
        </section>
      )
    }

    {
      inactiveModules.length > 0 && (
        <section
          aria-labelledby="modulos-desarrollo-heading"
          class="flex flex-col gap-4"
        >
          <h2
            id="modulos-desarrollo-heading"
            class="text-xl font-semibold text-base-content"
          >
            Próximamente
          </h2>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {inactiveModules.map((mod) => (
              <div
                aria-disabled="true"
                class="card card-compact bg-base-100 border border-base-300 h-full opacity-50 grayscale cursor-not-allowed select-none"
              >
                <div class="card-body gap-3 flex flex-col h-full">
                  <div class="flex items-start justify-between gap-2">
                    <div
                      aria-hidden="true"
                      class:list={[
                        "mb-1 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl",
                        mod.iconTone,
                      ]}
                    >
                      <Icon name={mod.icon} size={32} />
                    </div>
                    <span class="badge badge-neutral badge-sm mt-1 shrink-0 text-xs font-medium uppercase tracking-wide">
                      En desarrollo
                    </span>
                  </div>
                  <h3 class="card-title text-base font-semibold text-base-content">
                    {mod.title}
                  </h3>
                  <p class="text-sm text-base-content/70 flex-grow leading-relaxed">
                    {mod.description}
                  </p>
                  <div class="card-actions mt-2 justify-end">
                    <span class="flex items-center gap-1 text-sm font-medium text-base-content/40">
                      <Icon
                        name="boxicons:lock"
                        size={14}
                        aria-hidden="true"
                      />
                      No disponible
                    </span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </PageContainer>
</BaseLayout>
