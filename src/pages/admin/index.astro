---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";
import SyncDashboard from "@components/admin/SyncDashboard.astro";
import { resolveUrl } from "@lib/url";
import { can } from "@lib/roleConfig";

const user = Astro.locals.user;

interface AdminModule {
  title: string;
  icon: string;
  iconTone: string;
  href?: string;
  active: boolean;
}

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const modulesGroup1: AdminModule[] = [
  {
    title: "Usuarios",
    icon: "boxicons:group-filled",
    iconTone: "text-secondary",
    href: "/admin/usuarios",
    active: true,
  },
  {
    title: "Sugerencias y Reportes",
    icon: "boxicons:mail-open-filled",
    iconTone: "text-primary",
    href: "/admin/feedback",
    active: true,
  },
  {
    title: "Auditoría",
    icon: "boxicons:history",
    iconTone: "text-neutral",
    href: "/admin/auditoria",
    active: true,
  },
];

const modulesGroup2: AdminModule[] = [
  {
    title: "Operadores",
    icon: "boxicons:user-id-card-filled",
    iconTone: "text-error",
    href: "/admin/operadores",
    active: true,
  },
  {
    title: "Títulos",
    icon: "boxicons:list-ul-filled",
    iconTone: "text-base-content/30",
    active: false,
  },
  {
    title: "Recursos",
    icon: "boxicons:link-filled",
    iconTone: "text-accent",
    href: "/admin/recursos",
    active: true,
  },
  {
    title: "Aplicativos",
    icon: "boxicons:grid-circle-diagonal-right-filled",
    iconTone: "text-accent",
    href: "/admin/aplicativos",
    active: true,
  },
  {
    title: "Contactos",
    icon: "boxicons:phone-filled",
    iconTone: "text-primary",
    href: "/admin/contactos",
    active: true,
  },
];

const modulesGroupInvgate: AdminModule[] = [
  {
    title: "Ubicaciones InvGate",
    icon: "boxicons:map-filled",
    iconTone: "text-secondary",
    href: "/admin/invgate/ubicaciones",
    active: true,
  },
];
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      title="Administración"
      description={`Configuración y gestión centralizada del sistema. Bienvenido, ${user.username}.`}
    />

    <SyncDashboard />

    <div
      class="card bg-base-100 border border-base-300 divide-y divide-base-200 overflow-hidden"
    >
      {
        modulesGroup1.map((mod) => {
          const isLocked =
            (mod.href === "/admin/usuarios" ||
              mod.href === "/admin/auditoria" ||
              mod.href === "/admin/feedback") &&
            !can(user.role, "admin");

          if (mod.active && mod.href && !isLocked) {
            return (
              <a
                href={resolveUrl(mod.href)}
                class="flex items-center gap-4 px-6 py-5 hover:bg-base-200 transition-colors duration-150 group focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
                aria-label={`Ir a ${mod.title}`}
              >
                <Icon
                  name={mod.icon}
                  size={24}
                  class:list={["shrink-0 transition-colors", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-base md:text-lg font-semibold text-base-content">
                  {mod.title}
                </span>
                <Icon
                  name="boxicons:arrow-right-stroke-circle-filled"
                  size={22}
                  class="text-base-content/30 group-hover:text-base-content/60 transition-colors duration-150"
                  aria-hidden="true"
                />
              </a>
            );
          } else {
            return (
              <div
                aria-disabled="true"
                title={isLocked ? "Acceso restringido por rol" : "Próximamente"}
                class="flex items-center gap-4 px-6 py-5 opacity-40 cursor-not-allowed select-none"
              >
                <Icon
                  name={mod.icon}
                  size={24}
                  class:list={["shrink-0", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-base md:text-lg font-semibold text-base-content">
                  {mod.title}
                </span>
                {isLocked ? (
                  <Icon
                    name="boxicons:lock"
                    size={22}
                    class="text-base-content/60"
                    aria-hidden="true"
                  />
                ) : (
                  <span class="badge badge-ghost badge-sm font-medium">
                    Pronto
                  </span>
                )}
              </div>
            );
          }
        })
      }
    </div>

    <div
      class="card bg-base-100 border border-base-300 divide-y divide-base-200 overflow-hidden"
    >
      {
        modulesGroup2.map((mod) => {
          if (mod.active && mod.href) {
            return (
              <a
                href={resolveUrl(mod.href)}
                class="flex items-center gap-4 px-6 py-5 hover:bg-base-200 transition-colors duration-150 group focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
                aria-label={`Ir a ${mod.title}`}
              >
                <Icon
                  name={mod.icon}
                  size={24}
                  class:list={["shrink-0 transition-colors", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-base md:text-lg font-semibold text-base-content">
                  {mod.title}
                </span>
                <Icon
                  name="boxicons:arrow-right-stroke-circle-filled"
                  size={22}
                  class="text-base-content/30 group-hover:text-base-content/60 transition-colors duration-150"
                  aria-hidden="true"
                />
              </a>
            );
          } else {
            return (
              <div
                aria-disabled="true"
                title="Próximamente"
                class="flex items-center gap-4 px-6 py-5 opacity-40 cursor-not-allowed select-none"
              >
                <Icon
                  name={mod.icon}
                  size={24}
                  class:list={["shrink-0", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-base md:text-lg font-semibold text-base-content">
                  {mod.title}
                </span>
                <span class="badge badge-ghost badge-sm font-medium">
                  Pronto
                </span>
              </div>
            );
          }
        })
      }
    </div>

    <div
      class="card bg-base-100 border border-base-300 divide-y divide-base-200 overflow-hidden"
    >
      {
        modulesGroupInvgate.map((mod) => {
          const isLocked =
            mod.href === "/admin/invgate/ubicaciones" &&
            !can(user.role, "admin");

          if (mod.active && mod.href && !isLocked) {
            return (
              <a
                href={resolveUrl(mod.href)}
                class="flex items-center gap-4 px-6 py-5 hover:bg-base-200 transition-colors duration-150 group focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
                aria-label={`Ir a ${mod.title}`}
              >
                <Icon
                  name={mod.icon}
                  size={24}
                  class:list={["shrink-0 transition-colors", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-base md:text-lg font-semibold text-base-content">
                  {mod.title}
                </span>
                <Icon
                  name="boxicons:arrow-right-stroke-circle-filled"
                  size={22}
                  class="text-base-content/30 group-hover:text-base-content/60 transition-colors duration-150"
                  aria-hidden="true"
                />
              </a>
            );
          } else {
            return (
              <div
                aria-disabled="true"
                title={isLocked ? "Acceso restringido por rol" : "Próximamente"}
                class="flex items-center gap-4 px-6 py-5 opacity-40 cursor-not-allowed select-none"
              >
                <Icon
                  name={mod.icon}
                  size={24}
                  class:list={["shrink-0", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-base md:text-lg font-semibold text-base-content">
                  {mod.title}
                </span>
                {isLocked ? (
                  <Icon
                    name="boxicons:lock"
                    size={22}
                    class="text-base-content/60"
                    aria-hidden="true"
                  />
                ) : (
                  <span class="badge badge-ghost badge-sm font-medium">
                    Pronto
                  </span>
                )}
              </div>
            );
          }
        })
      }
    </div>
  </PageContainer>
</BaseLayout>
