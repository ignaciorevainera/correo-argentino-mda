---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";

const user = Astro.locals.user;

interface AdminModule {
  title: string;
  icon: string;
  iconTone: string;
  href?: string;
  active: boolean;
}

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith("/") ? path.slice(1) : path;
  return `${cleanBase}${cleanPath}`;
};

const modules: AdminModule[] = [
  {
    title: "Títulos de tickets",
    icon: "boxicons:list-ul-filled",
    iconTone: "text-base-content/30",
    active: false,
  },
  {
    title: "Contactos útiles",
    icon: "boxicons:phone-filled",
    iconTone: "text-primary",
    href: "/admin/contacts",
    active: true,
  },
  {
    title: "Enlaces y recursos",
    icon: "boxicons:link-filled",
    iconTone: "text-accent",
    href: "/admin/recursos",
    active: true,
  },
  {
    title: "Catálogo de aplicativos",
    icon: "boxicons:grid-circle-diagonal-right-filled",
    iconTone: "text-accent",
    href: "/admin/aplicativos",
    active: true,
  },
  {
    title: "Directorio de oficinas",
    icon: "boxicons:building-filled",
    iconTone: "text-success",
    href: "/admin/offices",
    active: true,
  },
  {
    title: "Inventario Cubics",
    icon: "boxicons:desktop-filled",
    iconTone: "text-info",
    href: "/admin/cubics",
    active: true,
  },
  {
    title: "Usuarios y accesos",
    icon: "boxicons:group-filled",
    iconTone: "text-secondary",
    href: "/admin/users",
    active: true,
  },
  {
    title: "Plantilla de operadores",
    icon: "boxicons:user-id-card-filled",
    iconTone: "text-warning",
    href: "/admin/operadores",
    active: true,
  },
  {
    title: "Alertas globales",
    icon: "boxicons:bell-ring-filled",
    iconTone: "text-base-content/30",
    active: false,
  },
  {
    title: "Logs de auditoría",
    icon: "boxicons:note-book-filled",
    iconTone: "text-base-content/30",
    active: false,
  },
];
---

<BaseLayout>
  <PageContainer>
    <PageHeader
      title="Administración"
      description={`Configuración y gestión centralizada del sistema. Bienvenido, ${user.username}.`}
    />

    <div class="card bg-base-100 border border-base-300 divide-y divide-base-200 overflow-hidden">
      {
        modules.map((mod) => {
          const isLocked = mod.href === "/admin/users" && user.role !== "admin";
          
          if (mod.active && mod.href && !isLocked) {
            return (
              <a
                href={resolveUrl(mod.href)}
                class="flex items-center gap-3 px-4 py-3 hover:bg-base-200 transition-colors duration-150 group focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
                aria-label={`Ir a ${mod.title}`}
              >
                <Icon
                  name={mod.icon}
                  size={18}
                  class:list={["shrink-0 transition-colors", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-sm font-medium text-base-content">
                  {mod.title}
                </span>
                <Icon
                  name="boxicons:arrow-right-stroke-circle-filled"
                  size={16}
                  class="text-base-content/30 group-hover:text-base-content/60 transition-colors duration-150"
                  aria-hidden="true"
                />
              </a>
            );
          } else {
            return (
              <div
                aria-disabled="true"
                title={isLocked ? "Acceso restringido por rol" : "Próximamente"}
                class="flex items-center gap-3 px-4 py-3 opacity-40 cursor-not-allowed select-none"
              >
                <Icon
                  name={mod.icon}
                  size={18}
                  class:list={["shrink-0", mod.iconTone]}
                  aria-hidden="true"
                />
                <span class="flex-1 text-sm font-medium text-base-content">
                  {mod.title}
                </span>
                {isLocked ? (
                  <Icon name="boxicons:lock" size={16} class="text-base-content/60" aria-hidden="true" />
                ) : (
                  <span class="badge badge-ghost badge-xs font-medium">
                    Pronto
                  </span>
                )}
              </div>
            );
          }
        })
      }
    </div>
  </PageContainer>
</BaseLayout>
