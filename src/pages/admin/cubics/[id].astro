---
import { db } from "@db/index";
import { cubics, agents, cubicAssignments } from "@db/schema";
import { eq, asc } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";


const user = Astro.locals.user;
if (user.role !== "admin") return Astro.redirect("/login");

const { id } = Astro.params;
const isNew = id === "new";
let successMsg = "";
let errorMsg = "";


if (Astro.request.method === "POST") {
  try {
    const fd = await Astro.request.formData();

    const cubicData = {
      name: fd.get("name")?.toString().trim() ?? "",
      ip: fd.get("ip")?.toString().trim() || null,
    };

    if (!cubicData.name) {
      errorMsg = "El nombre de red es obligatorio.";
    } else {
      let cubicId: number;

      if (isNew) {
        const [created] = await db
          .insert(cubics)
          .values(cubicData)
          .returning({ id: cubics.id });
        cubicId = created.id;
      } else {
        cubicId = Number(id);
        await db
          .update(cubics)
          .set(cubicData)
          .where(eq(cubics.id, cubicId));
      }

      
      await db
        .delete(cubicAssignments)
        .where(eq(cubicAssignments.cubicId, cubicId));

      const aShifts = fd.getAll("assign_shift");
      const aNames = fd.getAll("assign_agent_name");
      const aInitials = fd.getAll("assign_agent_initials");

      for (let i = 0; i < aShifts.length; i++) {
        const shift = aShifts[i]?.toString().trim();
        const agentName = aNames[i]?.toString().trim();
        const agentInitials =
          aInitials[i]?.toString().trim().toUpperCase() || null;

        if (!shift || !agentName) continue;

        
        let agentId: number;
        const existing = await db
          .select({ id: agents.id })
          .from(agents)
          .where(eq(agents.name, agentName))
          .get();

        if (existing) {
          agentId = existing.id;
          
          if (agentInitials) {
            await db
              .update(agents)
              .set({ avatarInitials: agentInitials })
              .where(eq(agents.id, agentId));
          }
        } else {
          const [created] = await db
            .insert(agents)
            .values({ name: agentName, avatarInitials: agentInitials })
            .returning({ id: agents.id });
          agentId = created.id;
        }

        try {
          await db.insert(cubicAssignments).values({
            cubicId,
            agentId,
            shift,
          });
        } catch (e: any) {
          
        }
      }

      if (isNew) {
        return Astro.redirect(`/admin/cubics/${cubicId}`);
      }
      successMsg = "Cubic actualizado con éxito.";
    }
  } catch (e: any) {
    errorMsg = e.message?.includes("UNIQUE")
      ? "Ya existe un cubic con ese nombre de red."
      : "Error al guardar el cubic.";
  }
}


type CubicRecord = {
  id: number;
  name: string;
  ip: string | null;
  status: string;
  lastPing: string | null;
  assignments: {
    shift: string;
    agent: { id: number; name: string; avatarInitials: string | null };
  }[];
};

let cubic: CubicRecord | null = null;

if (!isNew) {
  const result = await db.query.cubics.findFirst({
    where: eq(cubics.id, Number(id)),
    with: {
      assignments: {
        with: {
          agent: true,
        },
      },
    },
  });
  if (!result) return Astro.redirect("/admin/cubics");
  cubic = result as unknown as CubicRecord;
}

const pageTitle = isNew ? "Nuevo cubic" : `Editar: ${cubic!.name}`;

const shiftOptions = [
  { value: "morning", label: "Mañana" },
  { value: "afternoon_night", label: "Tarde / Noche" },
];
---

<BaseLayout title={`${pageTitle} | Portal Mesa de Ayuda`}>
  <PageContainer>

    {/* ── Breadcrumb / Volver ── */}
    <div class="flex items-center gap-2 text-sm text-base-content/60">
      <a href="/admin/cubics" class="flex items-center gap-1.5 hover:text-base-content transition-colors">
        <Icon name="boxicons:chevron-left" size={16} />
        Gestión de cubics
      </a>
      <span>/</span>
      <span class="text-base-content font-medium truncate">{pageTitle}</span>
    </div>

    <PageHeader
      title={pageTitle}
      description={isNew ? "Completá los datos para registrar un nuevo ordenador." : `Estado: ${cubic!.status} · IP: ${cubic!.ip ?? "sin asignar"}`}
    />

    {/* Feedback */}
    {errorMsg && (
      <div role="alert" class="alert alert-error alert-soft text-sm">
        <Icon name="boxicons:error-circle-filled" size={18} class="shrink-0" />
        <span>{errorMsg}</span>
      </div>
    )}
    {successMsg && (
      <div role="alert" class="alert alert-success alert-soft text-sm">
        <Icon name="boxicons:check-circle-filled" size={18} class="shrink-0" />
        <span>{successMsg}</span>
      </div>
    )}

    <form
      method="POST"
      id="cubic-form"
      onsubmit="return confirm('¿Estás seguro de que deseas aplicar estas modificaciones sobre el Cubic?');"
      class="space-y-4"
    >
      {/* ── Card: Datos técnicos del equipo ── */}
      <section class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body gap-4 p-5">
          <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
            <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary">
              <Icon name="boxicons:desktop-filled" size={15} />
            </span>
            Datos técnicos del equipo
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs">Nombre de red *</legend>
              <input
                type="text"
                name="name"
                required
                value={cubic?.name ?? ""}
                placeholder="b1842zacw2999.correo.local"
                autocomplete="off"
                class="input input-sm w-full font-mono"
              />
              <p class="fieldset-label text-xs text-base-content/50">
                Hostname FQDN del equipo en la red corporativa.
              </p>
            </fieldset>

            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs">Dirección IP</legend>
              <input
                type="text"
                name="ip"
                value={cubic?.ip ?? ""}
                placeholder="10.254.59.62"
                autocomplete="off"
                class="input input-sm w-full font-mono"
              />
              <p class="fieldset-label text-xs text-base-content/50">
                IPv4 asignada al equipo. Opcional.
              </p>
            </fieldset>
          </div>
        </div>
      </section>

      {/* ── Card: Asignación de turnos ── */}
      <section class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body gap-3 p-5">
          <div class="flex items-center justify-between">
            <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
              <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warning/10 text-warning">
                <Icon name="boxicons:group-filled" size={15} />
              </span>
              Asignación de turnos
            </h2>
            <button
              type="button"
              id="btn-add-assignment"
              class="btn btn-ghost btn-xs text-warning gap-1"
            >
              <Icon name="boxicons:plus" size={14} />
              Agregar
            </button>
          </div>

          <div id="assignments-container" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {(cubic?.assignments ?? []).map((a) => (
              <div class="assignment-row relative rounded-lg bg-base-200/50 p-4 border border-base-300">
                <button
                  type="button"
                  class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
                  aria-label="Quitar asignación"
                >
                  <Icon name="boxicons:trash" size={18} />
                </button>

                <div class="space-y-3 pr-6">
                  <fieldset class="fieldset gap-1">
                    <legend class="fieldset-legend text-xs font-bold">Turno</legend>
                    <select name="assign_shift" class="select select-sm w-full">
                      {shiftOptions.map((opt) => (
                        <option value={opt.value} selected={a.shift === opt.value}>
                          {opt.label}
                        </option>
                      ))}
                    </select>
                  </fieldset>

                  <fieldset class="fieldset gap-1">
                    <legend class="fieldset-legend text-xs font-bold">Nombre del operador</legend>
                    <input
                      type="text"
                      name="assign_agent_name"
                      value={a.agent.name}
                      class="input input-sm w-full"
                      placeholder="Ana Rojas"
                    />
                  </fieldset>

                  <fieldset class="fieldset gap-1">
                    <legend class="fieldset-legend text-xs font-bold">Iniciales avatar</legend>
                    <input
                      type="text"
                      name="assign_agent_initials"
                      value={a.agent.avatarInitials ?? ""}
                      maxlength={3}
                      class="input input-sm w-20 text-center font-bold uppercase tracking-widest"
                      placeholder="AR"
                    />
                  </fieldset>
                </div>
              </div>
            ))}
          </div>
          {(cubic?.assignments ?? []).length === 0 && (
            <p class="text-xs text-base-content/40 text-center py-1">Sin operadores asignados.</p>
          )}
        </div>
      </section>

      {/* ── Acciones ── */}
      <div class="flex items-center justify-between gap-3 pt-1">
        <a href="/admin/cubics" class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10">
          <Icon name="boxicons:arrow-left-filled" size={16} />
          Volver al listado
        </a>
        <button type="submit" class="btn btn-secondary btn-sm gap-2">
          <Icon name="boxicons:save-filled" size={16} />
          {isNew ? "Crear cubic" : "Guardar cambios"}
        </button>
      </div>
    </form>
  </PageContainer>
</BaseLayout>

{/* ── Template dinámico para nueva asignación ── */}
<template id="tpl-assignment-row">
  <div class="assignment-row relative rounded-lg bg-base-200/50 p-4 border border-base-300">
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
      aria-label="Quitar asignación"
    >
      <Icon name="boxicons:trash" size={18} />
    </button>

    <div class="space-y-3 pr-6">
      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Turno</legend>
        <select name="assign_shift" class="select select-sm w-full">
          <option value="morning">Mañana</option>
          <option value="afternoon_night">Tarde / Noche</option>
        </select>
      </fieldset>

      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Nombre del operador</legend>
        <input
          type="text"
          name="assign_agent_name"
          class="input input-sm w-full"
          placeholder="Ana Rojas"
        />
      </fieldset>

      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Iniciales avatar</legend>
        <input
          type="text"
          name="assign_agent_initials"
          maxlength="3"
          class="input input-sm w-20 text-center font-bold uppercase tracking-widest"
          placeholder="AR"
        />
      </fieldset>
    </div>
  </div>
</template>

<script>
  function initDynamicRows() {
    const container = document.getElementById("assignments-container")!;
    const tpl = document.getElementById(
      "tpl-assignment-row",
    ) as HTMLTemplateElement;

    document
      .getElementById("btn-add-assignment")
      ?.addEventListener("click", () => {
        container.appendChild(tpl.content.cloneNode(true));
        bindRemoveButtons();
      });

    function bindRemoveButtons() {
      container
        .querySelectorAll<HTMLButtonElement>(".remove-row-btn")
        .forEach((btn) => {
          btn.onclick = () => btn.closest(".assignment-row")?.remove();
        });
    }

    bindRemoveButtons();
  }

  initDynamicRows();
</script>
