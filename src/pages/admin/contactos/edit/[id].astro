---
import { db } from "@db/index";
import { providerContacts, contactCategories } from "@db/schema";
import { eq, asc } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import FormTextarea from "@components/ui/forms/FormTextarea.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { logAdminAction } from "@lib/auditLogger";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import SectionCard from "@components/ui/SectionCard.astro";
import FormLegend from "@components/ui/forms/FormLegend.astro";
import { resolveUrl } from "@lib/url";
import { redirectWithToast } from "@lib/api/redirectWithToast";
import { toastResponse } from "@lib/api/toastResponse";

const { id } = Astro.params;

let errorMsg = "";

const allCategories = await db
  .select()
  .from(contactCategories)
  .orderBy(asc(contactCategories.title));

let contact: typeof providerContacts.$inferSelect | null = null;

if (id) {
  const [result] = await db
    .select()
    .from(providerContacts)
    .where(eq(providerContacts.id, Number(id)));

  if (!result) return Astro.redirect(resolveUrl("/admin/contactos"));
  contact = {
    ...result,
    categoryId: result.categoryId ? String(result.categoryId) : "",
  } as any;
}

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  try {
    const fd = await Astro.request.formData();

    const categoryIdRaw = fd.get("categoryId")?.toString();
    const categoryId = categoryIdRaw && !isNaN(Number(categoryIdRaw)) ? Number(categoryIdRaw) : null;
    const provider = fd.get("provider")?.toString().trim() ?? "";
    const service = fd.get("service")?.toString().trim() ?? "";

    const phones =
      fd
        .get("phones")
        ?.toString()
        .split("\n")
        .map((s) => s.trim())
        .filter(Boolean) ?? [];

    const emails =
      fd
        .get("emails")
        ?.toString()
        .split("\n")
        .map((s) => s.trim())
        .filter(Boolean) ?? [];

    const urls =
      fd
        .get("urls")
        ?.toString()
        .split("\n")
        .map((s) => s.trim())
        .filter(Boolean)
        .map((line) => {
          const parts = line.split(",");
          if (parts.length >= 2) {
            const label = parts[0].trim();
            const url = parts.slice(1).join(",").trim();
            return { label, url };
          }
          return { label: "Enlace", url: line };
        }) ?? [];

    if (!provider || !service) {
      errorMsg = "Proveedor y servicio son obligatorios.";
    } else {
      if (id) {
        await db
          .update(providerContacts)
          .set({
            categoryId,
            provider,
            service,
            phones,
            emails,
            urls,
          })
          .where(eq(providerContacts.id, Number(id)));
        const oldName = contact ? `${contact.provider} - ${contact.service}` : "";
        const newName = `${provider} - ${service}`;
        if (oldName && oldName !== newName) {
          await logAdminAction(Astro.locals.user?.username || 'Sistema', `Actualizó el contacto de "${oldName}" a "${newName}"`);
        } else {
          await logAdminAction(Astro.locals.user?.username || 'Sistema', `Actualizó el contacto "${newName}"`);
        }
      }

      const toastMessage = "Contacto actualizado con éxito.";
      if (isAjax) {
        return toastResponse({ success: true, message: toastMessage, redirectUrl: resolveUrl("/admin/contactos") });
      }
      return redirectWithToast("/admin/contactos", toastMessage);
    }
  } catch (e: any) {
    if (isAjax) {
      return toastResponse({ success: false, error: e.message || "Error al guardar el contacto." });
    }
    errorMsg = "Error al guardar el contacto.";
  }
}

const pageTitle = `Editar: ${contact!.provider}`;

const phonesText = contact?.phones?.join("\n") ?? "";
const emailsText = contact?.emails?.join("\n") ?? "";
const urlsText =
  contact?.urls
    ?.map((u) => (u.label ? `${u.label}, ${u.url}` : u.url))
    .join("\n") ?? "";
---

<BaseLayout title={pageTitle}>
  <PageContainer>
    <div class="flex items-center gap-2 text-sm text-base-content/60">
      <a
        href={resolveUrl("/admin/contactos")}
        class="flex items-center gap-1.5 hover:text-base-content transition-colors"
      >
        <Icon name="boxicons:chevron-left" size={16} />
        Contactos
      </a>
      <span>/</span>
      <span class="text-base-content font-medium truncate">{pageTitle}</span>
    </div>

    <PageHeader
      title={pageTitle}
      description={`ID de contacto: ${contact!.id}`}
    />

    {
      errorMsg && (
        <script is:inline define:vars={{ errorMsg }}>
          window.addEventListener('load', () => window.showToast?.(errorMsg, "alert-error"));
        </script>
      )
    }

    <form
      method="POST"
      id="contact-form"
      data-async-form
      onsubmit="return confirm('¿Estás seguro de que deseas guardar estas modificaciones?');"
      class="space-y-4"
    >
      <SectionCard class="shadow-md">
          <h2
            class="flex items-center gap-2 text-sm font-semibold text-base-content"
          >
            <span
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
            >
              <Icon name="boxicons:phone-filled" size={15} />
            </span>
            Datos del contacto
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-3">
              <FormField
                id="input-provider"
                name="provider"
                label="Proveedor"
                required
                value={contact?.provider ?? ""}
                placeholder="ej: CORASA"
                autocomplete="off"
                inputClass="input-sm font-semibold"
              />

              <FormField
                id="input-service"
                name="service"
                label="Servicio"
                required
                value={contact?.service ?? ""}
                placeholder="ej: Mesa de Ayuda"
                autocomplete="off"
                inputClass="input-sm"
              />

              <SelectField
                id="select-categoryId"
                name="categoryId"
                label="Categoría"
                selectClass="select-sm"
              >
                <option value="" selected={!contact?.categoryId}>
                  Ninguna
                </option>
                {
                  allCategories.map((cat) => (
                    <option
                      value={cat.id}
                      selected={contact?.categoryId ? Number(cat.id) === Number(contact.categoryId) : false}
                    >
                      {cat.title}
                    </option>
                  ))
                }
              </SelectField>
            </div>

            <div class="space-y-3">
              <FormTextarea
                id="input-phones"
                name="phones"
                label="Teléfonos (uno por línea)"
                textareaClass="textarea-sm font-mono text-xs"
                value={phonesText}
                rows={2}
                placeholder="ej: 6316-1111
0810-777-7787"
              />
              <FormTextarea
                id="input-emails"
                name="emails"
                label="Correos electrónicos (uno por línea)"
                textareaClass="textarea-sm font-mono text-xs"
                value={emailsText}
                rows={2}
                placeholder="ej: soporte@correo.com.ar"
              />
              <FormTextarea
                id="input-urls"
                name="urls"
                label="Enlaces web (uno por línea como: Etiqueta, URL)"
                textareaClass="textarea-sm font-mono text-xs"
                value={urlsText}
                rows={2}
                placeholder="ej: Portal, http://sm.correo.local
http://www.google.com"
              />
            </div>
          </div>
      </SectionCard>

      <div class="flex items-center justify-between gap-3 pt-1">
        <a
          href={resolveUrl("/admin/contactos")}
          class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10"
        >
          <Icon name="boxicons:arrow-left-filled" size={16} />
          Volver al listado
        </a>
        <button type="submit" class="btn btn-secondary btn-sm gap-2">
          <Icon name="boxicons:save-filled" size={16} />
          Guardar cambios
        </button>
      </div>
    </form>
  </PageContainer>
  <AsyncFormScript />
</BaseLayout>
