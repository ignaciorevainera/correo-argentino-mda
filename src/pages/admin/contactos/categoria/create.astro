---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { contactCategories } from "@db/schema";
import { logAdminAction } from "@lib/auditLogger";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import { resolveUrl } from "@lib/url";
import SectionCard from "@components/ui/SectionCard.astro";
import FormLegend from "@components/ui/forms/FormLegend.astro";

let errorMsg = "";
let category = { id: "", title: "", icon: "", tone: "primary" };

const PREDEFINED_ICONS = [
  { value: "boxicons:star-filled", label: "Estrella (Destacados)" },
  { value: "boxicons:file-detail-filled", label: "Documento (Normativas)" },
  { value: "boxicons:group-filled", label: "Grupo (Usuarios / RRHH)" },
  { value: "boxicons:building-filled", label: "Edificio (Intranet)" },
  { value: "boxicons:chip-filled", label: "Microchip (Hardware)" },
  { value: "boxicons:spanner-filled", label: "Llave (Herramientas)" },
  { value: "boxicons:check-shield-filled", label: "Escudo (Seguridad / VPN)" },
  { value: "boxicons:link-filled", label: "Enlace (Portales / Accesos)" },
  { value: "boxicons:help-circle-filled", label: "Ayuda (Soporte / FAQ)" },
  { value: "boxicons:calendar-filled", label: "Calendario (Cronograma)" },
];

const iconsList = [...PREDEFINED_ICONS];

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  try {
    const formData = await Astro.request.formData();
    const title = formData.get("title")?.toString().trim();
    const icon = formData.get("icon")?.toString().trim();

    if (!title || !icon) {
      throw new Error("El título y el icono son obligatorios.");
    }

    if (title.toLowerCase() === "sin categoría" || title.toLowerCase() === "sin categoria") {
      throw new Error("No se puede crear una categoría con este nombre reservado.");
    }

    const tone = formData.get("tone")?.toString().trim() || "primary";

    await db.insert(contactCategories).values({
      title,
      icon,
      tone,
    });
    await logAdminAction(Astro.locals.user?.username || 'Sistema', `Creó la categoría de contactos "${title}"`);

    const successMsg = "Categoría creada con éxito.";
    if (isAjax) {
      return new Response(JSON.stringify({ success: true, message: successMsg, redirectUrl: resolveUrl("/admin/contactos") }), { status: 200, headers: { "Content-Type": "application/json" } });
    }
    return Astro.redirect(resolveUrl(`/admin/contactos?toast_msg=${encodeURIComponent(successMsg)}&toast_type=success`));
  } catch (error: any) {
    console.error("DEBUG ERROR CREATE CATEGORIA:", error);
    if (isAjax) {
      return new Response(JSON.stringify({ success: false, error: error.message || "Error al guardar la categoría." }), { status: 400, headers: { "Content-Type": "application/json" } });
    }
    errorMsg = error.message || "Error al guardar la categoría.";
  }
}
---

<BaseLayout title="Nueva categoría de contactos">
  <PageContainer>
    <div class="max-w-2xl mx-auto py-4 sm:py-8">
      <div class="flex items-center gap-2 text-sm text-base-content/60 mb-4">
        <a
          href={resolveUrl("/admin/contactos")}
          class="flex items-center gap-1.5 hover:text-base-content transition-colors"
        >
          <Icon name="boxicons:chevron-left" size={16} />
          Contactos
        </a>
        <span>/</span>
        <span class="text-base-content font-medium truncate">Nueva categoría</span>
      </div>

      <PageHeader
        title="Nueva categoría de contactos"
        description="Definí cómo se agruparán y visualizarán los contactos."
      />

      {
        errorMsg && (
          <script is:inline define:vars={{ errorMsg }}>
            const triggerToast = () => {
              if (window.showToast) {
                window.showToast(errorMsg, "alert-error");
              } else {
                setTimeout(triggerToast, 100);
              }
            };
            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", triggerToast);
            } else {
              triggerToast();
            }
          </script>
        )
      }

      <SectionCard>
        <div class="p-6 sm:p-8">
          <form method="POST" data-async-form class="space-y-5">
            <div class="grid grid-cols-1 gap-y-5">
              <FormField
                id="input-title"
                name="title"
                label="Título de la Categoría"
                required
                value={category.title}
                placeholder="Ej: Proveedores de red"
                inputClass="font-medium"
                autofocus
              />

              <SelectField
                id="select-icon"
                name="icon"
                label="Ícono Visual"
                selectClass="font-medium"
                options={iconsList}
                value="boxicons:star-filled"
              />

              <fieldset class="fieldset">
                <FormLegend class="mb-2"
                  >Color de Identificación (Tono)</FormLegend
                >
                <div
                  class="flex flex-col gap-2.5 bg-base-200/50 p-4 rounded-xl border border-base-300 w-full"
                >
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="primary"
                      class="radio radio-primary radio-sm"
                      checked
                    />
                    <span class="text-sm font-medium">Amarillo (Principal)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="secondary"
                      class="radio radio-secondary radio-sm"
                    />
                    <span class="text-sm font-medium">Azul (Secundario)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="accent"
                      class="radio radio-accent radio-sm"
                    />
                    <span class="text-sm font-medium">Celeste (Acento)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="success"
                      class="radio radio-success radio-sm"
                    />
                    <span class="text-sm font-medium">Verde (Éxito)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="info"
                      class="radio radio-info radio-sm"
                    />
                    <span class="text-sm font-medium">Azul claro (Info)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="warning"
                      class="radio radio-warning radio-sm"
                    />
                    <span class="text-sm font-medium">Naranja (Alerta)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="error"
                      class="radio radio-error radio-sm"
                    />
                    <span class="text-sm font-medium">Rojo (Error)</span>
                  </label>

                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      type="radio"
                      name="tone"
                      value="neutral"
                      class="radio radio-neutral radio-sm"
                    />
                    <span class="text-sm font-medium">Gris (Neutral)</span>
                  </label>
                </div>
              </fieldset>
            </div>

            <div
              class="flex justify-end gap-3 pt-6 mt-2 border-t border-base-200"
            >
              <a href={resolveUrl("/admin/contactos")} class="btn btn-ghost"
                >Cancelar</a
              >
              <button type="submit" class="btn btn-primary gap-2">
                <Icon name="boxicons:save" size={18} />
                Guardar Categoría
              </button>
            </div>
          </form>
        </div>
      </SectionCard>
    </div>
  </PageContainer>
  <AsyncFormScript />
</BaseLayout>
