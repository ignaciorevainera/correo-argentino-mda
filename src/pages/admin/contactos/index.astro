---
import { db } from "@db/index";
import { providerContacts } from "@db/schema";
import { eq } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import { logAdminAction } from "@lib/auditLogger";
import AdminContactsContent from "@components/admin/contacts/AdminContactsContent.astro";
import AdminContactsSkeleton from "@components/admin/contacts/AdminContactsSkeleton.astro";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!user || !["admin", "supervisor", "team_leader"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "delete_contact") {
    const contactId = Number(formData.get("contactId"));
    if (contactId) {
      try {
        const [deleted] = await db
          .delete(providerContacts)
          .where(eq(providerContacts.id, contactId))
          .returning({
            provider: providerContacts.provider,
            service: providerContacts.service,
          });

        if (deleted) {
          const successMsg = `Contacto "${deleted.provider} - ${deleted.service}" eliminado con éxito.`;
          await logAdminAction(Astro.locals.user?.username || 'Sistema', `Eliminó el contacto "${deleted.provider} - ${deleted.service}"`);
          return Astro.redirect(`${cleanBase}admin/contactos?toast_msg=${encodeURIComponent(successMsg)}&toast_type=success`);
        } else {
          return Astro.redirect(`${cleanBase}admin/contactos?toast_msg=${encodeURIComponent("El contacto indicado no existe.")}&toast_type=error`);
        }
      } catch (e) {
        return Astro.redirect(`${cleanBase}admin/contactos?toast_msg=${encodeURIComponent("Error al eliminar el contacto.")}&toast_type=error`);
      }
    }
  }
}
---

<BaseLayout>
  <AdminContactsContent server:defer>
    <AdminContactsSkeleton slot="fallback" />
  </AdminContactsContent>
</BaseLayout>
