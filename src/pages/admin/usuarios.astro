---
import { db } from "@db/index";
import { users } from "@db/schema";
import { eq } from "drizzle-orm";
import { passwordSchema, hashPassword } from "@lib/security";
import BaseLayout from "@layouts/BaseLayout.astro";
import { logAdminFromAstro } from "@lib/auditLogger";
import AdminUsersContent from "@components/admin/users/AdminUsersContent.astro";
import AdminUsersSkeleton from "@components/admin/users/AdminUsersSkeleton.astro";

let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const isAjax = Astro.request.headers.get('accept')?.includes('application/json');
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString() ?? "create";

  if (action === "create") {
    const username = formData.get("username")?.toString().trim().toLowerCase();
    const password = formData.get("password")?.toString();
    const role = formData.get("role")?.toString();

    if (username && password && role) {
      const pwdValidation = passwordSchema.safeParse(password);
      if (!pwdValidation.success) {
        errorMsg = pwdValidation.error.issues[0].message;
      } else {
        try {
          const hashedPassword = await hashPassword(password);
          await db.insert(users).values({
            username,
            password: hashedPassword,
            role: role as any,
          });
          successMsg = `Usuario "${username}" creado con éxito.`;
          await logAdminFromAstro(Astro.locals,
            `Creó al usuario "${username}" con rol ${role}`,
          );
        } catch (e) {
          errorMsg = "Error: El nombre de usuario ya existe.";
        }
      }
    }
  }

  if (action === "reset-password") {
    const userId = Number(formData.get("userId"));
    const newPassword = formData.get("newPassword")?.toString();
    if (userId && newPassword) {
      const pwdValidation = passwordSchema.safeParse(newPassword);
      if (!pwdValidation.success) {
        errorMsg = pwdValidation.error.issues[0].message;
      } else {
        try {
          const [targetUser] = await db
            .select({ username: users.username })
            .from(users)
            .where(eq(users.id, userId));
          const targetUsername = targetUser?.username || "desconocido";

          const hashedPassword = await hashPassword(newPassword);
          await db
            .update(users)
            .set({ password: hashedPassword })
            .where(eq(users.id, userId));
          successMsg = "Contraseña actualizada con éxito.";
          await logAdminFromAstro(Astro.locals,
            `Blanqueó la contraseña de "${targetUsername}"`,
          );
        } catch (e) {
          errorMsg = "Error al actualizar la contraseña.";
        }
      }
    }
  }

  if (action === "rename-username") {
    const userId = Number(formData.get("userId"));
    const newUsername = formData
      .get("newUsername")
      ?.toString()
      .trim()
      .toLowerCase();
    if (userId && newUsername) {
      try {
        const [existing] = await db
          .select({ username: users.username })
          .from(users)
          .where(eq(users.id, userId));
        const oldUsername = existing?.username || "desconocido";

        await db
          .update(users)
          .set({ username: newUsername })
          .where(eq(users.id, userId));
        successMsg = `Usuario renombrado a "${newUsername}" con éxito.`;
        await logAdminFromAstro(Astro.locals,
          `Renombró al usuario de "${oldUsername}" a "${newUsername}"`,
        );
      } catch (e) {
        errorMsg = "Error: Ese nombre de usuario ya existe.";
      }
    }
  }

  if (action === "change-role") {
    const userId = Number(formData.get("userId"));
    const newRole = formData.get("newRole")?.toString();
    if (userId && newRole) {
      try {
        const [targetUser] = await db
          .select({ username: users.username, role: users.role })
          .from(users)
          .where(eq(users.id, userId));
        const targetUsername = targetUser?.username || "desconocido";
        const oldRole = targetUser?.role || "desconocido";

        await db
          .update(users)
          .set({ role: newRole as any })
          .where(eq(users.id, userId));
        successMsg = "Rol de usuario actualizado con éxito.";
        await logAdminFromAstro(Astro.locals,
          `Cambió el rol de "${targetUsername}" de "${oldRole}" a "${newRole}"`,
        );
      } catch (e) {
        errorMsg = "Error al actualizar el rol de usuario.";
      }
    }
  }

  if (isAjax) {
    if (errorMsg) {
      return new Response(JSON.stringify({ success: false, error: errorMsg }), { status: 400, headers: {"Content-Type": "application/json"} });
    }
    // For forms in modals, we probably want them to reload to see the updated table, so redirectUrl: Astro.url.href
    return new Response(JSON.stringify({ success: true, message: successMsg, redirectUrl: Astro.url.href }), { status: 200, headers: {"Content-Type": "application/json"} });
  }
}
---

<BaseLayout>
  <AdminUsersContent server:defer successMsg={successMsg} errorMsg={errorMsg}>
    <AdminUsersSkeleton slot="fallback" />
  </AdminUsersContent>
</BaseLayout>
