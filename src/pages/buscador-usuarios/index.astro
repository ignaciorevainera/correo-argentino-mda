          if (copyTerminalBtn) copyTerminalBtn.innerHTML = originalIcon;
        }, 2000);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && document.activeElement?.tagName !== "INPUT") {
        e.preventDefault();
        searchInput?.focus();
      }
    });

    searchInput?.addEventListener("input", handleSearch);
    clearSearchBtn?.addEventListener("click", () => {
      if (searchInput) searchInput.value = "";
      currentUsers = [];
      displayResults([]);
    });

    btnSearchManager?.addEventListener("click", () => {
      const managerName = termInfoManager?.textContent;
      if (managerName && managerName !== "-" && managerName !== "No especificado") {
        closeTerminalModal();
        if (searchInput) {
          searchInput.value = managerName;
          handleSearch();
        }
      }
    });

    init();
  </script>
</BaseLayout>
