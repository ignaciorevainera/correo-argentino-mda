          });
        } else if (netUserBtn) {
          netUserBtn.classList.add("hidden");
        }

        fragment.appendChild(clone);
      });
      resultsGrid.appendChild(fragment);
    }

    async function copyToClipboard(text: string, btn: HTMLElement) {
      if (!text) return;
      const copied = await copyText(text);
      if (!copied) return;

      const tooltip = btn.closest(".tooltip") as HTMLElement | null;
      const originalTip = tooltip?.getAttribute("data-tip");
      const originalIcon = btn.innerHTML;

      if (tooltip) {
        tooltip.setAttribute("data-tip", "¡Copiado!");
        tooltip.classList.replace("tooltip-neutral", "tooltip-success");
        tooltip.classList.add("tooltip-open"); 
      }

      btn.innerHTML =
        '<svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-success animate-in zoom-in duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';

      setTimeout(() => {
        if (tooltip) {
          tooltip.setAttribute("data-tip", originalTip || "");
          tooltip.classList.replace("tooltip-success", "tooltip-neutral");
          tooltip.classList.remove("tooltip-open");
        }
        btn.innerHTML = originalIcon;
      }, 2000);
    }

    let searchTimeout: number;
    async function handleSearch() {
      if (!isLoaded || !searchInput) return;
      const query = (searchInput.value || "").trim();

      if (query === "") {
        displayResults([]);
        if (statusText)
          statusText.textContent = `Listo para buscar.`;
        return;
      }

      window.clearTimeout(searchTimeout);
      loadingIndicator?.classList.remove("hidden");

      searchTimeout = window.setTimeout(async () => {
        try {
          const token = "mda_live_bf9d7a2e8c5643190ab76d2e1f48c590";
          const url = `http://mda.correo.local/api_mda_find_extension/get_users.php?search=${encodeURIComponent(query)}`;
          const response = await fetch(url, {
            headers: {
              "X-API-Key": token
            }
          });
          
          if (!response.ok) throw new Error("API error");
          const data = await response.json();
          
          const mappedResults = (data.results || []).map((u: any) => ({
            nombre: u.fullname,
            dni: u.dni,
            usuario: u.username,
            interno: u.interno,
            telefono: u.telefono,
            email: u.username ? `${u.username}@correoargentino.com.ar` : null,
            sucursal: u.sucursal
          }));

          currentUsers = mappedResults;
          displayResults(currentUsers);
          if (resultsTitle?.firstChild)
            resultsTitle.firstChild.textContent = "Resultados ";
          loadingIndicator?.classList.add("hidden");
          if (statusText)
            statusText.textContent = `${mappedResults.length} encontrados`;
        } catch (error) {
          console.error(error);
          loadingIndicator?.classList.add("hidden");
          if (statusText)
            statusText.textContent = "Error al conectar con la base de datos";
        }
      }, 300);
    }

    // Funciones del modal de edición
    function openEditModal(user: any) {
      if (!editModal || !editFullname || !editDni || !editInterno || !editTelefono) return;

      editFullname.value = user.nombre || "";
      editDni.value = user.dni || "";
      editInterno.value = user.interno || "";
      editTelefono.value = user.telefono || "";

      editModal.showModal();
    }

    function closeEditModal() {
      if (editModal) {
        editModal.close();
      }
      if (editForm) {
        editForm.reset();
      }
    }

    closeEditModalBtn?.addEventListener("click", closeEditModal);

    editForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!editDni || !editInterno || !editTelefono || !saveEditBtn || !saveBtnSpinner) return;

      const dni = editDni.value;
      const interno = editInterno.value.trim();
      const telefono = editTelefono.value.trim();

      saveEditBtn.disabled = true;
      saveBtnSpinner.classList.remove("hidden");

      try {
        const token = "mda_live_bf9d7a2e8c5643190ab76d2e1f48c590";
        const url = `http://mda.correo.local/api_mda_find_extension/get_users.php`;

        const response = await fetch(url, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-API-Key": token
          },
          body: JSON.stringify({ dni, interno, telefono })
        });

        if (!response.ok) throw new Error("Error en la respuesta del servidor.");
        const result = await response.json();

        if (result.status === "success") {
          // Actualizar el estado local en la grilla actual
          const idx = currentUsers.findIndex((u) => u.dni === dni);
          if (idx !== -1) {
            currentUsers[idx].interno = interno || null;
            currentUsers[idx].telefono = telefono || null;
          }

          displayResults(currentUsers);

          // Mostrar feedback visual
          if (statusText) {
            const originalText = statusText.textContent;
            statusText.innerHTML = '<span class="text-success font-semibold flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="size-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> ¡Cambios guardados con éxito!</span>';
            setTimeout(() => {
              if (statusText) statusText.textContent = originalText;
            }, 3000);
          }

          closeEditModal();
        } else {
          alert("Error: " + (result.error || "No se pudo actualizar el contacto."));
        }
      } catch (err: any) {
        console.error(err);
        alert(err.message || "Error al conectar con la base de datos.");
      } finally {
        saveEditBtn.disabled = false;
        saveBtnSpinner.classList.add("hidden");
      }
    });

