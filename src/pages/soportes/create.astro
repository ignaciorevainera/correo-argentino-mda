---
import { getCleanBase } from "@lib/baseUrl";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import FormField from "@components/ui/forms/FormField.astro";
import FormTextarea from "@components/ui/forms/FormTextarea.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { supportGuides } from "@db/schema";
import { logAdminFromAstro } from "@lib/auditLogger";
import { redirectWithToast } from "@lib/api/redirectWithToast";

const cleanBase = getCleanBase();

let errorMsg = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const helpDeskName = data.get("helpDeskName")?.toString() || "";
    const legacyName = data.get("legacyName")?.toString() || null;
    const invgateName = data.get("invgateName")?.toString() || null;
    const route = data.get("route")?.toString() || null;
    const topics = data.get("topics")?.toString() || null;
    const contacts = data.get("contacts")?.toString() || null;
    const referents = data.get("referents")?.toString() || null;
    const notes = data.get("notes")?.toString() || null;

    if (!helpDeskName.trim()) {
      errorMsg = "El campo Mesa de Ayuda es obligatorio.";
    } else {
      await db.insert(supportGuides).values({
        helpDeskName,
        legacyName,
        invgateName,
        route,
        topics,
        contacts,
        referents,
        notes,
      });

      await logAdminFromAstro(Astro.locals, `Creó el soporte "${helpDeskName}"`);
      return redirectWithToast("/soportes", "Soporte creado con éxito.");
    }
  } catch (err) {
    console.error("Error creating support guide:", err);
    errorMsg = "Ocurrió un error al registrar el soporte.";
  }
}

const pageTitle = "Nuevo Soporte";
---

<BaseLayout>
  <PageContainer>
    <div class="mb-6">
      <a href={`${cleanBase}soportes`} class="btn btn-ghost btn-sm gap-2">
        <Icon name="boxicons:arrow-left" class="size-4" />
        Volver al listado
      </a>
    </div>

    <PageHeader 
      title={pageTitle} 
      description="Completa los campos para registrar un nuevo soporte en la guía."
    />

    <div class="mt-8 bg-base-100 p-6 md:p-8 rounded-2xl shadow-sm border border-base-200">
      {errorMsg && (
        <script is:inline define:vars={{ errorMsg }}>
          window.addEventListener('load', () => window.showToast?.(errorMsg, "alert-error"));
        </script>
      )}

      <form method="POST" class="flex flex-col gap-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <FormField id="helpDeskName" name="helpDeskName" label="Mesa de Ayuda" required />
          <FormField id="legacyName" name="legacyName" label="Nombre Anterior" />
          <FormField id="invgateName" name="invgateName" label="Nombre Invgate" />
          <FormField id="route" name="route" label="Ruta" />
        </div>

        <FormTextarea id="topics" name="topics" label="Tópicos (JSON array o texto separado)" textareaClass="font-mono" placeholder='["Tema 1", "Tema 2"]' rows={5} />
        <FormTextarea id="contacts" name="contacts" label="Contactos" rows={5} />
        <FormTextarea id="referents" name="referents" label="Referentes" rows={5} />
        <FormTextarea id="notes" name="notes" label="Notas" rows={5} />

        <div class="flex justify-end gap-3 mt-4 pt-6 border-t border-base-200">
          <a href={`${cleanBase}soportes`} class="btn btn-ghost">
            Cancelar
          </a>
          <button type="submit" class="btn btn-primary">
            <Icon name="boxicons:save" class="size-5" />
            Guardar Soporte
          </button>
        </div>
      </form>
    </div>
  </PageContainer>
</BaseLayout>
