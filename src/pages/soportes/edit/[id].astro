---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { supportGuides } from "@db/schema";
import { eq } from "drizzle-orm";
import { logAdminAction } from "@lib/auditLogger";
import { isAllowed } from "@lib/rolesMatrix";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!user || !isAllowed("Administrar Contenido", user.role)) {
  return Astro.redirect(`${cleanBase}soportes`);
}

const { id } = Astro.params;

if (!id || isNaN(Number(id))) {
  return Astro.redirect(`${cleanBase}soportes`);
}

const numericId = Number(id);

let errorMsg = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const helpDeskName = data.get("helpDeskName")?.toString() || "";
    const legacyName = data.get("legacyName")?.toString() || null;
    const invgateName = data.get("invgateName")?.toString() || null;
    const route = data.get("route")?.toString() || null;
    const topics = data.get("topics")?.toString() || null;
    const contacts = data.get("contacts")?.toString() || null;
    const referents = data.get("referents")?.toString() || null;
    const notes = data.get("notes")?.toString() || null;

    if (!helpDeskName.trim()) {
      errorMsg = "El campo Mesa de Ayuda es obligatorio.";
    } else {
      const [existing] = await db
        .select({ helpDeskName: supportGuides.helpDeskName })
        .from(supportGuides)
        .where(eq(supportGuides.id, numericId));
      const oldName = existing?.helpDeskName || "desconocido";

      await db
        .update(supportGuides)
        .set({
          helpDeskName,
          legacyName,
          invgateName,
          route,
          topics,
          contacts,
          referents,
          notes,
        })
        .where(eq(supportGuides.id, numericId));

      if (oldName !== helpDeskName) {
        await logAdminAction(user?.username || 'Sistema', `Actualizó el soporte de "${oldName}" a "${helpDeskName}"`);
      } else {
        await logAdminAction(user?.username || 'Sistema', `Actualizó el soporte "${helpDeskName}"`);
      }
      return Astro.redirect(
        `${cleanBase}soportes?toast_msg=${encodeURIComponent("Soporte actualizado con éxito.")}&toast_type=success`
      );
    }
  } catch (err) {
    console.error("Error updating support guide:", err);
    errorMsg = "Ocurrió un error al actualizar el registro.";
  }
}

const guide = await db.query.supportGuides.findFirst({
  where: eq(supportGuides.id, numericId),
});

if (!guide) {
  return Astro.redirect(`${cleanBase}soportes`);
}
---

<BaseLayout>
  <PageContainer>
    <div class="mb-6">
      <a href={`${cleanBase}soportes`} class="btn btn-ghost btn-sm gap-2">
        <Icon name="boxicons:arrow-left" class="size-4" />
        Volver al listado
      </a>
    </div>

    <PageHeader 
      title={`Editar Soporte: ${guide.helpDeskName}`} 
      description="Modifica los campos del soporte seleccionado."
    />

    <div class="mt-8 bg-base-100 p-6 md:p-8 rounded-2xl shadow-sm border border-base-200">
      {errorMsg && (
        <script is:inline define:vars={{ errorMsg }}>
          window.showToast?.(errorMsg, "alert-error");
        </script>
      )}

      <form method="POST" class="flex flex-col gap-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="form-control w-full">
            <label class="label" for="helpDeskName">
              <span class="label-text font-bold">Mesa de Ayuda <span class="text-error">*</span></span>
            </label>
            <input 
              type="text" 
              id="helpDeskName"
              name="helpDeskName" 
              value={guide.helpDeskName}
              required 
              class="input input-bordered w-full focus:input-primary" 
            />
          </div>

          <div class="form-control w-full">
            <label class="label" for="legacyName">
              <span class="label-text font-bold">Nombre Anterior</span>
            </label>
            <input 
              type="text" 
              id="legacyName"
              name="legacyName" 
              value={guide.legacyName || ""} 
              class="input input-bordered w-full focus:input-primary" 
            />
          </div>

          <div class="form-control w-full">
            <label class="label" for="invgateName">
              <span class="label-text font-bold">Nombre Invgate</span>
            </label>
            <input 
              type="text" 
              id="invgateName"
              name="invgateName" 
              value={guide.invgateName || ""} 
              class="input input-bordered w-full focus:input-primary" 
            />
          </div>

          <div class="form-control w-full">
            <label class="label" for="route">
              <span class="label-text font-bold">Ruta</span>
            </label>
            <input 
              type="text" 
              id="route"
              name="route" 
              value={guide.route || ""} 
              class="input input-bordered w-full focus:input-primary" 
            />
          </div>
        </div>

        <div class="form-control w-full">
          <label class="label" for="topics">
            <span class="label-text font-bold">Tópicos (JSON array o texto separado)</span>
          </label>
          <textarea 
            id="topics"
            name="topics" 
            class="textarea textarea-bordered w-full h-24 focus:textarea-primary font-mono text-sm"
          >{guide.topics || ""}</textarea>
        </div>

        <div class="form-control w-full">
          <label class="label" for="contacts">
            <span class="label-text font-bold">Contactos</span>
          </label>
          <textarea 
            id="contacts"
            name="contacts" 
            class="textarea textarea-bordered w-full h-24 focus:textarea-primary"
          >{guide.contacts || ""}</textarea>
        </div>

        <div class="form-control w-full">
          <label class="label" for="referents">
            <span class="label-text font-bold">Referentes</span>
          </label>
          <textarea 
            id="referents"
            name="referents" 
            class="textarea textarea-bordered w-full h-24 focus:textarea-primary"
          >{guide.referents || ""}</textarea>
        </div>

        <div class="form-control w-full">
          <label class="label" for="notes">
            <span class="label-text font-bold">Notas</span>
          </label>
          <textarea 
            id="notes"
            name="notes" 
            class="textarea textarea-bordered w-full h-24 focus:textarea-primary"
          >{guide.notes || ""}</textarea>
        </div>

        <div class="flex justify-end gap-3 mt-4 pt-6 border-t border-base-200">
          <a href={`${cleanBase}soportes`} class="btn btn-ghost">
            Cancelar
          </a>
          <button type="submit" class="btn btn-primary">
            <Icon name="boxicons:save" class="size-5" />
            Guardar Cambios
          </button>
        </div>
      </form>
    </div>
  </PageContainer>
</BaseLayout>
