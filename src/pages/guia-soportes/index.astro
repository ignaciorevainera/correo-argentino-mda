---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import guia from "../../data/guia_completa.json";
---

<BaseLayout title="Guía de Soportes">
  <div class="space-y-8 animate-fade-in">
    <!-- Page Header -->
    <section class="space-y-4">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <div>
          <h1 class="text-3xl font-bold text-base-content">
            Guía de Soportes
          </h1>
          <p class="text-base-content/70 text-sm max-w-2xl mt-1">
            Matriz unificada de equivalencias y derivación técnica de la Mesa de Ayuda.
          </p>
        </div>
        
        <div class="flex gap-2">
          <div class="relative w-full md:w-80 group">
            <Icon 
              name="heroicons:magnifying-glass" 
              class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-base-content/40" 
            />
            <input 
              id="global-search"
              type="text" 
              placeholder="Buscar grupo SM, Invgate, temas..." 
              class="input input-sm w-full pl-10 pr-12 bg-base-200 border-none focus:ring-2 focus:ring-primary text-sm transition-all"
              onkeyup="handleSearch(this.value)"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 px-1.5 py-0.5 rounded border border-base-content/10 text-xs text-base-content/40 font-medium bg-base-300">Ctrl+K</span>
          </div>
          <button class="btn btn-sm btn-secondary gap-2 font-bold uppercase text-xs text-white">
            <Icon name="heroicons:adjustments-horizontal" class="size-4" />
            Filtrar
          </button>
        </div>
      </div>
    </section>

    <!-- Unified Table View -->
    <div class="space-y-8">
      <section class="bg-base-100 rounded-xl shadow-sm overflow-hidden border border-base-content/10">
        <div class="overflow-x-auto">
          <table class="table table-zebra table-sm w-full" id="table-guia">
            <thead>
              <tr class="bg-secondary text-xs font-bold uppercase tracking-widest text-white">
                <th class="px-6 py-4">Service Manager</th>
                <th class="px-6 py-4">Invgate</th>
                <th class="px-6 py-4">Ruta de Búsqueda</th>
                <th class="px-6 py-4">Tópicos & Categorías</th>
              </tr>
            </thead>
            <tbody id="table-body" class="divide-y divide-base-content/5">
              <!-- Rows will be injected by JavaScript -->
            </tbody>
          </table>
        </div>
        
        <!-- Pagination Controls -->
        <div class="p-4 bg-base-200/50 border-t border-base-content/10 flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="text-xs text-base-content/50 font-bold uppercase tracking-wider" id="pagination-info">
            Mostrando 0 de 0 registros
          </div>
          <div class="join">
            <button class="join-item btn btn-xs btn-outline border-base-content/20 font-bold gap-1" onclick="changePage(-1)" id="btn-prev">
              <Icon name="heroicons:chevron-left" class="size-3" />
              Anterior
            </button>
            <span class="join-item px-4 flex items-center bg-base-100 border-y border-base-content/10 text-xs font-bold uppercase tracking-wider text-base-content/60" id="page-indicator">
              Página 1
            </span>
            <button class="join-item btn btn-xs btn-outline border-base-content/20 font-bold gap-1" onclick="changePage(1)" id="btn-next">
              Siguiente
              <Icon name="heroicons:chevron-right" class="size-3" />
            </button>
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- Toast Notification System -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2"></div>

  <!-- Data for client-side script -->
  <script define:vars={{ guia }}>
    window._GUIA_DATA = guia;
  </script>

  <script is:inline>
    // Initialize data from window
    const baseData = window._GUIA_DATA || [];
    // Pagination State
    let currentPage = 1;
    const rowsPerPage = 12;
    let filteredData = [...baseData];
    let currentSearchQuery = "";

    // Initial Render
    document.addEventListener('DOMContentLoaded', () => {
      renderTable();
    });

    // Search Logic
    function handleSearch(query) {
      currentSearchQuery = query.toLowerCase();
      
      filteredData = baseData.filter(item => {
        const temasContent = (item.temas || []).join(' ').toLowerCase();
        const rContent = (item.ruta || "").toLowerCase();
        const invContent = (item.invgate || "").toLowerCase();
        const smGroupsContent = (item.sm_groups || []).join(' ').toLowerCase();

        return smGroupsContent.includes(currentSearchQuery) || 
               invContent.includes(currentSearchQuery) || 
               rContent.includes(currentSearchQuery) ||
               temasContent.includes(currentSearchQuery);
      });

      currentPage = 1; 
      renderTable();
    }

    // Change Page
    function changePage(delta) {
      const maxPages = Math.ceil(filteredData.length / rowsPerPage) || 1;
      const newPage = currentPage + delta;

      if (newPage >= 1 && newPage <= maxPages) {
        currentPage = newPage;
        renderTable();
      }
    }

    // Render Table
    function renderTable() {
      const tbody = document.getElementById('table-body');
      if (!tbody) return;

      const start = (currentPage - 1) * rowsPerPage;
      const end = start + rowsPerPage;
      const paginatedItems = filteredData.slice(start, end);
      const maxPages = Math.ceil(filteredData.length / rowsPerPage) || 1;

      // Update UI Controls
      const indicator = document.getElementById('page-indicator');
      const info = document.getElementById('pagination-info');
      const btnPrev = document.getElementById('btn-prev');
      const btnNext = document.getElementById('btn-next');

      if (indicator) indicator.textContent = `Página ${currentPage} de ${maxPages}`;
      if (btnPrev) btnPrev.disabled = currentPage === 1;
      if (btnNext) btnNext.disabled = currentPage === maxPages;
      if (info) info.textContent = `Mostrando ${paginatedItems.length} de ${filteredData.length} registros`;

      // Build rows
      tbody.innerHTML = paginatedItems.map((item, idx) => {
        const groups = item.sm_groups || [];
        const itemIndex = start + idx;
        
        // Truncation logic
        const maxVisible = 3;
        let visibleGroups = groups;
        let hiddenCount = 0;

        // If searching, identify the matched group
        let matchedIndex = -1;
        if (currentSearchQuery) {
          matchedIndex = groups.findIndex(g => g.toLowerCase().includes(currentSearchQuery));
        }

        if (groups.length > maxVisible && !currentSearchQuery) {
          visibleGroups = groups.slice(0, maxVisible);
          hiddenCount = groups.length - maxVisible;
        } else if (groups.length > maxVisible && currentSearchQuery) {
          if (matchedIndex >= maxVisible) {
            visibleGroups = [groups[matchedIndex], ...groups.slice(0, maxVisible - 1)];
            hiddenCount = groups.length - maxVisible;
          } else {
            visibleGroups = groups.slice(0, maxVisible);
            hiddenCount = groups.length - maxVisible;
          }
        }

        return `
          <tr class="hover:bg-primary/5 transition-colors group">
            <td class="px-6 py-4">
              <div class="flex flex-wrap gap-1.5 max-w-xs" id="group-container-${itemIndex}">
                ${visibleGroups.map((group) => {
                  const isMatch = currentSearchQuery && group.toLowerCase().includes(currentSearchQuery);
                  return `
                    <span class="px-2 py-0.5 rounded border text-xs font-bold uppercase transition-all
                      ${isMatch 
                        ? 'bg-primary/20 border-primary text-secondary ring-1 ring-primary animate-pulse' 
                        : 'bg-base-200 border-base-content/10 text-base-content/60'}">
                      ${group}
                    </span>
                  `;
                }).join('')}
                ${hiddenCount > 0 ? `
                  <button 
                    onclick="expandGroups(${itemIndex})"
                    class="px-2 py-0.5 rounded bg-base-300 hover:bg-primary hover:text-white border border-base-content/5 text-xs font-black text-base-content/40 flex items-center gap-1 transition-colors group/more" 
                    title="Click para ver todos los grupos"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-2.5 h-2.5 group-hover/more:rotate-90 transition-transform">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    ${hiddenCount} MÁS
                  </button>
                ` : ''}
              </div>
            </td>
            <td class="px-6 py-4">
              <button 
                class="flex items-center gap-2 group/btn transition-colors text-left"
                onclick="copyText('${item.invgate}')"
                title="Click para copiar"
              >
                <span class="px-2 py-0.5 bg-secondary text-white rounded text-xs font-bold shadow-sm transition-transform group-hover/btn:scale-105">
                  ${item.invgate || '-'}
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 text-secondary opacity-0 group-hover/btn:opacity-100 transition-opacity">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
                </svg>
              </button>
            </td>
            <td class="px-6 py-4">
              ${item.ruta ? `
                <button 
                  class="flex items-center gap-2 text-base-content/60 font-mono text-xs hover:text-secondary group/btn transition-colors text-left"
                  onclick="copyText('${item.ruta}')"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-secondary group-hover/btn:scale-110 transition-transform">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                  </svg>
                  <span class="whitespace-nowrap overflow-hidden text-ellipsis max-w-[150px]" title="${item.ruta}">
                    ${item.ruta}
                  </span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 opacity-0 group-hover/btn:opacity-100 transition-opacity">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
                  </svg>
                </button>
              ` : '<span class="text-base-content/20 italic text-xs">Sin ruta asignada</span>'}
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-wrap gap-1">
                ${(item.temas || []).length > 0 ? item.temas.map(tema => `
                  <span class="px-1.5 py-0.5 bg-base-200 text-base-content/70 text-xs rounded font-medium border border-base-content/5">
                    ${tema}
                  </span>
                `).join('') : '<span class="text-base-content/20 italic text-xs">Sin tópicos</span>'}
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    // Expand Groups Utility
    function expandGroups(itemIndex) {
      const item = filteredData[itemIndex];
      const container = document.getElementById(`group-container-${itemIndex}`);
      if (!item || !container) return;

      container.innerHTML = item.sm_groups.map(group => {
        const isMatch = currentSearchQuery && group.toLowerCase().includes(currentSearchQuery);
        return `
          <span class="px-2 py-0.5 rounded border text-xs font-bold uppercase transition-all animate-fade-in
            ${isMatch 
              ? 'bg-primary/20 border-primary text-secondary ring-1 ring-primary' 
              : 'bg-base-200 border-base-content/10 text-base-content/60'}">
            ${group}
          </span>
        `;
      }).join('') + `
        <button 
          onclick="renderTable()" 
          class="px-2 py-0.5 rounded bg-secondary text-white text-xs font-black uppercase flex items-center gap-1 hover:scale-105 transition-transform"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-2.5 h-2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
          </svg>
          Contraer
        </button>
      `;
    }

    // Copy to Clipboard
    async function copyText(text) {
      if (!text || text === '-' || text === 'null') return;
      try {
        await navigator.clipboard.writeText(text);
        showToast(`Copiado: ${text}`);
      } catch (err) {
        console.error('Error al copiar: ', err);
      }
    }

    // Toast Notification
    function showToast(message) {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'alert alert-info shadow-lg py-2 px-4 text-xs font-bold text-white bg-secondary border-none animate-slide-up';
      toast.innerHTML = `
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>${message}</span>
        </div>
      `;
      container.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-x-full');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    // Shortcut Ctrl+K
    window.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('global-search').focus();
      }
    });
  </script>

  <style>
    .animate-fade-in {
      animation: fadeIn 0.4s ease-out;
    }
    .animate-slide-up {
      animation: slideUp 0.3s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes slideUp {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
  </style>
</BaseLayout>
