---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
---

<BaseLayout title="Cronograma">
  <div class="w-full pb-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-base-content">
        Cronograma
      </h1>
      <p class="mt-1 text-base-content/70">
        Planificacion de tareas y seguimiento semanal del equipo.
      </p>
    </div>

    <div
      class="mt-8 flex w-full min-h-100 flex-col items-center justify-center rounded-2xl border-2 border-dashed border-base-300 bg-base-200/30 p-12 text-center"
    >
      <Icon name="boxicons:calendar" class="mb-4 size-12 text-base-content/20" />

      <h2 class="mb-2 text-xl font-medium text-base-content">
        Seccion sin contenido
      </h2>

      <p class="max-w-md text-balance text-sm text-base-content/70">
        El modulo de cronograma se encuentra vacio tal como se solicito.
      </p>
    </div>
  </div>
</BaseLayout>
