---
import BaseLayout from "@layouts/BaseLayout.astro";
import CronogramaDashboard from "@components/cronograma/CronogramaDashboard.astro";
---

<BaseLayout title="Cronograma | Mesa de Ayuda">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-base-content">Cronograma</h1>
      <p class="text-base-content/60 mt-1">Gestión integral de asistencia y modalidades del equipo MDA.</p>
    </div>

    <CronogramaDashboard />
  </div>
</BaseLayout>
