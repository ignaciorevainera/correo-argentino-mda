---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import CopyButton from "@components/ui/CopyButton.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import OpenExternalUrlButton from "@components/ui/OpenExternalUrlButton.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchEmptyState from "@components/ui/SearchEmptyState.astro";
import { db } from "@/db";
import type { UsefulContactCategory } from "@/types/contactos";

const usefulContactCategories = (await db.query.contactCategories.findMany({
  with: {
    contacts: true,
  },
})) as UsefulContactCategory[];

interface CategoryTheme {
  iconContainerClass: string;
  headerClass: string;
  topBorderClass: string;
  badgeClass: string;
}

const themeByTone: Record<UsefulContactCategory["tone"], CategoryTheme> = {
  primary: {
    iconContainerClass: "border-primary bg-primary text-primary-content",
    headerClass: "bg-primary/10",
    topBorderClass: "border-t-primary",
    badgeClass: "badge-primary",
  },
  secondary: {
    iconContainerClass: "border-secondary bg-secondary text-secondary-content",
    headerClass: "bg-secondary/10",
    topBorderClass: "border-t-secondary",
    badgeClass: "badge-secondary",
  },
  accent: {
    iconContainerClass: "border-accent bg-accent text-accent-content",
    headerClass: "bg-accent/10",
    topBorderClass: "border-t-accent",
    badgeClass: "badge-accent",
  },
  info: {
    iconContainerClass: "border-info bg-info text-info-content",
    headerClass: "bg-info/10",
    topBorderClass: "border-t-info",
    badgeClass: "badge-info",
  },
  success: {
    iconContainerClass: "border-success bg-success text-success-content",
    headerClass: "bg-success/10",
    topBorderClass: "border-t-success",
    badgeClass: "badge-success",
  },
  warning: {
    iconContainerClass: "border-warning bg-warning text-warning-content",
    headerClass: "bg-warning/10",
    topBorderClass: "border-t-warning",
    badgeClass: "badge-warning",
  },
};

const getCategoryTheme = (category: UsefulContactCategory): CategoryTheme =>
  themeByTone[category.tone];

const getCategorySearchText = (category: UsefulContactCategory): string =>
  category.contacts
    .map((contact) =>
      [
        category.title,
        contact.provider,
        contact.service,
        contact.phones.join(" "),
        contact.emails.join(" "),
        contact.urls
          .map((resource) => `${resource.label} ${resource.url}`)
          .join(" "),
      ].join(" "),
    )
    .join(" ");

const getContactSearchText = (
  category: UsefulContactCategory,
  contact: UsefulContactCategory["contacts"][number],
): string =>
  [
    category.title,
    contact.provider,
    contact.service,
    contact.phones.join(" "),
    contact.emails.join(" "),
    contact.urls
      .map((resource) => `${resource.label} ${resource.url}`)
      .join(" "),
  ].join(" ");

function getShortUrl(url: string): string {
  try {
    return url.replace(/^(https?:\/\/)?(www\.)?/, "").replace(/\/$/, "");
  } catch {
    return url;
  }
}

const contactHeaderGridClass =
  "grid grid-cols-[1.2fr_0.8fr_2fr_4fr_4fr] items-start gap-4";
const contactRowGridClass =
  "grid grid-cols-[1.2fr_0.8fr_2fr_4fr_4fr] items-start gap-4";
---

<BaseLayout>
  <PageContainer width="xl">
    <PageHeader
      description="Directorio operativo para ubicar teléfonos, correos y accesos clave sin salir del flujo de soporte."
    />

    <div class="w-full max-w-xl">
      <label class="input input-bordered w-full" for="contacts-search">
        <Icon
          name="boxicons:search"
          size={20}
          class="text-base-content/50"
          aria-hidden="true"
        />
        <input
          id="contacts-search"
          type="search"
          class="grow"
          placeholder="Buscar por proveedor, servicio, teléfono, email o link"
          autocomplete="off"
          aria-label="Buscar contacto por proveedor, servicio, teléfono, email o link"
        />
      </label>
    </div>

    <SearchEmptyState
      id="contacts-empty-state"
      title="Sin resultados"
      description="No hay contactos que coincidan con la búsqueda actual. Probá con otro proveedor, servicio, teléfono, correo o enlace."
    />

    <section
      class="flex flex-col gap-5"
      aria-label="Directorio de contactos"
      id="contacts-grid"
    >
      {
        usefulContactCategories.map((category) => {
          const categoryTheme = getCategoryTheme(category);

          return (
            <article
              class:list={[
                "card overflow-hidden border border-t-4 border-base-300 bg-base-100 shadow-md",
                categoryTheme.topBorderClass,
              ]}
              data-contact-category-card
              data-category-search={getCategorySearchText(category)}
            >
              <header
                class:list={[
                  "flex items-center justify-between gap-3 border-b border-base-300 p-4",
                  categoryTheme.headerClass,
                ]}
              >
                <div class="flex min-w-0 items-center gap-3">
                  <span
                    class:list={[
                      "inline-flex size-10 shrink-0 items-center justify-center rounded-lg border shadow-sm",
                      categoryTheme.iconContainerClass,
                    ]}
                    aria-hidden="true"
                  >
                    <Icon name={category.icon} size={24} />
                  </span>

                  <div class="min-w-0">
                    <h2 class="truncate text-base font-semibold text-base-content">
                      {category.title}
                    </h2>
                    <p class="text-xs text-base-content/60">
                      {category.contacts.length} referencias disponibles
                    </p>
                  </div>
                </div>
              </header>

              <div class="card-body p-0">
                <DataTable
                  ariaLabel={`Contactos útiles de ${category.title}`}
                  minWidthClass="min-w-260"
                  headerGridClass={contactHeaderGridClass}
                  rowGridClass={contactRowGridClass}
                  class="rounded-none border-0 shadow-none"
                >
                  <div slot="header" class="min-w-0">
                    <DataTableHeaderCell sortKey="service">
                      Servicio
                    </DataTableHeaderCell>
                  </div>
                  <div slot="header" class="min-w-0">
                    <DataTableHeaderCell sortKey="provider">
                      Proveedor
                    </DataTableHeaderCell>
                  </div>
                  <div slot="header" class="min-w-0">
                    <DataTableHeaderCell sortKey="phone">
                      Teléfono
                    </DataTableHeaderCell>
                  </div>
                  <div slot="header" class="min-w-0">
                    <DataTableHeaderCell sortKey="email">
                      Correo
                    </DataTableHeaderCell>
                  </div>
                  <div slot="header" class="min-w-0">
                    <DataTableHeaderCell sortKey="url">
                      Sitio web
                    </DataTableHeaderCell>
                  </div>

                  {category.contacts.map((contact) => (
                    <article
                      class:list={[
                        contactRowGridClass,
                        "border-b border-base-300/70 px-4 py-3 transition-colors last:border-b-0 hover:bg-base-200/50",
                      ]}
                      data-table-row
                      data-contact-row
                      data-contact-search={getContactSearchText(
                        category,
                        contact,
                      )}
                      data-sort-service={contact.service}
                      data-sort-provider={contact.provider}
                      data-sort-phone={contact.phones.join(" ")}
                      data-sort-email={contact.emails.join(" ")}
                      data-sort-url={contact.urls
                        .map((resource) => resource.url)
                        .join(" ")}
                    >
                      <div class="min-w-0">
                        <p
                          class="text-sm font-medium leading-snug text-base-content"
                          data-highlight-target
                        >
                          {contact.service}
                        </p>
                      </div>

                      <div class="min-w-0">
                        <p
                          class="text-xs font-semibold uppercase tracking-wider text-base-content/55"
                          data-highlight-target
                        >
                          {contact.provider}
                        </p>
                      </div>

                      <div class="min-w-0">
                        {contact.phones.length > 0 ? (
                          <div class="flex flex-col gap-1.5">
                            {contact.phones.map((phone) => (
                              <div class="group flex min-w-0 items-center gap-1">
                                <span
                                  class="inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
                                  aria-hidden="true"
                                >
                                  <Icon
                                    name="boxicons:phone-filled"
                                    size={16}
                                  />
                                </span>
                                <span
                                  class="min-w-0 flex-1 wrap-break-word px-1.5 py-1 font-mono text-xs text-base-content/80"
                                  data-highlight-target
                                >
                                  {phone}
                                </span>
                                <CopyButton
                                  value={phone}
                                  variant="icon"
                                  appearance="ghost"
                                  size="xs"
                                  ariaLabel={`Copiar teléfono ${phone}`}
                                  class="shrink-0 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                />
                              </div>
                            ))}
                          </div>
                        ) : (
                          <span class="text-xs italic text-base-content/45">
                            Sin teléfono
                          </span>
                        )}
                      </div>

                      <div class="min-w-0">
                        {contact.emails.length > 0 ? (
                          <div class="flex flex-col gap-1.5">
                            {contact.emails.map((email) => (
                              <div class="group flex min-w-0 items-center gap-1">
                                <span
                                  class="inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
                                  aria-hidden="true"
                                >
                                  <Icon
                                    name="boxicons:pencil-draw-filled"
                                    class="size-3.5"
                                  />
                                </span>
                                <span
                                  class="min-w-0 flex-1 break-all px-1.5 py-1 font-mono text-xs text-base-content/80"
                                  data-highlight-target
                                >
                                  {email}
                                </span>
                                <CopyButton
                                  value={email}
                                  variant="icon"
                                  appearance="ghost"
                                  size="xs"
                                  ariaLabel={`Copiar correo ${email}`}
                                  class="shrink-0 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                />
                                <OpenExternalUrlButton
                                  href={`mailto:${email}`}
                                  variant="icon"
                                  size="xs"
                                  appearance="ghost"
                                  newTab={false}
                                  class="shrink-0 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                  ariaLabel={`Abrir cliente de correo para ${email}`}
                                />
                              </div>
                            ))}
                          </div>
                        ) : (
                          <span class="text-xs italic text-base-content/45">
                            Sin correo
                          </span>
                        )}
                      </div>

                      <div class="min-w-0">
                        {contact.urls.length > 0 ? (
                          <div class="flex flex-col gap-1.5">
                            {contact.urls.map((resource) => (
                              <div class="group flex min-w-0 items-center gap-1">
                                <span
                                  class="inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary"
                                  aria-hidden="true"
                                >
                                  <Icon
                                    name="boxicons:planet-filled"
                                    size={16}
                                  />
                                </span>
                                <span
                                  class="min-w-0 flex-1 break-all px-1.5 py-1 font-mono text-xs text-base-content/80"
                                  data-highlight-target
                                >
                                  {getShortUrl(resource.url)}
                                </span>
                                <CopyButton
                                  value={resource.url}
                                  variant="icon"
                                  appearance="ghost"
                                  size="xs"
                                  class="shrink-0 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                  ariaLabel={`Copiar link ${resource.label} de ${contact.service}`}
                                />
                                <OpenExternalUrlButton
                                  href={resource.url}
                                  variant="icon"
                                  size="xs"
                                  appearance="ghost"
                                  class="shrink-0 opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 focus-visible:opacity-100"
                                  ariaLabel={`Abrir ${resource.label} en una nueva pestaña`}
                                />
                              </div>
                            ))}
                          </div>
                        ) : (
                          <span class="text-xs italic text-base-content/45">
                            Sin sitio web
                          </span>
                        )}
                      </div>
                    </article>
                  ))}
                </DataTable>
              </div>
            </article>
          );
        })
      }
    </section>
  </PageContainer>

  <script>
    const normalizeValue = (value: string): string =>
      value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    const escapeRegExp = (value: string): string =>
      value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const escapeHtml = (value: string): string =>
      value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const highlightText = (element: HTMLElement, query: string): void => {
      const originalText =
        element.dataset.originalText ?? element.textContent ?? "";

      if (!element.dataset.originalText) {
        element.dataset.originalText = originalText;
      }

      if (query.length === 0) {
        element.textContent = originalText;
        return;
      }

      const matcher = new RegExp(`(${escapeRegExp(query)})`, "ig");

      if (!matcher.test(originalText)) {
        element.textContent = originalText;
        return;
      }

      matcher.lastIndex = 0;
      const highlighted = originalText
        .split(matcher)
        .map((chunk, index) =>
          index % 2 === 1
            ? `<mark class=\"rounded bg-warning/30 px-0.5 text-base-content\">${escapeHtml(chunk)}</mark>`
            : escapeHtml(chunk),
        )
        .join("");

      element.innerHTML = highlighted;
    };

    const searchInput =
      document.querySelector<HTMLInputElement>("#contacts-search");
    const emptyState = document.querySelector<HTMLElement>(
      "#contacts-empty-state",
    );
    const categoryCards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-contact-category-card]"),
    );
    const contactRows = Array.from(
      document.querySelectorAll<HTMLElement>("[data-contact-row]"),
    );

    const updateContactSearch = (): void => {
      if (!(searchInput instanceof HTMLInputElement)) {
        return;
      }

      const rawSearchValue = searchInput.value.trim();
      const searchValue = normalizeValue(rawSearchValue);
      let visibleRows = 0;

      contactRows.forEach((row) => {
        const searchableContent = normalizeValue(
          row.dataset.contactSearch ?? "",
        );
        const isVisible =
          searchValue.length === 0 || searchableContent.includes(searchValue);

        row.classList.toggle("hidden", !isVisible);

        const rowTargets = Array.from(
          row.querySelectorAll<HTMLElement>("[data-highlight-target]"),
        );

        rowTargets.forEach((target) => {
          highlightText(target, isVisible ? rawSearchValue : "");
        });

        if (isVisible) {
          visibleRows += 1;
        }
      });

      categoryCards.forEach((categoryCard) => {
        const categoryRows = Array.from(
          categoryCard.querySelectorAll<HTMLElement>("[data-contact-row]"),
        );
        const hasVisibleRows = categoryRows.some(
          (row) => !row.classList.contains("hidden"),
        );

        categoryCard.classList.toggle("hidden", !hasVisibleRows);
      });

      emptyState?.classList.toggle("hidden", visibleRows > 0);
      if (emptyState) {
        if (visibleRows > 0) {
          emptyState.classList.remove("flex");
        } else {
          emptyState.classList.add("flex");
        }
      }
    };

    searchInput?.addEventListener("input", updateContactSearch);
    updateContactSearch();
  </script>
</BaseLayout>
