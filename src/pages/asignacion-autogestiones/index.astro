  (op) => op.estado === "Disponible",
).length;
const noDisponiblesList = operadores.filter((op) => op.estado !== "Disponible");
const noDisponiblesCount = noDisponiblesList.length;

const breakdown: Record<string, number> = {
  Vacaciones: 0,
  Licencia: 0,
  "En reunión": 0,
  "Tarea administrativa": 0,
};
