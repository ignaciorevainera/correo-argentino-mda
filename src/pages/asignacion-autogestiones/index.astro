---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import PageHeader from "@components/ui/PageHeader.astro";
---

<BaseLayout title="Asignacion de autogestiones">
  <div class="w-full pb-8">
    <PageHeader
      title="Asignacion de autogestiones"
      description="Distribucion semiautomatica de tickets de AG entrantes para el equipo operativo."
      class="mb-8"
    />

    <div
      class="mt-8 flex w-full min-h-100 flex-col items-center justify-center rounded-2xl border-2 border-dashed border-base-300 bg-base-200/30 p-12 text-center"
    >
      <Icon
        name="boxicons:git-branch"
        class="mb-4 size-12 text-base-content/20"
      />

      <h2 class="mb-2 text-xl font-medium text-base-content">
        Seccion sin contenido
      </h2>

      <p class="max-w-md text-balance text-sm text-base-content/70">
        El contenido de este modulo se encuentra vacio tal como se solicito.
      </p>
    </div>
  </div>
</BaseLayout>
