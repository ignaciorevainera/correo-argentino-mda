---
import { Icon } from "astro-icon/components";
---

<div
  class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
  id="sync-dashboard"
>
  <div
    class="card bg-base-100 border border-base-300 flex flex-row items-center justify-between p-5 md:p-6"
  >
    <div class="flex-1 min-w-0">
      <div
        class="text-xs font-semibold uppercase tracking-wider text-base-content/60 truncate"
      >
        Sincronización de Terminales
      </div>
      <div
        class="text-lg md:text-xl font-bold mt-0.5 text-base-content"
        id="sync-status"
      >
        Cargando...
      </div>
      <div class="text-xs text-base-content/50 mt-1 truncate" id="sync-desc">
        Esperando datos...
      </div>
    </div>
    <div
      class="bg-base-200/60 text-base-content/40 p-3 rounded-xl shrink-0 ml-4"
      id="sync-icon-container"
    >
      <Icon
        name="boxicons:history"
        size={32}
        class="transition-transform duration-1000"
      />
    </div>
  </div>

  <div
    class="card bg-base-100 border border-base-300 flex flex-row items-center justify-between p-5 md:p-6"
  >
    <div class="flex-1 min-w-0">
      <div
        class="text-xs font-semibold uppercase tracking-wider text-base-content/60 truncate"
      >
        Monitoreo de Cubics (Ping)
      </div>
      <div
        class="text-lg md:text-xl font-bold mt-0.5 text-base-content"
        id="ping-status"
      >
        Cargando...
      </div>
      <div class="text-xs text-base-content/50 mt-1 truncate" id="ping-desc">
        Esperando datos...
      </div>
    </div>
    <div
      class="bg-base-200/60 text-base-content/40 p-3 rounded-xl shrink-0 ml-4"
      id="ping-icon-container"
    >
      <Icon name="boxicons:desktop-filled" size={32} />
    </div>
  </div>

  <div
    class="card bg-base-100 border border-base-300 flex flex-row items-center justify-between p-5 md:p-6"
  >
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <div
          class="text-xs font-semibold uppercase tracking-wider text-base-content/60 truncate"
        >
          Integración InvGate
        </div>
        <button
          type="button"
          id="invgate-refresh-btn"
          class="btn btn-ghost btn-circle btn-xs text-base-content/50 hover:text-base-content focus:outline-none focus-visible:ring-1 focus-visible:ring-primary"
          title="Verificar conexión de InvGate"
          aria-label="Verificar conexión de InvGate"
        >
          <Icon
            name="boxicons:refresh-ccw-filled"
            size={14}
            id="invgate-refresh-icon"
          />
        </button>
      </div>
      <div
        class="text-lg md:text-xl font-bold mt-0.5 text-base-content"
        id="invgate-status"
      >
        Cargando...
      </div>
      <div class="text-xs text-base-content/50 mt-1 truncate" id="invgate-desc">
        Esperando datos...
      </div>
      <div class="mt-1">
        <a
          href="https://releases.invgate.com/service-desk/api/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs link link-secondary link-hover"
        >
          Documentación de la API
        </a>
      </div>
    </div>
    <div
      class="bg-base-200/60 text-base-content/40 p-3 rounded-xl shrink-0 ml-4"
      id="invgate-icon-container"
    >
      <Icon name="boxicons:link-filled" size={32} />
    </div>
  </div>
</div>

<script>
  async function updateDashboard() {
    try {
      const res = await fetch("/api/admin/sync-status");
      if (!res.ok) throw new Error("Error en la respuesta de la API");

      const data = await res.json();

      const syncStatusEl = document.getElementById("sync-status");
      const syncDescEl = document.getElementById("sync-desc");
      const syncIconContainer = document.getElementById("sync-icon-container");

      const pingStatusEl = document.getElementById("ping-status");
      const pingDescEl = document.getElementById("ping-desc");
      const pingIconContainer = document.getElementById("ping-icon-container");

      const formatDate = (isoString: string | null) => {
        if (!isoString) return "Nunca";
        try {
          const date = new Date(isoString);
          return date.toLocaleString("es-AR", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          });
        } catch {
          return "Fecha inválida";
        }
      };

      // 1. Actualizar Sincronización de Terminales
      if (data.sync) {
        let statusText = "Detenido";
        let statusClass = "text-lg md:text-xl font-bold mt-0.5 text-error";
        let iconContainerClass =
          "bg-error/15 text-error p-3 rounded-xl shrink-0 ml-4";
        let isSpinning = false;

        if (data.sync.status === "online") {
          statusText = "En Ejecución";
          statusClass = "text-lg md:text-xl font-bold mt-0.5 text-success";
          iconContainerClass =
            "bg-success/15 text-success p-3 rounded-xl shrink-0 ml-4";
          isSpinning = true;
        } else if (data.sync.lastStatus === "error") {
          statusText = "Fallo de Sincronización";
          statusClass =
            "text-lg md:text-xl font-bold mt-0.5 text-error font-bold";
          iconContainerClass =
            "bg-error/15 text-error p-3 rounded-xl shrink-0 ml-4";
        } else if (data.sync.lastStatus === "success") {
          statusText = "Sincronizado";
          statusClass = "text-lg md:text-xl font-bold mt-0.5 text-success";
          iconContainerClass =
            "bg-success/15 text-success p-3 rounded-xl shrink-0 ml-4";
        }

        if (syncStatusEl) {
          syncStatusEl.textContent = statusText;
          syncStatusEl.className = statusClass;
        }

        if (syncDescEl) {
          let descText = `Última: ${formatDate(data.sync.lastExecution)} | Próxima: ${formatDate(data.sync.nextExecution)}`;
          if (data.sync.error) {
            descText += ` - Error: ${data.sync.error}`;
          }
          syncDescEl.textContent = descText;
          syncDescEl.title = descText;
        }

        if (syncIconContainer) {
          syncIconContainer.className = iconContainerClass;
          const iconEl = syncIconContainer.querySelector("svg");
          if (iconEl) {
            if (isSpinning) {
              iconEl.classList.add("animate-spin");
            } else {
              iconEl.classList.remove("animate-spin");
            }
          }
        }
      }

      // 2. Actualizar Monitoreo de Cubics
      if (data.ping) {
        let statusText = "Inactivo";
        let statusClass = "text-lg md:text-xl font-bold mt-0.5 text-error";
        let iconContainerClass =
          "bg-error/15 text-error p-3 rounded-xl shrink-0 ml-4";
        let isPulse = false;

        if (data.ping.status === "online") {
          statusText = "Activo";
          statusClass = "text-lg md:text-xl font-bold mt-0.5 text-success";
          iconContainerClass =
            "bg-success/15 text-success p-3 rounded-xl shrink-0 ml-4";
          isPulse = true;
        }

        if (pingStatusEl) {
          pingStatusEl.textContent = statusText;
          pingStatusEl.className = statusClass;
        }

        if (pingDescEl) {
          const descText = `Último ping registrado: ${formatDate(data.ping.lastPing)}`;
          pingDescEl.textContent = descText;
          pingDescEl.title = descText;
        }

        if (pingIconContainer) {
          pingIconContainer.className = iconContainerClass;
          const iconEl = pingIconContainer.querySelector("svg");
          if (iconEl) {
            if (isPulse) {
              iconEl.classList.add("animate-pulse");
            } else {
              iconEl.classList.remove("animate-pulse");
            }
          }
        }
      }
    } catch (err) {
      console.error("[SyncDashboard] Error al actualizar estado:", err);
      const syncStatusEl = document.getElementById("sync-status");
      const pingStatusEl = document.getElementById("ping-status");
      const syncIconContainer = document.getElementById("sync-icon-container");
      const pingIconContainer = document.getElementById("ping-icon-container");

      if (syncStatusEl) {
        syncStatusEl.textContent = "Error de Conexión";
        syncStatusEl.className =
          "text-lg md:text-xl font-bold mt-0.5 text-warning";
      }
      if (pingStatusEl) {
        pingStatusEl.textContent = "Error de Conexión";
        pingStatusEl.className =
          "text-lg md:text-xl font-bold mt-0.5 text-warning";
      }
      if (syncIconContainer) {
        syncIconContainer.className =
          "bg-warning/15 text-warning p-3 rounded-xl shrink-0 ml-4";
      }
      if (pingIconContainer) {
        pingIconContainer.className =
          "bg-warning/15 text-warning p-3 rounded-xl shrink-0 ml-4";
      }
    }
  }

  const invgateStatusEl = document.getElementById("invgate-status");
  const invgateDescEl = document.getElementById("invgate-desc");
  const invgateIconContainer = document.getElementById(
    "invgate-icon-container",
  );
  const invgateRefreshBtn = document.getElementById("invgate-refresh-btn");
  const invgateRefreshIcon = document.getElementById("invgate-refresh-icon");

  async function updateInvgateStatus() {
    if (!invgateStatusEl) return;

    if (invgateRefreshIcon) {
      invgateRefreshIcon.classList.add("animate-spin");
    }
    if (invgateRefreshBtn) {
      invgateRefreshBtn.setAttribute("disabled", "true");
    }

    try {
      const res = await fetch("/api/admin/invgate-status");
      if (!res.ok) throw new Error("Error en la respuesta de la API");

      const data = await res.json();

      let statusText = "Desconectado";
      let statusClass = "text-lg md:text-xl font-bold mt-0.5 text-error";
      let iconContainerClass =
        "bg-error/15 text-error p-3 rounded-xl shrink-0 ml-4";

      if (data.ok) {
        statusText = "Conectado";
        statusClass = "text-lg md:text-xl font-bold mt-0.5 text-success";
        iconContainerClass =
          "bg-success/15 text-success p-3 rounded-xl shrink-0 ml-4";
      }

      invgateStatusEl.textContent = statusText;
      invgateStatusEl.className = statusClass;

      if (invgateDescEl) {
        const descText = data.message || `HTTP ${data.status}`;
        invgateDescEl.textContent = descText;
        invgateDescEl.title = descText;
      }

      if (invgateIconContainer) {
        invgateIconContainer.className = iconContainerClass;
      }
    } catch (err) {
      console.error("[SyncDashboard] Error al verificar InvGate:", err);
      invgateStatusEl.textContent = "Error de Conexión";
      invgateStatusEl.className =
        "text-lg md:text-xl font-bold mt-0.5 text-warning";
      if (invgateIconContainer) {
        invgateIconContainer.className =
          "bg-warning/15 text-warning p-3 rounded-xl shrink-0 ml-4";
      }
    } finally {
      if (invgateRefreshIcon) {
        invgateRefreshIcon.classList.remove("animate-spin");
      }
      if (invgateRefreshBtn) {
        invgateRefreshBtn.removeAttribute("disabled");
      }
    }
  }

  function initInvgate() {
    const btn = document.getElementById("invgate-refresh-btn");
    if (btn) {
      btn.onclick = (e) => {
        e.preventDefault();
        updateInvgateStatus();
      };
    }
    updateInvgateStatus();
  }

  updateDashboard();
  initInvgate();

  document.addEventListener("astro:page-load", () => {
    updateDashboard();
    initInvgate();
  });

  const syncInterval = setInterval(updateDashboard, 30000);

  document.addEventListener("astro:before-swap", () => {
    clearInterval(syncInterval);
  });
</script>
