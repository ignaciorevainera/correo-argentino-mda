---
import { getResolvedSearchParams } from "@lib/navigation";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import { Icon } from "astro-icon/components";
import UbicacionRow from "./UbicacionRow.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import ActionCancelButton from "@components/ui/ActionCancelButton.astro";
import ActionConfirmButton from "@components/ui/ActionConfirmButton.astro";
import { db } from "@db/index";
import { provinces } from "@db/schema";
import { officeTypeLabelByType } from "@lib/officeHelpers";

const allProvinces = await db.select().from(provinces).orderBy(provinces.name);

const searchParams = getResolvedSearchParams(Astro.request, Astro.url);
const page = parseInt(searchParams.get("page") ?? "1", 10) || 1;
const filter = searchParams.get("filter") ?? "unmatched";
const q = searchParams.get("q") ?? "";
const sync = searchParams.get("sync") === "true";

// Call API locally
const cookie = Astro.request.headers.get("cookie") || "";
const apiUrl = new URL("/api/invgate/locations", Astro.url.origin);
apiUrl.searchParams.set("page", page.toString());
apiUrl.searchParams.set("filter", filter);
apiUrl.searchParams.set("q", q);
if (sync) {
  apiUrl.searchParams.set("action", "sync");
}

let apiData: any = null;
let apiError = "";

try {
  const res = await fetch(apiUrl.toString(), {
    headers: {
      cookie,
    },
  });
  if (res.ok) {
    apiData = await res.json();
  } else {
    const errorText = await res.text();
    apiError = `Error ${res.status}: ${errorText}`;
  }
} catch (err: any) {
  apiError = err.message;
}

const hasRun = apiData && apiData.stats !== null;
const stats = apiData?.stats;
const results = apiData?.results || [];
const pagination = apiData?.pagination || { page: 1, limit: 50, totalPages: 1, totalItems: 0 };

const headerGridClass = "grid-cols-[120px_1.5fr_100px_120px_100px_1.2fr_120px_1.5fr] gap-4";
const rowGridClass = "grid grid-cols-[120px_1.5fr_100px_120px_100px_1.2fr_120px_1.5fr] items-center gap-4";
---

<PageContainer width="xl">
  <PageHeader
    title="Ubicaciones InvGate"
    description="Comparativa de ubicaciones reportadas por InvGate contra las oficinas registradas en la base de datos de MDA."
  />

  {apiError && (
    <div class="alert alert-error my-4 shadow-sm" role="alert">
      <Icon name="boxicons:error-circle-solid" size={24} aria-hidden="true" />
      <div>
        <h3 class="font-bold">Error de sincronización</h3>
        <p class="text-sm">{apiError}</p>
      </div>
    </div>
  )}

  {!hasRun ? (
    /* --- EMPTY STATE (NOT SYNCED YET) --- */
    <div class="flex flex-col items-center justify-center text-center p-12 my-8 bg-base-100 border border-base-200 rounded-2xl shadow-sm">
      <div class="rounded-full bg-base-200 p-6 mb-4 text-base-content/40">
        <Icon name="boxicons:map-filled" size={48} aria-hidden="true" />
      </div>
      <h2 class="text-xl font-bold mb-2 text-base-content">Sin datos de comparación</h2>
      <p class="max-w-md text-base-content/70 mb-6 text-sm">
        Aún no se ha realizado la comparación de ubicaciones entre InvGate y la base de datos de MDA. Sincronice los datos para comenzar.
      </p>
      <a href="/admin/invgate/ubicaciones?sync=true" class="btn btn-primary btn-md gap-2">
        <Icon name="boxicons:refresh-ccw-filled" size={20} aria-hidden="true" />
        Sincronizar ahora
      </a>
    </div>
  ) : (
    /* --- COMPARISON RUNS / CACHED CONTENT --- */
    <div>
      <!-- Stats Summary cards -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5 my-6">
        <div class="card bg-base-100 shadow border border-base-200 p-4">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Total InvGate</span>
          <span class="text-2xl font-bold mt-1 text-base-content">{stats.totalInvgate}</span>
        </div>
        <div class="card bg-base-100 shadow border border-base-200 p-4 border-l-4 border-l-success">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Matcheados</span>
          <span class="text-2xl font-bold mt-1 text-success">{stats.matched}</span>
        </div>
        <div class="card bg-base-100 shadow border border-base-200 p-4 border-l-4 border-l-warning">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Solo en MDA</span>
          <span class="text-2xl font-bold mt-1 text-warning">{stats.unmatchedMda}</span>
        </div>
        <div class="card bg-base-100 shadow border border-base-200 p-4 border-l-4 border-l-error">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Solo en InvGate</span>
          <span class="text-2xl font-bold mt-1 text-error">{stats.unmatchedInvgate}</span>
        </div>
        <div class="card bg-base-100 shadow border border-base-200 p-4">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Total MDA</span>
          <span class="text-2xl font-bold mt-1 text-base-content">{stats.totalMda}</span>
        </div>
      </div>

      <!-- Search & Filters Toolbar -->
      <div class="mb-6 flex flex-col md:flex-row gap-4 items-stretch md:items-center justify-between">
        <!-- Filter buttons -->
        <div class="join border border-base-200 rounded-lg">
          <a
            href={`/admin/invgate/ubicaciones?filter=all&q=${encodeURIComponent(q)}`}
            class:list={["join-item btn btn-md", filter === "all" ? "btn-active btn-neutral" : "bg-base-100"]}
          >
            Todos
          </a>
          <a
            href={`/admin/invgate/ubicaciones?filter=matched&q=${encodeURIComponent(q)}`}
            class:list={["join-item btn btn-md", filter === "matched" ? "btn-active btn-neutral" : "bg-base-100"]}
          >
            Matcheados
          </a>
          <a
            href={`/admin/invgate/ubicaciones?filter=unmatched&q=${encodeURIComponent(q)}`}
            class:list={["join-item btn btn-md", filter === "unmatched" ? "btn-active btn-neutral" : "bg-base-100"]}
          >
            Solo en InvGate
          </a>
        </div>

        <div class="flex gap-2">
          <!-- Trigger Sync -->
          <a href="/admin/invgate/ubicaciones?sync=true" class="btn btn-outline btn-md gap-2" title="Volver a sincronizar">
            <Icon name="boxicons:refresh-ccw-filled" size={18} aria-hidden="true" />
            Sincronizar
          </a>

          <!-- Search Form -->
          <form method="GET" action="/admin/invgate/ubicaciones" class="w-full md:w-80">
            <input type="hidden" name="filter" value={filter} />
            <SearchBar id="ubicaciones-search" placeholder="Buscar ubicación, NIS, CP..." size="md" />
          </form>
        </div>
      </div>

      <!-- Results Table -->
      {results.length === 0 ? (
        <div class="flex flex-col items-center justify-center text-center p-12 bg-base-100 border border-base-200 rounded-xl">
          <div class="rounded-full bg-base-200 p-4 mb-2 text-base-content/40">
            <Icon name="boxicons:search" size={32} aria-hidden="true" />
          </div>
          <p class="text-base-content/60 text-sm">No se encontraron ubicaciones para la búsqueda o filtro seleccionado.</p>
        </div>
      ) : (
        <div class="space-y-4">
          <DataTable
            ariaLabel="Resultados de la comparación de ubicaciones"
            minWidthClass="min-w-[1000px]"
            headerGridClass={headerGridClass}
            rowGridClass={rowGridClass}
          >
            <div slot="header"><DataTableHeaderCell>Estado</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>Ubicación InvGate</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>NIS</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>CP</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>CC</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>Oficina MDA</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>Código MDA</DataTableHeaderCell></div>
            <div slot="header"><DataTableHeaderCell>Dirección MDA</DataTableHeaderCell></div>
            <div id="locations-container" class="contents">
              {results.map((row: any) => (
                <UbicacionRow row={row} rowGridClass={rowGridClass} />
              ))}
            </div>
          </DataTable>

          <!-- Infinite Scroll Sentinel -->
          {pagination.totalPages > 1 && (
            <div id="locations-sentinel" class="py-8 flex justify-center">
              <span class="loading loading-spinner loading-md text-primary" id="locations-spinner"></span>
            </div>
          )}
        </div>
      )}
    </div>
  )}
</PageContainer>

<dialog id="create_office_modal" class="modal">
  <div class="modal-box max-w-lg">
    <h3 class="font-bold text-lg mb-4 text-base-content">Crear nueva oficina</h3>
    <form id="create_office_form" class="space-y-4">
      <FormField id="office-code" name="code" label="Código NIS" required />
      <FormField id="office-name" name="name" label="Nombre" required />
      <FormField id="office-address" name="address" label="Dirección" />
      <SelectField id="office-province" name="provinceCode" label="Provincia" required>
        <option value="" disabled selected>Seleccioná una provincia</option>
        {allProvinces.map((prov) => (
          <option value={prov.code}>{prov.name}</option>
        ))}
      </SelectField>
      <FormField id="office-cc" name="cc" label="Centro de Costo" />
      <SelectField id="office-type" name="type" label="Tipo" required>
        <option value="" disabled selected>Seleccioná un tipo</option>
        {Object.entries(officeTypeLabelByType).map(([key, label]) => (
          <option value={key}>{label}</option>
        ))}
      </SelectField>
      <div class="modal-action flex justify-end gap-2 mt-6">
        <ActionCancelButton
          type="button"
          label="Cancelar"
          onclick="document.getElementById('create_office_modal').close()"
        />
        <ActionConfirmButton
          type="submit"
          color="btn-primary"
          label="Crear"
        />
      </div>
    </form>
  </div>
</dialog>

<script is:inline>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
      const toast = document.createElement("div");
      toast.className = "toast toast-end toast-bottom z-50 p-4";
      toast.innerHTML = `
        <div class="alert alert-success shadow-md py-3 px-5 text-sm flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 stroke-current" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Copiado al portapapeles</span>
        </div>
      `;
      document.body.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 2000);
    }).catch(err => {
      console.error("Fallo al copiar: ", err);
    });
  }

  document.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-create-office-btn]");
    if (!btn) return;

    const nis = btn.getAttribute("data-nis");
    const name = btn.getAttribute("data-name");
    const cc = btn.getAttribute("data-cc");
    const address = btn.getAttribute("data-address");
    const invgateId = btn.getAttribute("data-invgate-id");
    const invgateDisplayName = btn.getAttribute("data-invgate-display-name");
    const invgateCp = btn.getAttribute("data-invgate-cp");
    const invgateInvgateAddress = btn.getAttribute("data-invgate-invgate-address");

    const modal = document.getElementById("create_office_modal");
    if (!modal) return;

    const form = document.getElementById("create_office_form");
    if (form) {
      form.reset();
      form.querySelector("[name='code']").value = nis || "";
      form.querySelector("[name='name']").value = name || "";
      form.querySelector("[name='cc']").value = cc || "";
      form.querySelector("[name='address']").value = address || "";
    }

    window.lastTriggeringBtn = btn;
    window.lastInvgateLink = invgateId ? {
      invgateLocationId: parseInt(invgateId, 10),
      invgateDisplayName: invgateDisplayName || "",
      invgateCp: invgateCp || "",
      invgateAddress: invgateInvgateAddress || "",
    } : null;
    modal.showModal();
  });

  (function setupCreateForm() {
    const form = document.getElementById("create_office_form");
    const modal = document.getElementById("create_office_modal");
    if (!form || !modal) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

        const formData = new FormData(form);
        const data: any = {
          code: formData.get("code"),
          name: formData.get("name"),
          address: (formData.get("address") || "").toUpperCase() || null,
          provinceCode: formData.get("provinceCode"),
          cc: formData.get("cc"),
          type: formData.get("type"),
        };
        if (window.lastInvgateLink) {
          data.invgateLink = window.lastInvgateLink;
        }

      try {
        const res = await fetch("/api/admin/offices/create", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok && result.success) {
          window.showToast?.("Oficina creada con éxito.", "alert-success");
          modal.close();

          const row = window.lastTriggeringBtn ? window.lastTriggeringBtn.closest("[data-location-row]") : null;
          if (row) {
            const badgeDiv = row.querySelector("div:first-child");
            if (badgeDiv) {
              badgeDiv.innerHTML = '<span class="badge badge-success text-success-content badge-sm font-medium">Match</span>';
            }

            const actionDiv = row.querySelector("[data-create-btn-container]");
            if (actionDiv) {
              const parent = actionDiv.parentNode;
              parent.innerHTML = `<span class="text-sm text-base-content font-medium">${data.name}</span>`;
            }

            const codeDiv = row.querySelector("div:nth-child(7)");
            if (codeDiv) {
              codeDiv.textContent = data.code;
            }

            const addressDiv = row.querySelector("div:nth-child(8)");
            if (addressDiv) {
              addressDiv.textContent = data.address || "—";
              addressDiv.setAttribute("title", data.address || "—");
            }
          }
        } else {
          window.showToast?.(result.error || "Error al crear la oficina", "alert-error");
        }
      } catch (err) {
        window.showToast?.("Error de conexión al servidor", "alert-error");
      }
    });
  })();
</script>

<script is:inline define:vars={{
  initialPage: pagination.page,
  totalPages: pagination.totalPages,
  filter,
  q
}}>
  document.addEventListener("DOMContentLoaded", () => {
    const sentinel = document.getElementById("locations-sentinel");
    const container = document.getElementById("locations-container");
    const spinner = document.getElementById("locations-spinner");
    
    let currentPage = initialPage;
    let hasMore = currentPage < totalPages;
    let isLoading = false;

    if (!sentinel || !container) return;

    if (!hasMore) {
      sentinel.classList.add("hidden");
    }

    const fetchNextPage = async () => {
      if (isLoading || !hasMore) return;
      isLoading = true;
      spinner?.classList.remove("hidden");

      try {
        currentPage++;
        const params = new URLSearchParams();
        params.set("page", currentPage.toString());
        params.set("filter", filter);
        if (q) params.set("q", q);

        const response = await fetch(`/api/invgate/locations/rows?${params.toString()}`);
        if (!response.ok) throw new Error("API call failed");

        const html = await response.text();
        const newHasMore = response.headers.get("X-Has-More") === "true";
        
        hasMore = newHasMore;
        container.insertAdjacentHTML("beforeend", html);

        if (!hasMore) {
          sentinel.classList.add("hidden");
        }
      } catch (err) {
        console.error("Error fetching locations:", err);
        // Revert page count on error so the page can be retried on next intersection
        currentPage--;
      } finally {
        isLoading = false;
        if (!hasMore && spinner) {
          spinner.classList.add("hidden");
        }
      }
    };

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !isLoading && hasMore) {
        fetchNextPage();
      }
    }, { rootMargin: "200px" });

    observer.observe(sentinel);
  });
</script>
