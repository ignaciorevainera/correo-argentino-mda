---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";

const headerGridClass = "grid-cols-[120px_1fr_100px_120px_100px_1fr_120px_1.5fr] gap-4";
const rowGridClass = "grid grid-cols-[120px_1fr_100px_120px_100px_1fr_120px_1.5fr] items-center gap-4";
---

<PageContainer width="xl">
  <div class="skeleton-debounced">
    <PageHeader
      title="Ubicaciones InvGate"
      description="Comparativa de ubicaciones reportadas por InvGate contra las oficinas registradas en la base de datos de MDA."
    />

    <!-- Stats Grid Skeleton -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 my-6">
      {
        Array.from({ length: 4 }).map(() => (
          <div class="card bg-base-100 shadow border border-base-200 p-4 space-y-3">
            <div class="h-4 w-28 skeleton rounded bg-base-200/50" />
            <div class="h-8 w-16 skeleton rounded-lg bg-base-200/50" />
          </div>
        ))
      }
    </div>

    <!-- Search & Filters skeleton -->
    <div class="mb-6 flex flex-col md:flex-row gap-4 items-stretch md:items-center justify-between">
      <!-- Filter tabs skeleton -->
      <div class="flex gap-2">
        <div class="h-10 w-24 skeleton rounded bg-base-200/50" />
        <div class="h-10 w-32 skeleton rounded bg-base-200/50" />
        <div class="h-10 w-28 skeleton rounded bg-base-200/50" />
      </div>

      <!-- Search input skeleton -->
      <div class="h-10 w-full md:w-80 skeleton rounded bg-base-200/50" />
    </div>

    <!-- Table Skeleton -->
    <div class="space-y-4">
      <DataTable
        ariaLabel="Cargando comparación de ubicaciones..."
        minWidthClass="min-w-[1000px]"
        headerGridClass={headerGridClass}
        rowGridClass={rowGridClass}
      >
        <div slot="header"><DataTableHeaderCell>Estado</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>Ubicación InvGate</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>NIS</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>CP</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>CC</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>Oficina MDA</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>Código MDA</DataTableHeaderCell></div>
        <div slot="header"><DataTableHeaderCell>Dirección MDA</DataTableHeaderCell></div>

        {
          Array.from({ length: 10 }).map(() => (
            <div
              class:list={[
                rowGridClass,
                "border-b border-base-200 px-4 py-4 last:border-b-0 animate-pulse",
              ]}
            >
              <div class="h-6 w-20 skeleton rounded-full bg-base-200/50" />
              <div class="h-4 w-40 skeleton rounded bg-base-200/50" />
              <div class="h-4 w-12 skeleton rounded bg-base-200/50" />
              <div class="h-4 w-20 skeleton rounded bg-base-200/50" />
              <div class="h-4 w-16 skeleton rounded bg-base-200/50" />
              <div class="h-4 w-32 skeleton rounded bg-base-200/50" />
              <div class="h-4 w-14 skeleton rounded bg-base-200/50" />
              <div class="h-4 w-48 skeleton rounded bg-base-200/50" />
            </div>
          ))
        }
      </DataTable>
    </div>
  </div>
</PageContainer>
