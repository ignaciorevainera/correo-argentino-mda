---
import { getCleanBase } from "@lib/baseUrl";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import { supportGuides } from "@db/schema";
import { asc } from "drizzle-orm";

const cleanBase = getCleanBase();

const guides = await db.query.supportGuides.findMany({
  orderBy: [asc(supportGuides.helpDeskName)],
});

const headerGridClass = "grid-cols-[80px_2.5fr_2fr_2fr_120px] gap-4";
const rowGridClass =
  "grid grid-cols-[80px_2.5fr_2fr_2fr_120px] items-center gap-4";
---

<PageContainer>
  <PageHeader 
    title="Administración de Soportes" 
    description="Gestiona la guía unificada de Mesa de Ayuda y edita la equivalencia de grupos y tópicos."
  />

  {/* ── Toolbar ── */}
  <div
    class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-8"
  >
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold text-base-content">
        Soportes registrados
      </h2>
      {
        guides.length > 0 && (
          <span
            id="guide-count-badge"
            class="badge badge-neutral badge-sm font-mono"
          >
            {guides.length}
          </span>
        )
      }
    </div>

    <div
      class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto"
    >
      <SearchBar
        id="admin-guide-search"
        label="Buscar soporte"
        placeholder="Buscar por mesa, nombre anterior o invgate"
        class="w-full sm:w-80"
      />
    </div>
  </div>

  {/* ── Tabla ── */}
  <div class="mt-4">
    <DataTable
      ariaLabel="Listado de soportes registrados para edición"
      minWidthClass="min-w-200"
      headerGridClass={headerGridClass}
      rowGridClass={rowGridClass}
    >
      <div slot="header">
        <DataTableHeaderCell sortKey="id">ID</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="helpdesk">Mesa de Ayuda</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="legacy">Nombre Anterior</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="invgate">Invgate</DataTableHeaderCell>
      </div>
      <div slot="header" class="text-right">
        <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
      </div>

      {
        guides.length === 0 ? (
          <div class="flex flex-col items-center gap-3 py-16 text-base-content/50 col-span-5">
            <div class="rounded-full bg-base-200 p-4">
              <Icon
                name="boxicons:buoy-filled"
                size={32}
                class="opacity-30"
                aria-hidden="true"
              />
            </div>
            <div class="space-y-1 text-center">
              <p class="text-sm font-semibold">No hay soportes registrados</p>
            </div>
          </div>
        ) : (
          guides.map((guide) => (
            <article
              data-table-row
              data-sort-id={guide.id}
              data-sort-helpdesk={guide.helpDeskName}
              data-sort-legacy={guide.legacyName ?? ""}
              data-sort-invgate={guide.invgateName ?? ""}
              data-search-text={`${guide.helpDeskName} ${guide.legacyName ?? ""} ${guide.invgateName ?? ""}`.toLowerCase()}
              class:list={[
                rowGridClass,
                "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-200/50 last:border-b-0",
              ]}
            >
              {/* ID */}
              <div class="min-w-0">
                <span class="font-mono text-sm text-base-content/50">
                  #{guide.id}
                </span>
              </div>

              {/* Mesa de Ayuda */}
              <div class="min-w-0">
                <p
                  data-highlight-target
                  class="truncate text-sm font-semibold text-base-content"
                >
                  {guide.helpDeskName || <span class="text-base-content/30 italic">Sin especificar</span>}
                </p>
              </div>

              {/* Nombre Anterior */}
              <div class="min-w-0">
                {guide.legacyName ? (
                  <span
                    data-highlight-target
                    class="text-sm px-2 py-0.5 bg-base-200 rounded font-mono text-base-content/85"
                  >
                    {guide.legacyName}
                  </span>
                ) : (
                  <span class="text-sm text-base-content/30 italic">N/A</span>
                )}
              </div>

              {/* Invgate */}
              <div class="min-w-0">
                {guide.invgateName ? (
                  <span
                    data-highlight-target
                    class="text-sm px-2 py-0.5 bg-secondary/10 text-secondary rounded font-medium"
                  >
                    {guide.invgateName}
                  </span>
                ) : (
                  <span class="text-sm text-base-content/30 italic">N/A</span>
                )}
              </div>

              {/* Acciones */}
              <div class="flex items-center justify-end">
                <ActionEditButton
                  href={`${cleanBase}admin/soportes/${guide.id}`}
                  ariaLabel={`Editar soporte ${guide.helpDeskName}`}
                />
              </div>
            </article>
          ))
        )}
      </DataTable>
    </div>
  </PageContainer>

<script>
  import {
    matchesSearchQuery,
    highlightSearchTargets,
  } from "@lib/clientSearch";

  const searchInput = document.querySelector<HTMLInputElement>(
    "#admin-guide-search",
  );
  const rows = document.querySelectorAll<HTMLElement>("[data-table-row]");
  const countBadge = document.querySelector<HTMLElement>(
    "#guide-count-badge",
  );

  function applyFilters() {
    const query = searchInput?.value.trim() || "";
    let visibleCount = 0;

    rows.forEach((row) => {
      const searchText = row.dataset.searchText || "";
      const isVisible = matchesSearchQuery(query, [searchText]);

      row.classList.toggle("hidden", !isVisible);
      highlightSearchTargets(row, isVisible ? query : "");

      if (isVisible) {
        visibleCount++;
      }
    });

    if (countBadge) {
      countBadge.textContent = visibleCount.toString();
    }
  }

  searchInput?.addEventListener("input", applyFilters);
</script>
