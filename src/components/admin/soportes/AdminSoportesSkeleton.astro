---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";

const headerGridClass = "grid-cols-[80px_2.5fr_2fr_2fr_120px] gap-4";
---

<PageContainer>
  <div class="skeleton-debounced">
    <PageHeader 
      title="Administración de Soportes" 
      description="Gestiona la guía unificada de Mesa de Ayuda y edita la equivalencia de grupos y tópicos."
    />

    <!-- Toolbar Skeleton -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-8">
      <div class="flex items-center gap-3">
        <div class="h-6 w-44 skeleton rounded"></div>
        <div class="h-5 w-8 skeleton rounded font-mono"></div>
      </div>
      <div class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto">
        <div class="h-10 w-full sm:w-80 skeleton rounded-lg"></div>
      </div>
    </div>

    <!-- Table Skeleton -->
    <div class="mt-4 border border-base-300 rounded-xl overflow-hidden bg-base-100">
      <div class={`grid ${headerGridClass} border-b border-base-300 px-4 py-3 bg-base-200/50`}>
        <div><div class="h-5 w-8 skeleton rounded"></div></div>
        <div><div class="h-5 w-28 skeleton rounded"></div></div>
        <div><div class="h-5 w-24 skeleton rounded"></div></div>
        <div><div class="h-5 w-16 skeleton rounded"></div></div>
        <div><div class="h-5 w-16 skeleton rounded justify-self-end"></div></div>
      </div>

      <div class="divide-y divide-base-300">
        {Array.from({ length: 8 }).map(() => (
          <div class={`grid ${headerGridClass} items-center px-4 py-4`}>
            <div><div class="h-4 w-6 skeleton rounded font-mono"></div></div>
            <div><div class="h-4 w-44 skeleton rounded"></div></div>
            <div><div class="h-4 w-28 skeleton rounded font-mono"></div></div>
            <div><div class="h-5 w-20 skeleton rounded"></div></div>
            <div class="flex justify-end"><div class="h-6 w-16 skeleton rounded"></div></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageContainer>
