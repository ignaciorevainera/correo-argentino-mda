---
import { db } from "@db/index";
import { users } from "@db/schema";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import { Icon } from "astro-icon/components";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ActionRoleButton from "@components/ui/ActionRoleButton.astro";
import ActionPasswordButton from "@components/ui/ActionPasswordButton.astro";
import { rolesMatrix } from "@lib/rolesMatrix";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import PasswordField from "@components/ui/forms/PasswordField.astro";
import AsyncFormScript from "@components/admin/ui/AsyncFormScript.astro";
import SectionCard from "@components/ui/SectionCard.astro";
import Modal from "@components/ui/Modal.astro";

interface Props {
  successMsg?: string;
  errorMsg?: string;
}

const { successMsg = "", errorMsg = "" } = Astro.props;

const allUsers = await db.select().from(users);

const headerGridClass = "grid-cols-[1fr_140px_320px] gap-4";
const rowGridClass = "grid grid-cols-[1fr_140px_320px] items-center gap-4";
---

<PageContainer width="xl">
  <PageHeader
    title="Gestión de usuarios"
    description="Alta de operadores, asignación de roles y revisión de accesos activos en el portal."
  />

  <div class="mb-6 flex justify-start">
    <button
      type="button"
      class="btn btn-soft btn-lg btn-accent gap-2"
      onclick="document.getElementById('modal-permissions-matrix').showModal()"
    >
      <Icon name="boxicons:universal-access-filled" size={24} />
      Ver tabla comparativa de permisos por rol
    </button>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_400px]">
    <!-- ─── Table: Usuarios registrados ─── -->
    <section
      class="lg:order-1"
      aria-labelledby="tabla-usuarios"
    >
      <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between gap-4">
          <h2
            id="tabla-usuarios"
            class="text-lg font-semibold text-base-content"
          >
            Usuarios registrados
          </h2>
          {
            allUsers.length > 0 && (
              <span class="badge badge-neutral badge-sm font-mono">
                {allUsers.length}
              </span>
            )
          }
        </div>

        <DataTable
          ariaLabel="Listado de usuarios registrados"
          minWidthClass="min-w-200"
          headerGridClass={headerGridClass}
          rowGridClass={rowGridClass}
        >
          <div slot="header">
            <DataTableHeaderCell sortKey="username"
              >Usuario</DataTableHeaderCell
            >
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="role">Rol</DataTableHeaderCell>
          </div>
          <div slot="header" class="text-right">
            <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
          </div>

          {
            allUsers.length === 0 ? (
              <div class="flex flex-col items-center gap-3 py-16 text-base-content/50">
                <div class="rounded-full bg-base-200 p-4">
                  <Icon
                    name="boxicons:group-filled"
                    size={32}
                    class="opacity-30"
                    aria-hidden="true"
                  />
                </div>
                <div class="space-y-1 text-center">
                  <p class="text-sm font-semibold">
                    No hay usuarios registrados
                  </p>
                  <p class="text-xs">
                    Creá el primer usuario desde el formulario.
                  </p>
                </div>
              </div>
            ) : (
              allUsers.map((u) => (
                <article
                  data-table-row
                  data-sort-username={u.username}
                  data-sort-role={u.role}
                  class:list={[
                    rowGridClass,
                    "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-200/50 last:border-b-0",
                  ]}
                >
                  <div class="min-w-0">
                    <div class="flex items-center gap-3">
                      <div
                        class:list={[
                          "flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-bold shadow-sm",
                          u.role === "admin"
                            ? "bg-error text-error-content"
                            : u.role === "supervisor"
                              ? "bg-info text-info-content"
                              : u.role === "team_leader" || u.role === "team-leader" || u.role === "team leader"
                                ? "bg-accent text-accent-content"
                                : u.role === "referent"
                                  ? "bg-warning text-warning-content"
                                  : "bg-neutral text-neutral-content",
                        ]}
                        aria-hidden="true"
                      >
                        {u.username.slice(0, 2).toUpperCase()}
                      </div>
                      <span class="font-medium font-mono text-base-content truncate">
                        {u.username}
                      </span>
                    </div>
                  </div>

                  <div class="flex items-center gap-2 min-w-0">
                    <span
                      class:list={[
                        "badge badge-sm font-bold uppercase tracking-wide whitespace-nowrap",
                        u.role === "admin"
                          ? "badge-error"
                          : u.role === "supervisor"
                            ? "badge-info"
                            : u.role === "team_leader" || u.role === "team-leader" || u.role === "team leader"
                              ? "badge-accent"
                              : u.role === "referent"
                                ? "badge-warning"
                                : "badge-neutral",
                      ]}
                    >
                      {u.role === "admin"
                        ? "Admin"
                        : u.role === "supervisor"
                          ? "Supervisor"
                          : u.role === "team_leader" || u.role === "team-leader" || u.role === "team leader"
                            ? "Team Leader"
                            : u.role === "referent"
                              ? "Referente"
                              : "Agente"}
                    </span>
                  </div>

                  <div class="flex items-center justify-end gap-2">
                    <ActionRoleButton
                      data-action="change-role-btn"
                      data-user-id={u.id}
                      data-user-role={u.role}
                      ariaLabel={`Cambiar rol de ${u.username}`}
                    />

                    <ActionEditButton
                      onclick={`document.getElementById('modal-rename-${u.id}').showModal()`}
                      ariaLabel={`Renombrar usuario ${u.username}`}
                    />

                    <ActionPasswordButton
                      onclick={`document.getElementById('modal-reset-${u.id}').showModal()`}
                      ariaLabel={`Blanquear contraseña de ${u.username}`}
                    />
                  </div>

                  {/* ── Modales (Fuera del flujo visual de la fila) ── */}
                  <Modal id={`modal-rename-${u.id}`}>
                    <Fragment slot="content">
                      <h3 class="mb-1 text-base font-semibold text-base-content">
                        Renombrar usuario
                      </h3>
                      <p class="mb-4 text-xs text-base-content/60">
                        Usuario actual:{" "}
                        <span class="font-mono font-semibold">
                          {u.username}
                        </span>
                      </p>
                      <form method="POST" class="space-y-3" data-async-form>
                        <input
                          type="hidden"
                          name="action"
                          value="rename-username"
                        />
                        <input type="hidden" name="userId" value={u.id} />
                        <FormField
                          id={`new-username-${u.id}`}
                          name="newUsername"
                          required
                          label="Nuevo nombre de red"
                          placeholder={u.username}
                          autocomplete="off"
                          inputClass="input-sm"
                        />
                        <div class="flex items-center justify-end gap-2 mt-4 pt-3 border-t border-base-200">
                          <button
                            type="submit"
                            class="btn btn-secondary btn-sm gap-1"
                          >
                            <Icon name="boxicons:check-filled" size={14} />
                            Guardar
                          </button>
                          <button
                            type="button"
                            class="btn btn-ghost btn-sm"
                            onclick="this.closest('dialog').close()"
                          >
                            Cancelar
                          </button>
                        </div>
                      </form>
                    </Fragment>
                  </Modal>

                  <Modal id={`modal-reset-${u.id}`}>
                    <Fragment slot="content">
                      <h3 class="mb-1 text-base font-semibold text-base-content">
                        Blanquear contraseña
                      </h3>
                      <p class="mb-4 text-xs text-base-content/60">
                        Establece una nueva contraseña para{" "}
                        <span class="font-mono font-semibold">
                          {u.username}
                        </span>
                        .
                      </p>
                      <form method="POST" class="space-y-3" data-async-form>
                        <input
                          type="hidden"
                          name="action"
                          value="reset-password"
                        />
                        <input type="hidden" name="userId" value={u.id} />
                        <PasswordField
                          id={`reset-password-${u.id}`}
                          name="newPassword"
                          required
                          label="Nueva contraseña"
                          confirmPassword={true}
                          confirmLabel="Repetir nueva contraseña"
                          autocomplete="new-password"
                          inputClass="input-sm"
                        />
                        <div class="flex items-center justify-end gap-2 mt-4 pt-3 border-t border-base-200">
                          <button
                            type="submit"
                            class="btn btn-warning btn-sm gap-1"
                          >
                            <Icon
                              name="boxicons:lock-open-filled"
                              size={14}
                            />
                            Blanquear
                          </button>
                          <button
                            type="button"
                            class="btn btn-ghost btn-sm"
                            onclick="this.closest('dialog').close()"
                          >
                            Cancelar
                          </button>
                        </div>
                      </form>
                    </Fragment>
                  </Modal>
                </article>
              ))
            )
          }
        </DataTable>
      </div>
    </section>

    <!-- ─── Form: Nuevo usuario ─── -->
    <section class="lg:order-2" aria-labelledby="form-nuevo-usuario">
      <SectionCard class="shadow-md lg:sticky lg:top-24">
        <h2 id="form-nuevo-usuario" class="card-title text-base gap-2">
          <div
            aria-hidden="true"
            class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-secondary/10 text-secondary"
          >
            <Icon name="boxicons:user-plus-filled" size={18} />
          </div>
          Nuevo usuario
        </h2>

        {
          (successMsg || errorMsg) && (
            <script is:inline define:vars={{ successMsg, errorMsg }}>
              window.addEventListener('load', () => {
                if (successMsg) window.showToast?.(successMsg, "alert-success");
                if (errorMsg) window.showToast?.(errorMsg, "alert-error");
              });
            </script>
          )
        }

        <form method="POST" class="space-y-4" data-async-form>
          <FormField
            id="admin-username"
            name="username"
            required
            label="Nombre de red"
            placeholder="ej: jgonzalez"
            autocomplete="off"
            helpText="Credencial de dominio del operador."
          />

          <PasswordField
            id="admin-password"
            name="password"
            required
            label="Contraseña inicial"
            confirmPassword={true}
            confirmLabel="Repetir contraseña"
            autocomplete="new-password"
          />

          <SelectField
            id="admin-role"
            name="role"
            label="Rol en sistema"
            options={[
              { value: "agent", label: "Agente" },
              { value: "referent", label: "Referente" },
              { value: "team_leader", label: "Team Leader" },
              { value: "supervisor", label: "Supervisor" },
              { value: "admin", label: "Administrador" }
            ]}
            helpText="Define el nivel de acceso a módulos del portal."
          />

          <input type="hidden" name="action" value="create" />
          <button type="submit" class="btn btn-secondary w-full gap-2 mt-2">
            <Icon name="boxicons:user-check-filled" size={18} />
            Dar de alta
          </button>
        </form>
      </SectionCard>
    </section>
  </div>
</PageContainer>

<Modal id="modal-change-role">
  <Fragment slot="content">
    <h3 class="mb-1 text-base font-semibold text-base-content">
      Cambiar rol de usuario
    </h3>
    <p class="mb-4 text-xs text-base-content/60">
      Modifica el rol del usuario en el sistema.
    </p>
    <form method="POST" class="space-y-4" data-async-form>
      <input type="hidden" name="action" value="change-role" />
      <input type="hidden" name="userId" id="change-role-user-id" />
      <SelectField
        id="change-role-select"
        name="newRole"
        label="Nuevo rol"
        selectClass="select-sm"
        options={[
          { value: "agent", label: "Agente" },
          { value: "referent", label: "Referente" },
          { value: "team_leader", label: "Team Leader" },
          { value: "supervisor", label: "Supervisor" },
          { value: "admin", label: "Administrador" }
        ]}
      />

      <div
        id="role-desc-container"
        class="p-3 bg-base-200 border border-base-300 rounded-lg text-xs space-y-1 transition-all duration-300"
      >
        <span class="font-bold text-base-content block"
          >Permisos del rol:</span
        >
        <p id="role-permissions-desc" class="text-base-content/70">
          Selecciona un rol para ver sus permisos.
        </p>
      </div>

      <div class="flex items-center justify-end gap-2 mt-4 pt-3 border-t border-base-200">
        <button type="submit" class="btn btn-primary btn-sm gap-1">
          <Icon name="boxicons:check-filled" size={14} />
          Guardar
        </button>
        <button
          type="button"
          class="btn btn-ghost btn-sm"
          onclick="this.closest('dialog').close()">Cancelar</button
        >
      </div>
    </form>
  </Fragment>
</Modal>

<Modal id="modal-permissions-matrix" title="Matriz de permisos por rol" icon="boxicons:universal-access-filled" size="full" class="w-fit max-w-[calc(100vw-3rem)]">
  <Fragment slot="content">
    <p class="mb-4 text-xs text-base-content/60">
      Detalle comparativo de las acciones y accesos permitidos para cada rol
      en la plataforma.
    </p>
    <div>
      <table class="table table-xs md:table-sm w-full">
        <thead>
          <tr class="text-base-content/70">
            <th class="bg-base-200/30">Funcionalidad / Ruta</th>
            <th class="bg-neutral text-neutral-content text-center font-bold"
              >Agente</th
            >
            <th class="bg-warning text-warning-content text-center font-bold"
              >Referente</th
            >
            <th class="bg-accent text-accent-content text-center font-bold"
              >Team Leader</th
            >
            <th class="bg-info text-info-content text-center font-bold"
              >Supervisor</th
            >
            <th class="bg-error text-error-content text-center font-bold"
              >Admin</th
            >
          </tr>
        </thead>
        <tbody>
          {
            rolesMatrix.map((row) => (
              <tr class="hover:bg-base-200/20 transition-colors">
                <td class="font-medium text-base-content/80 text-xs md:text-sm whitespace-nowrap flex items-center gap-2 py-3">
                  <Icon
                    name={row.icon}
                    size={16}
                    class="text-base-content/65 shrink-0"
                  />
                  <span>{row.feature}</span>
                </td>
                <td class="text-center bg-base-200/5">
                  {row.agent ? (
                    <Icon
                      name="boxicons:check"
                      class="inline-block text-success"
                      size={24}
                    />
                  ) : (
                    <Icon
                      name="boxicons:x"
                      class="inline-block text-error"
                      size={24}
                    />
                  )}
                </td>
                <td class="text-center bg-warning/5">
                  {row.referent ? (
                    <Icon
                      name="boxicons:check"
                      class="inline-block text-success"
                      size={24}
                    />
                  ) : (
                    <Icon
                      name="boxicons:x"
                      class="inline-block text-error"
                      size={24}
                    />
                  )}
                </td>
                <td class="text-center bg-accent/5">
                  {row.team_leader ? (
                    <Icon
                      name="boxicons:check"
                      class="inline-block text-success"
                      size={24}
                    />
                  ) : (
                    <Icon
                      name="boxicons:x"
                      class="inline-block text-error"
                      size={24}
                    />
                  )}
                </td>
                <td class="text-center bg-info/5">
                  {row.supervisor ? (
                    <Icon
                      name="boxicons:check"
                      class="inline-block text-success"
                      size={24}
                    />
                  ) : (
                    <Icon
                      name="boxicons:x"
                      class="inline-block text-error"
                      size={24}
                    />
                  )}
                </td>
                <td class="text-center bg-error/5">
                  {row.admin ? (
                    <Icon
                      name="boxicons:check"
                      class="inline-block text-success"
                      size={24}
                    />
                  ) : (
                    <Icon
                      name="boxicons:x"
                      class="inline-block text-error"
                      size={24}
                    />
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </Fragment>
</Modal>

<AsyncFormScript />

<script>
  // La validación de contraseñas es gestionada internamente por el componente PasswordField

  function initUsersAdmin() {
    const roleSelect = document.getElementById("change-role-select") as HTMLSelectElement | null;
    if (!roleSelect) return false;

    const roleDescriptions = {
      admin:
        "Acceso total al sistema. Puede gestionar usuarios, configuraciones generales, ver el sistema de diseño y acceder a todas las herramientas de supervisión.",
      supervisor:
        "Acceso completo a la sección de Supervisión. Puede ingresar a Cronograma, Auditorías de Calidad y Asignación de Autogestiones. Acceso general al panel de administración excepto la creación de usuarios.",
      team_leader:
        "Acceso intermedio. Puede modificar cronogramas, controlar la asistencia del equipo, auditar la calidad y realizar asignaciones de autogestión. Acceso general al panel de administración excepto la creación de usuarios.",
      referent:
        "Acceso limitado a la sección de Supervisión. Únicamente tiene permisos para ingresar a la pantalla de Asignación de Autogestiones.",
      agent:
        "Acceso operativo básico. Consulta de catálogos y herramientas comunes. No tiene acceso a pantallas de Supervisión ni de Administración.",
    };

    const modal = document.getElementById("modal-change-role") as HTMLDialogElement | null;
    const userIdInput = document.getElementById("change-role-user-id") as HTMLInputElement | null;
    const descEl = document.getElementById("role-permissions-desc");
    const containerEl = document.getElementById("role-desc-container");

    const updateDesc = (role: keyof typeof roleDescriptions) => {
      if (descEl) {
        descEl.textContent =
          roleDescriptions[role] || "Sin descripción disponible.";
      }
      if (containerEl) {
        containerEl.className =
          "p-3 border rounded-lg text-xs space-y-1 transition-all duration-300";
        if (role === "admin") {
          containerEl.classList.add("bg-error/5", "border-error/30");
        } else if (role === "supervisor") {
          containerEl.classList.add("bg-info/5", "border-info/30");
        } else if (role === "team_leader") {
          containerEl.classList.add("bg-accent/5", "border-accent/30");
        } else if (role === "referent") {
          containerEl.classList.add("bg-warning/5", "border-warning/30");
        } else {
          containerEl.classList.add("bg-base-200", "border-base-300");
        }
      }
    };

    roleSelect?.addEventListener("change", (e) => {
      const val = (e.target as HTMLSelectElement).value as keyof typeof roleDescriptions;
      updateDesc(val);
    });

    document
      .querySelectorAll('[data-action="change-role-btn"]')
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const userId = btn.getAttribute("data-user-id");
          const userRole = btn.getAttribute("data-user-role") as keyof typeof roleDescriptions;

          if (userIdInput && roleSelect && modal) {
            userIdInput.value = userId || "";
            roleSelect.value = userRole || "agent";
            updateDesc(roleSelect.value as keyof typeof roleDescriptions);
            modal.showModal();
          }
        });
      });

    return true;
  }

  function setupUsersObserver() {
    if (initUsersAdmin()) return;

    const observer = new MutationObserver((_, obs) => {
      if (initUsersAdmin()) {
        obs.disconnect();
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });
  }

  setupUsersObserver();

  document.addEventListener("astro:page-load", () => {
    setupUsersObserver();
  });
</script>
