---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";

const headerGridClass = "grid-cols-[1fr_140px_320px] gap-4";
const rowGridClass = "grid grid-cols-[1fr_140px_320px] items-center gap-4";
---

<PageContainer width="xl">
  <PageHeader
    title="Gestión de usuarios"
    description="Alta de operadores, asignación de roles y revisión de accesos activos en el portal."
  />

  <div class="mb-6 flex justify-start">
    <div class="h-12 w-96 skeleton rounded-xl"></div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <!-- Form Skeleton -->
    <div class="lg:order-2">
      <div class="card bg-base-100 border border-base-300 shadow-md">
        <div class="card-body gap-5">
          <div class="h-6 w-32 skeleton rounded"></div>
          <div class="space-y-4">
            <div class="space-y-2">
              <div class="h-3 w-24 skeleton rounded"></div>
              <div class="h-10 w-full skeleton rounded-lg"></div>
            </div>
            <div class="space-y-2">
              <div class="h-3 w-24 skeleton rounded"></div>
              <div class="h-10 w-full skeleton rounded-lg"></div>
            </div>
            <div class="space-y-2">
              <div class="h-3 w-24 skeleton rounded"></div>
              <div class="h-10 w-full skeleton rounded-lg"></div>
            </div>
            <div class="h-10 w-full skeleton rounded-lg mt-2"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Table Skeleton -->
    <div class="lg:col-span-2 lg:order-1 space-y-3">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-lg font-semibold text-base-content">
          Usuarios registrados
        </h2>
        <div class="h-5 w-8 skeleton rounded-full"></div>
      </div>

      <DataTable
        ariaLabel="Cargando usuarios..."
        minWidthClass="min-w-200"
        headerGridClass={headerGridClass}
        rowGridClass={rowGridClass}
      >
        <div slot="header">
          <DataTableHeaderCell sortKey="username">Usuario</DataTableHeaderCell>
        </div>
        <div slot="header">
          <DataTableHeaderCell sortKey="role">Rol</DataTableHeaderCell>
        </div>
        <div slot="header" class="text-right">
          <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
        </div>

        {
          Array.from({ length: 4 }).map(() => (
            <div
              class:list={[
                rowGridClass,
                "border-b border-base-300 px-4 py-4 last:border-b-0",
              ]}
            >
              <div class="flex items-center gap-3">
                <div class="size-8 rounded-full skeleton" />
                <div class="h-4 w-28 skeleton rounded" />
              </div>
              <div class="h-5 w-20 skeleton rounded-full" />
              <div class="flex justify-end gap-2">
                <div class="h-8 w-14 skeleton rounded-lg" />
                <div class="h-8 w-20 skeleton rounded-lg" />
                <div class="h-8 w-20 skeleton rounded-lg" />
              </div>
            </div>
          ))
        }
      </DataTable>
    </div>
  </div>
</PageContainer>
