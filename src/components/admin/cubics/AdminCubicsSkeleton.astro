---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";

const headerGridClass = "grid-cols-[1.5fr_130px_100px_2fr_140px] gap-4";
const rowGridClass =
  "grid grid-cols-[1.5fr_130px_100px_2fr_140px] items-center gap-4";
---

<PageContainer>
  <div class="skeleton-debounced">
    <PageHeader
      description="Administración del parque de ordenadores de la Mesa de Ayuda, asignaciones y estado operativo."
    />

    {/* ── Toolbar Skeleton ── */}
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <h2 class="text-lg font-semibold text-base-content">
          Ordenadores registrados
        </h2>
        <div class="h-5 w-8 skeleton rounded-full"></div>
      </div>
      <div class="h-10 w-32 skeleton rounded-lg"></div>
    </div>

    {/* ── Tabla Skeleton ── */}
    <DataTable
      ariaLabel="Cargando ordenadores..."
      minWidthClass="min-w-200"
      headerGridClass={headerGridClass}
      rowGridClass={rowGridClass}
      class="mt-4"
    >
      <div slot="header">
        <DataTableHeaderCell sortKey="name">Terminal</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="ip">Dirección IP</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="status">Estado</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell>Operadores</DataTableHeaderCell>
      </div>
      <div slot="header" class="text-right">
        <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
      </div>

      {
        Array.from({ length: 5 }).map(() => (
          <div class:list={[rowGridClass, "border-b border-base-300 px-4 py-4 last:border-b-0"]}>
            <div class="h-4 w-28 skeleton rounded font-mono"></div>
            <div class="h-5 w-24 skeleton rounded"></div>
            <div class="space-y-1">
              <div class="h-4 w-16 skeleton rounded-full"></div>
              <div class="h-3 w-12 skeleton rounded"></div>
            </div>
            <div class="flex gap-1">
              <div class="size-8 rounded-full skeleton"></div>
              <div class="size-8 rounded-full skeleton"></div>
            </div>
            <div class="flex justify-end gap-2">
              <div class="h-7 w-16 skeleton rounded-lg"></div>
              <div class="h-7 w-16 skeleton rounded-lg"></div>
            </div>
          </div>
        ))
      }
    </DataTable>
  </div>
</PageContainer>
