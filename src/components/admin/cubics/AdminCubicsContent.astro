---
import { db } from "@db/index";
import { cubics, agents, operatorAttendance } from "@db/schema";
import { asc, and, eq } from "drizzle-orm";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import { Icon } from "astro-icon/components";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ActionDeleteButton from "@components/ui/ActionDeleteButton.astro";
import { getShiftType } from "@lib/cubics";
import OperatorAvatar from "@components/cubics/OperatorAvatar.astro";




const allCubics = await db.query.cubics.findMany({
  orderBy: [asc(cubics.name)],
  with: {
    assignments: {
      with: {
        agent: true,
      },
    },
  },
});

const todayStr = new Date().toLocaleDateString("en-CA", { timeZone: "America/Argentina/Buenos_Aires" });



const allAgents = await db
  .select({
    id: agents.id,
    horarioDefault: agents.horarioDefault,
    entradaReal: operatorAttendance.entradaReal,
  })
  .from(agents)
  .leftJoin(
    operatorAttendance,
    and(
      eq(operatorAttendance.agentId, agents.id),
      eq(operatorAttendance.date, todayStr)
    )
  );

const agentShiftMap = new Map<number, "Diurno" | "Nocturno">();
for (const agent of allAgents) {
  const shiftType = getShiftType(agent.entradaReal, agent.horarioDefault);
  agentShiftMap.set(agent.id, shiftType);
}

const statusLabel: Record<string, string> = {
  online: "Online",
  offline: "Offline",
};

const statusBadgeClass: Record<string, string> = {
  online: "badge-success",
  offline: "badge-error",
};

function timeAgo(dateString: string | null) {
  if (!dateString) return 'Nunca';
  
  const date = new Date(dateString);
  const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
  
  if (seconds < 60) return 'Hace un momento';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `Hace ${minutes} min`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `Hace ${hours} hr`;
  const days = Math.floor(hours / 24);
  return `Hace ${days} día${days > 1 ? 's' : ''}`;
}

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith('/') ? base : base + '/';
const headerGridClass = "grid-cols-[1.5fr_130px_100px_2fr_140px] gap-4";
const rowGridClass =
  "grid grid-cols-[1.5fr_130px_100px_2fr_140px] items-center gap-4";
---

<PageContainer>
  <PageHeader
    description="Administración del parque de ordenadores de la Mesa de Ayuda, asignaciones y estado operativo."
  />



  {/* ── Toolbar ── */}
  <div class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold text-base-content">
        Ordenadores registrados
      </h2>
      {allCubics.length > 0 && (
        <span class="badge badge-neutral badge-sm font-mono">
          {allCubics.length}
        </span>
      )}
    </div>

    <a href={`${cleanBase}admin/inventario-terminales/new`} class="btn btn-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
      <Icon name="boxicons:plus" size={18} />
      Registrar nuevo cubic
    </a>
  </div>

  {/* ── Tabla ── */}
  <DataTable
    ariaLabel="Listado de ordenadores registrados"
    minWidthClass="min-w-200"
    headerGridClass={headerGridClass}
    rowGridClass={rowGridClass}
  >
    <div slot="header">
      <DataTableHeaderCell sortKey="name">Terminal</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="ip">Dirección IP</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="status">Estado</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell>Operadores</DataTableHeaderCell>
    </div>
    <div slot="header" class="text-right">
      <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
    </div>

    {allCubics.length === 0 ? (
      <div class="flex flex-col items-center gap-3 py-16 text-base-content/50">
        <div class="rounded-full bg-base-200 p-4">
          <Icon
            name="boxicons:server-filled"
            size={32}
            class="opacity-30"
            aria-hidden="true"
          />
        </div>
        <div class="space-y-1 text-center">
          <p class="text-sm font-semibold">No hay ordenadores registrados</p>
          <p class="text-xs">
            Comenzá registrando el primer cubic desde el botón superior.
          </p>
        </div>
      </div>
    ) : (
      allCubics.map((cubic) => {
        return (
          <article
            data-table-row
            data-sort-name={cubic.name}
            data-sort-ip={cubic.ip ?? ""}
            data-sort-status={cubic.status}
            class:list={[
              rowGridClass,
              "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-200/50 last:border-b-0",
            ]}
          >
            {/* Terminal */}
            <div class="min-w-0">
              <p class="truncate font-mono text-sm font-semibold text-base-content">
                {cubic.name}
              </p>
            </div>

            {/* IP */}
            <div>
              <span class="rounded-md bg-base-200 px-2 py-1 font-mono text-sm text-base-content/80">
                {cubic.ip || <span class="text-base-content/30">&mdash;</span>}
              </span>
            </div>

            {/* Estado */}
            <div>
              <div class="flex flex-col gap-1">
                <span
                  class:list={[
                    "badge badge-sm font-bold uppercase tracking-wide",
                    statusBadgeClass[cubic.status] ?? "badge-neutral",
                    cubic.status === 'online' ? 'animate-pulse' : '',
                  ]}
                >
                  {statusLabel[cubic.status] ?? cubic.status}
                </span>
                <span class="text-xs text-base-content/50">
                  {timeAgo(cubic.lastPing)}
                </span>
              </div>
            </div>

            {/* Operadores */}
            <div class="min-w-0">
              {cubic.assignments.length > 0 ? (
                <div class="flex flex-wrap items-center gap-1.5">
                  {cubic.assignments.map((assignment) => {
                    const shift = agentShiftMap.get(assignment.agent.id) || "Diurno";
                    return (
                      <OperatorAvatar
                        name={`${assignment.agent.name} — ${shift}`}
                        avatarInitials={assignment.agent.avatarInitials ?? assignment.agent.name.slice(0, 2).toUpperCase()}
                        shiftType={shift}
                        size="sm"
                      />
                    );
                  })}
                </div>
              ) : (
                <span class="text-xs text-base-content/30">&mdash;</span>
              )}
            </div>

            {/* Acciones */}
            <div class="flex items-center justify-end gap-2">
              <ActionEditButton
                href={`${cleanBase}admin/inventario-terminales/${cubic.id}`}
                ariaLabel={`Editar ${cubic.name}`}
              />

              <form
                method="POST"
                class="inline"
                onsubmit="return confirm('¿Estás seguro de que deseas dar de baja este ordenador del sistema?')"
              >
                <input type="hidden" name="action" value="delete_cubic" />
                <input type="hidden" name="cubicId" value={cubic.id} />
                <ActionDeleteButton
                  ariaLabel={`Eliminar ${cubic.name}`}
                />
              </form>
            </div>
          </article>
        );
      })
    )}
  </DataTable>
</PageContainer>

<script>
  setTimeout(() => {
    window.location.reload();
  }, 300000);
</script>

