---
import { getDisponibilidadHoy } from "@/lib/disponibilidad";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import { Icon } from "astro-icon/components";



const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

// Fetch operators using the availability service
const allOperatorsRaw = await getDisponibilidadHoy();
allOperatorsRaw.sort((a, b) => a.nombre.localeCompare(b.nombre));

const allOperators = allOperatorsRaw.map((op) => ({
  id: op.agentId,
  name: op.nombre,
  username: op.username || "",
  locationName: op.location || "Monte Grande",
  status: op.disponible ? "disponible" : (op.motivo || "Franco"),
}));

const statusLabels: Record<string, string> = {
  disponible: "Disponible",
  "En break": "En Break",
  "Fuera de horario": "Fuera de Horario",
  Franco: "Franco",
  Licencia: "Licencia",
  Vacaciones: "Vacaciones",
};

const statusBadgeClass: Record<string, string> = {
  disponible: "badge-success text-white shadow-sm shadow-success/20",
  "En break": "badge-warning text-warning-content shadow-sm shadow-warning/20",
  "Fuera de horario": "badge-neutral text-neutral-content/75 opacity-70",
  Franco: "badge-neutral text-neutral-content/50 opacity-60",
  Licencia: "badge-error text-error-content shadow-sm shadow-error/20",
  Vacaciones: "badge-info text-info-content shadow-sm shadow-info/20",
};

const headerGridClass = "grid-cols-[90px_1.2fr_1fr_140px_120px] gap-4";
const rowGridClass =
  "grid grid-cols-[90px_1.2fr_1fr_140px_120px] items-center gap-4";
---

<PageContainer>
  <PageHeader
    description="Administración de la plantilla de operadores, ubicaciones y estados."
  />



  <div
    class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
  >
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold text-base-content">
        Operadores registrados
      </h2>
      {
        allOperators.length > 0 && (
          <span
            id="operator-count-badge"
            class="badge badge-neutral badge-sm font-mono"
          >
            {allOperators.length}
          </span>
        )
      }
    </div>

    <div
      class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto"
    >
      <SearchInput
        id="admin-operator-search"
        label="Buscar operador"
        placeholder="Buscar por ID, nombre o ubicación"
        class="w-full sm:w-64"
      />
      <a
        href={`${cleanBase}admin/operadores/create`}
        class="btn btn-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent w-full sm:w-auto"
      >
        <Icon name="boxicons:plus" size={18} />
        Nuevo operador
      </a>
    </div>
  </div>

  <DataTable
    ariaLabel="Listado de operadores registrados"
    minWidthClass="min-w-200"
    headerGridClass={headerGridClass}
    rowGridClass={rowGridClass}
    emptyStateTitle="No hay coincidencias"
    emptyStateDescription="No hemos podido encontrar operadores que coincidan con los filtros seleccionados. Probá modificando los criterios o restableciendo la búsqueda para explorar el directorio completo."
    showClearButton={true}
    clearButtonHref={`${cleanBase}admin/operadores`}
  >
    <div slot="header">
      <DataTableHeaderCell sortKey="id">ID</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="name">Nombre</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="location"
        >Ubicación presencial</DataTableHeaderCell
      >
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="status">Estado</DataTableHeaderCell>
    </div>
    <div slot="header" class="text-right">
      <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
    </div>

    {
      allOperators.length === 0 ? (
        <div class="flex flex-col items-center gap-3 py-16 text-base-content/50">
          <div class="rounded-full bg-base-200 p-4">
            <Icon
              name="boxicons:user-id-card-filled"
              size={32}
              class="opacity-30"
              aria-hidden="true"
            />
          </div>
          <div class="space-y-1 text-center">
            <p class="text-sm font-semibold">No hay operadores registrados</p>
            <p class="text-xs">
              Comenzá cargando el primer operador desde el botón superior.
            </p>
          </div>
        </div>
      ) : (
        <>
          {allOperators.map((op) => (
            <article
              data-table-row
              data-sort-id={op.id}
              data-sort-name={op.name}
              data-sort-location={op.locationName}
              data-sort-status={op.status}
              data-search-text={`${op.id} ${op.username} ${op.name} ${op.locationName} ${statusLabels[op.status] ?? op.status}`.toLowerCase()}
              class:list={[
                rowGridClass,
                "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-200/50 last:border-b-0",
              ]}
            >
              <div>
                <span
                  data-highlight-target
                  class="rounded-md bg-base-200 px-2 py-1 font-mono text-sm font-semibold text-base-content"
                >
                  ID: {op.id}
                </span>
              </div>

              <div class="min-w-0">
                <p
                  data-highlight-target
                  class="truncate text-sm font-semibold text-base-content"
                >
                  {op.name} {op.username ? `(${op.username})` : ""}
                </p>
              </div>

              <div class="min-w-0">
                {op.locationName ? (
                  <span
                    data-highlight-target
                    class="truncate text-sm text-base-content/70"
                  >
                    {op.locationName}
                  </span>
                ) : (
                  <span class="text-base-content/30">&mdash;</span>
                )}
              </div>

              <div>
                <span
                  class:list={[
                    "badge badge-xs font-bold uppercase tracking-wider text-tiny py-2 h-auto whitespace-nowrap",
                    statusBadgeClass[op.status] ?? "badge-neutral",
                  ]}
                >
                  {statusLabels[op.status] ?? op.status}
                </span>
              </div>

              <div class="flex items-center justify-end gap-1">
                <a
                  href={`${cleanBase}admin/operadores/edit/${op.id}`}
                  class="btn btn-sm btn-ghost h-7 px-2 text-base-content/60 hover:text-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                  aria-label={`Editar ${op.name}`}
                >
                  <Icon name="boxicons:pencil-filled" size={14} />
                  <span class="hidden sm:inline">Editar</span>
                </a>

                <form
                  method="POST"
                  action={`${cleanBase}admin/operadores/edit/${op.id}/eliminar`}
                  class="inline"
                  onsubmit="return confirm('¿Estás seguro de que querés eliminar este operador? Se borrarán también sus turnos vinculados.')"
                >
                  <button
                    type="submit"
                    class="btn btn-ghost btn-sm h-7 rounded-lg px-2 text-base-content/60 hover:text-error hover:bg-error/10 transition-all duration-200"
                    aria-label={`Eliminar ${op.name}`}
                  >
                    <Icon name="boxicons:trash-filled" size={14} />
                    <span class="hidden sm:inline">Eliminar</span>
                  </button>
                </form>
              </div>
            </article>
          ))}
        </>
      )
    }
  </DataTable>
</PageContainer>

<script>
  import {
    matchesSearchQuery,
    highlightSearchTargets,
  } from "@lib/clientSearch";

  function initSearch() {
    const searchInput = document.querySelector<HTMLInputElement>(
      "#admin-operator-search",
    );
    if (!searchInput) return false;

    const rows = document.querySelectorAll<HTMLElement>("[data-table-row]");
    const countBadge = document.querySelector<HTMLElement>(
      "#operator-count-badge",
    );

    function applyFilters() {
      const query = searchInput.value.trim();
      let visibleCount = 0;

      rows.forEach((row) => {
        const searchText = row.dataset.searchText || "";
        const isVisible = matchesSearchQuery(query, [searchText]);

        row.classList.toggle("hidden", !isVisible);
        highlightSearchTargets(row, isVisible ? query : "");

        if (isVisible) {
          visibleCount++;
        }
      });

      if (countBadge) {
        countBadge.textContent = visibleCount.toString();
      }
    }

    searchInput.addEventListener("input", applyFilters);
    return true;
  }

  function setupSearchObserver() {
    if (initSearch()) return;

    const observer = new MutationObserver((_, obs) => {
      if (initSearch()) {
        obs.disconnect();
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });
  }

  setupSearchObserver();

  document.addEventListener("astro:page-load", () => {
    setupSearchObserver();
  });
</script>
