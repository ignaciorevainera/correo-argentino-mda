---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import { Icon } from "astro-icon/components";

const headerGridClass = "grid-cols-[1.5fr_1.5fr_1.5fr_140px] gap-4";
const rowGridClass =
  "grid grid-cols-[1.5fr_1.5fr_1.5fr_140px] items-center gap-4";
---

<PageContainer>
  <div class="skeleton-debounced">
    <PageHeader
      description="Listar, crear, modificar y eliminar los contactos útiles de la mesa de ayuda."
    />

    {/* ── Toolbar Skeleton ── */}
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <h2 class="text-lg font-semibold text-base-content">
          Contactos registrados
        </h2>
        <div class="h-5 w-8 skeleton rounded-full"></div>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto">
        <div class="h-10 w-full sm:w-44 skeleton rounded-lg"></div>
        <div class="h-10 w-full sm:w-64 skeleton rounded-lg"></div>
        <div class="h-10 w-full sm:w-32 skeleton rounded-lg"></div>
      </div>
    </div>

    {/* ── Tabla Skeleton ── */}
    <DataTable
      ariaLabel="Cargando contactos..."
      minWidthClass="min-w-200"
      headerGridClass={headerGridClass}
      rowGridClass={rowGridClass}
      class="mt-4"
    >
      <div slot="header">
        <DataTableHeaderCell sortKey="provider">Proveedor</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="service">Servicio</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="category">Categoría</DataTableHeaderCell>
      </div>
      <div slot="header" class="text-right">
        <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
      </div>

      {
        Array.from({ length: 5 }).map(() => (
          <div class:list={[rowGridClass, "border-b border-base-300 px-4 py-4 last:border-b-0"]}>
            <div class="h-4 w-24 skeleton rounded"></div>
            <div class="h-4 w-32 skeleton rounded"></div>
            <div class="h-5 w-20 skeleton rounded-full"></div>
            <div class="flex justify-end gap-2">
              <div class="h-7 w-16 skeleton rounded-lg"></div>
              <div class="h-7 w-16 skeleton rounded-lg"></div>
            </div>
          </div>
        ))
      }
    </DataTable>
  </div>
</PageContainer>
