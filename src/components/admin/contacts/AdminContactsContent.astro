---
import { db } from "@db/index";
import { providerContacts, contactCategories } from "@db/schema";
import { eq, asc } from "drizzle-orm";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import { Icon } from "astro-icon/components";



const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const allCategories = await db
  .select()
  .from(contactCategories)
  .orderBy(asc(contactCategories.title));

const allContacts = await db
  .select({
    id: providerContacts.id,
    provider: providerContacts.provider,
    service: providerContacts.service,
    categoryId: providerContacts.categoryId,
    categoryTitle: contactCategories.title,
    categoryTone: contactCategories.tone,
  })
  .from(providerContacts)
  .leftJoin(
    contactCategories,
    eq(providerContacts.categoryId, contactCategories.id),
  )
  .orderBy(asc(providerContacts.provider), asc(providerContacts.service));

const categoryBadgeClass: Record<string, string> = {
  primary: "badge-primary",
  secondary: "badge-secondary",
  accent: "badge-accent",
  info: "badge-info",
  success: "badge-success",
  warning: "badge-warning",
};

const headerGridClass = "grid-cols-[1.5fr_1.5fr_1.5fr_140px] gap-4";
const rowGridClass =
  "grid grid-cols-[1.5fr_1.5fr_1.5fr_140px] items-center gap-4";
---

<PageContainer>
  <PageHeader
    description="Listar, crear, modificar y eliminar los contactos útiles de la mesa de ayuda."
  />



  {/* ── Toolbar ── */}
  <div
    class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
  >
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold text-base-content">
        Contactos registrados
      </h2>
      {
        allContacts.length > 0 && (
          <span
            id="contact-count-badge"
            class="badge badge-neutral badge-sm font-mono"
          >
            {allContacts.length}
          </span>
        )
      }
    </div>

    <div
      class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto"
    >
      <select
        id="admin-contact-category-filter"
        class="select border-base-300 w-full sm:w-auto focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
        aria-label="Filtrar por categoría"
      >
        <option value="all">Todas las categorías</option>
        {
          allCategories.map((cat) => (
            <option value={cat.id}>{cat.title}</option>
          ))
        }
      </select>
      <SearchInput
        id="admin-contact-search"
        label="Buscar contacto"
        placeholder="Buscar por proveedor o servicio"
        class="w-full sm:w-64"
      />
      <a
        href={`${cleanBase}admin/contactos/new`}
        class="btn btn-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent w-full sm:w-auto text-xs"
      >
        <Icon name="boxicons:plus" size={18} />
        Nuevo contacto
      </a>
    </div>
  </div>

  {/* ── Tabla ── */}
  <DataTable
    ariaLabel="Listado de contactos registrados"
    minWidthClass="min-w-200"
    headerGridClass={headerGridClass}
    rowGridClass={rowGridClass}
  >
    <div slot="header">
      <DataTableHeaderCell sortKey="provider">Proveedor</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="service">Servicio</DataTableHeaderCell>
    </div>
    <div slot="header">
      <DataTableHeaderCell sortKey="category">Categoría</DataTableHeaderCell>
    </div>
    <div slot="header" class="text-right">
      <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
    </div>

    {
      allContacts.length === 0 ? (
        <div class="flex flex-col items-center gap-3 py-16 text-base-content/50">
          <div class="rounded-full bg-base-200 p-4">
            <Icon
              name="boxicons:phone-filled"
              size={32}
              class="opacity-30"
              aria-hidden="true"
            />
          </div>
          <div class="space-y-1 text-center">
            <p class="text-sm font-semibold">No hay contactos registrados</p>
            <p class="text-xs">
              Comenzá cargando el primer contacto desde el botón superior.
            </p>
          </div>
        </div>
      ) : (
        <>
          {allContacts.map((contact) => (
            <article
              data-table-row
              data-sort-provider={contact.provider}
              data-sort-service={contact.service}
              data-sort-category={contact.categoryTitle ?? ""}
              data-category-id={contact.categoryId ?? ""}
              data-search-text={`${contact.provider} ${contact.service} ${contact.categoryTitle ?? ""}`.toLowerCase()}
              class:list={[
                rowGridClass,
                "border-b border-base-300 px-4 py-3 transition-colors hover:bg-base-200/50 last:border-b-0",
              ]}
            >
              {/* Proveedor */}
              <div class="min-w-0">
                <span
                  data-highlight-target
                  class="font-mono text-sm font-semibold text-base-content"
                >
                  {contact.provider}
                </span>
              </div>

              {/* Servicio */}
              <div class="min-w-0">
                <p
                  data-highlight-target
                  class="truncate text-sm font-semibold text-base-content"
                >
                  {contact.service}
                </p>
              </div>

              {/* Categoría */}
              <div>
                {contact.categoryTitle ? (
                  <span
                    data-highlight-target
                    class:list={[
                      "badge badge-sm font-bold uppercase tracking-wide",
                      categoryBadgeClass[contact.categoryTone ?? ""] ??
                        "badge-neutral",
                    ]}
                  >
                    {contact.categoryTitle}
                  </span>
                ) : (
                  <span class="text-base-content/30">&mdash;</span>
                )}
              </div>

              {/* Acciones */}
              <div class="flex items-center justify-end gap-1">
                <a
                  href={`${cleanBase}admin/contactos/${contact.id}`}
                  class="btn btn-sm btn-ghost h-7 px-2 text-base-content/60 hover:text-secondary rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent text-xs"
                  aria-label={`Editar ${contact.provider}`}
                >
                  <Icon name="boxicons:pencil-filled" size={14} />
                  <span>Editar</span>
                </a>

                <form
                  method="POST"
                  class="inline"
                  onsubmit="return confirm('¿Estás seguro de que querés eliminar este contacto?')"
                >
                  <input type="hidden" name="action" value="delete_contact" />
                  <input type="hidden" name="contactId" value={contact.id} />
                  <button
                    type="submit"
                    class="btn btn-ghost btn-sm h-7 rounded-lg px-2 text-base-content/60 hover:text-error hover:bg-error/10 transition-all duration-200 text-xs"
                    aria-label={`Eliminar ${contact.provider}`}
                  >
                    <Icon name="boxicons:trash-filled" size={14} />
                    <span>Eliminar</span>
                  </button>
                </form>
              </div>
            </article>
          ))}
        </>
      )
    }
  </DataTable>
</PageContainer>

<script>
  import {
    matchesSearchQuery,
    highlightSearchTargets,
  } from "@lib/clientSearch";

  const searchInput = document.querySelector<HTMLInputElement>(
    "#admin-contact-search",
  );
  const categoryFilter = document.querySelector<HTMLSelectElement>(
    "#admin-contact-category-filter",
  );
  const rows = document.querySelectorAll<HTMLElement>("[data-table-row]");
  const countBadge = document.querySelector<HTMLElement>(
    "#contact-count-badge",
  );

  function applyFilters() {
    const query = searchInput?.value.trim() || "";
    const categoryValue = categoryFilter?.value || "all";
    let visibleCount = 0;

    rows.forEach((row) => {
      const searchText = row.dataset.searchText || "";
      const rowCategory = row.dataset.categoryId || "";

      const matchSearch = matchesSearchQuery(query, [searchText]);
      const matchCategory =
        categoryValue === "all" || rowCategory === categoryValue;

      const isVisible = matchSearch && matchCategory;

      row.classList.toggle("hidden", !isVisible);
      highlightSearchTargets(row, isVisible ? query : "");

      if (isVisible) {
        visibleCount++;
      }
    });

    if (countBadge) {
      countBadge.textContent = visibleCount.toString();
    }
  }

  searchInput?.addEventListener("input", applyFilters);
  categoryFilter?.addEventListener("change", applyFilters);
</script>
