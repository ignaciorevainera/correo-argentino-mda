---
import { Icon } from "astro-icon/components";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { officeTypeLabelByType } from "@lib/officeHelpers";

export interface OfficeFormData {
  id?: number;
  // Campos Obligatorios
  code: string;
  name: string;
  provinceCode: string;
  type: string;
  officeType?: string | null;
  address: string | null;

  // Campos Opcionales Base
  locality?: string | null;
  county?: string | null;
  zone?: string | null;
  paqarAdmision?: boolean | null;
  paqarEntrega?: boolean | null;

  // Relacionales y adicionales
  parentNis?: string | null;
  email?: string | null;
  notes?: string | null;
  contacts?: {
    role: string | null;
    timeSlot: string | null;
    contact: { id: number; name: string; phone: string | null };
  }[];
  assets?: {
    id: number;
    type: string;
    hostname: string | null;
    ip: string | null;
  }[];
}

interface Props {
  office?: OfficeFormData | null;
  groupedProvinces: {
    regionName: string;
    provinces: { code: string; name: string }[];
  }[];
  isNew: boolean;
}

const { office, groupedProvinces, isNew } = Astro.props;

const officeTypes = Object.entries(officeTypeLabelByType).map(
  ([value, label]) => ({
    value,
    label,
  })
);

const assetTypeOptions = [
  { value: "server", label: "Servidor" },
  { value: "client", label: "Cliente" },
  { value: "printer", label: "Impresora" },
];

let currentType = office?.type || "TELEGRAFIA";
if (office?.type === "SUCURSAL") {
  if (office?.officeType === "AUTOMATIZADA") {
    currentType = "SUCURSAL_AUTOMATIZADA";
  } else if (office?.officeType === "NO_AUTOMATIZADA") {
    currentType = "SUCURSAL_NO_AUTOMATIZADA";
  }
}
---

<form
  method="POST"
  id="office-form"
  onsubmit="return confirm('¿Estás seguro de que deseas guardar estas modificaciones?');"
  class="space-y-4"
>
  {/* ── Top: Datos básicos ── */}
  <section class="card bg-base-100 border border-base-300 shadow-md">
    <div class="card-body gap-4 p-5">
      <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
        <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary">
          <Icon name="boxicons:building-filled" size={15} />
        </span>
        Datos básicos
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="space-y-3">
          <FormField
            id="input-code"
            name="code"
            label="Código"
            required
            value={office?.code ?? ""}
            placeholder="I2659"
            autocomplete="off"
            inputClass="input-sm font-mono"
          />

          <SelectField
            id="select-type"
            name="type"
            label="Tipo"
            required
            options={officeTypes}
            value={currentType}
            selectClass="select-sm"
          />

          <FormField
            id="input-zone"
            name="zone"
            label="Zona"
            value={office?.zone ?? ""}
            placeholder="ej: ZONA SUR"
            autocomplete="off"
            inputClass="input-sm"
          />
        </div>

        <div class="space-y-3">
          <FormField
            id="input-name"
            name="name"
            label="Nombre"
            required
            value={office?.name ?? ""}
            placeholder="ej: Neuquén"
            autocomplete="off"
            inputClass="input-sm"
          />

          <FormField
            id="input-email"
            type="email"
            name="email"
            label="Email"
            value={office?.email ?? ""}
            placeholder="oficina@correo.com.ar"
            inputClass="input-sm"
          />

          <FormField
            id="input-county"
            name="county"
            label="Partido / Departamento"
            value={office?.county ?? ""}
            placeholder="ej: Confluencia"
            autocomplete="off"
            inputClass="input-sm"
          />
        </div>

        <div class="space-y-3">
          <SelectField
            id="select-provinceCode"
            name="provinceCode"
            label="Provincia"
            required
            selectClass="select-sm"
          >
            <option value="" disabled selected={!office?.provinceCode}>
              Seleccionar provincia
            </option>
            {groupedProvinces.map((group) => (
              <optgroup label={group.regionName}>
                {group.provinces.map((p) => (
                  <option
                    value={p.code}
                    selected={office?.provinceCode === p.code}
                  >
                    {p.name}
                  </option>
                ))}
              </optgroup>
            ))}
          </SelectField>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Dirección *</legend>
            <div class="relative w-full">
              <input
                type="text"
                name="address"
                required
                value={office?.address ?? ""}
                placeholder="ej: Santa Fe 101"
                autocomplete="off"
                class="input input-sm w-full"
              />
              <ul id="address-suggestions" class="menu bg-base-100 w-full rounded-box absolute top-full mt-1 z-50 shadow-lg hidden max-h-60 overflow-y-auto"></ul>
            </div>
          </fieldset>

          <FormField
            id="input-locality"
            name="locality"
            label="Localidad"
            value={office?.locality ?? ""}
            placeholder="ej: Neuquén"
            autocomplete="off"
            inputClass="input-sm"
          />
        </div>

        <div class="col-span-1 md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="col-span-1">
            <FormField
              id="input-parentNis"
              name="parentNis"
              label="NIS Padre (Dependencia)"
              value={office?.parentNis ?? ""}
              placeholder="ej: I2659"
              autocomplete="off"
              inputClass="input-sm font-mono"
            />
          </div>
          
          <div class="col-span-2 flex items-center gap-6 mt-6 md:mt-0 md:justify-end">
            <label class="cursor-pointer label gap-2">
              <span class="label-text font-medium">Admite Paq.AR (Admisión)</span>
              <input
                type="checkbox"
                name="paqarAdmision"
                class="toggle toggle-primary toggle-sm"
                checked={office?.paqarAdmision || false}
              />
            </label>
            <label class="cursor-pointer label gap-2">
              <span class="label-text font-medium">Entrega Paq.AR (Entrega)</span>
              <input
                type="checkbox"
                name="paqarEntrega"
                class="toggle toggle-primary toggle-sm"
                checked={office?.paqarEntrega || false}
              />
            </label>
          </div>
        </div>

        <div class="col-span-1 md:col-span-3">
          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Notas</legend>
            <textarea
              name="notes"
              rows={2}
              class="textarea w-full text-sm"
              placeholder="Observaciones internas"
            >{office?.notes ?? ""}</textarea>
          </fieldset>
        </div>
      </div>
    </div>
  </section>

  {/* ── Bottom: Infra + Contactos ── */}
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
    {/* ── Infraestructura ── */}
    <section class="card bg-base-100 border border-base-300 shadow-md">
      <div class="card-body gap-3 p-5">
        <div class="flex items-center justify-between">
          <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
            <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-info/10 text-info">
              <Icon name="boxicons:server-filled" size={15} />
            </span>
            Infraestructura tecnológico
          </h2>
          <button
            type="button"
            id="btn-add-asset"
            class="btn btn-ghost btn-xs text-info gap-1"
          >
            <Icon name="boxicons:plus" size={14} />
            Agregar
          </button>
        </div>

        <div id="assets-container" class="space-y-3">
          {(office?.assets ?? []).map((a) => (
            <div class="asset-row relative grid grid-cols-1 md:grid-cols-3 gap-3 rounded-lg bg-base-200/50 p-4 border border-base-300 pr-10">
              <SelectField
                id={`asset-type-${a.id}`}
                name="asset_type"
                label="Tipo"
                options={assetTypeOptions}
                value={a.type}
                selectClass="select-sm"
              />
              <FormField
                id={`asset-hostname-${a.id}`}
                name="asset_hostname"
                label="Hostname"
                value={a.hostname ?? ""}
                placeholder="SRV-NEU-01"
                inputClass="input-sm font-mono"
              />
              <FormField
                id={`asset-ip-${a.id}`}
                name="asset_ip"
                label="IP"
                value={a.ip ?? ""}
                placeholder="10.0.1.1"
                inputClass="input-sm font-mono"
              />
              <button
                type="button"
                class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
                aria-label="Quitar equipo"
              >
                <Icon name="boxicons:trash" size={18} />
              </button>
            </div>
          ))}
        </div>
        {(office?.assets ?? []).length === 0 && (
          <p class="text-xs text-base-content/40 text-center py-1">
            Sin equipos registrados.
          </p>
        )}
      </div>
    </section>

    {/* ── Personal a cargo ── */}
    <section class="card bg-base-100 border border-base-300 shadow-md flex-1">
      <div class="card-body gap-3 p-5">
        <div class="flex items-center justify-between">
          <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
            <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warning/10 text-warning">
              <Icon name="boxicons:group-filled" size={15} />
            </span>
            Contactos
          </h2>
          <button
            type="button"
            id="btn-add-contact"
            class="btn btn-ghost btn-xs text-warning gap-1"
          >
            <Icon name="boxicons:plus" size={14} />
            Agregar
          </button>
        </div>

        <div id="contacts-container" class="space-y-3">
          {(office?.contacts ?? []).map((oc) => (
            <div class="contact-row relative rounded-lg bg-base-200/50 p-4 border border-base-300">
              <input type="hidden" name="contact_id" value={oc.contact.id} />
              <button
                type="button"
                class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
                aria-label="Quitar contacto"
              >
                <Icon name="boxicons:trash" size={18} />
              </button>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pr-6">
                <FormField
                  id={`contact-name-${oc.contact.id}`}
                  name="contact_name"
                  label="Nombre"
                  value={oc.contact.name}
                  placeholder="García Juan"
                  inputClass="input-sm"
                />
                <FormField
                  id={`contact-phone-${oc.contact.id}`}
                  name="contact_phone"
                  label="Teléfono"
                  value={oc.contact.phone ?? ""}
                  placeholder="0299-123456"
                  inputClass="input-sm font-mono"
                />
                <FormField
                  id={`contact-role-${oc.contact.id}`}
                  name="contact_role"
                  label="Rol"
                  value={oc.role ?? ""}
                  placeholder="Jefe"
                  inputClass="input-sm"
                />
                <FormField
                  id={`contact-timeslot-${oc.contact.id}`}
                  name="contact_timeslot"
                  label="Horario"
                  value={oc.timeSlot ?? ""}
                  placeholder="Mañana"
                  inputClass="input-sm"
                />
              </div>
            </div>
          ))}
        </div>
        {(office?.contacts ?? []).length === 0 && (
          <p class="text-xs text-base-content/40 text-center py-1">
            Sin personal vinculado.
          </p>
        )}
      </div>
    </section>
  </div>
  
  {/* ── Acciones ── */}
  <div class="flex items-center justify-between gap-3 pt-1">
    <a
      href="/admin/oficinas"
      class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10"
    >
      <Icon name="boxicons:arrow-left-filled" size={16} />
      Volver al listado
    </a>
    <button type="submit" class="btn btn-secondary btn-sm gap-2">
      <Icon name="boxicons:save-filled" size={16} />
      {isNew ? "Crear sucursal" : "Guardar cambios"}
    </button>
  </div>
</form>

{/* ── Templates dinámicos ── */}
<template id="tpl-asset-row">
  <div class="asset-row relative grid grid-cols-1 md:grid-cols-3 gap-3 rounded-lg bg-base-200/50 p-4 border border-base-300 pr-10">
    <SelectField
      id="tpl-asset-type"
      name="asset_type"
      label="Tipo"
      options={[
        { value: "server", label: "Servidor" },
        { value: "client", label: "Cliente" },
        { value: "printer", label: "Impresora" }
      ]}
      selectClass="select-sm"
    />
    <FormField
      id="tpl-asset-hostname"
      name="asset_hostname"
      label="Hostname"
      placeholder="SRV-NEU-01"
      inputClass="input-sm font-mono"
    />
    <FormField
      id="tpl-asset-ip"
      name="asset_ip"
      label="IP"
      placeholder="10.0.1.1"
      inputClass="input-sm font-mono"
    />
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
      aria-label="Quitar equipo"
    >
      <Icon name="boxicons:trash" size={18} />
    </button>
  </div>
</template>

<template id="tpl-contact-row">
  <div class="contact-row relative rounded-lg bg-base-200/50 p-4 border border-base-300">
    <input type="hidden" name="contact_id" value="" />
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
      aria-label="Quitar contacto"
    >
      <Icon name="boxicons:trash" size={18} />
    </button>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pr-6">
      <FormField
        id="tpl-contact-name"
        name="contact_name"
        label="Nombre"
        placeholder="García Juan"
        inputClass="input-sm"
      />
      <FormField
        id="tpl-contact-phone"
        name="contact_phone"
        label="Teléfono"
        placeholder="0299-123456"
        inputClass="input-sm font-mono"
      />
      <FormField
        id="tpl-contact-role"
        name="contact_role"
        label="Rol"
        placeholder="Jefe"
        inputClass="input-sm"
      />
      <FormField
        id="tpl-contact-timeslot"
        name="contact_timeslot"
        label="Horario"
        placeholder="Mañana"
        inputClass="input-sm"
      />
    </div>
  </div>
</template>

<script>
  console.log("OfficeForm: client script module loaded");

  function initDynamicRows() {
    console.log("initDynamicRows: starting initialization");
    const assetsContainer = document.getElementById("assets-container");
    const contactsContainer = document.getElementById("contacts-container");
    if (!assetsContainer || !contactsContainer) {
      console.log("initDynamicRows: container elements not found, skipping");
      return;
    }

    const tplAsset = document.getElementById(
      "tpl-asset-row"
    ) as HTMLTemplateElement;
    const tplContact = document.getElementById(
      "tpl-contact-row"
    ) as HTMLTemplateElement;
    if (!tplAsset || !tplContact) {
      console.log("initDynamicRows: template elements not found, skipping");
      return;
    }

    const addAssetBtn = document.getElementById("btn-add-asset");
    if (addAssetBtn && !addAssetBtn.dataset.bound) {
      addAssetBtn.dataset.bound = "true";
      addAssetBtn.addEventListener("click", () => {
        assetsContainer.appendChild(tplAsset.content.cloneNode(true));
        bindRemoveButtons(assetsContainer);
      });
    }

    const addContactBtn = document.getElementById("btn-add-contact");
    if (addContactBtn && !addContactBtn.dataset.bound) {
      addContactBtn.dataset.bound = "true";
      addContactBtn.addEventListener("click", () => {
        contactsContainer.appendChild(tplContact.content.cloneNode(true));
        bindRemoveButtons(contactsContainer);
      });
    }

    function bindRemoveButtons(container: HTMLElement) {
      container
        .querySelectorAll<HTMLButtonElement>(".remove-row-btn")
        .forEach((btn) => {
          btn.onclick = () => btn.closest(".asset-row, .contact-row")?.remove();
        });
    }

    bindRemoveButtons(assetsContainer);
    bindRemoveButtons(contactsContainer);
    console.log("initDynamicRows: completed successfully");
  }

  function initAddressAutocomplete() {
    console.log("initAddressAutocomplete: starting initialization");
    const input = document.querySelector('input[name="address"]') as HTMLInputElement;
    if (!input) {
      console.warn("initAddressAutocomplete: input[name='address'] not found");
      return;
    }

    if (input.dataset.autocompleteBound === "true") {
      console.log("initAddressAutocomplete: already bound, skipping");
      return;
    }
    input.dataset.autocompleteBound = "true";

    const container = input.closest('.relative');
    if (!container) {
      console.warn("initAddressAutocomplete: .relative wrapper not found for input");
      return;
    }
    
    const ul = document.getElementById("address-suggestions") as HTMLUListElement;
    if (!ul) {
      console.warn("initAddressAutocomplete: #address-suggestions ul not found");
      return;
    }

    console.log("initAddressAutocomplete: binding input and click listeners");
    let timeout: ReturnType<typeof setTimeout>;

    input.addEventListener("input", () => {
      clearTimeout(timeout);
      const val = input.value.trim();
      console.log("initAddressAutocomplete input value changed:", val);
      
      if (val.length < 3) {
        ul.classList.add("hidden");
        ul.innerHTML = "";
        return;
      }

      timeout = setTimeout(async () => {
        try {
          const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
          const url = `${baseUrl}/api/offices/search-address?q=${encodeURIComponent(val)}`;
          console.log("initAddressAutocomplete: fetching", url);
          
          const res = await fetch(url);
          console.log("initAddressAutocomplete: response status is", res.status);
          
          if (!res.ok) {
            const errText = await res.text();
            console.error("API error response body:", errText);
            throw new Error("API error: " + res.status);
          }
          
          const data: { address: string; nis: string }[] = await res.json();
          console.log("initAddressAutocomplete: received data:", data);
          
          ul.innerHTML = "";
          if (data.length > 0) {
            data.forEach(item => {
              const li = document.createElement("li");
              const a = document.createElement("a");
              a.textContent = `${item.address} (NIS: ${item.nis})`;
              a.addEventListener("click", (e) => {
                e.preventDefault();
                console.log("initAddressAutocomplete: suggestion clicked:", item.address);
                input.value = item.address || "";
                ul.classList.add("hidden");
                ul.innerHTML = "";
                input.dispatchEvent(new Event("input", { bubbles: true }));
              });
              li.appendChild(a);
              ul.appendChild(li);
            });
            ul.classList.remove("hidden");
          } else {
            ul.classList.add("hidden");
          }
        } catch (error) {
          console.error("Error fetching addresses:", error);
        }
      }, 300);
    });

    document.addEventListener("click", (e) => {
      if (!container.contains(e.target as Node)) {
        ul.classList.add("hidden");
      }
    });
    console.log("initAddressAutocomplete: completed successfully");
  }

  function runInitializations() {
    try {
      initDynamicRows();
    } catch (e) {
      console.error("Error running initDynamicRows:", e);
    }
    try {
      initAddressAutocomplete();
    } catch (e) {
      console.error("Error running initAddressAutocomplete:", e);
    }
  }

  // Initialize immediately
  runInitializations();

  // Initialize on page load (Astro View Transitions compatibility)
  document.addEventListener("astro:page-load", () => {
    console.log("OfficeForm: astro:page-load fired, re-initializing");
    runInitializations();
  });
</script>
