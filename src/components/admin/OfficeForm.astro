---
import { Icon } from "astro-icon/components";
import { officeTypeLabelByType } from "@lib/officeHelpers";

export interface OfficeFormData {
  id?: number;
  // Campos Obligatorios
  code: string;
  name: string;
  provinceCode: string;
  type: string;
  officeType?: string | null;
  address: string | null;

  // Campos Opcionales Base
  locality?: string | null;
  county?: string | null;
  zone?: string | null;
  paqarAdmision?: boolean | null;
  paqarEntrega?: boolean | null;

  // Relacionales y adicionales
  parentNis?: string | null;
  email?: string | null;
  notes?: string | null;
  contacts?: {
    role: string | null;
    timeSlot: string | null;
    contact: { id: number; name: string; phone: string | null };
  }[];
  assets?: {
    id: number;
    type: string;
    hostname: string | null;
    ip: string | null;
  }[];
}

interface Props {
  office?: OfficeFormData | null;
  groupedProvinces: {
    regionName: string;
    provinces: { code: string; name: string }[];
  }[];
  isNew: boolean;
}

const { office, groupedProvinces, isNew } = Astro.props;

const officeTypes = Object.entries(officeTypeLabelByType).map(
  ([value, label]) => ({
    value,
    label,
  })
);

const assetTypeOptions = [
  { value: "server", label: "Servidor" },
  { value: "client", label: "Cliente" },
  { value: "printer", label: "Impresora" },
];

let currentType = office?.type || "TELEGRAFIA";
if (office?.type === "SUCURSAL") {
  if (office?.officeType === "AUTOMATIZADA") {
    currentType = "SUCURSAL_AUTOMATIZADA";
  } else if (office?.officeType === "NO_AUTOMATIZADA") {
    currentType = "SUCURSAL_NO_AUTOMATIZADA";
  }
}
---

<form
  method="POST"
  id="office-form"
  onsubmit="return confirm('¿Estás seguro de que deseas guardar estas modificaciones?');"
  class="space-y-4"
>
  {/* ── Top: Datos básicos ── */}
  <section class="card bg-base-100 border border-base-300 shadow-md">
    <div class="card-body gap-4 p-5">
      <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
        <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary/10 text-secondary">
          <Icon name="boxicons:building-filled" size={15} />
        </span>
        Datos básicos
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="space-y-3">
          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Código *</legend>
            <input
              type="text"
              name="code"
              required
              value={office?.code ?? ""}
              placeholder="I2659"
              autocomplete="off"
              class="input input-sm w-full font-mono"
            />
          </fieldset>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Tipo *</legend>
            <select name="type" required class="select select-sm w-full">
              {officeTypes.map((t) => (
                <option value={t.value} selected={currentType === t.value}>
                  {t.label}
                </option>
              ))}
            </select>
          </fieldset>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Zona</legend>
            <input
              type="text"
              name="zone"
              value={office?.zone ?? ""}
              placeholder="ej: ZONA SUR"
              autocomplete="off"
              class="input input-sm w-full"
            />
          </fieldset>
        </div>

        <div class="space-y-3">
          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Nombre *</legend>
            <input
              type="text"
              name="name"
              required
              value={office?.name ?? ""}
              placeholder="ej: Neuquén"
              autocomplete="off"
              class="input input-sm w-full"
            />
          </fieldset>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Email</legend>
            <input
              type="email"
              name="email"
              value={office?.email ?? ""}
              placeholder="oficina@correo.com.ar"
              class="input input-sm w-full"
            />
          </fieldset>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Partido / Departamento</legend>
            <input
              type="text"
              name="county"
              value={office?.county ?? ""}
              placeholder="ej: Confluencia"
              autocomplete="off"
              class="input input-sm w-full"
            />
          </fieldset>
        </div>

        <div class="space-y-3">
          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Provincia *</legend>
            <select
              name="provinceCode"
              required
              class="select select-sm w-full"
            >
              <option value="" disabled selected={!office?.provinceCode}>
                Seleccionar provincia
              </option>
              {groupedProvinces.map((group) => (
                <optgroup label={group.regionName}>
                  {group.provinces.map((p) => (
                    <option
                      value={p.code}
                      selected={office?.provinceCode === p.code}
                    >
                      {p.name}
                    </option>
                  ))}
                </optgroup>
              ))}
            </select>
          </fieldset>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Dirección *</legend>
            <input
              type="text"
              name="address"
              required
              value={office?.address ?? ""}
              placeholder="ej: Santa Fe 101"
              class="input input-sm w-full"
            />
          </fieldset>

          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Localidad</legend>
            <input
              type="text"
              name="locality"
              value={office?.locality ?? ""}
              placeholder="ej: Neuquén"
              autocomplete="off"
              class="input input-sm w-full"
            />
          </fieldset>
        </div>

        <div class="col-span-1 md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="col-span-1">
            <fieldset class="fieldset gap-1">
              <legend class="fieldset-legend text-xs">NIS Padre (Dependencia)</legend>
              <input
                type="text"
                name="parentNis"
                value={office?.parentNis ?? ""}
                placeholder="ej: I2659"
                autocomplete="off"
                class="input input-sm w-full font-mono"
              />
            </fieldset>
          </div>
          
          <div class="col-span-2 flex items-center gap-6 mt-6 md:mt-0 md:justify-end">
            <label class="cursor-pointer label gap-2">
              <span class="label-text font-medium">Admite Paq.AR (Admisión)</span>
              <input
                type="checkbox"
                name="paqarAdmision"
                class="toggle toggle-primary toggle-sm"
                checked={office?.paqarAdmision || false}
              />
            </label>
            <label class="cursor-pointer label gap-2">
              <span class="label-text font-medium">Entrega Paq.AR (Entrega)</span>
              <input
                type="checkbox"
                name="paqarEntrega"
                class="toggle toggle-primary toggle-sm"
                checked={office?.paqarEntrega || false}
              />
            </label>
          </div>
        </div>

        <div class="col-span-1 md:col-span-3">
          <fieldset class="fieldset gap-1">
            <legend class="fieldset-legend text-xs">Notas</legend>
            <textarea
              name="notes"
              rows={2}
              class="textarea w-full text-sm"
              placeholder="Observaciones internas"
            >{office?.notes ?? ""}</textarea>
          </fieldset>
        </div>
      </div>
    </div>
  </section>

  {/* ── Bottom: Infra + Contactos ── */}
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
    {/* ── Infraestructura ── */}
    <section class="card bg-base-100 border border-base-300 shadow-md">
      <div class="card-body gap-3 p-5">
        <div class="flex items-center justify-between">
          <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
            <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-info/10 text-info">
              <Icon name="boxicons:server-filled" size={15} />
            </span>
            Infraestructura tecnológico
          </h2>
          <button
            type="button"
            id="btn-add-asset"
            class="btn btn-ghost btn-xs text-info gap-1"
          >
            <Icon name="boxicons:plus" size={14} />
            Agregar
          </button>
        </div>

        <div id="assets-container" class="space-y-3">
          {(office?.assets ?? []).map((a) => (
            <div class="asset-row relative grid grid-cols-1 md:grid-cols-3 gap-3 rounded-lg bg-base-200/50 p-4 border border-base-300 pr-10">
              <fieldset class="fieldset gap-1">
                <legend class="fieldset-legend text-xs font-bold">Tipo</legend>
                <select name="asset_type" class="select select-sm w-full">
                  {assetTypeOptions.map((opt) => (
                    <option value={opt.value} selected={a.type === opt.value}>
                      {opt.label}
                    </option>
                  ))}
                </select>
              </fieldset>
              <fieldset class="fieldset gap-1">
                <legend class="fieldset-legend text-xs font-bold">Hostname</legend>
                <input
                  type="text"
                  name="asset_hostname"
                  value={a.hostname ?? ""}
                  class="input input-sm w-full font-mono"
                  placeholder="SRV-NEU-01"
                />
              </fieldset>
              <fieldset class="fieldset gap-1">
                <legend class="fieldset-legend text-xs font-bold">IP</legend>
                <input
                  type="text"
                  name="asset_ip"
                  value={a.ip ?? ""}
                  class="input input-sm w-full font-mono"
                  placeholder="10.0.1.1"
                />
              </fieldset>
              <button
                type="button"
                class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
                aria-label="Quitar equipo"
              >
                <Icon name="boxicons:trash" size={18} />
              </button>
            </div>
          ))}
        </div>
        {(office?.assets ?? []).length === 0 && (
          <p class="text-xs text-base-content/40 text-center py-1">
            Sin equipos registrados.
          </p>
        )}
      </div>
    </section>

    {/* ── Personal a cargo ── */}
    <section class="card bg-base-100 border border-base-300 shadow-md flex-1">
      <div class="card-body gap-3 p-5">
        <div class="flex items-center justify-between">
          <h2 class="flex items-center gap-2 text-sm font-semibold text-base-content">
            <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warning/10 text-warning">
              <Icon name="boxicons:group-filled" size={15} />
            </span>
            Contactos
          </h2>
          <button
            type="button"
            id="btn-add-contact"
            class="btn btn-ghost btn-xs text-warning gap-1"
          >
            <Icon name="boxicons:plus" size={14} />
            Agregar
          </button>
        </div>

        <div id="contacts-container" class="space-y-3">
          {(office?.contacts ?? []).map((oc) => (
            <div class="contact-row relative rounded-lg bg-base-200/50 p-4 border border-base-300">
              <input type="hidden" name="contact_id" value={oc.contact.id} />
              <button
                type="button"
                class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
                aria-label="Quitar contacto"
              >
                <Icon name="boxicons:trash" size={18} />
              </button>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pr-6">
                <fieldset class="fieldset gap-1">
                  <legend class="fieldset-legend text-xs font-bold">Nombre</legend>
                  <input
                    type="text"
                    name="contact_name"
                    value={oc.contact.name}
                    class="input input-sm w-full"
                    placeholder="García Juan"
                  />
                </fieldset>
                <fieldset class="fieldset gap-1">
                  <legend class="fieldset-legend text-xs font-bold">Teléfono</legend>
                  <input
                    type="text"
                    name="contact_phone"
                    value={oc.contact.phone ?? ""}
                    class="input input-sm w-full font-mono"
                    placeholder="0299-123456"
                  />
                </fieldset>
                <fieldset class="fieldset gap-1">
                  <legend class="fieldset-legend text-xs font-bold">Rol</legend>
                  <input
                    type="text"
                    name="contact_role"
                    value={oc.role ?? ""}
                    class="input input-sm w-full"
                    placeholder="Jefe"
                  />
                </fieldset>
                <fieldset class="fieldset gap-1">
                  <legend class="fieldset-legend text-xs font-bold">Horario</legend>
                  <input
                    type="text"
                    name="contact_timeslot"
                    value={oc.timeSlot ?? ""}
                    class="input input-sm w-full"
                    placeholder="Mañana"
                  />
                </fieldset>
              </div>
            </div>
          ))}
        </div>
        {(office?.contacts ?? []).length === 0 && (
          <p class="text-xs text-base-content/40 text-center py-1">
            Sin personal vinculado.
          </p>
        )}
      </div>
    </section>
  </div>
  
  {/* ── Acciones ── */}
  <div class="flex items-center justify-between gap-3 pt-1">
    <a
      href="/admin/offices"
      class="btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent btn-ghost text-neutral hover:bg-neutral/10"
    >
      <Icon name="boxicons:arrow-left-filled" size={16} />
      Volver al listado
    </a>
    <button type="submit" class="btn btn-secondary btn-sm gap-2">
      <Icon name="boxicons:save-filled" size={16} />
      {isNew ? "Crear sucursal" : "Guardar cambios"}
    </button>
  </div>
</form>

{/* ── Templates dinámicos ── */}
<template id="tpl-asset-row">
  <div class="asset-row relative grid grid-cols-1 md:grid-cols-3 gap-3 rounded-lg bg-base-200/50 p-4 border border-base-300 pr-10">
    <fieldset class="fieldset gap-1">
      <legend class="fieldset-legend text-xs font-bold">Tipo</legend>
      <select name="asset_type" class="select select-sm w-full">
        <option value="server">Servidor</option>
        <option value="client">Cliente</option>
        <option value="printer">Impresora</option>
      </select>
    </fieldset>
    <fieldset class="fieldset gap-1">
      <legend class="fieldset-legend text-xs font-bold">Hostname</legend>
      <input
        type="text"
        name="asset_hostname"
        class="input input-sm w-full font-mono"
        placeholder="SRV-NEU-01"
      />
    </fieldset>
    <fieldset class="fieldset gap-1">
      <legend class="fieldset-legend text-xs font-bold">IP</legend>
      <input
        type="text"
        name="asset_ip"
        class="input input-sm w-full font-mono"
        placeholder="10.0.1.1"
      />
    </fieldset>
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
      aria-label="Quitar equipo"
    >
      <Icon name="boxicons:trash" size={18} />
    </button>
  </div>
</template>

<template id="tpl-contact-row">
  <div class="contact-row relative rounded-lg bg-base-200/50 p-4 border border-base-300">
    <input type="hidden" name="contact_id" value="" />
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-square text-error/60 hover:text-error remove-row-btn absolute top-2 right-2"
      aria-label="Quitar contacto"
    >
      <Icon name="boxicons:trash" size={18} />
    </button>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pr-6">
      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Nombre</legend>
        <input
          type="text"
          name="contact_name"
          class="input input-sm w-full"
          placeholder="García Juan"
        />
      </fieldset>
      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Teléfono</legend>
        <input
          type="text"
          name="contact_phone"
          class="input input-sm w-full font-mono"
          placeholder="0299-123456"
        />
      </fieldset>
      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Rol</legend>
        <input
          type="text"
          name="contact_role"
          class="input input-sm w-full"
          placeholder="Jefe"
        />
      </fieldset>
      <fieldset class="fieldset gap-1">
        <legend class="fieldset-legend text-xs font-bold">Horario</legend>
        <input
          type="text"
          name="contact_timeslot"
          class="input input-sm w-full"
          placeholder="Mañana"
        />
      </fieldset>
    </div>
  </div>
</template>

<script>
  function initDynamicRows() {
    const assetsContainer = document.getElementById("assets-container")!;
    const contactsContainer = document.getElementById("contacts-container")!;
    const tplAsset = document.getElementById(
      "tpl-asset-row"
    ) as HTMLTemplateElement;
    const tplContact = document.getElementById(
      "tpl-contact-row"
    ) as HTMLTemplateElement;

    document.getElementById("btn-add-asset")?.addEventListener("click", () => {
      assetsContainer.appendChild(tplAsset.content.cloneNode(true));
      bindRemoveButtons(assetsContainer);
    });

    document
      .getElementById("btn-add-contact")
      ?.addEventListener("click", () => {
        contactsContainer.appendChild(tplContact.content.cloneNode(true));
        bindRemoveButtons(contactsContainer);
      });

    function bindRemoveButtons(container: HTMLElement) {
      container
        .querySelectorAll<HTMLButtonElement>(".remove-row-btn")
        .forEach((btn) => {
          btn.onclick = () => btn.closest(".asset-row, .contact-row")?.remove();
        });
    }

    bindRemoveButtons(assetsContainer);
    bindRemoveButtons(contactsContainer);
  }

  // Initialize immediately and also on view transitions
  initDynamicRows();
  document.addEventListener("astro:page-load", initDynamicRows);
</script>
