---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";

const linksGridCols = "grid-cols-[40px_40px_minmax(0,1.5fr)_minmax(0,2fr)_minmax(0,1.5fr)_80px] gap-4";
---

<PageContainer>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
    <PageHeader
      title="Gestión de Enlaces y Recursos"
      description="Refactorizá, reordená y organizá los accesos rápidos de soporte técnico."
    />
    <div class="flex gap-2 shrink-0">
      <div class="h-9 w-36 skeleton rounded-lg"></div>
      <div class="h-9 w-40 skeleton rounded-lg"></div>
    </div>
  </div>

  <!-- Contenedor Principal Split View Skeleton -->
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 items-start">
    
    <!-- Panel Izquierdo: Categorías Sidebar -->
    <aside class="lg:col-span-1 bg-base-100 border border-base-300 rounded-box p-4 shadow-sm flex flex-col gap-3">
      <div class="flex items-center justify-between border-b border-base-200 pb-2">
        <span class="text-xs font-bold uppercase tracking-wider text-base-content/60">Categorías</span>
      </div>

      <div class="flex flex-col gap-1">
        {
          Array.from({ length: 5 }).map(() => (
            <div class="flex items-center justify-between px-3 py-2.5 rounded-lg border border-transparent">
              <div class="flex items-center gap-2.5 min-w-0 grow">
                <div class="size-8 rounded-md shrink-0 border border-base-300 skeleton"></div>
                <div class="h-4 w-24 skeleton rounded"></div>
              </div>
              <div class="h-5 w-8 skeleton rounded ml-2"></div>
            </div>
          ))
        }
      </div>
    </aside>

    <!-- Panel Derecho: Enlaces DataTable -->
    <main class="lg:col-span-3 flex flex-col gap-4">
      <div class="bg-base-100 border border-base-300 rounded-box p-4 shadow-sm">
        
        <!-- Cabecera de Categoría Seleccionada y Buscador -->
        <div class="flex flex-col sm:flex-row gap-4 items-center justify-between mb-4 pb-4 border-b border-base-200">
          <div class="flex items-center gap-3">
            <div class="size-9 rounded-lg border border-base-300 skeleton"></div>
            <div class="space-y-1.5">
              <div class="h-5 w-32 skeleton rounded"></div>
              <div class="h-3.5 w-60 skeleton rounded"></div>
            </div>
          </div>
          <div class="w-full sm:max-w-xs shrink-0">
            <div class="h-10 w-full skeleton rounded-lg"></div>
          </div>
        </div>

        <!-- Tabla Única de Enlaces -->
        <div class="border border-base-300 rounded-xl overflow-hidden bg-base-100 shadow-sm">
          <div class={`grid ${linksGridCols} border-b border-base-300 px-4 py-3 bg-base-200/50`}>
            <div></div> <!-- Grab Handle placeholder -->
            <div><div class="h-5 w-10 skeleton rounded"></div></div>
            <div><div class="h-5 w-16 skeleton rounded"></div></div>
            <div><div class="h-5 w-24 skeleton rounded"></div></div>
            <div><div class="h-5 w-12 skeleton rounded"></div></div>
            <div><div class="h-5 w-16 skeleton rounded justify-self-end"></div></div>
          </div>

          <div class="divide-y divide-base-200">
            {
              Array.from({ length: 6 }).map(() => (
                <div class={`grid ${linksGridCols} items-center px-4 py-3`}>
                  <div class="flex justify-center"><div class="h-5 w-5 skeleton rounded"></div></div>
                  <div><div class="size-8 skeleton rounded-md"></div></div>
                  <div><div class="h-4 w-32 skeleton rounded"></div></div>
                  <div><div class="h-4 w-44 skeleton rounded"></div></div>
                  <div><div class="h-4 w-40 skeleton rounded font-mono"></div></div>
                  <div class="flex justify-end gap-1"><div class="h-6 w-16 skeleton rounded"></div></div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </main>
  </div>
</PageContainer>
