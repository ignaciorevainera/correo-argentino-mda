---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { resourceCategories, resourceLinks } from "@db/schema";
import { eq } from "drizzle-orm";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";
const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith("/") ? path.slice(1) : path;
  return `${cleanBase}${cleanPath}`;
};

const q = Astro.url.searchParams.get("q")?.trim() || "";

let uncategorizedDbId: number | null = null;
let filteredCategories: any[] = [];

const dbCategories = await db
  .select()
  .from(resourceCategories)
  .orderBy(resourceCategories.title);

dbCategories.forEach((cat) => {
  const t = cat.title.toLowerCase();
  if (t === "sin categoría" || t === "sin categoria") {
    uncategorizedDbId = cat.id;
  } else {
    filteredCategories.push(cat);
  }
});
const categories = filteredCategories;

const links = await db
  .select({
    id: resourceLinks.id,
    title: resourceLinks.title,
    subtitle: resourceLinks.subtitle,
    url: resourceLinks.url,
    categoryName: resourceCategories.title,
    categoryId: resourceLinks.categoryId,
    iconPath: resourceLinks.iconPath,
    deprecated: resourceLinks.deprecated,
    sortOrder: resourceLinks.sortOrder,
  })
  .from(resourceLinks)
  .leftJoin(resourceCategories, eq(resourceLinks.categoryId, resourceCategories.id))
  .orderBy(resourceLinks.sortOrder, resourceLinks.title);

const linksGridCols = "grid-cols-[40px_40px_minmax(0,1.5fr)_minmax(0,2fr)_minmax(0,1.5fr)_80px] gap-4";

const toneColors: Record<string, string> = {
  primary: "text-primary bg-primary/10 border-primary/20",
  secondary: "text-secondary bg-secondary/10 border-secondary/20",
  accent: "text-accent bg-accent/10 border-accent/20",
  info: "text-info bg-info/10 border-info/20",
  success: "text-success bg-success/10 border-success/20",
  warning: "text-warning bg-warning/10 border-warning/20",
  error: "text-error bg-error/10 border-error/20",
  neutral: "text-neutral bg-neutral/10 border-neutral/20",
};

// Map to pre-calculate links count per category
const categoryCounts = new Map<string | number, number>();
let uncategorizedCount = 0;

links.forEach((link) => {
  if (!link.categoryId || link.categoryId === uncategorizedDbId) {
    uncategorizedCount++;
    categoryCounts.set("uncategorized", uncategorizedCount);
  } else {
    categoryCounts.set(link.categoryId, (categoryCounts.get(link.categoryId) || 0) + 1);
  }
});
---

<PageContainer>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
    <PageHeader
      title="Gestión de Enlaces y Recursos"
      description="Refactorizá, reordená y organizá los accesos rápidos de soporte técnico."
    />
    <div class="flex gap-2 shrink-0">
      <a href={resolveUrl("/admin/recursos/categoria/create")} class="btn btn-outline btn-sm gap-2">
        <Icon name="boxicons:folder-plus" size={16} />
        Nueva Categoría
      </a>
      <a
        id="btn-add-link"
        href={resolveUrl("/admin/recursos/enlace/create")}
        class="btn btn-primary btn-sm gap-2"
      >
        <Icon name="boxicons:plus" size={16} />
        Agregar Sitio Web
      </a>
    </div>
  </div>

  <!-- Contenedor Principal Split View -->
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 items-start">
    
    <!-- Panel Izquierdo: Categorías -->
    <aside class="lg:col-span-1 bg-base-100 border border-base-300 rounded-box p-4 shadow-sm flex flex-col gap-3">
      <div class="flex items-center justify-between border-b border-base-200 pb-2">
        <span class="text-xs font-bold uppercase tracking-wider text-base-content/60">Categorías</span>
      </div>

      <nav class="flex flex-col gap-1" id="categories-list">
        <div
          class="group flex items-center justify-between px-3 py-2.5 rounded-lg border border-transparent hover:bg-base-200/60 transition-all cursor-pointer select-none category-item"
          data-category-id="all"
          data-category-tone="neutral"
          data-category-title="Todos"
        >
          <div class="flex items-center gap-2.5 min-w-0 grow">
            <div class={`flex items-center justify-center size-8 rounded-md shrink-0 border ${toneColors.neutral}`}>
              <Icon name="boxicons:grid-9-filled" size={18} />
            </div>
            <span class="text-sm font-semibold truncate label-title">Todos</span>
          </div>
          
          <div class="flex items-center gap-1.5 shrink-0 ml-2">
            <span class="badge badge-sm badge-ghost font-mono count-badge" data-count={links.length}>
              {links.length}
            </span>
          </div>
        </div>

        {
          categories.length === 0 ? (
            <p class="text-xs text-base-content/50 py-4 text-center">No hay categorías registradas.</p>
          ) : (
            categories.map((cat) => {
              const count = categoryCounts.get(cat.id) || 0;
              return (
                <div
                  class="group flex items-center justify-between px-3 py-2.5 rounded-lg border border-transparent hover:bg-base-200/60 transition-all cursor-pointer select-none category-item"
                  data-category-id={cat.id}
                  data-category-tone={cat.tone}
                  data-category-title={cat.title}
                  data-category-dropzone
                >
                  <div class="flex items-center gap-2.5 min-w-0 grow">
                    <div class={`flex items-center justify-center size-8 rounded-md shrink-0 border ${toneColors[cat.tone] || toneColors.primary}`}>
                      <Icon name={cat.iconName} size={18} />
                    </div>
                    <span class="text-sm font-semibold truncate label-title">{cat.title}</span>
                  </div>
                  
                  <div class="flex items-center gap-1.5 shrink-0 ml-2">
                    <span class="badge badge-sm badge-ghost font-mono count-badge" data-count={count}>
                      {count}
                    </span>
                    {cat.title.toLowerCase() !== "sin categoría" && cat.title.toLowerCase() !== "sin categoria" && (
                      <div class="hidden group-hover:flex items-center gap-0.5">
                        <a
                          href={resolveUrl(`/admin/recursos/categoria/edit/${cat.id}`)}
                          class="btn btn-xs btn-ghost btn-square text-base-content/60 hover:text-primary"
                          title="Editar"
                          onclick="event.stopPropagation();"
                        >
                          <Icon name="boxicons:pencil" size={14} />
                        </a>
                        <button
                          type="button"
                          class="btn btn-xs btn-ghost btn-square text-base-content/60 hover:text-error"
                          title="Eliminar"
                          onclick={`event.stopPropagation(); window.openDeleteCategoryModal('${cat.id}')`}
                        >
                          <Icon name="boxicons:trash" size={14} />
                        </button>
                      </div>
                    )}
                  </div>
                </div>
              );
            })
          )
        }

        {/* Sin categoría */}
        {(() => {
          const uncategorizedCount = categoryCounts.get("uncategorized") || 0;
          if (uncategorizedCount === 0) return null;
          return (
            <div
              class="group flex items-center justify-between px-3 py-2.5 rounded-lg border border-transparent hover:bg-base-200/60 transition-all cursor-pointer select-none category-item"
              data-category-id="uncategorized"
              data-category-tone="warning"
              data-category-title="Sin categoría"
              data-category-dropzone
            >
              <div class="flex items-center gap-2.5 min-w-0 grow">
                <div class="flex items-center justify-center size-8 rounded-md shrink-0 border border-warning/20 bg-warning/10 text-warning">
                  <Icon name="boxicons:folder" size={18} />
                </div>
                <span class="text-sm font-semibold truncate label-title">Sin categoría</span>
              </div>
              <div class="flex items-center gap-1.5 shrink-0 ml-2">
                <span class="badge badge-sm badge-ghost font-mono count-badge" data-count={uncategorizedCount}>
                  {uncategorizedCount}
                </span>
              </div>
            </div>
          );
        })()}
      </nav>
    </aside>

    <!-- Panel Derecho: Enlaces -->
    <main class="lg:col-span-3 flex flex-col gap-4">
      <div class="bg-base-100 border border-base-300 rounded-box p-4 shadow-sm">
        
        <!-- Cabecera de Categoría Seleccionada y Buscador -->
        <div class="flex flex-col sm:flex-row gap-4 items-center justify-between mb-4 pb-4 border-b border-base-200">
          <div class="flex items-center gap-3">
            <div id="active-category-icon-wrapper" class="flex items-center justify-center size-9 rounded-lg border text-primary bg-primary/10 border-primary/20">
              <Icon id="active-category-icon" name="boxicons:folder" size={20} />
            </div>
            <div>
              <h2 id="active-category-title" class="text-lg font-bold text-base-content">Cargando...</h2>
              <p id="reorder-instructions" class="text-xs text-base-content/60">Arrastrá las filas para cambiar el orden del menú.</p>
            </div>
          </div>
          <div class="w-full sm:max-w-xs shrink-0">
            <SearchInput
              id="recursos-search"
              name="q"
              value={q}
              label="Buscar enlace"
              placeholder="Buscar por título o URL..."
            />
          </div>
        </div>

        <!-- Tabla Única de Enlaces -->
        <DataTable
          id="recursos-table"
          ariaLabel="Listado de enlaces en la categoría"
          headerGridClass={linksGridCols}
          rowGridClass={linksGridCols}
        >
          <Fragment slot="header">
            <DataTableHeaderCell></DataTableHeaderCell>
            <DataTableHeaderCell>Ícono</DataTableHeaderCell>
            <DataTableHeaderCell>Título</DataTableHeaderCell>
            <DataTableHeaderCell>Descripción</DataTableHeaderCell>
            <DataTableHeaderCell>URL</DataTableHeaderCell>
            <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
          </Fragment>

          <div id="links-container" class="divide-y divide-base-200">
            {
              links.length === 0 ? (
                <div class="flex flex-col items-center gap-3 py-16 text-base-content/50" id="empty-state">
                  <div class="rounded-full bg-base-200/40 p-4">
                    <Icon name="boxicons:data" size={32} class="opacity-30" aria-hidden="true" />
                  </div>
                  <div class="space-y-1 text-center">
                    <p class="text-sm font-semibold">No hay enlaces registrados</p>
                    <p class="text-xs">Comenzá agregando un nuevo sitio web.</p>
                  </div>
                </div>
              ) : (
                links.map((link) => (
                  <div
                    class:list={[
                      "group grid items-center px-4 py-3 transition-colors hover:bg-base-200/30 link-row",
                      linksGridCols,
                      link.deprecated && "opacity-50"
                    ]}
                    data-table-row
                    data-link-row
                    data-link-id={link.id}
                    data-link-category={(!link.categoryId || link.categoryId === uncategorizedDbId) ? "uncategorized" : link.categoryId}
                    data-link-search={`${link.title} ${link.subtitle || ""} ${link.url}`.toLowerCase()}
                    draggable="true"
                  >
                    <div class="flex items-center justify-center text-base-content/30 cursor-grab active:cursor-grabbing hover:text-base-content/70 transition-colors drag-handle">
                      <Icon name="boxicons:menu" size={20} />
                    </div>

                    <div class="flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-md border border-base-300 bg-base-200 p-0.5">
                      {link.iconPath ? (
                        <img
                          src={`${cleanBase}api/icons/${link.iconPath}`}
                          alt={`Ícono de ${link.title}`}
                          class="h-full w-full object-contain"
                        />
                      ) : (
                        <Icon name="boxicons:link" class="h-5 w-5 text-base-content/40" />
                      )}
                    </div>

                    <div class="min-w-0 truncate font-semibold flex items-center gap-2" title={link.title}>
                      <span class="truncate" data-highlight-target>{link.title}</span>
                      {link.deprecated && (
                        <span class="badge badge-neutral badge-xs font-semibold uppercase shrink-0">
                          Obsoleto
                        </span>
                      )}
                    </div>

                    <div class="min-w-0 truncate text-sm text-base-content/60" title={link.subtitle || ""} data-highlight-target>
                      {link.subtitle || "—"}
                    </div>

                    <!-- URL -->
                    <div class="min-w-0 truncate">
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-secondary hover:underline block truncate text-sm font-mono"
                        title={link.url}
                        data-highlight-target
                      >
                        {link.url.replace(/^https?:\/\/(www\.)?/, "")}
                      </a>
                    </div>

                    <!-- Acciones -->
                    <div class="flex items-center justify-end gap-1">
                      <a
                        href={resolveUrl(`/admin/recursos/enlace/edit/${link.id}`)}
                        class="btn btn-xs btn-ghost btn-square text-base-content/60 hover:text-primary hover:bg-primary/10"
                        title="Editar Enlace"
                      >
                        <Icon name="boxicons:pencil" size={16} />
                      </a>
                      <form
                        method="POST"
                        action={resolveUrl(`/admin/recursos/enlace/edit/${link.id}/eliminar`)}
                        class="inline"
                        onsubmit="return confirm('¿Estás seguro de que deseas eliminar este enlace?');"
                      >
                        <button
                          type="submit"
                          class="btn btn-xs btn-ghost btn-square text-base-content/60 hover:text-error hover:bg-error/10"
                          title="Eliminar Enlace"
                        >
                          <Icon name="boxicons:trash" size={16} />
                        </button>
                      </form>
                    </div>
                  </div>
                ))
              )
            }
          </div>
        </DataTable>
        
        <!-- Estado vacío de categoría sin elementos -->
        <div id="category-empty-state" class="hidden flex-col items-center gap-3 py-16 text-base-content/50">
          <div class="rounded-full bg-base-200/40 p-4">
            <Icon name="boxicons:link" size={32} class="opacity-30" />
          </div>
          <div class="space-y-1 text-center">
            <p class="text-sm font-semibold">Esta categoría está vacía</p>
            <p class="text-xs">Arrastrá enlaces aquí o creá uno nuevo.</p>
          </div>
        </div>

      </div>
    </main>
  </div>

  <!-- Modal de Eliminación de Categoría -->
  <dialog id="delete-category-modal" class="modal modal-bottom sm:modal-middle">
    <div class="modal-box max-w-lg w-full">
      <h3 class="font-bold text-lg text-base-content">Eliminar Categoría</h3>
      <p class="py-4 text-base-content/80 text-sm">¿Qué deseas hacer con los enlaces que están asignados a esta categoría?</p>
      <form id="delete-category-form" method="POST" action="">
        <div class="flex flex-col gap-3 mt-2">
          <label class="label cursor-pointer flex-row items-start justify-start gap-4 p-4 border border-base-300 rounded-lg hover:bg-base-200 transition-colors">
            <input type="radio" name="deleteOption" value="unassign" class="radio radio-primary shrink-0 mt-0.5" checked />
            <div class="flex flex-col gap-1 flex-1 min-w-0">
              <span class="label-text font-bold text-base leading-tight whitespace-normal">Desvincular y conservar enlaces</span>
              <span class="text-xs text-base-content/60 leading-relaxed whitespace-normal">La categoría será eliminada, pero los enlaces se conservarán y se moverán a "Sin categoría".</span>
            </div>
          </label>

          <label class="label cursor-pointer flex-row items-start justify-start gap-4 p-4 border border-base-300 rounded-lg hover:bg-base-200 transition-colors">
            <input type="radio" name="deleteOption" value="cascade" class="radio radio-error shrink-0 mt-0.5" />
            <div class="flex flex-col gap-1 flex-1 min-w-0">
              <span class="label-text font-bold text-error text-base leading-tight whitespace-normal">Eliminar todo en Cascada</span>
              <span class="text-xs text-base-content/60 leading-relaxed whitespace-normal">La categoría y todos los enlaces que contenga serán eliminados permanentemente. Esta acción no se puede deshacer.</span>
            </div>
          </label>
        </div>
        
        <div class="modal-action flex-col sm:flex-row mt-6 gap-2">
          <button type="button" class="btn btn-ghost w-full sm:w-auto" onclick="document.getElementById('delete-category-modal').close()">Cancelar</button>
          <button type="submit" class="btn btn-error gap-2 w-full sm:w-auto ml-0 sm:ml-2">
            <Icon name="boxicons:trash" size={20} />
            Confirmar Eliminación
          </button>
        </div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>cerrar</button>
    </form>
  </dialog>
</PageContainer>

<script>
  // Styling mappings
  const toneColors: Record<string, string> = {
    primary: "text-primary bg-primary/10 border-primary/20",
    secondary: "text-secondary bg-secondary/10 border-secondary/20",
    accent: "text-accent bg-accent/10 border-accent/20",
    info: "text-info bg-info/10 border-info/20",
    success: "text-success bg-success/10 border-success/20",
    warning: "text-warning bg-warning/10 border-warning/20",
    error: "text-error bg-error/10 border-error/20",
    neutral: "text-neutral bg-neutral/10 border-neutral/20",
  };

  // State
  let activeCategoryId = "";
  
  // Elements
  const categoriesList = document.getElementById("categories-list");
  const categoryItems = Array.from(document.querySelectorAll<HTMLElement>(".category-item"));
  const linkRows = Array.from(document.querySelectorAll<HTMLElement>(".link-row"));
  const linksContainer = document.getElementById("links-container");
  const searchInput = document.querySelector<HTMLInputElement>("#recursos-search");
  
  const activeIconWrapper = document.getElementById("active-category-icon-wrapper");
  const activeCategoryTitle = document.getElementById("active-category-title");
  const btnAddLink = document.getElementById("btn-add-link") as HTMLAnchorElement | null;
  const generalEmptyState = document.getElementById("empty-state");
  const categoryEmptyState = document.getElementById("category-empty-state");
  const reorderSpinner = document.getElementById("reorder-spinner");

  // Selection Handler
  const selectCategory = (categoryId: string) => {
    activeCategoryId = categoryId;
    
    // Update Category visual classes in sidebar
    categoryItems.forEach(item => {
      const isSelected = item.dataset.categoryId === categoryId;
      const tone = item.dataset.categoryTone || "primary";
      
      // Clean classes
      item.classList.remove("bg-base-200/60", "border-base-300", "shadow-sm", "bg-primary/5", "bg-secondary/5", "bg-accent/5", "bg-info/5", "bg-success/5", "bg-warning/5", "bg-error/5", "bg-neutral/5");
      
      if (isSelected) {
        item.classList.add(`bg-${tone}/5`, "border-base-300", "shadow-sm");
      } else {
        item.classList.add("border-transparent");
      }
    });

    // Update Header of current selection
    const selectedItem = categoryItems.find(item => item.dataset.categoryId === categoryId);
    if (selectedItem && activeCategoryTitle && activeIconWrapper) {
      const title = selectedItem.dataset.categoryTitle || "";
      const tone = selectedItem.dataset.categoryTone || "primary";
      
      activeCategoryTitle.textContent = title;
      
      // Update icon tone classes
      activeIconWrapper.className = `flex items-center justify-center size-9 rounded-lg border ${toneColors[tone] || toneColors.primary}`;
      
      // Update icon SVG
      const icon = selectedItem.querySelector("svg")?.cloneNode(true);
      const iconTarget = activeIconWrapper.querySelector("svg");
      if (icon && iconTarget) {
        activeIconWrapper.replaceChild(icon, iconTarget);
      }
    }

    // Prefill categoryId in Creation URL
    if (btnAddLink) {
      const base = import.meta.env.BASE_URL || "/";
      const cleanBase = base.endsWith("/") ? base : base + "/";
      if (categoryId === "all") {
        btnAddLink.href = `${cleanBase}admin/recursos/enlace/create`;
      } else {
        btnAddLink.href = `${cleanBase}admin/recursos/enlace/create?categoryId=${encodeURIComponent(categoryId)}`;
      }
    }

    // Toggle reorder handle visibility based on "Todos" category selection
    const isAll = categoryId === "all";
    const dragHandles = Array.from(document.querySelectorAll(".drag-handle"));
    dragHandles.forEach(h => {
      if (isAll) {
        h.classList.add("invisible", "pointer-events-none");
      } else {
        h.classList.remove("invisible", "pointer-events-none");
      }
    });

    const reorderInstructions = document.getElementById("reorder-instructions");
    if (reorderInstructions) {
      reorderInstructions.classList.toggle("hidden", isAll);
    }

    // Refresh rows visibility
    filterLinks();
  };

  // Initialize original text for highlighting
  const highlightTargets = Array.from(document.querySelectorAll<HTMLElement>("[data-highlight-target]"));
  highlightTargets.forEach(el => {
    el.dataset.originalText = el.textContent?.trim() || "";
  });

  // Filters links based on active category and query
  const filterLinks = () => {
    const query = searchInput?.value.trim().toLowerCase() || "";
    let visibleCount = 0;

    linkRows.forEach(row => {
      const rowCategory = row.dataset.linkCategory || "";
      const searchContent = row.dataset.linkSearch || "";
      
      const matchesCategory = activeCategoryId === "all" || rowCategory === activeCategoryId;
      const matchesSearch = query === "" || searchContent.includes(query);
      const isVisible = matchesCategory && matchesSearch;

      row.classList.toggle("hidden", !isVisible);
      if (isVisible) {
        visibleCount++;
        
        // Highlight matching terms
        const targets = Array.from(row.querySelectorAll<HTMLElement>("[data-highlight-target]"));
        targets.forEach(el => {
          const original = el.dataset.originalText || el.textContent?.trim() || "";
          if (query === "") {
            el.textContent = original;
          } else {
            const escapedQuery = query.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
            const regex = new RegExp(`(${escapedQuery})`, "gi");
            el.innerHTML = original.replace(regex, '<mark class="bg-warning/30 text-warning-content rounded-sm px-0.5">$1</mark>');
          }
        });
      }
    });

    // Handle Empty States
    if (generalEmptyState) generalEmptyState.classList.add("hidden");
    
    if (visibleCount === 0) {
      categoryEmptyState?.classList.remove("hidden");
      categoryEmptyState?.classList.add("flex");
    } else {
      categoryEmptyState?.classList.add("hidden");
      categoryEmptyState?.classList.remove("flex");
    }
  };

  // Add click handlers to Category menu items
  categoryItems.forEach(item => {
    item.addEventListener("click", () => {
      const id = item.dataset.categoryId;
      if (id) selectCategory(id);
    });
  });

  // Select first category on load
  if (categoryItems.length > 0) {
    const firstCatId = categoryItems[0].dataset.categoryId;
    if (firstCatId) selectCategory(firstCatId);
  }

  // Hook search
  searchInput?.addEventListener("input", filterLinks);

  // ----------------------------------------------------
  // Drag and Drop: Reorder links inside category
  // ----------------------------------------------------
  let draggedRow: HTMLElement | null = null;

  linkRows.forEach(row => {
    row.addEventListener("dragstart", (e) => {
      if (activeCategoryId === "all") {
        e.preventDefault();
        return;
      }
      draggedRow = row;
      row.classList.add("opacity-40", "border-primary/50", "border-dashed");
      if (e.dataTransfer) {
        e.dataTransfer.effectAllowed = "move";
        e.dataTransfer.setData("text/plain", row.dataset.linkId || "");
      }
    });

    row.addEventListener("dragend", () => {
      row.classList.remove("opacity-40", "border-primary/50", "border-dashed");
      draggedRow = null;
    });

    row.addEventListener("dragover", (e) => {
      e.preventDefault();
      if (!draggedRow || draggedRow === row) return;

      const currentCategory = row.dataset.linkCategory;
      const draggedCategory = draggedRow.dataset.linkCategory;
      if (currentCategory !== draggedCategory) return; // Only allow sorting within same category

      const bounding = row.getBoundingClientRect();
      const offset = e.clientY - bounding.top - bounding.height / 2;

      if (linksContainer) {
        if (offset < 0) {
          linksContainer.insertBefore(draggedRow, row);
        } else {
          linksContainer.insertBefore(draggedRow, row.nextSibling);
        }
      }
    });

    row.addEventListener("drop", (e) => {
      e.preventDefault();
      saveReorderedLinks();
    });
  });

  // ----------------------------------------------------
  // Drag and Drop: Move link to another category
  // ----------------------------------------------------
  categoryItems.forEach(zone => {
    zone.addEventListener("dragover", (e) => {
      e.preventDefault();
      const targetCategoryId = zone.dataset.categoryId;
      if (targetCategoryId === "all") return;
      if (draggedRow && draggedRow.dataset.linkCategory !== targetCategoryId) {
        zone.classList.add("bg-base-300", "scale-[1.02]");
      }
    });

    zone.addEventListener("dragleave", () => {
      zone.classList.remove("bg-base-300", "scale-[1.02]");
    });

    zone.addEventListener("drop", async (e) => {
      e.preventDefault();
      const targetCategoryId = zone.dataset.categoryId;
      if (targetCategoryId === "all") return;
      zone.classList.remove("bg-base-300", "scale-[1.02]");

      const linkId = e.dataTransfer?.getData("text/plain");

      if (!linkId || !targetCategoryId || !draggedRow) return;
      
      const sourceCategoryId = draggedRow.dataset.linkCategory;
      if (sourceCategoryId === targetCategoryId) return;

      // Update in local state/DOM
      draggedRow.dataset.linkCategory = targetCategoryId;
      
      // Update link badges if necessary (no badge in this layout, but filters are updated)
      filterLinks();

      // Update counters visually
      const sourceBadge = categoryItems.find(item => item.dataset.categoryId === sourceCategoryId)?.querySelector(".count-badge");
      const targetBadge = zone.querySelector(".count-badge");
      
      if (sourceBadge) {
        const count = Math.max(0, parseInt(sourceBadge.textContent || "0") - 1);
        sourceBadge.textContent = String(count);
      }
      if (targetBadge) {
        const count = parseInt(targetBadge.textContent || "0") + 1;
        targetBadge.textContent = String(count);
      }

      // Save to database
      await saveReorderedLinks();
    });
  });

  // Bulk update call to API
  const saveReorderedLinks = async () => {
    if (reorderSpinner) reorderSpinner.classList.remove("hidden");

    try {
      // Gather all rows in their current DOM positions to build sequential orders
      const allRows = Array.from(document.querySelectorAll<HTMLElement>(".link-row"));
      
      // We group them by category to update order properly inside each category
      const categoryGroups: Record<string, HTMLElement[]> = {};
      allRows.forEach(row => {
        const catId = row.dataset.linkCategory || "";
        if (!categoryGroups[catId]) categoryGroups[catId] = [];
        categoryGroups[catId].push(row);
      });

      const items: any[] = [];
      Object.keys(categoryGroups).forEach(catId => {
        categoryGroups[catId].forEach((row, index) => {
          items.push({
            id: row.dataset.linkId,
            sortOrder: index * 10, // increments of 10
            categoryId: catId
          });
        });
      });

      const base = import.meta.env.BASE_URL || "/";
      const cleanBase = base.endsWith("/") ? base : base + "/";
      
      const response = await fetch(`${cleanBase}api/admin/recursos/reorder`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items }),
      });

      if (!response.ok) {
        throw new Error("Error de red al intentar guardar cambios");
      }
      
      (window as any).showToast?.("Menú y categorías sincronizadas con éxito", "alert-success");
    } catch (err) {
      console.error(err);
      (window as any).showToast?.("Error al guardar el nuevo orden del menú", "alert-error");
    } finally {
      if (reorderSpinner) reorderSpinner.classList.add("hidden");
    }
  };

  // ----------------------------------------------------
  // Modal logic attached to window for delete modal
  // ----------------------------------------------------
  (window as any).openDeleteCategoryModal = (categoryId: string) => {
    const modal = document.getElementById("delete-category-modal") as (HTMLDialogElement & { showModal(): void }) | null;
    const form = document.getElementById("delete-category-form") as HTMLFormElement | null;
    
    if (modal && form) {
      const base = import.meta.env.BASE_URL || "/";
      const cleanBase = base.endsWith("/") ? base : base + "/";
      const cleanPath = `admin/recursos/categoria/edit/${categoryId}/eliminar`;
      
      form.action = `${cleanBase}${cleanPath}`;
      modal.showModal();
    }
  };
</script>
