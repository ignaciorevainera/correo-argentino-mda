---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";

const headerGridClass = "grid-cols-[80px_1fr_90px_150px_1fr_140px] gap-4";
const rowGridClass =
  "grid grid-cols-[80px_1fr_90px_150px_1fr_140px] items-center gap-4";
---

<PageContainer>
  <div class="skeleton-debounced">
    <PageHeader
      description="Administración del directorio operativo de oficinas, contactos y activos tecnológicos."
    />

    {/* ── Filtros Skeleton ── */}
    <div class="flex flex-col gap-4 rounded-box border border-base-300 bg-base-100 p-4 shadow-md">
      <div class="w-full">
        <div class="h-12 w-full skeleton rounded-lg"></div>
      </div>
      <div class="flex flex-wrap items-center gap-3 w-full">
        <div class="h-10 flex-1 min-w-40 skeleton rounded-lg"></div>
        <div class="h-10 flex-1 min-w-40 skeleton rounded-lg"></div>
        <div class="h-10 flex-1 min-w-40 skeleton rounded-lg"></div>
        <div class="h-10 flex-1 min-w-40 skeleton rounded-lg"></div>
        <div class="flex-2 min-w-70 h-10 skeleton rounded-lg"></div>
      </div>
    </div>

    {/* ── Toolbar Superior Skeleton ── */}
    <div class="flex items-center justify-between gap-4 mt-6">
      <div class="flex items-center gap-3">
        <h2 class="text-lg font-semibold text-base-content">
          Oficinas registradas
        </h2>
        <div class="h-5 w-12 skeleton rounded-full"></div>
      </div>
      <div class="h-10 w-36 skeleton rounded-lg"></div>
    </div>

    {/* ── Tabla Skeleton ── */}
    <DataTable
      ariaLabel="Cargando oficinas..."
      minWidthClass="min-w-200"
      headerGridClass={headerGridClass}
      rowGridClass={rowGridClass}
      class="mt-4"
    >
      <div slot="header">
        <DataTableHeaderCell sortKey="code">Código</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="name">Nombre</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="parent-nis">NIS Padre</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="type">Tipo</DataTableHeaderCell>
      </div>
      <div slot="header">
        <DataTableHeaderCell sortKey="region">Provincia / Región</DataTableHeaderCell>
      </div>
      <div slot="header" class="text-right">
        <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>
      </div>

      {
        Array.from({ length: 5 }).map(() => (
          <div class:list={[rowGridClass, "border-b border-base-300 px-4 py-4 last:border-b-0"]}>
            <div class="h-4 w-12 skeleton rounded"></div>
            <div class="h-4 w-40 skeleton rounded"></div>
            <div class="h-4 w-16 skeleton rounded"></div>
            <div class="h-6 w-24 skeleton rounded-lg"></div>
            <div class="h-4 w-32 skeleton rounded"></div>
            <div class="flex justify-end gap-2">
              <div class="h-7 w-16 skeleton rounded-lg"></div>
              <div class="h-7 w-16 skeleton rounded-lg"></div>
            </div>
          </div>
        ))
      }
    </DataTable>
  </div>
</PageContainer>
