---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";

const headerGridClass = "grid-cols-[1fr_1.1fr_2.2fr_1.2fr_150px] gap-4";
---

<PageContainer width="xxl">
  <div class="skeleton-debounced">
    <section class="space-y-4">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <PageHeader
          description="Matriz unificada de equivalencias y derivación técnica de la Mesa de Ayuda."
          class="max-w-2xl"
        />
        <div class="flex gap-2 w-full md:w-auto">
          <div class="h-10 w-full md:w-80 skeleton rounded-lg"></div>
        </div>
      </div>
    </section>

    <div class="space-y-8 mt-6" id="main-view-directory">
      <section class="bg-base-100 rounded-xl shadow-md overflow-hidden border border-base-content/10">
        <div class="border border-base-300 rounded-xl overflow-hidden bg-base-100">
          <!-- Table Header Skeleton -->
          <div class={`grid ${headerGridClass} border-b border-base-300 px-4 py-3 bg-base-200/50`}>
            <div><div class="h-5 w-24 skeleton rounded"></div></div>
            <div><div class="h-5 w-20 skeleton rounded"></div></div>
            <div><div class="h-5 w-32 skeleton rounded"></div></div>
            <div><div class="h-5 w-16 skeleton rounded"></div></div>
            <div><div class="h-5 w-16 skeleton rounded"></div></div>
          </div>

          <!-- Rows Skeleton (10 rows) -->
          <div class="divide-y divide-base-300">
            {Array.from({ length: 10 }).map(() => (
              <div class={`grid ${headerGridClass} items-center px-4 py-4`}>
                <div><div class="h-4 w-28 skeleton rounded"></div></div>
                <div><div class="h-4 w-24 skeleton rounded"></div></div>
                <div><div class="h-4 w-52 skeleton rounded"></div></div>
                <div><div class="h-4 w-16 skeleton rounded"></div></div>
                <div><div class="h-6 w-16 skeleton rounded justify-self-start"></div></div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>
  </div>
</PageContainer>
