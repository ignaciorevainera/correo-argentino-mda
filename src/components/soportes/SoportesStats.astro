---
import { Icon } from "astro-icon/components";

interface Props {
  total: number;
  active: number;
  totalMembers: number;
}

const { total, active, totalMembers } = Astro.props;
---

<div
  class="flex flex-wrap gap-6 bg-base-200/50 rounded-xl p-4 border border-base-300/50"
>
  <div class="flex items-center gap-2.5">
    <div class="bg-secondary/10 p-2 rounded-lg text-secondary">
      <Icon name="boxicons:group-alt-filled" size={20} aria-hidden="true" />
    </div>
    <div>
      <div class="text-xs text-base-content/60">Total de mesas</div>
      <div class="text-lg font-bold font-mono">{total}</div>
    </div>
  </div>

  <div class="border-r border-base-300 hidden md:block h-10 self-center"></div>

  <div class="flex items-center gap-2.5">
    <div class="bg-success/10 p-2 rounded-lg text-success">
      <Icon name="boxicons:check-circle" size={20} aria-hidden="true" />
    </div>
    <div>
      <div class="text-xs text-base-content/60">Activas</div>
      <div class="text-lg font-bold font-mono text-success">{active}</div>
    </div>
  </div>

  <div class="border-r border-base-300 hidden md:block h-10 self-center"></div>

  <div class="flex items-center gap-2.5">
    <div class="bg-primary/10 p-2 rounded-lg text-primary">
      <Icon name="boxicons:group-filled" size={20} aria-hidden="true" />
    </div>
    <div>
      <div class="text-xs text-base-content/60">Miembros globales</div>
      <div class="text-lg font-bold font-mono">{totalMembers}</div>
    </div>
  </div>
</div>
