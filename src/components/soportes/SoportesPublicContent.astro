---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import SearchEmptyState from "@components/ui/SearchEmptyState.astro";
import { getSupportGuides } from "@lib/supportGuidesQueries";
import SupportGuideRow from "@components/support-guides/SupportGuideRow.astro";

const searchParams = Astro.url.searchParams;
const searchFilter = searchParams.get("search") || "";

const { data: guides, hasMore } = await getSupportGuides({
  page: 1,
  limit: 100,
  search: searchFilter,
});

const headerGridClass = "grid-cols-[1fr_1.1fr_2.2fr_1.2fr_150px] gap-4";
---

<PageContainer width="xxl">
  <!-- Page Header -->
  <section class="space-y-4">
    <div
      class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4"
    >
      <PageHeader
        description="Matriz unificada de equivalencias y derivación técnica de la Mesa de Ayuda."
        class="max-w-2xl"
      />

      <form
        method="GET"
        class="flex gap-2 w-full md:w-auto"
        id="search-form"
        aria-label="Filtros de guías de soporte"
      >
        <SearchInput
          id="global-search"
          name="search"
          value={searchFilter}
          label="Buscar grupo SM, Invgate, temas o ruta..."
          placeholder="Buscar por grupo SM, Invgate..."
          class="w-full md:w-80"
        />
        {
          searchFilter !== "" && (
            <a
              href="/soportes"
              class="btn btn-soft text-base-content/70 hover:text-base-content"
              aria-label="Limpiar filtros"
              title="Limpiar búsqueda"
            >
              Limpiar
            </a>
          )
        }
      </form>
    </div>
  </section>

  <!-- Unified Table View -->
  <div class="space-y-8" id="main-view-directory">
    <section
      class="bg-base-100 rounded-xl shadow-md overflow-hidden border border-base-content/10"
      id="guides-table-wrapper"
    >
      <div id="guides-table-container" class:list={[guides.length === 0 && "hidden"]}>
        <DataTable
          ariaLabel="Guía de soportes"
          minWidthClass="min-w-240"
          headerGridClass={headerGridClass}
          rowGridClass={headerGridClass}
          id="table-guia-root"
        >
          <div slot="header">
            <DataTableHeaderCell sortKey="legacy"
              >Nombre Anterior</DataTableHeaderCell
            >
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="invgate">Invgate</DataTableHeaderCell>
          </div>
          <div slot="header">
            <DataTableHeaderCell>Ruta de búsqueda</DataTableHeaderCell>
          </div>
          <div slot="header">
            <DataTableHeaderCell>Tópicos</DataTableHeaderCell>
          </div>
          <div slot="header">
            <DataTableHeaderCell>Acciones</DataTableHeaderCell>
          </div>

          {guides.map((guide) => <SupportGuideRow guide={guide} />)}
        </DataTable>
      </div>

      <SearchEmptyState
        id="no-results-state"
        class={guides.length > 0 ? "hidden" : "flex"}
        title="No hay coincidencias"
        description="No hemos podido encontrar guías que coincidan con la búsqueda. Probá modificando los criterios o restableciendo la búsqueda para explorar el directorio completo."
        showClearButton={true}
        clearButtonHref={import.meta.env.BASE_URL + "soportes"}
        clearButtonText="Restablecer búsqueda"
      />

      <div
        id="scroll-sentinel"
        class:list={[
          "py-8 text-center flex justify-center",
          !hasMore && "hidden",
        ]}
        data-has-more={hasMore ? "true" : "false"}
      >
        <span
          class="loading loading-spinner loading-md text-primary hidden"
          id="loading-spinner"></span>
      </div>
    </section>
  </div>
</PageContainer>

<script>
  import { highlightSearchTargets } from "@lib/clientSearch";

  const container = document.querySelector<HTMLElement>(
    "[data-table-sort-body]",
  );
  const sentinel = document.getElementById("scroll-sentinel");
  const spinner = document.getElementById("loading-spinner");
  const noResultsState = document.getElementById("no-results-state");
  const searchInput =
    document.querySelector<HTMLInputElement>("#global-search");
  const form = document.getElementById("search-form") as HTMLFormElement;

  let currentPage = 1;
  let currentSearch = searchInput?.value.trim() || "";
  let isLoading = false;
  let hasMore = sentinel?.getAttribute("data-has-more") === "true";
  let searchTimeout: ReturnType<typeof setTimeout>;

  const getQueryParams = (pageNumber: number) => {
    const params = new URLSearchParams();
    params.set("page", pageNumber.toString());
    params.set("limit", "100");
    if (currentSearch) {
      params.set("search", currentSearch);
    }
    return params.toString();
  };

  const fetchGuides = async (isNewSearch: boolean) => {
    if (isLoading) return;
    isLoading = true;
    spinner?.classList.remove("hidden");

    try {
      const query = getQueryParams(currentPage);
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const response = await fetch(`${baseUrl}/api/support-guides?${query}`);
      if (!response.ok) throw new Error("API call failed");

      const html = await response.text();
      const newHasMore = response.headers.get("X-Has-More") === "true";
      const totalCount = parseInt(
        response.headers.get("X-Total-Count") || "0",
        10,
      );

      hasMore = newHasMore;

      if (container) {
        if (isNewSearch) {
          container.innerHTML = html;
        } else {
          container.insertAdjacentHTML("beforeend", html);
        }
      }

      const tableContainer = document.getElementById("guides-table-container");
      if (noResultsState && tableContainer) {
        if (totalCount === 0) {
          noResultsState.classList.remove("hidden");
          noResultsState.classList.add("flex");
          tableContainer.classList.add("hidden");
        } else {
          noResultsState.classList.add("hidden");
          noResultsState.classList.remove("flex");
          tableContainer.classList.remove("hidden");
        }
      }

      if (currentSearch && container) {
        const newArticles = Array.from(
          container.querySelectorAll<HTMLElement>(
            "[data-master-detail-sort-item]",
          ),
        );
        newArticles.forEach((item) => {
          highlightSearchTargets(item, currentSearch);
        });
      }

      if (!hasMore) {
        sentinel?.classList.add("hidden");
      } else {
        sentinel?.classList.remove("hidden");
      }
    } catch (err) {
      console.error("Error fetching guides:", err);
    } finally {
      isLoading = false;
      spinner?.classList.add("hidden");
    }
  };

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    currentSearch = searchInput?.value.trim() || "";
    currentPage = 1;
    hasMore = true;
    fetchGuides(true);
  });

  searchInput?.addEventListener("input", (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentSearch = (e.target as HTMLInputElement).value.trim();
      currentPage = 1;
      hasMore = true;
      fetchGuides(true);
    }, 300);
  });

  if (sentinel) {
    const observer = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];
        if (entry.isIntersecting && hasMore && !isLoading) {
          currentPage += 1;
          fetchGuides(false);
        }
      },
      {
        rootMargin: "200px",
      },
    );
    observer.observe(sentinel);
  }

  // Highlight initial results if there's a search on page load
  if (currentSearch && container) {
    const initialArticles = Array.from(
      container.querySelectorAll<HTMLElement>("[data-master-detail-sort-item]"),
    );
    initialArticles.forEach((item) => {
      highlightSearchTargets(item, currentSearch);
    });
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
