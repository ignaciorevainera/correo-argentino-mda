---
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import { invgateGet } from "@lib/invgateClient";
import { db } from "@db/index";
import { supportGuides } from "@db/schema";
import { asc } from "drizzle-orm";
import { isAllowed } from "@lib/rolesMatrix";
import HelpdeskCard from "./HelpdeskCard.astro";
import UnassignedRecords from "./UnassignedRecords.astro";
import SoportesStats from "./SoportesStats.astro";
import ExportCsvButton from "@components/ui/ExportCsvButton.astro";
import SearchEmptyState from "@components/ui/SearchEmptyState.astro";
import type { InvgateHelpdesk, InvgateHelpdeskAndLevel } from "@/types/invgate";
import { HIDDEN_HELPDESK_IDS } from "@lib/soportesConfig";

const user = Astro.locals.user;
const isAdminUser = user
  ? isAllowed("Administrar Contenido", user.role)
  : false;

const hdResult =
  await invgateGet<InvgateHelpdeskAndLevel[]>("helpdesksandlevels");
const allItems: InvgateHelpdeskAndLevel[] =
  hdResult.ok && Array.isArray(hdResult.data) ? hdResult.data : [];
const invgateError = !hdResult.ok;

const parentHelpdesks = allItems.filter(
  (item) => item.level_order === undefined,
);

const parentMap = new Map<number, InvgateHelpdeskAndLevel>();
parentHelpdesks.forEach((h) => parentMap.set(h.id, h));

const subLevelsByParent = new Map<number, InvgateHelpdeskAndLevel[]>();
allItems
  .filter((item) => item.level_order !== undefined && item.parent_id !== null)
  .forEach((level) => {
    const pid = level.parent_id as number;
    const list = subLevelsByParent.get(pid) || [];
    list.push(level);
    subLevelsByParent.set(pid, list);
  });

const visibleHelpdesks = parentHelpdesks
  .filter((hd) => !HIDDEN_HELPDESK_IDS.includes(hd.id))
  .sort((a, b) => (a.name || "").localeCompare(b.name || ""));

const parentNameMap = new Map<number, string>();
visibleHelpdesks.forEach((hd) => {
  if (hd.parent_id && parentMap.has(hd.parent_id)) {
    parentNameMap.set(hd.id, parentMap.get(hd.parent_id)!.name || "");
  }
});

const guides = await db.query.supportGuides.findMany({
  orderBy: [asc(supportGuides.helpDeskName)],
});

const groupedRecords = new Map<number, typeof guides>();
const unassignedRecords: typeof guides = [];

guides.forEach((g) => {
  if (g.invgate_id !== null) {
    const existing = groupedRecords.get(g.invgate_id) || [];
    existing.push(g);
    groupedRecords.set(g.invgate_id, existing);
  } else {
    unassignedRecords.push(g);
  }
});

const uniqueParentNames = [
  ...new Set(
    visibleHelpdesks.map((hd) => parentNameMap.get(hd.id)).filter(Boolean),
  ),
].sort((a, b) => a!.localeCompare(b!)) as string[];

const activeCount = visibleHelpdesks.filter((hd) => hd.status_id === 1).length;
const totalMembers = visibleHelpdesks.reduce(
  (acc, hd) => acc + (hd.total_members || 0),
  0,
);
---

<PageContainer width="xxl">
  <PageHeader
    description="Matriz unificada de equivalencias y derivacion tecnica de la Mesa de Ayuda."
    class="max-w-2xl"
  />

  {
    invgateError && (
      <div role="alert" class="alert alert-warning mt-4">
        <Icon name="boxicons:x-circle-filled" size={20} />
        <span>
          No se pudo conectar con InvGate. Mostrando datos locales disponibles.
        </span>
      </div>
    )
  }

  <UnassignedRecords count={unassignedRecords.length} isAdmin={isAdminUser} />

  <SoportesStats
    total={visibleHelpdesks.length}
    active={activeCount}
    totalMembers={totalMembers}
  />

  <div class="flex flex-nowrap items-center gap-2 md:gap-3 w-full">
    <div class="flex-1 min-w-0">
      <SearchBar
        id="soportes-search"
        placeholder="Buscar por nombre SM, Invgate, topico..."
        class="w-full"
      />
    </div>

    <select
      id="filter-status"
      class="select select-bordered shrink-0 select-sm md:select-md"
    >
      <option value="all">Todos los estados</option>
      <option value="active">Activos</option>
      <option value="inactive">Inactivos</option>
    </select>

    {
      uniqueParentNames.length > 0 && (
        <select
          id="filter-parent"
          class="select select-bordered shrink-0 select-sm md:select-md"
        >
          <option value="all">Todas las mesas padre</option>
          {uniqueParentNames.map((name) => (
            <option value={name}>{name}</option>
          ))}
        </select>
      )
    }

    <select
      id="sort-by"
      class="select select-bordered shrink-0 select-sm md:select-md"
    >
      <option value="name-asc">Nombre A-Z</option>
      <option value="name-desc">Nombre Z-A</option>
      <option value="members-desc">Más miembros</option>
      <option value="members-asc">Menos miembros</option>
      <option value="topics-desc">Más tópicos</option>
      <option value="topics-asc">Menos tópicos</option>
    </select>

    <button
      id="clear-filters"
      class="btn btn-outline btn-error font-semibold gap-2 shrink-0 btn-sm md:btn-md"
      aria-label="Limpiar todos los filtros"
      title="Limpiar todos los filtros"
    >
      <Icon name="boxicons:trash" class="size-4" aria-hidden="true" />
      <span class="hidden lg:inline">Limpiar filtros</span>
    </button>
    <ExportCsvButton
      id="export-csv"
      title="Exportar como CSV"
      label="CSV"
      shortLabel="CSV"
      iconSize={16}
    />
  </div>

  <div
    id="soportes-grid"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
  >
    {
      visibleHelpdesks.map((hd) => {
        const records = groupedRecords.get(hd.id) || [];
        const parentName = parentNameMap.get(hd.id);
        const subLevels = subLevelsByParent.get(hd.id) || [];
        return (
          <HelpdeskCard
            helpdesk={hd}
            records={records}
            isAdmin={isAdminUser}
            parentName={parentName}
            subLevels={subLevels}
          />
        );
      })
    }

    {
      visibleHelpdesks.length === 0 && guides.length === 0 && (
        <div class="col-span-full flex flex-col items-center gap-3 py-16 text-base-content/50">
          <div class="rounded-full bg-base-200 p-4">
            <Icon
              name="boxicons:group-alt-filled"
              size={32}
              class="opacity-30"
              aria-hidden="true"
            />
          </div>
          <p class="text-sm font-semibold">No hay mesas de ayuda disponibles</p>
          <p class="text-xs">
            Verifica la conexion con InvGate o registra soportes manualmente.
          </p>
        </div>
      )
    }

    <SearchEmptyState
      id="no-results-state-soportes"
      class="hidden col-span-full"
      title="Sin resultados"
      description="No se encontraron mesas de ayuda o áreas que coincidan con los filtros aplicados."
      showClearButton={true}
      clearButtonId="btn-clear-empty-soportes"
      clearButtonText="Limpiar filtros"
    />
  </div>
</PageContainer>

<script>
  import {
    matchesSearchQuery,
    highlightSearchTargets,
  } from "@lib/clientSearch";

  const searchInput =
    document.querySelector<HTMLInputElement>("#soportes-search");
  const filterStatus =
    document.querySelector<HTMLSelectElement>("#filter-status");
  const filterParent =
    document.querySelector<HTMLSelectElement>("#filter-parent");
  const sortBy = document.querySelector<HTMLSelectElement>("#sort-by");
  const grid = document.querySelector<HTMLElement>("#soportes-grid");
  const cards = document.querySelectorAll<HTMLElement>("[data-card-for]");

  function applyFiltersAndSort() {
    const query = searchInput?.value.trim() || "";
    const statusFilter = filterStatus?.value || "all";
    const parentFilter = filterParent?.value || "all";
    const sortValue = sortBy?.value || "name-asc";

    const visible: HTMLElement[] = [];

    cards.forEach((card) => {
      const searchText = card.dataset.searchText || "";
      const cardStatus = card.dataset.status || "";
      const cardParent = card.dataset.parentName || "";

      const matchesSearch = matchesSearchQuery(query, [searchText]);
      const matchesStatus =
        statusFilter === "all" || cardStatus === statusFilter;
      const matchesParent =
        parentFilter === "all" || cardParent === parentFilter;

      const isVisible = matchesSearch && matchesStatus && matchesParent;
      card.classList.toggle("hidden", !isVisible);

      if (isVisible) {
        visible.push(card);
        highlightSearchTargets(card, query);
      }
    });

    const noResultsState = document.getElementById("no-results-state-soportes");
    if (noResultsState) {
      if (visible.length === 0) {
        noResultsState.classList.remove("hidden");
        noResultsState.classList.add("flex");
      } else {
        noResultsState.classList.add("hidden");
        noResultsState.classList.remove("flex");
      }
    }

    visible.sort((a, b) => {
      const getName = (el: HTMLElement) =>
        (el.dataset.name || "").toLowerCase();
      const getMembers = (el: HTMLElement) =>
        parseInt(el.dataset.memberCount || "0", 10);
      const getTopics = (el: HTMLElement) =>
        parseInt(el.dataset.topicCount || "0", 10);

      switch (sortValue) {
        case "name-desc":
          return getName(b).localeCompare(getName(a));
        case "members-desc":
          return getMembers(b) - getMembers(a);
        case "members-asc":
          return getMembers(a) - getMembers(b);
        case "topics-desc":
          return getTopics(b) - getTopics(a);
        case "topics-asc":
          return getTopics(a) - getTopics(b);
        default:
          return getName(a).localeCompare(getName(b));
      }
    });

    if (grid) {
      visible.forEach((card) => grid.appendChild(card));
    }
  }

  searchInput?.addEventListener("input", applyFiltersAndSort);
  filterStatus?.addEventListener("change", applyFiltersAndSort);
  filterParent?.addEventListener("change", applyFiltersAndSort);
  sortBy?.addEventListener("change", applyFiltersAndSort);

  cards.forEach((card) => {
    card.addEventListener("members-loaded", () => {
      if (searchInput?.value) applyFiltersAndSort();
    });
  });

  const clearFiltersBtn =
    document.querySelector<HTMLButtonElement>("#clear-filters");
  const clearEmptyBtn = document.querySelector<HTMLButtonElement>(
    "#btn-clear-empty-soportes",
  );

  const resetFilters = () => {
    if (searchInput) searchInput.value = "";
    if (filterStatus) filterStatus.value = "all";
    if (filterParent) filterParent.value = "all";
    if (sortBy) sortBy.value = "name-asc";
    applyFiltersAndSort();
  };

  clearFiltersBtn?.addEventListener("click", resetFilters);
  clearEmptyBtn?.addEventListener("click", resetFilters);

  const exportCsvBtn = document.querySelector<HTMLButtonElement>("#export-csv");
  const exportPdfBtn = document.querySelector<HTMLButtonElement>("#export-pdf");

  exportCsvBtn?.addEventListener("click", () => {
    const visibleCards = Array.from(cards).filter(
      (c) => !c.classList.contains("hidden"),
    );

    let csvContent = "\uFEFF";
    csvContent += "Nombre,Estado,Mesa Padre,Miembros,Tópicos,Nombres Legacy\n";

    visibleCards.forEach((card) => {
      const name = (card.dataset.name || "").replace(/"/g, '""');
      const status = card.dataset.status === "active" ? "Activo" : "Inactivo";
      const parentName = (card.dataset.parentName || "").replace(/"/g, '""');
      const members = card.dataset.memberCount || "0";

      const topics = Array.from(card.querySelectorAll(".badge-secondary"))
        .map((el) => el.textContent?.trim() || "")
        .join(", ")
        .replace(/"/g, '""');

      const legacy = Array.from(card.querySelectorAll(".badge-ghost"))
        .filter((el) => !el.querySelector(".line-clamp-2"))
        .map((el) => el.textContent?.trim() || "")
        .filter(Boolean)
        .join(", ")
        .replace(/"/g, '""');

      csvContent += `"${name}","${status}","${parentName}",${members},"${topics}","${legacy}"\n`;
    });

    const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    link.setAttribute("download", "soportes-helpdesks.csv");
    link.style.visibility = "hidden";
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });

  exportPdfBtn?.addEventListener("click", () => {
    window.print();
  });
</script>

<style>
  @media print {
    :global(header),
    :global(footer),
    :global(aside),
    :global(nav),
    #soportes-search,
    #filter-status,
    #filter-parent,
    #sort-by,
    #clear-filters,
    #export-csv,
    #export-pdf,
    :global(.card-actions),
    :global(.alert) {
      display: none !important;
    }
    #soportes-grid {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 12px !important;
    }
    :global(.card) {
      break-inside: avoid;
      box-shadow: none !important;
      border: 1px solid #e5e7eb !important;
    }
  }
</style>
