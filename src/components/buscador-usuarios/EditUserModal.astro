---
import Modal from "@components/ui/Modal.astro";
---

<Modal id="edit-user-modal" title="Editar Datos de Contacto" icon="boxicons:pencil">
  <Fragment slot="content">
    <p
      class="text-xs text-base-content/50 mb-6 bg-base-200/50 p-2.5 rounded-lg border border-base-300"
    >
      Modifica los datos del colaborador. Las actualizaciones se guardarán
      inmediatamente en la base de datos central.
    </p>

    <form id="edit-user-form" class="space-y-4">
      <!-- Nombre (Solo lectura para contexto) -->
      <div class="form-control w-full">
        <label class="label py-1">
          <span
            class="label-text font-bold text-xs uppercase text-base-content/40 tracking-wider"
            >Nombre del Colaborador</span
          >
        </label>
        <input
          type="text"
          id="edit-user-fullname"
          class="input input-bordered w-full bg-base-200 border-base-300 text-base-content/70 cursor-not-allowed font-medium"
          disabled
          readonly
        />
      </div>

      <input type="hidden" id="edit-user-dni" />

      <div class="grid grid-cols-2 gap-4">
        <!-- Campo Interno -->
        <div class="form-control w-full">
          <label class="label py-1" for="edit-user-interno">
            <span
              class="label-text font-bold text-xs uppercase text-base-content/40 tracking-wider"
              >Interno</span
            >
          </label>
          <input
            type="text"
            id="edit-user-interno"
            placeholder="Ej. 4231"
            class="input input-bordered w-full bg-base-100 border-base-300 focus:border-primary text-base font-mono focus:outline-hidden"
            autocomplete="off"
          />
        </div>

        <!-- Campo Teléfono -->
        <div class="form-control w-full">
          <label class="label py-1" for="edit-user-telefono">
            <span
              class="label-text font-bold text-xs uppercase text-base-content/40 tracking-wider"
              >Teléfono</span
            >
          </label>
          <input
            type="text"
            id="edit-user-telefono"
            placeholder="Ej. 11 1234-5678"
            class="input input-bordered w-full bg-base-100 border-base-300 focus:border-primary text-base font-mono focus:outline-hidden"
            autocomplete="off"
          />
        </div>
      </div>
    </form>
  </Fragment>
  <Fragment slot="actions">
    <button
      type="button"
      class="btn btn-ghost border border-base-300 hover:bg-base-200 cursor-pointer"
      id="close-edit-modal-btn"
    >
      Cancelar
    </button>
    <button
      type="submit"
      class="btn btn-primary gap-2 cursor-pointer shadow-md"
      id="save-edit-btn"
    >
      <span
        id="save-btn-spinner"
        class="loading loading-spinner loading-xs hidden"></span>
      Guardar Cambios
    </button>
  </Fragment>
</Modal>
