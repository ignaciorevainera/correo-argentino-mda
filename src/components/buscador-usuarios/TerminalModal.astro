---
import { Icon } from "astro-icon/components";
import Modal from "@components/ui/Modal.astro";
---

<Modal id="terminal-modal" class="max-w-5xl w-full p-0 font-mono">
  <Fragment slot="content">
    <!-- Barra de título de terminal estilo Windows/Linux -->
    <div
      class="bg-base-200 px-4 py-2.5 flex items-center justify-between border-b border-base-300 select-none"
    >
      <div class="flex items-center gap-2">
        <span class="text-xs font-semibold text-base-content/70"
          >cmd.exe - net user <span id="terminal-user-title"></span> /domain</span
        >
      </div>
    </div>

    <!-- Tabs de Navegación -->
    <div class="flex border-b border-base-300 bg-base-200/50 px-4">
      <button
        id="tab-panel-btn"
        class="px-4 py-3 text-xs font-bold border-b-2 border-secondary text-secondary transition-all focus:outline-hidden cursor-pointer font-sans"
        type="button"
      >
        Panel Organizado
      </button>
      <button
        id="tab-console-btn"
        class="px-4 py-3 text-xs font-bold border-b-2 border-transparent text-base-content/60 hover:text-base-content transition-all focus:outline-hidden cursor-pointer font-sans"
        type="button"
      >
        Consola CMD
      </button>
    </div>

    <!-- Pantalla de Terminal / Contenido Principal -->
    <div class="p-6 relative min-h-125 flex flex-col justify-stretch">
      <!-- Loader general -->
      <div
        id="terminal-loading"
        class="hidden absolute inset-0 bg-base-100/95 flex-col items-center justify-center gap-3 z-20"
      >
        <span class="loading loading-spinner loading-lg text-secondary"></span>
        <span class="text-xs text-base-content/60"
          >Consultando Active Directory...</span
        >
      </div>

      <!-- VISTA 1: Panel Organizado -->
      <div
        id="view-panel"
        class="grid grid-cols-1 md:grid-cols-3 gap-6 flex-1 items-stretch"
      >
        <!-- Columna Izquierda: Detalles del usuario -->
        <div
          class="md:col-span-1 space-y-4 border-r border-base-300 pr-4 flex flex-col justify-start max-h-130 overflow-y-auto scrollbar-thin"
        >
          <div
            class="text-xxs text-base-content/50 uppercase tracking-widest border-b border-base-300 pb-1 mb-1 font-bold font-sans"
          >
            Detalles de Red
          </div>

          <div class="space-y-3 font-sans">
            <!-- Cuenta de red -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:user-filled" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Cuenta de Red
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5 font-mono break-all"
                    id="term-info-username"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar cuenta"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-username"
                title="Copiar cuenta"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Nombre Completo -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:user-id-card-filled" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Nombre Completo
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-fullname"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar nombre"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-fullname"
                title="Copiar nombre"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Cargo -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:briefcase" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Cargo / Puesto
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-title"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar cargo"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-title"
                title="Copiar cargo"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Número de Legajo -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:badge" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Número de Legajo
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5 font-mono"
                    id="term-info-employeenumber"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar legajo"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-employeenumber"
                title="Copiar legajo"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Ubicación / Oficina -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:building" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Ubicación / Oficina
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-office"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar oficina"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-office"
                title="Copiar oficina"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Jefe / Supervisor -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:user-circle-filled" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Jefe Directo / Supervisor
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5 flex items-center justify-between gap-2"
                  >
                    <span id="term-info-manager">-</span>
                    <button
                      type="button"
                      id="btn-search-manager"
                      class="btn btn-secondary btn-xs font-sans px-2 hidden cursor-pointer shrink-0"
                      title="Buscar supervisor en el portal"
                    >
                      <Icon name="boxicons:search" size={12} class="shrink-0" />
                      <span>Buscar</span>
                    </button>
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0 animate-fade-in"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar jefe"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-manager"
                title="Copiar jefe"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>
          </div>

          <!-- Separador Diagnóstico -->
          <div
            class="text-xxs text-base-content/50 uppercase tracking-widest border-b border-base-300 pb-1 mt-5 mb-1 font-bold font-sans"
          >
            Seguridad y Acceso
          </div>

          <div class="space-y-3 font-sans">
            <!-- Último cambio de contraseña -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:lock-filled" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Último cambio de clave
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-pwdlastset"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar fecha"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-pwdlastset"
                title="Copiar fecha"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Último inicio de sesión -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:door-open-alt-filled" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Último login en red
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-lastlogon"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar login"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-lastlogon"
                title="Copiar login"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Fecha de creación (alta) -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:calendar-plus" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Fecha de alta (cuenta)
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-whencreated"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar fecha de alta"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-whencreated"
                title="Copiar fecha de alta"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>

            <!-- Vencimiento de Cuenta -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative flex items-center justify-between gap-4"
            >
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class="size-8 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center shrink-0"
                >
                  <Icon name="boxicons:timer" size={18} />
                </div>
                <div class="min-w-0 flex-1">
                  <span
                    class="text-base-content/50 text-xxs uppercase font-bold tracking-wider select-none"
                  >
                    Vencimiento cuenta
                  </span>
                  <div
                    class="text-sm font-semibold text-base-content mt-0.5"
                    id="term-info-expires"
                  >
                    -
                  </div>
                </div>
              </div>
              <button
                type="button"
                class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity p-1 cursor-pointer shrink-0"
                data-copy-control
                data-copy-value=""
                data-copy-label-default="Copiar vencimiento"
                data-copy-label-success="Copiado"
                data-copy-replace-label="false"
                id="btn-copy-expires"
                title="Copiar vencimiento"
              >
                <Icon
                  name="boxicons:copy"
                  size={14}
                  data-copy-icon-default
                  class="transition-all duration-200"
                />
                <Icon
                  name="boxicons:check-filled"
                  size={14}
                  data-copy-icon-success
                  class="hidden opacity-0 scale-75 text-success transition-all duration-200"
                />
              </button>
            </div>
          </div>
        </div>

        <!-- Columna Derecha: Grupos de Red -->
        <div class="md:col-span-2 flex flex-col space-y-3.5 items-stretch">
          <!-- Cabecera de grupos con Copiar Todos -->
          <div
            class="flex items-center justify-between border-b border-base-300 pb-2"
          >
            <div class="flex items-center gap-2">
              <span
                class="text-xxs text-base-content/50 uppercase tracking-widest font-bold font-sans"
                >Grupos de Dominio</span
              >
              <span
                class="badge badge-sm badge-secondary text-secondary-content text-xxs font-sans font-bold"
                id="terminal-groups-count">0 grupos</span
              >
            </div>
            <button
              type="button"
              class="btn btn-ghost btn-xs text-secondary hover:bg-secondary/10 font-sans cursor-pointer gap-1 transition-all"
              id="copy-all-groups-btn"
              title="Copiar lista de grupos filtrados"
            >
              <Icon name="boxicons:copy" size={12} />
              <span>Copiar todos</span>
            </button>
          </div>

          <!-- Buscador y Conmutador de Vista -->
          <div class="flex items-center gap-3">
            <SearchBar id="terminal-groups-search" placeholder="Buscar o filtrar grupos..." size="xs" clearable class="flex-1" />

            <!-- Selector de vista Grilla/Lista -->
            <div class="join bg-base-200/50 shrink-0">
              <button
                type="button"
                id="btn-view-grid"
                class="btn btn-sm join-item px-3 text-secondary bg-base-300 cursor-pointer border-0"
                title="Vista Grilla"
              >
                <Icon name="boxicons:grid" size={16} />
              </button>
              <button
                type="button"
                id="btn-view-list"
                class="btn btn-sm join-item px-3 text-base-content/50 hover:text-base-content bg-transparent cursor-pointer border-0"
                title="Vista Lista"
              >
                <Icon name="boxicons:list-ul" size={16} />
              </button>
            </div>
          </div>

          <!-- Filtros rápidos por categorías -->
          <div
            class="flex flex-wrap gap-1.5 py-1 border-b border-base-300/40 pb-2"
            id="group-category-filters"
          >
            <button
              type="button"
              data-filter="all"
              class="btn btn-xs rounded-full"
              >Todos (<span id="count-all">0</span>)</button
            >
            <button
              type="button"
              data-filter="seguridad"
              class="btn btn-xs rounded-full"
              ><Icon name="boxicons:shield" size={12} />Seguridad (<span
                id="count-seguridad">0</span
              >)</button
            >
            <button
              type="button"
              data-filter="correo"
              class="btn btn-xs rounded-full"
              ><Icon name="boxicons:envelope" size={12} />Correo (<span
                id="count-correo">0</span
              >)</button
            >
            <button
              type="button"
              data-filter="sistemas"
              class="btn btn-xs rounded-full"
              ><Icon name="boxicons:desktop" size={12} />Sistemas (<span
                id="count-sistemas">0</span
              >)</button
            >
            <button
              type="button"
              data-filter="otros"
              class="btn btn-xs rounded-full"
              ><Icon name="boxicons:key" size={12} />Otros (<span
                id="count-otros">0</span
              >)</button
            >
          </div>

          <!-- Listado de grupos scrollable (por defecto en grid) -->
          <div
            id="terminal-groups-list"
            class="flex-1 bg-base-200/30 border border-base-300 p-3.5 rounded-lg overflow-y-auto max-h-95 min-h-95 scrollbar-thin transition-all grid grid-cols-2 gap-2"
          >
            <!-- Elementos dinámicos -->
          </div>
        </div>
      </div>

      <!-- VISTA 2: Consola CMD -->
      <div id="view-console" class="hidden space-y-4 flex-1">
        <div class="flex items-center gap-2 text-base-content/50 text-xs">
          <span>Microsoft Windows [Versión 10.0.19045]</span>
        </div>
        <div class="text-xs text-base-content/50">
          (c) Microsoft Corporation. Todos los derechos reservados.
        </div>

        <div class="flex items-start gap-1 text-xs">
          <span class="text-secondary font-bold shrink-0">C:\Users\mda&gt;</span
          >
          <span class="text-base-content font-mono"
            >net user "<span id="terminal-command-username"></span>" /domain</span
          >
        </div>

        <!-- Resultados de la consola -->
        <div
          class="bg-base-250 border border-base-300 p-4 rounded-md min-h-105 max-h-105 overflow-y-auto text-xs scrollbar-thin"
        >
          <pre
            id="terminal-output"
            class="whitespace-pre-wrap text-base-content/90 font-mono">
          </pre>
        </div>
      </div>
    </div>

    <!-- Footer / Acciones -->
    <div
