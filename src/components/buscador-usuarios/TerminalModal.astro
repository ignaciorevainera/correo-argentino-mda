---
import { Icon } from "astro-icon/components";
---

<dialog id="terminal-modal" class="modal modal-bottom sm:modal-middle">
  <div
    class="modal-box border border-base-300 bg-base-100 text-base-content font-mono p-0 overflow-hidden shadow-2xl rounded-xl max-w-5xl w-full"
  >
    <!-- Barra de título de terminal estilo Windows/Linux -->
    <div
      class="bg-base-200 px-4 py-2.5 flex items-center justify-between border-b border-base-300 select-none"
    >
      <div class="flex items-center gap-2">
        <div class="flex gap-1.5">
          <span class="size-3 rounded-full bg-error inline-block"></span>
          <span class="size-3 rounded-full bg-warning inline-block"></span>
          <span class="size-3 rounded-full bg-success inline-block"></span>
        </div>
        <span class="text-xs font-semibold text-base-content/70"
          >cmd.exe - net user <span id="terminal-user-title"></span> /domain</span
        >
      </div>
      <button
        type="button"
        class="text-base-content/50 hover:text-base-content transition-colors font-sans text-lg font-bold cursor-pointer"
        id="close-terminal-btn"
        aria-label="Cerrar terminal"
      >
        &times;
      </button>
    </div>

    <!-- Tabs de Navegación -->
    <div class="flex border-b border-base-300 bg-base-200/50 px-4">
      <button
        id="tab-panel-btn"
        class="px-4 py-3 text-xs font-bold border-b-2 border-primary text-primary transition-all focus:outline-hidden cursor-pointer font-sans"
        type="button"
      >
        Panel Organizado
      </button>
      <button
        id="tab-console-btn"
        class="px-4 py-3 text-xs font-bold border-b-2 border-transparent text-base-content/60 hover:text-base-content transition-all focus:outline-hidden cursor-pointer font-sans"
        type="button"
      >
        Consola CMD
      </button>
    </div>

    <!-- Pantalla de Terminal / Contenido Principal -->
    <div class="p-6 relative min-h-125 flex flex-col justify-stretch">
      <!-- Loader general -->
      <div
        id="terminal-loading"
        class="hidden absolute inset-0 bg-base-100/95 flex-col items-center justify-center gap-3 z-20"
      >
        <span class="loading loading-spinner loading-lg text-primary"></span>
        <span class="text-xs text-base-content/60"
          >Consultando Active Directory...</span
        >
      </div>

      <!-- VISTA 1: Panel Organizado -->
      <div
        id="view-panel"
        class="grid grid-cols-1 md:grid-cols-3 gap-6 flex-1 items-stretch"
      >
        <!-- Columna Izquierda: Detalles del usuario -->
        <div
          class="md:col-span-1 space-y-4 border-r border-base-300 pr-4 flex flex-col justify-start max-h-130 overflow-y-auto scrollbar-thin"
        >
          <div
            class="text-[10px] text-base-content/50 uppercase tracking-widest border-b border-base-300 pb-1 mb-1 font-bold font-sans"
          >
            Detalles de Red
          </div>

          <div class="space-y-3 font-sans">
            <!-- Cuenta de red -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon name="boxicons:user" size={14} class="text-primary" />
                  Cuenta de Red
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-username"
                  title="Copiar cuenta"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1 font-mono break-all"
                id="term-info-username"
              >
                -
              </div>
            </div>

            <!-- Nombre Completo -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:user-id-card-filled"
                    size={14}
                    class="text-primary"
                  />
                  Nombre Completo
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-fullname"
                  title="Copiar nombre"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-fullname"
              >
                -
              </div>
            </div>

            <!-- Cargo -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:briefcase"
                    size={14}
                    class="text-primary"
                  />
                  Cargo / Puesto
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-title"
                  title="Copiar cargo"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-title"
              >
                -
              </div>
            </div>

            <!-- Número de Legajo -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon name="boxicons:badge" size={14} class="text-primary" />
                  Número de Legajo
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-employeenumber"
                  title="Copiar legajo"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1 font-mono"
                id="term-info-employeenumber"
              >
                -
              </div>
            </div>

            <!-- Ubicación / Oficina -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:building"
                    size={14}
                    class="text-primary"
                  />
                  Ubicación / Oficina
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-office"
                  title="Copiar oficina"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-office"
              >
                -
              </div>
            </div>

            <!-- Jefe / Supervisor -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:user-circle-filled"
                    size={14}
                    class="text-primary"
                  />
                  Jefe Directo / Supervisor
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-manager"
                  title="Copiar jefe"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1 flex items-center justify-between gap-2"
              >
                <span id="term-info-manager">-</span>
                <button
                  type="button"
                  id="btn-search-manager"
                  class="btn btn-ghost btn-xs text-primary hover:bg-primary/10 gap-1 p-1 hidden cursor-pointer text-[10px]"
                  title="Buscar supervisor en el portal"
                >
                  <Icon name="boxicons:search" size={12} class="shrink-0" />
                  <span>Buscar</span>
                </button>
              </div>
            </div>
          </div>

          <!-- Separador Diagnóstico -->
          <div
            class="text-[10px] text-base-content/50 uppercase tracking-widest border-b border-base-300 pb-1 mt-5 mb-1 font-bold font-sans"
          >
            Seguridad y Acceso
          </div>

          <div class="space-y-3 font-sans">
            <!-- Último cambio de contraseña -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:lock-filled"
                    size={14}
                    class="text-primary"
                  />
                  Último cambio de clave
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-pwdlastset"
                  title="Copiar fecha"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-pwdlastset"
              >
                -
              </div>
            </div>

            <!-- Intentos fallidos y Estado de Cuenta (Grid en 1 fila) -->
            <div class="grid grid-cols-2 gap-2">
              <!-- Estado / Bloqueo -->
              <div
                class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group"
              >
                <span
                  class="text-base-content/50 text-[9px] uppercase font-bold tracking-wider flex items-center gap-1 select-none"
                >
                  <Icon
                    name="boxicons:lock-open-filled"
                    size={14}
                    class="text-warning"
                  />
                  Bloqueo / Estado
                </span>
                <div class="mt-1" id="term-info-lockout">-</div>
              </div>

              <!-- Intentos Fallidos -->
              <div
                class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group"
              >
                <span
                  class="text-base-content/50 text-[9px] uppercase font-bold tracking-wider flex items-center gap-1 select-none"
                >
                  <Icon
                    name="boxicons:alert-octagon-filled"
                    size={14}
                    class="text-error"
                  />
                  Intentos fallidos
                </span>
                <div
                  class="text-sm font-semibold text-base-content mt-1"
                  id="term-info-badpwdcount"
                >
                  -
                </div>
              </div>
            </div>

            <!-- Último inicio de sesión -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:door-open-alt-filled"
                    size={14}
                    class="text-primary"
                  />
                  Último login en red
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-lastlogon"
                  title="Copiar login"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-lastlogon"
              >
                -
              </div>
            </div>

            <!-- Fecha de creación (alta) -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon
                    name="boxicons:calendar-plus"
                    size={14}
                    class="text-primary"
                  />
                  Fecha de alta (cuenta)
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-whencreated"
                  title="Copiar fecha de alta"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-whencreated"
              >
                -
              </div>
            </div>

            <!-- Vencimiento de Cuenta -->
            <div
              class="bg-base-200/50 border border-base-300 rounded-lg p-3 hover:border-base-content/20 transition-colors group relative"
            >
              <div class="flex items-center justify-between">
                <span
                  class="text-base-content/50 text-[10px] uppercase font-bold tracking-wider flex items-center gap-1.5 select-none"
                >
                  <Icon name="boxicons:timer" size={14} class="text-primary" />
                  Vencimiento cuenta
                </span>
                <button
                  type="button"
                  class="text-base-content/40 hover:text-primary transition-colors opacity-0 group-hover:opacity-100 p-0.5 cursor-pointer"
                  data-copy-field="term-info-expires"
                  title="Copiar vencimiento"
                >
                  <Icon name="boxicons:copy" size={13} />
                </button>
              </div>
              <div
                class="text-sm font-semibold text-base-content mt-1"
                id="term-info-expires"
              >
                -
              </div>
            </div>
          </div>
        </div>

        <!-- Columna Derecha: Grupos de Red -->
        <div class="md:col-span-2 flex flex-col space-y-3.5 items-stretch">
          <!-- Cabecera de grupos con Copiar Todos -->
          <div
            class="flex items-center justify-between border-b border-base-300 pb-2"
          >
            <div class="flex items-center gap-2">
              <span
                class="text-[10px] text-base-content/50 uppercase tracking-widest font-bold font-sans"
                >Grupos de Dominio</span
              >
              <span
                class="badge badge-sm badge-primary text-[10px] font-sans font-bold"
                id="terminal-groups-count">0 grupos</span
              >
            </div>
            <button
              type="button"
              class="btn btn-ghost btn-xs text-primary hover:bg-primary/10 font-sans cursor-pointer gap-1 transition-all"
              id="copy-all-groups-btn"
              title="Copiar lista de grupos filtrados"
            >
              <Icon name="boxicons:copy" size={12} />
              <span>Copiar todos</span>
            </button>
          </div>

          <!-- Buscador y Conmutador de Vista -->
          <div class="flex items-center gap-3">
            <!-- Caja de búsqueda de grupos -->
            <div class="relative flex-1">
              <input
                type="text"
                id="terminal-groups-search"
                placeholder="Buscar o filtrar grupos..."
                class="w-full bg-base-200 border border-base-300 rounded-lg pl-8 pr-8 py-2 text-xs text-base-content placeholder-base-content/40 focus:outline-hidden focus:border-primary font-sans transition-all"
                autocomplete="off"
              />
              <Icon
                name="boxicons:search"
                size={14}
                class="absolute left-2.5 top-1/2 -translate-y-1/2 text-base-content/50"
              />
              <button
                type="button"
                id="clear-group-search"
                class="absolute right-2.5 top-1/2 -translate-y-1/2 text-base-content/50 hover:text-base-content transition-colors hidden cursor-pointer text-sm"
              >
                &times;
              </button>
            </div>

            <!-- Selector de vista Grilla/Lista -->
            <div class="join border border-base-300 bg-base-100 shrink-0">
              <button
                type="button"
                id="btn-view-grid"
                class="btn btn-xs join-item px-2.5 text-primary bg-base-300 cursor-pointer"
                title="Vista Grilla"
              >
                <Icon name="boxicons:grid" size={14} />
              </button>
              <button
                type="button"
                id="btn-view-list"
                class="btn btn-xs join-item px-2.5 text-base-content/50 hover:text-base-content bg-base-100 cursor-pointer"
                title="Vista Lista"
              >
                <Icon name="boxicons:list-ul" size={14} />
              </button>
            </div>
          </div>

          <!-- Filtros rápidos por categorías -->
          <div
            class="flex flex-wrap gap-1.5 py-1 border-b border-base-300/40 pb-2"
            id="group-category-filters"
          >
            <button
              type="button"
              data-filter="all"
              class="btn btn-xs rounded-full cursor-pointer transition-all bg-primary/20 text-primary border border-primary/30 hover:bg-primary/30 font-sans font-bold gap-1"
            >
              Todos (<span id="count-all">0</span>)
            </button>
            <button
              type="button"
              data-filter="seguridad"
              class="btn btn-xs rounded-full cursor-pointer transition-all bg-base-200 text-base-content/60 border border-base-300 hover:bg-base-300 hover:text-base-content font-sans font-bold gap-1"
            >
              <Icon name="boxicons:shield" size={12} /> Seguridad (<span
                id="count-seguridad">0</span
              >)
            </button>
            <button
              type="button"
              data-filter="correo"
              class="btn btn-xs rounded-full cursor-pointer transition-all bg-base-200 text-base-content/60 border border-base-300 hover:bg-base-300 hover:text-base-content font-sans font-bold gap-1"
            >
              <Icon name="boxicons:envelope" size={12} /> Correo (<span
                id="count-correo">0</span
              >)
            </button>
            <button
              type="button"
              data-filter="sistemas"
              class="btn btn-xs rounded-full cursor-pointer transition-all bg-base-200 text-base-content/60 border border-base-300 hover:bg-base-300 hover:text-base-content font-sans font-bold gap-1"
            >
              <Icon name="boxicons:desktop" size={12} /> Sistemas (<span
                id="count-sistemas">0</span
              >)
            </button>
            <button
              type="button"
              data-filter="otros"
              class="btn btn-xs rounded-full cursor-pointer transition-all bg-base-200 text-base-content/60 border border-base-300 hover:bg-base-300 hover:text-base-content font-sans font-bold gap-1"
            >
              <Icon name="boxicons:key" size={12} /> Otros (<span
                id="count-otros">0</span
              >)
            </button>
          </div>

          <!-- Listado de grupos scrollable (por defecto en grid) -->
          <div
            id="terminal-groups-list"
            class="flex-1 bg-base-200/30 border border-base-300 p-3.5 rounded-lg overflow-y-auto max-h-95 min-h-95 scrollbar-thin transition-all grid grid-cols-1 sm:grid-cols-2 gap-2"
          >
            <!-- Elementos dinámicos -->
          </div>
        </div>
      </div>

      <!-- VISTA 2: Consola CMD -->
      <div id="view-console" class="hidden space-y-4 flex-1">
        <div class="flex items-center gap-2 text-base-content/50 text-xs">
          <span>Microsoft Windows [Versión 10.0.19045]</span>
        </div>
        <div class="text-xs text-base-content/50">
          (c) Microsoft Corporation. Todos los derechos reservados.
        </div>

        <div class="flex items-start gap-1 text-xs">
          <span class="text-primary font-bold shrink-0">C:\Users\mda&gt;</span>
          <span class="text-base-content font-mono"
            >net user "<span id="terminal-command-username"></span>" /domain</span
          >
        </div>

        <!-- Resultados de la consola -->
        <div
          class="bg-base-250 border border-base-300 p-4 rounded-md min-h-105 max-h-105 overflow-y-auto text-xs scrollbar-thin"
        >
          <pre
            id="terminal-output"
            class="whitespace-pre-wrap text-base-content/90 font-mono leading-relaxed">
          </pre>
        </div>
      </div>
    </div>

    <!-- Footer / Acciones -->
    <div
      class="bg-base-200 px-4 py-3 flex items-center justify-between border-t border-base-300 select-none"
    >
      <span class="text-[10px] text-base-content/50 font-sans"
        >Conexión LDAP segura con mda.correo.local</span
      >
      <div class="flex gap-2">
        <button
          type="button"
          class="btn btn-ghost border border-base-300 btn-xs text-base-content/85 hover:bg-base-300 font-sans cursor-pointer gap-1"
          id="copy-terminal-btn"
        >
          <Icon name="boxicons:copy" size={12} />
          Copiar salida raw
        </button>
        <button
          type="button"
          class="btn btn-ghost border border-base-300 btn-xs text-base-content/85 hover:bg-base-300 font-sans cursor-pointer"
          id="close-terminal-footer-btn"
        >
          Cerrar
        </button>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
