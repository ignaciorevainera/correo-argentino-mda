---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
---

<PageContainer width="xl">
  <div class="skeleton-debounced">
    <PageHeader
      description="Accesos clave para resolver tareas operativas de soporte con menos fricción."
      class="max-w-3xl"
    />

    <div class="h-12 w-full max-w-md skeleton rounded-lg mb-4"></div>

    <!-- Announcement Banner Skeleton -->
    <div class="h-28 w-full skeleton rounded-xl mb-6"></div>

    <!-- Cards Grid Skeleton -->
    <div     class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3 mt-4">
      {Array.from({ length: 6 }).map(() => (
        <div class="card bg-base-100 border border-base-300 shadow-sm p-5 rounded-2xl h-64">
          <div class="flex items-center gap-3 mb-4">
            <div class="size-8 skeleton rounded-lg"></div>
            <div class="h-5 w-36 skeleton rounded"></div>
          </div>
          <div class="space-y-4">
            {Array.from({ length: 3 }).map(() => (
              <div class="flex flex-col gap-1">
                <div class="h-4 w-44 skeleton rounded"></div>
                <div class="h-3 w-64 skeleton rounded"></div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</PageContainer>
