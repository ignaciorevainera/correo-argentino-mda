---
import { getCleanBase } from "@lib/baseUrl";
import AnnouncementBanner from "@components/ui/AnnouncementBanner.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import CategoryCard from "@pages/recursos/_components/CategoryCard.astro";
import SearchEmptyState from "@components/ui/SearchEmptyState.astro";
import { db } from "@db/index";
import { resourceCategories } from "@db/schema";
import { asc } from "drizzle-orm";
import type { CategoryTone, CategoryViewModel } from "@pages/recursos/_components/types";
import { decrypt } from "@lib/encryption";

const isAuthenticated = Astro.locals.user && Astro.locals.user.id !== 0;

const rawCategories = await db.query.resourceCategories.findMany({
  orderBy: [asc(resourceCategories.sortOrder), asc(resourceCategories.title)],
  with: {
    links: true,
  },
});

const importantCategories = rawCategories.map(
  (category): CategoryViewModel => ({
    id: String(category.id),
    category: category.title,
    icon: category.iconName as unknown as `boxicons:${string}`,
    tone: (category.tone || "primary") as CategoryTone,
    links: category.links
      .sort((a, b) => {
        const orderA = a.sortOrder ?? 0;
        const orderB = b.sortOrder ?? 0;
        if (orderA !== orderB) {
          return orderA - orderB;
        }
        return a.title.localeCompare(b.title);
      })
      .map((link) => ({
        ...link,
        id: String(link.id),
        subtitle: link.subtitle ?? undefined,
        iconPath: link.iconPath ?? undefined,
        deprecated: link.deprecated ?? false,
        credentials: isAuthenticated && (link.credentialUsername || link.credentialPassword)
          ? {
              username: link.credentialUsername || "",
              password: link.credentialPassword ? decrypt(link.credentialPassword) : undefined,
            }
          : undefined,
      })),
  }),
);

const cleanBase = getCleanBase();
---

<PageContainer width="xl">
  <PageHeader
    description="Accesos clave para resolver tareas operativas de soporte con menos fricción."
    class="max-w-3xl"
  />

  <SearchBar
    id="important-links-search"
    label="Buscar enlaces y recursos"
    placeholder="Buscar por nombre, URL o descripción"
    class="max-w-md"
  />

  <AnnouncementBanner
    title="Nuevo catálogo de aplicativos"
    description="Descarga herramientas de mesa de ayuda desde un paquete .zip o por aplicativo individual para mantener la operatoria diaria."
    icon="boxicons:link-filled"
    badgeLabel="Nuevo"
    href={`${cleanBase}recursos/aplicativos`}
    ctaLabel="Ir al catálogo"
    tone="primary"
  />

  <div
    id="important-links-grid"
    class="masonry-grid"
  >
    {
      importantCategories.map((category) => (
        <div class="grid-item">
          <CategoryCard category={category} />
        </div>
      ))
    }
  </div>

  <SearchEmptyState
    id="important-links-empty"
    title="Sin resultados"
    description="La búsqueda no coincidió con ningún enlace. Probá con otro nombre, URL o descripción."
  />
</PageContainer>

<style is:global>
  ::highlight(search-match) {
    background-color: rgba(226, 173, 31, 0.3);
    color: inherit;
  }

  .masonry-grid {
    position: relative;
  }

  .masonry-grid .grid-item {
    width: 100%;
    margin-bottom: 8px;
    break-inside: avoid;
  }

  @media (min-width: 768px) {
    .masonry-grid .grid-item {
      width: calc(50% - 4px);
    }
  }

  @media (min-width: 1280px) {
    .masonry-grid .grid-item {
      width: calc(33.333% - 5.333px);
    }
  }
</style>

<script>
  import { matchesSearchQuery, highlightSearchTargets } from "@lib/clientSearch";
  import Masonry from "masonry-layout";

  const searchInput = document.getElementById("important-links-search") as HTMLInputElement | null;
  const linksGrid = document.getElementById("important-links-grid") as HTMLElement | null;
  const emptyState = document.getElementById("important-links-empty") as HTMLElement | null;
  const categoryCards = Array.from(document.querySelectorAll<HTMLElement>("[data-link-category]"));

  const GAP = 8;

  const getColumnWidth = (): number => {
    if (!linksGrid) return 0;
    const width = linksGrid.offsetWidth;
    const columns = width >= 1280 ? 3 : width >= 768 ? 2 : 1;
    return (width - GAP * (columns - 1)) / columns;
  };

  let msnry: Masonry | null = null;
  if (linksGrid) {
    msnry = new Masonry(linksGrid, {
      itemSelector: ".grid-item",
      columnWidth: getColumnWidth(),
      gutter: GAP,
      transitionDuration: "0.2s",
      initLayout: true,
    });

    const resizeObserver = new ResizeObserver(() => {
      if (!msnry) return;
      msnry.options.columnWidth = getColumnWidth();
      msnry.layout();
    });
    resizeObserver.observe(linksGrid);

    linksGrid.addEventListener("toggle", (event) => {
      const target = event.target as HTMLDetailsElement | null;
      if (!target || target.tagName !== "DETAILS") return;

      if (target.open) {
        document.querySelectorAll<HTMLDetailsElement>("details[open]").forEach((details) => {
          if (details !== target) {
            details.open = false;
          }
        });
      }

      requestAnimationFrame(() => {
        requestAnimationFrame(() => msnry?.layout());
      });
    }, true);
  }

  let isFiltered = false;

  const updateVisibleLinks = (): void => {
    const query = searchInput?.value.trim() ?? "";

    if (query.length === 0 && !isFiltered) {
      return;
    }

    isFiltered = query.length > 0;
    let visibleLinks = 0;

    categoryCards.forEach((categoryCard) => {
      const categorySearch = categoryCard.dataset.categorySearch ?? "";
      const categoryItems = Array.from(categoryCard.querySelectorAll<HTMLElement>("[data-link-item]"));
      let visibleCategoryLinks = 0;

      categoryItems.forEach((item) => {
        const linkSearch = item.dataset.linkSearch ?? "";
        const isVisible = matchesSearchQuery(query, [categorySearch, linkSearch]);

        item.classList.toggle("hidden", !isVisible);
        highlightSearchTargets(item, isVisible ? query : "");

        if (isVisible) {
          visibleLinks += 1;
          visibleCategoryLinks += 1;
        }
      });

      const isCategoryVisible = visibleCategoryLinks > 0;
      categoryCard.classList.toggle("hidden", !isCategoryVisible);

      const categoryTitle = categoryCard.querySelector<HTMLElement>("header [data-highlight-target]");
      if (categoryTitle) {
        highlightSearchTargets(categoryTitle, isCategoryVisible ? query : "");
      }
    });

    linksGrid?.classList.toggle("hidden", visibleLinks === 0);
    emptyState?.classList.toggle("hidden", visibleLinks > 0);
    emptyState?.classList.toggle("flex", visibleLinks === 0);

    requestAnimationFrame(() => msnry?.layout());
  };

  searchInput?.addEventListener("input", updateVisibleLinks);

  if (searchInput && searchInput.value.trim().length > 0) {
    updateVisibleLinks();
  }
</script>
