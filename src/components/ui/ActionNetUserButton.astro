---
import { Icon } from "astro-icon/components";

interface Props {
  ariaLabel: string;
  class?: string;
  size?: "xs" | "default";
  [key: string]: any;
}

const {
  ariaLabel,
  class: className = "",
  size = "default",
  ...attrs
} = Astro.props;

const isXs = size === "xs";
const btnClasses = isXs
  ? "btn btn-xs btn-soft btn-accent grow gap-2"
  : "btn btn-sm md:btn-md btn-soft grow btn-accent gap-2";
const iconName = "boxicons:terminal-filled";
const iconSize = isXs ? 14 : 18;
---

<button
  type="button"
  class:list={[btnClasses, className]}
  aria-label={ariaLabel}
  {...attrs}
>
  <Icon name={iconName} size={iconSize} />
</button>
