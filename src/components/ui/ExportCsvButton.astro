---
import { Icon } from "astro-icon/components";

interface Props {
  href?: string;
  id?: string;
  class?: string;
  label?: string;
  shortLabel?: string;
  ariaLabel?: string;
  title?: string;
  icon?: string;
  iconSize?: number;
}

const {
  href,
  id,
  class: className = "btn btn-primary font-semibold shadow-sm shrink-0 gap-2",
  label = "Exportar CSV",
  shortLabel = "CSV",
  ariaLabel,
  title,
  icon = "boxicons:file-detail-filled",
  iconSize = 20,
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  id={id}
  class={className}
  aria-label={ariaLabel || title}
  title={title}
  download={href ? true : undefined}
>
  <Icon name={icon} size={iconSize} aria-hidden="true" />
  <span class="hidden sm:inline">{label}</span>
  <span class="sm:hidden">{shortLabel}</span>
</Tag>
