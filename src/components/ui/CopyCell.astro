---
interface Props {
  text: string;
  monospace?: boolean;
}

const { text, monospace = false } = Astro.props;
---

<div
  class="tooltip block w-full text-left"
  data-tip="Click para copiar"
  data-copy-cell
>
  <button
    type="button"
    class="group -ml-2 inline-flex w-full cursor-pointer items-start justify-between gap-2 rounded-md p-2 text-left transition-colors hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-none"
    data-copy-cell-trigger
    data-copy-value={text}
    aria-label={`Copiar ${text}`}
  >
    <span class:list={["text-sm break-all", monospace && "font-mono"]}
      >{text}</span
    >
    <svg
      class="size-4 shrink-0 text-base-content/40 transition-colors group-hover:text-primary group-focus-visible:text-primary"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
  </button>
</div>

<script>
  const defaultTooltipMessage = "Click para copiar";
  const copiedTooltipMessage = "¡Copiado!";

  const fallbackCopyToClipboard = (value: string): boolean => {
    const textarea = document.createElement("textarea");
    textarea.value = value;
    textarea.setAttribute("readonly", "");
    textarea.setAttribute("aria-hidden", "true");
    textarea.style.position = "fixed";
    textarea.style.left = "-9999px";
    textarea.style.top = "0";
    textarea.style.opacity = "0";

    document.body.append(textarea);
    textarea.focus();
    textarea.select();

    let copied = false;

    try {
      copied = document.execCommand("copy");
    } catch {
      copied = false;
    }

    textarea.remove();
    return copied;
  };

  const copyToClipboard = async (value: string): Promise<boolean> => {
    const canUseClipboardApi =
      typeof navigator !== "undefined" &&
      typeof navigator.clipboard !== "undefined" &&
      typeof navigator.clipboard.writeText === "function";

    if (canUseClipboardApi) {
      try {
        await navigator.clipboard.writeText(value);
        return true;
      } catch {
        return fallbackCopyToClipboard(value);
      }
    }

    return fallbackCopyToClipboard(value);
  };

  const copyCells = document.querySelectorAll("[data-copy-cell]");

  copyCells.forEach((copyCell) => {
    if (!(copyCell instanceof HTMLElement)) {
      return;
    }

    if (copyCell.dataset.copyCellBound === "true") {
      return;
    }

    copyCell.dataset.copyCellBound = "true";

    const trigger = copyCell.querySelector("[data-copy-cell-trigger]");
    if (!(trigger instanceof HTMLButtonElement)) {
      return;
    }

    let resetTimer: number | null = null;

    trigger.addEventListener("click", async () => {
      const value = trigger.getAttribute("data-copy-value") ?? "";
      if (value.length === 0) {
        return;
      }

      const copied = await copyToClipboard(value);
      if (!copied) {
        return;
      }

      copyCell.classList.add("tooltip-open", "tooltip-success");
      copyCell.setAttribute("data-tip", copiedTooltipMessage);

      if (resetTimer !== null) {
        window.clearTimeout(resetTimer);
      }

      resetTimer = window.setTimeout(() => {
        copyCell.classList.remove("tooltip-open", "tooltip-success");
        copyCell.setAttribute("data-tip", defaultTooltipMessage);
      }, 2000);
    });
  });
</script>
