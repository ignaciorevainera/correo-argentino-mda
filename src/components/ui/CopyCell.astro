---
import { Icon } from "astro-icon/components";

interface Props {
  text: string;
  monospace?: boolean;
}

const { text, monospace = false } = Astro.props;
---

<div
  class="tooltip tooltip-top tooltip-neutral block w-full text-left"
  data-tip="Clic para copiar"
  data-copy-cell
>
  <button
    type="button"
    class="group -ml-2 inline-flex w-full cursor-pointer items-start justify-between gap-3 rounded-md p-2 text-left transition-colors duration-200 hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
    data-copy-cell-trigger
    data-copy-value={text}
    aria-label={`Copiar ${text}`}
  >
    <span
      class:list={[
        "break-all text-sm text-base-content/80 transition-colors duration-200 group-hover:text-accent group-focus-visible:text-accent",
        monospace && "font-mono",
      ]}>{text}</span
    >
    <span
      class="relative inline-flex size-4 shrink-0 items-center justify-center"
      aria-hidden="true"
    >
      <Icon
        name="boxicons:clipboard"
        class="absolute inset-0 m-auto size-4 text-base-content/50 opacity-0 transition-all duration-200 group-hover:text-accent group-hover:opacity-100 group-focus-visible:text-accent group-focus-visible:opacity-100"
        data-copy-icon-default
      />
      <Icon
        name="boxicons:check"
        class="absolute inset-0 m-auto hidden size-4 text-success"
        data-copy-icon-success
      />
    </span>
  </button>
</div>

<script>
  const defaultTooltipMessage = "Clic para copiar";
  const copiedTooltipMessage = "¡Copiado!";

  const fallbackCopyToClipboard = (value: string): boolean => {
    const textarea = document.createElement("textarea");
    textarea.value = value;
    textarea.setAttribute("readonly", "");
    textarea.setAttribute("aria-hidden", "true");
    textarea.style.position = "fixed";
    textarea.style.left = "-9999px";
    textarea.style.top = "0";
    textarea.style.opacity = "0";

    document.body.append(textarea);
    textarea.focus();
    textarea.select();

    let copied = false;

    try {
      copied = document.execCommand("copy");
    } catch {
      copied = false;
    }

    textarea.remove();
    return copied;
  };

  const copyToClipboard = async (value: string): Promise<boolean> => {
    const canUseClipboardApi =
      typeof navigator !== "undefined" &&
      typeof navigator.clipboard !== "undefined" &&
      typeof navigator.clipboard.writeText === "function";

    if (canUseClipboardApi) {
      try {
        await navigator.clipboard.writeText(value);
        return true;
      } catch {
        return fallbackCopyToClipboard(value);
      }
    }

    return fallbackCopyToClipboard(value);
  };

  const copyCells = document.querySelectorAll("[data-copy-cell]");

  copyCells.forEach((copyCell) => {
    if (!(copyCell instanceof HTMLElement)) {
      return;
    }

    if (copyCell.dataset.copyCellBound === "true") {
      return;
    }

    copyCell.dataset.copyCellBound = "true";

    const trigger = copyCell.querySelector("[data-copy-cell-trigger]");
    if (!(trigger instanceof HTMLButtonElement)) {
      return;
    }

    const defaultIcon = trigger.querySelector("[data-copy-icon-default]");
    const successIcon = trigger.querySelector("[data-copy-icon-success]");

    let resetTimer: number | null = null;

    trigger.addEventListener("click", async () => {
      const value = trigger.getAttribute("data-copy-value") ?? "";
      if (value.length === 0) {
        return;
      }

      const copied = await copyToClipboard(value);
      if (!copied) {
        return;
      }

      copyCell.classList.add("tooltip-open", "tooltip-success");
      copyCell.setAttribute("data-tip", copiedTooltipMessage);
      trigger.classList.add("text-success");

      if (defaultIcon instanceof Element) {
        defaultIcon.classList.add("hidden");
      }

      if (successIcon instanceof Element) {
        successIcon.classList.remove("hidden");
      }

      if (resetTimer !== null) {
        window.clearTimeout(resetTimer);
      }

      resetTimer = window.setTimeout(() => {
        copyCell.classList.remove("tooltip-open", "tooltip-success");
        copyCell.setAttribute("data-tip", defaultTooltipMessage);
        trigger.classList.remove("text-success");

        if (defaultIcon instanceof Element) {
          defaultIcon.classList.remove("hidden");
        }

        if (successIcon instanceof Element) {
          successIcon.classList.add("hidden");
        }
      }, 2000);
    });
  });
</script>
