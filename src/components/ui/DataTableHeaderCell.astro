---
import { Icon } from "astro-icon/components";

interface Props {
  sortKey?: string;
  align?: "left" | "right";
  monospace?: boolean;
  class?: string;
}

const {
  sortKey,
  align = "left",
  monospace = false,
  class: className = "",
} = Astro.props;

const contentClasses = [
  "min-w-0 text-xs font-semibold uppercase tracking-wide text-secondary-content",
  align === "right" ? "text-right" : "text-left",
  monospace && "font-mono",
  className,
];

const innerClasses = [
  "flex min-w-0 items-center gap-1.5",
  align === "right" ? "justify-end" : "justify-start",
];
---

{
  sortKey ? (
    <button
      type="button"
      class:list={[
        "w-full cursor-pointer rounded-md transition-opacity hover:opacity-85 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-content",
        contentClasses,
      ]}
      data-table-sort-key={sortKey}
      data-table-sort-direction="none"
      aria-sort="none"
    >
      <span class:list={innerClasses}>
        <span class="min-w-0 truncate">
          <slot />
        </span>
        <span
          class="relative inline-flex size-4 shrink-0 items-center justify-center"
          aria-hidden="true"
        >
          <Icon
            name="boxicons:arrow-down-up-filled"
            class="absolute inset-0 m-auto size-3.5 opacity-70 transition-opacity"
            data-table-sort-icon="none"
          />
          <Icon
            name="boxicons:arrow-up-a-z-filled"
            class="absolute inset-0 m-auto hidden size-3.5 opacity-0 transition-opacity"
            data-table-sort-icon="ascending"
          />
          <Icon
            name="boxicons:arrow-down-a-z-filled"
            class="absolute inset-0 m-auto hidden size-3.5 opacity-0 transition-opacity"
            data-table-sort-icon="descending"
          />
        </span>
      </span>
    </button>
  ) : (
    <span class:list={["block px-2 py-1.5", contentClasses]}>
      <span class:list={innerClasses}>
        <span class="min-w-0 truncate">
          <slot />
        </span>
      </span>
    </span>
  )
}
