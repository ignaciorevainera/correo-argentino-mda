---
import { getSectionTitle, getResolvedPathname } from "@lib/navigation";

interface Props {
  title?: string;
  description?: string;
  headingLevel?: "h1" | "h2";
  class?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  title,
  description,
  headingLevel = "h1",
  class: className,
  titleClass,
  descriptionClass,
} = Astro.props;

const resolvedPath = getResolvedPathname(Astro.request, Astro.url);
const inferredTitle = title || getSectionTitle(resolvedPath) || "Portal";

const HeadingTag = headingLevel;
---

<header class:list={["space-y-2", className]}>
  <HeadingTag
    class:list={[
      "text-3xl font-bold tracking-tight text-base-content",
      titleClass,
    ]}
  >
    {inferredTitle}
  </HeadingTag>

  {
    Astro.slots.has("description") ? (
      <div
        class:list={[
          "max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base",
          descriptionClass,
        ]}
      >
        <slot name="description" />
      </div>
    ) : description ? (
      <p
        class:list={[
          "max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base",
          descriptionClass,
        ]}
      >
        {description}
      </p>
    ) : null
  }
</header>
