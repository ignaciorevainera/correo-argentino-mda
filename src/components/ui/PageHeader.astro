---
interface Props {
  title: string;
  description?: string;
  headingLevel?: "h1" | "h2";
  class?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  title,
  description,
  headingLevel = "h1",
  class: className,
  titleClass,
  descriptionClass,
} = Astro.props;

const HeadingTag = headingLevel;
---

<header class:list={["space-y-2", className]}>
  <HeadingTag
    class:list={[
      "text-3xl font-bold tracking-tight text-base-content",
      titleClass,
    ]}
  >
    {title}
  </HeadingTag>

  {
    description && (
      <p
        class:list={[
          "max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base",
          descriptionClass,
        ]}
      >
        {description}
      </p>
    )
  }
</header>
