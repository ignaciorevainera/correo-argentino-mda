---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  label: string;
  placeholder?: string;
  name?: string;
  value?: string;
  autocomplete?: string;
  class?: string;
}

const {
  id,
  label,
  placeholder = "Buscar",
  name,
  value,
  autocomplete = "off",
  class: className = "",
} = Astro.props;
---

<label
  class:list={[
    "input input-bordered w-full bg-base-100 transition-colors focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-accent",
    className,
  ]}
>
  <span class="sr-only">{label}</span>
  <Icon
    name="boxicons:search"
    class="size-4 shrink-0 text-base-content/50"
    aria-hidden="true"
  />
  <input
    id={id}
    name={name}
    type="search"
    class="grow"
    placeholder={placeholder}
    value={value}
    autocomplete={autocomplete}
    aria-label={label}
  />
</label>
