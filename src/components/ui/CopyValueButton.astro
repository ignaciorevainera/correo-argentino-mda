---
import { Icon } from "astro-icon/components";
import type { BoxiconName } from "@/types/contactos-utiles";

interface Props {
  value: string;
  ariaLabel: string;
  variant?: "phone" | "email";
}

interface VariantConfig {
  icon: BoxiconName;
  iconContainerHoverClass: string;
  copyIconHoverClass: string;
}

const { value, ariaLabel, variant = "phone" } = Astro.props;

const variantConfigMap: Record<NonNullable<Props["variant"]>, VariantConfig> = {
  phone: {
    icon: "boxicons:phone",
    iconContainerHoverClass: "group-hover:bg-info/20 group-hover:text-info",
    copyIconHoverClass: "group-hover:text-info",
  },
  email: {
    icon: "boxicons:envelope",
    iconContainerHoverClass: "group-hover:bg-accent/20 group-hover:text-accent",
    copyIconHoverClass: "group-hover:text-accent",
  },
};

const variantConfig = variantConfigMap[variant];
---

<button
  type="button"
  class="group flex w-full items-center gap-2 rounded-lg border border-base-300 bg-base-100 px-2 py-2 text-left transition-colors hover:bg-base-200 focus-visible:bg-base-200 focus-visible:outline-2 focus-visible:outline-accent"
  data-copy-trigger
  data-copy-value={value}
  aria-label={ariaLabel}
>
  <span
    class:list={[
      "inline-flex size-7 shrink-0 items-center justify-center rounded-md bg-base-200 text-base-content/70 transition-colors",
      variantConfig.iconContainerHoverClass,
    ]}
    aria-hidden="true"
  >
    <Icon name={variantConfig.icon} class="size-4" />
  </span>

  <span
    class="min-w-0 flex-1 truncate font-mono text-xs text-base-content md:text-sm"
  >
    {value}
  </span>

  <span
    class="relative inline-flex size-4 shrink-0 items-center justify-center"
  >
    <Icon
      name="boxicons:clipboard"
      class:list={[
        "absolute inset-0 m-auto size-4 text-base-content/60 transition-all duration-200",
        variantConfig.copyIconHoverClass,
      ]}
      data-copy-icon-default
      aria-hidden="true"
    />
    <Icon
      name="boxicons:check"
      class="absolute inset-0 m-auto hidden size-4 scale-75 text-success opacity-0 transition-all duration-200"
      data-copy-icon-success
      aria-hidden="true"
    />
  </span>
</button>
