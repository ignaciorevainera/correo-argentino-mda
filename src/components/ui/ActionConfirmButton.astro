---
interface Props {
  label: string;
  size?: "xs" | "default";
  type?: "button" | "submit";
  class?: string;
  id?: string;
  [key: string]: any;
}

const { label, size = "default", type = "button", class: className = "", id, ...attrs } = Astro.props;

const isXs = size === "xs";
const btnClasses = isXs
  ? "btn btn-xs btn-soft btn-secondary gap-2"
  : "btn btn-sm md:btn-md btn-soft btn-secondary gap-2";
---

<button
  type={type}
  id={id}
  class:list={[btnClasses, className]}
  {...attrs}
>
  {label}
</button>
