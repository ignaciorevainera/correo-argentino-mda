---
interface Props {
  id: string;
  title: string;
  description?: string;
  class?: string;
}

const { id, title, description, class: className = "" } = Astro.props;
---

<section
  id={id}
  aria-labelledby={`${id}-title`}
  class:list={["scroll-mt-24 space-y-4", className]}
>
  <div class="flex flex-col gap-2 border-b border-base-300 pb-3">
    <p class="font-mono text-xs font-semibold uppercase tracking-wide text-secondary">
      {id}
    </p>
    <h2 id={`${id}-title`} class="text-xl font-bold text-base-content">
      {title}
    </h2>
    {
      description && (
        <p class="max-w-3xl text-sm leading-relaxed text-base-content/70">
          {description}
        </p>
      )
    }
  </div>

  <slot />
</section>
