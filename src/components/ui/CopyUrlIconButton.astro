---
import { Icon } from "astro-icon/components";

interface Props {
  copyValue: string;
  ariaLabel: string;
  tooltipText?: string;
  tooltipPosition?: "top" | "right" | "bottom" | "left";
  buttonClass?: string;
}

const {
  copyValue,
  ariaLabel,
  tooltipText = copyValue,
  tooltipPosition = "left",
  buttonClass = "",
} = Astro.props;

const tooltipPositionClassMap: Record<
  NonNullable<Props["tooltipPosition"]>,
  string
> = {
  top: "tooltip-top",
  right: "tooltip-right",
  bottom: "tooltip-bottom",
  left: "tooltip-left",
};

const tooltipPositionClass = tooltipPositionClassMap[tooltipPosition];
---

<div class:list={["tooltip tooltip-neutral", tooltipPositionClass]}>
  <div class="tooltip-content">
    <span class="font-mono text-xs">{tooltipText}</span>
  </div>

  <button
    type="button"
    class:list={[
      "btn btn-ghost btn-square btn-sm transition-colors",
      buttonClass,
    ]}
    data-copy-trigger
    data-copy-value={copyValue}
    aria-label={ariaLabel}
  >
    <span class="relative inline-flex size-4 items-center justify-center">
      <Icon
        name="boxicons:clipboard"
        class="absolute inset-0 m-auto size-4"
        data-copy-icon-default
        aria-hidden="true"
      />
      <Icon
        name="boxicons:check"
        class="absolute inset-0 m-auto hidden size-4 scale-75 text-success opacity-0 transition-all duration-200"
        data-copy-icon-success
        aria-hidden="true"
      />
    </span>
  </button>
</div>
