---
interface Props {
  variant?:
    | "primary"
    | "secondary"
    | "accent"
    | "neutral"
    | "info"
    | "success"
    | "warning"
    | "error";
  size?: "sm" | "md" | "lg" | "icon";
  appearance?: "solid" | "outline" | "ghost" | "link";
  href?: string;
  disabled?: boolean;
  class?: string;
}

const variants = {
  primary: {
    solid: "btn-primary",
    outline: "btn-outline btn-primary",
    ghost: "btn-ghost text-primary hover:bg-primary/10",
    link: "btn-link text-primary",
  },
  secondary: {
    solid: "btn-secondary",
    outline: "btn-outline btn-secondary",
    ghost: "btn-ghost text-secondary hover:bg-secondary/10",
    link: "btn-link text-secondary",
  },
  accent: {
    solid: "btn-accent",
    outline: "btn-outline btn-accent",
    ghost: "btn-ghost text-accent hover:bg-accent/10",
    link: "btn-link text-accent",
  },
  neutral: {
    solid: "btn-neutral",
    outline: "btn-outline btn-neutral",
    ghost: "btn-ghost text-neutral hover:bg-neutral/10",
    link: "btn-link text-neutral",
  },
  info: {
    solid: "btn-info",
    outline: "btn-outline btn-info",
    ghost: "btn-ghost text-info hover:bg-info/10",
    link: "btn-link text-info",
  },
  success: {
    solid: "btn-success",
    outline: "btn-outline btn-success",
    ghost: "btn-ghost text-success hover:bg-success/10",
    link: "btn-link text-success",
  },
  warning: {
    solid: "btn-warning",
    outline: "btn-outline btn-warning",
    ghost: "btn-ghost text-warning hover:bg-warning/10",
    link: "btn-link text-warning",
  },
  error: {
    solid: "btn-error",
    outline: "btn-outline btn-error",
    ghost: "btn-ghost text-error hover:bg-error/10",
    link: "btn-link text-error",
  },
};

const sizes = {
  sm: "btn-sm",
  md: "",
  lg: "btn-lg",
  icon: "btn-square",
};

const {
  variant = "secondary",
  size = "sm",
  appearance = "solid",
  href,
  disabled = false,
  class: className = "",
} = Astro.props;

const base =
  "btn rounded-lg font-medium normal-case transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent";

const disabledClass = "btn-disabled pointer-events-none opacity-60";
---

{
  href ? (
    <a
      href={href}
      aria-disabled={disabled ? "true" : undefined}
      class:list={[
        base,
        sizes[size],
        variants[variant][appearance],
        disabled && disabledClass,
        className,
      ]}
    >
      <slot name="icon-left" />
      <slot />
      <slot name="icon-right" />
    </a>
  ) : (
    <button
      type="button"
      class:list={[
        base,
        sizes[size],
        variants[variant][appearance],
        className,
      ]}
      disabled={disabled}
    >
      <slot name="icon-left" />
      <slot />
      <slot name="icon-right" />
    </button>
  )
}
