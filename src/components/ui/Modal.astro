---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  title?: string;
  icon?: string;
  size?: "sm" | "md" | "lg" | "xl" | "full" | "2xl" | "3xl";
  zIndex?: string;
  titleClass?: string;
  class?: string;
}

const {
  id,
  title,
  icon,
  size = "md",
  zIndex,
  titleClass,
  class: className,
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: "max-w-sm",
  md: "max-w-md",
  lg: "max-w-lg",
  xl: "max-w-xl",
  full: "max-w-5xl",
  "2xl": "max-w-2xl",
  "3xl": "max-w-3xl",
};
---

<dialog {id} class:list={["modal modal-bottom sm:modal-middle", zIndex]}>
  <div
    class:list={[
      "modal-box w-11/12 sm:w-full p-4 sm:p-5",
      sizeClasses[size],
      className,
    ]}
  >
    {
      title && (
        <h3
          class:list={[
            "flex items-center gap-2 mb-3 text-base-content",
            titleClass || "font-bold text-lg",
          ]}
        >
          {icon && (
            <Icon name={icon} class="text-secondary shrink-0" size={22} />
          )}
          {title}
        </h3>
      )
    }
    <slot name="content" />
    <slot name="actions" />
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
