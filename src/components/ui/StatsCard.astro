---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  label: string;
  value: string | number;
  subtitle: string;
  color?: "primary" | "secondary" | "accent" | "info" | "success" | "warning" | "error";
  size?: "sm" | "md" | "lg";
  accentIcon?: string;
  class?: string;
}

const {
  icon,
  label,
  value,
  subtitle,
  color = "primary",
  size,
  accentIcon,
  class: className = "",
} = Astro.props;
---

<div
  class:list={["card card-border bg-base-100 border-base-200 shadow-sm", className]}
>
  <div class="card-body">
    <div class="stat">
      <div class:list={["stat-figure", `text-${color}`]}>
        <Icon name={`boxicons:${icon}`} size={18} />
      </div>
      <div class="stat-title">{label}</div>
      <div class:list={["stat-value", `text-${color}`]}>{value}</div>
      <div class="stat-desc">{subtitle}</div>
    </div>
  </div>
</div>
