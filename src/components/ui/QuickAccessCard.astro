---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  title: string;
  description: string;
  icon: string;
  iconTone?: string;
  locked?: boolean;
}

const {
  href,
  title,
  description,
  icon,
  iconTone = "bg-secondary/10 text-secondary",
  locked = false,
} = Astro.props;

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";
const isWebUrl = (value: string): boolean => /^https?:\/\//i.test(value);
const resolvedHref =
  isWebUrl(href) ||
  href.startsWith("mailto:") ||
  href.startsWith("tel:") ||
  href.startsWith(cleanBase)
    ? href
    : `${cleanBase}${href.startsWith("/") ? href.slice(1) : href}`;

const Wrapper = locked ? "div" : "a";
---

<Wrapper
  {...!locked
    ? { href: resolvedHref, "aria-label": `Abrir ${title}` }
    : { "aria-label": `${title} (Restringido)` }}
  class:list={[
    "card card-compact bg-base-100 border border-base-300 h-full shadow-md",
    locked
      ? "opacity-40 grayscale cursor-not-allowed select-none"
      : "transition-all duration-300 hover:-translate-y-1 hover:border-primary group focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2",
  ]}
>
  <div class="card-body gap-3 flex flex-col h-full">
    <div
      aria-hidden="true"
      class:list={[
        "mb-1 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl transition-colors",
        iconTone,
      ]}
    >
      <Icon
        name={icon}
        size={32}
        class={locked
          ? ""
          : "transition-transform duration-300 group-hover:scale-110"}
      />
    </div>
    <h3
      class="card-title text-base font-semibold text-base-content transition-colors"
    >
      {title}
    </h3>
    <p class="text-sm text-base-content/70 grow leading-relaxed">
      {description}
    </p>
    <div class="card-actions mt-2 justify-end">
      {
        locked ? (
          <Icon
            name="boxicons:lock"
            size={24}
            class="opacity-60"
            aria-hidden="true"
          />
        ) : (
          <span class="flex items-center gap-1 text-sm font-medium text-base-content/40 transition-colors duration-300">
            Acceder{" "}
            <Icon
              name="boxicons:arrow-right-stroke-filled"
              size={24}
              aria-hidden="true"
            />
          </span>
        )
      }
    </div>
  </div>
</Wrapper>
