---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  title: string;
  description: string;
  icon: string;
  iconTone?: string;
}

const {
  href,
  title,
  description,
  icon,
  iconTone = "bg-secondary/10 text-secondary",
} = Astro.props;
---

<a
  href={href}
  aria-label={`Abrir ${title}`}
  class="card card-compact bg-base-100 border border-base-300 h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary group focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
>
  <div class="card-body gap-3 flex flex-col h-full">
    <div
      aria-hidden="true"
      class:list={[
        "mb-1 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl transition-colors",
        iconTone,
      ]}
    >
      <Icon name={icon} class="size-6 transition-transform duration-300 group-hover:scale-110" />
    </div>
    <h3 class="card-title text-base font-semibold text-base-content transition-colors">
      {title}
    </h3>
    <p class="text-sm text-base-content/70 flex-grow leading-relaxed">
      {description}
    </p>
    <div class="card-actions mt-2 justify-end">
      <span class="flex items-center gap-1 text-sm font-medium text-base-content/40 transition-colors duration-300">
        Acceder <Icon name="boxicons:arrow-right-stroke-filled" class="size-5" />
      </span>
    </div>
  </div>
</a>
