---
import { Icon } from "astro-icon/components";

interface Props {
  href?: string;
  ariaLabel: string;
  class?: string;
  [key: string]: any;
}

const { href, ariaLabel, class: className = "", ...attrs } = Astro.props;
---

{
  href ? (
    <a
      href={href}
      class:list={[
        "btn btn-sm md:btn-md btn-soft btn-secondary gap-2",
        className,
      ]}
      aria-label={ariaLabel}
      {...attrs}
    >
      <Icon name="boxicons:pencil-filled" size={18} />
    </a>
  ) : (
    <button
      type="button"
      class:list={[
        "btn btn-sm md:btn-md btn-soft btn-secondary gap-2",
        className,
      ]}
      aria-label={ariaLabel}
      {...attrs}
    >
      <Icon name="boxicons:pencil-filled" size={18} />
    </button>
  )
}
