---
import SearchEmptyState from "./SearchEmptyState.astro";

interface Props {
  ariaLabel: string;
  minWidthClass?: string;
  headerGridClass: string;
  class?: string;
  bodyClass?: string;
  id?: string;
  // empty state props
  emptyStateTitle?: string;
  emptyStateDescription?: string;
  showClearButton?: boolean;
  clearButtonText?: string;
  clearButtonId?: string;
  clearButtonHref?: string;
}

const {
  ariaLabel,
  minWidthClass = "min-w-max md:min-w-full",
  headerGridClass,
  class: className = "",
  bodyClass = "",
  id,
  emptyStateTitle,
  emptyStateDescription,
  showClearButton = false,
  clearButtonText,
  clearButtonId,
  clearButtonHref,
} = Astro.props;
---

<section
  id={id}
  class:list={["relative w-full", className]}
  aria-label={ariaLabel}
  data-master-detail-table-root
  data-master-detail-view="grouped"
>
  <div
    class:list={[
      "rounded-box overflow-auto border border-base-300 bg-base-200/70 shadow-md",
    ]}
    data-master-detail-table-wrapper
  >
    <div class:list={[minWidthClass]}>
      <div
        class:list={[
          "grid border-b border-secondary/40 bg-secondary px-4 py-2.5 text-secondary-content shadow-sm uppercase font-mono",
          headerGridClass,
        ]}
        data-master-detail-table-header
      >
        <slot name="header" />
      </div>

      <div class:list={bodyClass} data-master-detail-table-body>
        <slot />
      </div>
    </div>
  </div>

  <SearchEmptyState
    id={id ? `${id}-empty-state` : undefined}
    title={emptyStateTitle}
    description={emptyStateDescription}
    showClearButton={showClearButton}
    clearButtonText={clearButtonText}
    clearButtonId={clearButtonId}
    clearButtonHref={clearButtonHref}
  />
</section>

<script>
  import { initMasterDetailTableSortObserver } from "@lib/clientMasterDetailTableSort";

  initMasterDetailTableSortObserver();

  document.addEventListener("astro:page-load", () => {
    initMasterDetailTableSortObserver();
  });
</script>
