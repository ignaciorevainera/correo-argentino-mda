---
import { Icon } from "astro-icon/components";

interface Props {
  ariaLabel: string;
  minWidthClass?: string;
  headerGridClass: string;
  class?: string;
  bodyClass?: string;
}

const {
  ariaLabel,
  minWidthClass = "min-w-max md:min-w-full",
  headerGridClass,
  class: className = "",
  bodyClass = "",
} = Astro.props;
---

<section
  class:list={[
    "overflow-x-auto rounded-box border border-base-300 bg-base-200/70 shadow-sm",
    className,
  ]}
  aria-label={ariaLabel}
  data-master-detail-table-root
  data-master-detail-view="grouped"
>
  <div class:list={[minWidthClass]}>
    <div
      class:list={[
        "grid border-b border-secondary/40 bg-secondary px-4 py-2.5 text-secondary-content shadow-sm uppercase font-mono",
        headerGridClass,
      ]}
      data-master-detail-table-header
    >
      <slot name="header" />
    </div>

    <div class:list={bodyClass} data-master-detail-table-body>
      <slot />

      <div data-table-empty-state class="hidden flex flex-col items-center gap-3 py-16 text-base-content/50">
        <div class="rounded-full bg-base-200 p-4">
          <Icon
            name="boxicons:search"
            size={32}
            class="opacity-30"
            aria-hidden="true"
          />
        </div>
        <div class="space-y-1 text-center">
          <p class="text-sm font-semibold">No se encontraron resultados</p>
          <p class="text-xs">Probá con otros términos de búsqueda.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { bindMasterDetailTableSort } from "@lib/clientMasterDetailTableSort";

  bindMasterDetailTableSort();
</script>
