---
interface Props {
  name: string;
  role: string;
  value: string;
  sampleClass: string;
  description?: string;
}

const { name, role, value, sampleClass, description } = Astro.props;
---

<article
  class="overflow-hidden rounded-lg border border-base-300 bg-base-100 shadow-sm transition-colors hover:border-base-content/25"
>
  <div
    class:list={[
      "flex min-h-24 items-end justify-start border-b border-base-300 p-3",
      sampleClass,
    ]}
    aria-hidden="true"
  >
    <span class="rounded-md bg-base-100/90 px-2 py-1 font-mono text-xs text-base-content shadow-sm">
      {value}
    </span>
  </div>

  <div class="space-y-2 p-4">
    <div class="space-y-1">
      <p class="text-sm font-semibold text-base-content">{name}</p>
      <p class="font-mono text-xs text-base-content/60">{role}</p>
    </div>

    {
      description && (
        <p class="text-sm leading-relaxed text-base-content/70">
          {description}
        </p>
      )
    }
  </div>
</article>
