---
interface MonthOption {
  value: string;
  label: string;
}

interface Props {
  id: string;
  options?: MonthOption[];
  selected?: string;
  class?: string;
}

const { id, options = [], selected = "", class: className = "" } = Astro.props;
---

<select
  id={id}
  class:list={["select select-bordered select-sm gap-2", className]}
>
  {options.map((opt) => (
    <option value={opt.value} selected={opt.value === selected}>
      {opt.label}
    </option>
  ))}
</select>
