---
import { Icon } from "astro-icon/components";

export interface Props {
  id: string;
  placeholder?: string;
  ariaLabel?: string;
  class?: string;
}

const {
  id,
  placeholder = "Buscar...",
  ariaLabel,
  class: wrapperClass = "",
} = Astro.props;
---

<div class:list={["relative group", wrapperClass]}>
  <div
    class="join w-full shadow-md rounded-xl overflow-hidden border border-base-300 group-focus-within:border-base-content/30 group-focus-within:ring-2 group-focus-within:ring-base-content/5 transition-[border-color,box-shadow] duration-300 bg-base-100"
  >
    <label class="input input-lg w-full bg-transparent border-0" for={id}>
      <Icon
        name="boxicons:search"
        size={24}
        class="text-base-content/50 opacity-70 group-focus-within:opacity-100 group-focus-within:text-primary transition-all duration-300"
      />
      <input
        type="text"
        {id}
        {placeholder}
        aria-label={ariaLabel ?? placeholder}
        class="grow text-base sm:text-lg"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd
        class="kbd kbd-sm font-sans font-bold text-base-content/50 group-focus-within:opacity-0 transition-opacity duration-300"
      >
        /
      </kbd>
    </label>
  </div>
</div>
