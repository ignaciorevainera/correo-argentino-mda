---
import { Icon } from "astro-icon/components";

interface Props {
  ariaLabel: string;
  class?: string;
  size?: "xs" | "default";
  [key: string]: any;
}

const {
  ariaLabel,
  class: className = "",
  size = "default",
  ...attrs
} = Astro.props;

const isXs = size === "xs";
const btnClasses = isXs
  ? "btn btn-xs btn-soft btn-success gap-2"
  : "btn btn-sm md:btn-md btn-soft btn-success gap-2";
const iconName = "boxicons:user-plus-filled";
const iconSize = isXs ? 14 : 18;
---

<div class="tooltip tooltip-top tooltip-neutral" data-tip="Agregar a InvGate">
  <button
    type="button"
    class:list={[btnClasses, className]}
    aria-label={ariaLabel}
    {...attrs}
  >
    <Icon name={iconName} size={iconSize} />
  </button>
</div>
