---
import { Icon } from "astro-icon/components";

interface Props {
  icon?: string;
  label?: string;
  ariaLabel?: string;
  size?: "xs" | "default";
  class?: string;
  [key: string]: any;
}

const {
  icon = "boxicons:info-square-filled",
  label = "Ver más",
  ariaLabel,
  size = "default",
  class: className = "",
  ...attrs
} = Astro.props;

const isXs = size === "xs";
const btnClasses = isXs
  ? "btn btn-xs btn-soft btn-success gap-2"
  : "btn btn-sm md:btn-md btn-soft btn-success gap-2";
const iconSize = isXs ? 14 : 18;
---

<button
  type="button"
  class:list={[btnClasses, className]}
  aria-label={ariaLabel}
  {...attrs}
>
  <Icon name={icon} size={iconSize} aria-hidden="true" />
  {label && <span>{label}</span>}
</button>
