---
export interface TabItem {
  value: string;
  label: string;
  count?: number;
}

interface Props {
  tabs: TabItem[];
  activeValue: string;
  name?: string;
  activeClasses?: Record<string, string>;
  class?: string;
  id?: string;
  submitOnChange?: boolean;
}

const {
  tabs,
  activeValue,
  name = "type",
  activeClasses = {},
  class: className,
  id,
  submitOnChange = true,
} = Astro.props;
---

{submitOnChange && (
  <input
    type="hidden"
    name={name}
    value={activeValue}
    id={`filter-tabs-hidden-${name}`}
  />
)}
<div
  id={id}
  class:list={["tabs tabs-box gap-1.5 filter-tabs-box", className]}
  role="tablist"
>
  {
    tabs.map((tab) => {
      const isActive = tab.value === activeValue;
      const officeClass = activeClasses[tab.value] || "";

      return (
        <button
          type="button"
          role="tab"
          data-tab-value={tab.value}
          aria-selected={isActive ? "true" : "false"}
          class:list={[
            "tab transition-all duration-200 flex items-center gap-2",
            officeClass,
            isActive ? "tab-active" : "",
          ]}
          onclick={submitOnChange ? `document.getElementById('filter-tabs-hidden-${name}').value = '${tab.value}'; this.form.submit();` : undefined}
        >
          <span>{tab.label}</span>
          {tab.count !== undefined && (
            <span class="badge badge-sm bg-base-200 text-current border-none">
              {tab.count}
            </span>
          )}
        </button>
      );
    })
  }
</div>

