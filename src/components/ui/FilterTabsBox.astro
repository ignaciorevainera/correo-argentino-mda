---
export interface TabItem {
  value: string;
  label: string;
  count?: number;
}

interface Props {
  tabs: TabItem[];
  activeValue: string;
  name?: string;
  activeClasses?: Record<string, string>;
  class?: string;
}

const {
  tabs,
  activeValue,
  name = "type",
  activeClasses = {},
  class: className,
} = Astro.props;
---

<input type="hidden" name={name} value={activeValue} id={`filter-tabs-hidden-${name}`} />
<div class:list={["tabs tabs-box gap-1.5", className]} role="tablist">
  {
    tabs.map((tab) => {
      const isActive = tab.value === activeValue;
      const officeClass = activeClasses[tab.value] || "";

      return (
        <button
          type="button"
          role="tab"
          aria-selected={isActive ? "true" : "false"}
          class:list={[
            "tab transition-all duration-200 flex items-center gap-2",
            officeClass,
            isActive ? "tab-active" : "",
          ]}
          onclick={`document.getElementById('filter-tabs-hidden-${name}').value = '${tab.value}'; this.form.submit();`}
        >
          <span>{tab.label}</span>
          {tab.count !== undefined && (
            <span class="badge badge-sm bg-base-100 text-current border-none">
              {tab.count}
            </span>
          )}
        </button>
      );
    })
  }
</div>

