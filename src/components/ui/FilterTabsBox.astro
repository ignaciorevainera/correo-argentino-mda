  .tabs-box .tab {
    background-color: color-mix(in srgb, var(--color-base-300, #e5e7eb) 60%, transparent) !important;
    border-color: color-mix(in srgb, var(--color-base-300, #e5e7eb) 40%, transparent) !important;
