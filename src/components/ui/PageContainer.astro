---
interface Props {
  width?: "default" | "xl" | "xxl" | "full";
  gap?: "md" | "lg";
  as?: "div" | "section";
  class?: string;
  [key: string]: any;
}

const {
  width = "default",
  gap = "md",
  as = "div",
  class: className = "",
  ...rest
} = Astro.props;

const ContainerTag = as;

const widthClassByVariant: Record<NonNullable<Props["width"]>, string> = {
  default: "max-w-6xl",
  xl: "max-w-7xl",
  xxl: "max-w-[1400px]",
  full: "max-w-full",
};

const gapClassByVariant: Record<NonNullable<Props["gap"]>, string> = {
  md: "gap-6",
  lg: "gap-8",
};
---

<ContainerTag
  class:list={[
    "mx-auto flex w-full flex-col",
    widthClassByVariant[width],
    gapClassByVariant[gap],
    className,
  ]}
  {...rest}
>
  <slot />
</ContainerTag>
