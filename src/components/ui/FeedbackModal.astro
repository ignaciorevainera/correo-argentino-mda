---
import { Icon } from "astro-icon/components";

const user = Astro.locals.user || { username: "Invitado" };
---

<dialog id="feedback_modal" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box max-w-lg border border-base-300 bg-base-100 p-6 rounded-2xl shadow-xl relative">
    {/* Botón de cerrar (X) en la esquina superior derecha */}
    <button
      type="button"
      class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4"
      aria-label="Cerrar modal"
      data-close-feedback-modal
    >
      <Icon name="boxicons:x" size={20} />
    </button>

    <h3 class="text-lg font-bold text-base-content mb-4 flex items-center gap-2">
      <Icon name="boxicons:mail-open" size={24} class="text-primary" />
      <span>Enviar Comentarios o Reportes</span>
    </h3>

    {/* Pestañas de Navegación del Modal */}
    <div class="tabs tabs-boxed grid grid-cols-2 bg-base-200 mb-6 rounded-md p-1">
      <button
        type="button"
        id="tab-sugerencia"
        class="tab tab-active flex items-center justify-center gap-2 text-sm font-semibold py-2 rounded-md transition-all bg-base-100 shadow-sm"
      >
        <Icon name="boxicons:light-bulb-on" size={18} />
        <span>Sugerir Idea</span>
      </button>
      <button
        type="button"
        id="tab-bug"
        class="tab flex items-center justify-center gap-2 text-sm font-medium py-2 rounded-md transition-all text-base-content/60"
      >
        <Icon name="boxicons:bug" size={18} />
        <span>Reportar Bug</span>
      </button>
    </div>

    {/* Formulario de Sugerir Idea */}
    <form id="suggestion-form" class="space-y-4">
      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Asunto</label>
        <input
          type="text"
          id="sug-asunto"
          placeholder="Ej: Agregar exportación a Excel en terminales"
          class="input input-bordered w-full rounded-md text-sm"
          required
        />
      </div>

      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Área o Categoría</label>
        <select id="sug-categoria" class="select select-bordered w-full rounded-md text-sm" required>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="cronograma">Cronograma</option>
          <option value="asistencia">Asistencia</option>
          <option value="calidad">Calidad</option>
          <option value="autogesitones">Autogestiones</option>
          <option value="titulos">Títulos</option>
          <option value="soportes">Soportes</option>
          <option value="usuarios">Buscador de Usuarios</option>
          <option value="contactos">Contactos</option>
          <option value="enlaces">Enlaces/Recursos</option>
          <option value="oficinas">Oficinas</option>
          <option value="inventario">Inventario de Terminales</option>
          <option value="otros">Otros</option>
        </select>
      </div>

      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Tu Propuesta</label>
        <textarea
          id="sug-mensaje"
          placeholder="Describe detalladamente tu propuesta o idea..."
          class="textarea textarea-bordered w-full h-32 rounded-md text-sm"
          required
        ></textarea>
      </div>

      <div class="modal-action flex items-center justify-between mt-6">
        <div class="text-xxs text-base-content/50">
          Enviando como: <span class="font-semibold text-base-content">{user.username}</span>
        </div>
        <div class="flex gap-2">
          <button type="button" class="btn btn-ghost rounded-md" data-close-feedback-modal>
            Cancelar
          </button>
          <button type="submit" class="btn btn-primary rounded-md">
            Enviar sugerencia
          </button>
        </div>
      </div>
    </form>

    {/* Formulario de Reportar Bug */}
    <form id="bug-form" class="space-y-4 hidden">
      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Asunto</label>
        <input
          type="text"
          id="bug-asunto"
          placeholder="Ej: El buscador no funciona"
          class="input input-bordered w-full rounded-md text-sm"
          required
        />
      </div>

      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Área o Categoría</label>
        <select id="bug-categoria" class="select select-bordered w-full rounded-md text-sm" required>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="cronograma">Cronograma</option>
          <option value="asistencia">Asistencia</option>
          <option value="calidad">Calidad</option>
          <option value="autogesitones">Autogestiones</option>
          <option value="titulos">Títulos</option>
          <option value="soportes">Soportes</option>
          <option value="usuarios">Buscador de Usuarios</option>
          <option value="contactos">Contactos</option>
          <option value="enlaces">Enlaces/Recursos</option>
          <option value="oficinas">Oficinas</option>
          <option value="inventario">Inventario de Terminales</option>
          <option value="otros">Otros</option>
        </select>
      </div>

      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Gravedad</label>
        <select id="bug-gravedad" class="select select-bordered w-full rounded-md text-sm" required>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="leve">Leve (Visual / Estético)</option>
          <option value="moderado">Moderado (Funcionalidad con alternativa)</option>
          <option value="critico">Crítico (Fallo bloqueante)</option>
        </select>
      </div>

      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Descripción del Fallo</label>
        <textarea
          id="bug-descripcion"
          placeholder="Describe detalladamente qué ocurrió..."
          class="textarea textarea-bordered w-full h-20 rounded-md text-sm"
          required
        ></textarea>
      </div>

      <div class="form-control w-full">
        <label class="label py-1 text-xxs font-semibold uppercase text-base-content/60">Pasos para Reproducir</label>
        <textarea
          id="bug-pasos"
          placeholder="1. Ingresar a /mapa-sucursales&#10;2. Cambiar a vista móvil&#10;3. Observar que..."
          class="textarea textarea-bordered w-full h-32 rounded-md text-sm"
          required
        ></textarea>
      </div>

      <div class="modal-action flex items-center justify-between mt-6">
        <div class="text-xxs text-base-content/50">
          Enviando como: <span class="font-semibold text-base-content">{user.username}</span>
        </div>
        <div class="flex gap-2">
          <button type="button" class="btn btn-ghost rounded-md" data-close-feedback-modal>
            Cancelar
          </button>
          <button type="submit" class="btn btn-primary rounded-md">
            Reportar bug
          </button>
        </div>
      </div>
    </form>
  </div>

  {/* Backdrop para poder cerrar haciendo clic afuera */}
  <form method="dialog" class="modal-backdrop">
    <button>Cerrar</button>
  </form>
</dialog>

<script>
  import { actions, isInputError } from "astro:actions";
  import { showToast } from "../../lib/toastClient";

  // Variables y Elementos del DOM
  const modal = document.getElementById("feedback_modal") as HTMLDialogElement;
  const tabSugerencia = document.getElementById("tab-sugerencia");
  const tabBug = document.getElementById("tab-bug");
  const formSugerencia = document.getElementById("suggestion-form") as HTMLFormElement;
  const formBug = document.getElementById("bug-form") as HTMLFormElement;
  const closeButtons = document.querySelectorAll("[data-close-feedback-modal]");
  const openButtons = document.querySelectorAll("[data-open-feedback-modal]");

  let activeType: "sugerencia" | "bug" = "sugerencia";

  // 1. Manejo del cambio de pestañas
  function switchTab(activeTab: HTMLElement, inactiveTab: HTMLElement, showForm: HTMLFormElement, hideForm: HTMLFormElement, type: "sugerencia" | "bug") {
    activeTab.classList.add("tab-active", "bg-base-100", "shadow-sm", "font-semibold");
    activeTab.classList.remove("text-base-content/60", "font-medium");
    inactiveTab.classList.remove("tab-active", "bg-base-100", "shadow-sm", "font-semibold");
    inactiveTab.classList.add("text-base-content/60", "font-medium");
    showForm.classList.remove("hidden");
    hideForm.classList.add("hidden");
    activeType = type;
  }

  tabSugerencia?.addEventListener("click", () => {
    if (tabSugerencia && tabBug && formSugerencia && formBug) {
      switchTab(tabSugerencia, tabBug, formSugerencia, formBug, "sugerencia");
    }
  });

  tabBug?.addEventListener("click", () => {
    if (tabBug && tabSugerencia && formBug && formSugerencia) {
      switchTab(tabBug, tabSugerencia, formBug, formSugerencia, "bug");
    }
  });

  // Función de mapeo para preseleccionar la categoría según la ruta activa
  function getCategoryFromPath(path: string): string {
    const normalized = path.toLowerCase().replace(/\/$/, "");
    
    if (normalized.includes("/supervision/cronograma")) return "cronograma";
    if (normalized.includes("/supervision/asistencia")) return "asistencia";
    if (normalized.includes("/supervision/calidad")) return "calidad";
    if (normalized.includes("/supervision/asignacion")) return "autogesitones";
    if (normalized.includes("/supervision")) return "cronograma"; // default fallback
    
    if (normalized.includes("/titulos-tickets")) return "titulos";
    if (normalized.includes("/guia-soportes")) return "soportes";
    if (normalized.includes("/buscador-usuarios")) return "usuarios";
    if (normalized.includes("/contactos")) return "contactos";
    if (normalized.includes("/enlaces-recursos") || normalized.includes("/recursos")) return "enlaces";
    if (normalized.includes("/directorio-oficinas") || normalized.includes("/oficinas")) return "oficinas";
    if (normalized.includes("/inventario-equipos") || normalized.includes("/inventario-terminales")) return "inventario";
    
    return "otros";
  }

  function autoSelectCategory() {
    const category = getCategoryFromPath(window.location.pathname);
    const sugSelect = document.getElementById("sug-categoria") as HTMLSelectElement | null;
    const bugSelect = document.getElementById("bug-categoria") as HTMLSelectElement | null;
    
    if (sugSelect) sugSelect.value = category;
    if (bugSelect) bugSelect.value = category;
  }

  // 2. Controladores de abrir y cerrar
  openButtons.forEach(btn => {
    btn.addEventListener("click", () => {
      if (modal) {
        autoSelectCategory();
        modal.showModal();
      }
    });
  });

  closeButtons.forEach(btn => {
    btn.addEventListener("click", () => {
      if (modal) {
        modal.close();
      }
    });
  });

  // 3. Manejo de envío asíncrono
  async function handleFormSubmit(e: SubmitEvent, type: "sugerencia" | "bug", form: HTMLFormElement) {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.classList.add("loading");
    }

    try {
      const userAgent = `Ruta: ${window.location.pathname} | ${navigator.userAgent}`;
      let payload: any = {
        type,
        userAgent,
      };

      if (type === "sugerencia") {
        payload.subject = (document.getElementById("sug-asunto") as HTMLInputElement).value;
        payload.category = (document.getElementById("sug-categoria") as HTMLSelectElement).value;
        payload.description = (document.getElementById("sug-mensaje") as HTMLTextAreaElement).value;
      } else {
        payload.subject = (document.getElementById("bug-asunto") as HTMLInputElement).value;
        payload.category = (document.getElementById("bug-categoria") as HTMLSelectElement).value;
        payload.severity = (document.getElementById("bug-gravedad") as HTMLSelectElement).value;
        payload.description = (document.getElementById("bug-descripcion") as HTMLTextAreaElement).value;
        payload.steps = (document.getElementById("bug-pasos") as HTMLTextAreaElement).value;
      }

      const { data, error } = await actions.submitFeedback(payload);

      if (error) {
        if (isInputError(error)) {
          const messages = Object.values(error.fields)
            .flat()
            .join(". ");
          showToast(`Error de validación: ${messages}`, "alert-error");
        } else {
          showToast(`Error al enviar: ${error.message}`, "alert-error");
        }
      } else if (data?.success) {
        showToast(
          type === "sugerencia" ? "¡Sugerencia enviada correctamente!" : "¡Reporte de bug enviado con éxito!",
          "alert-success"
        );
        form.reset();
        modal.close();
      }
    } catch (err: any) {
      showToast("Ocurrió un error inesperado al enviar.", "alert-error");
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.classList.remove("loading");
      }
    }
  }

  formSugerencia?.addEventListener("submit", (e) => handleFormSubmit(e, "sugerencia", formSugerencia));
  formBug?.addEventListener("submit", (e) => handleFormSubmit(e, "bug", formBug));
</script>
