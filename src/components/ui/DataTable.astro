---
import SearchEmptyState from "./SearchEmptyState.astro";

interface Props {
  ariaLabel: string;
  minWidthClass?: string;
  headerGridClass: string;
  rowGridClass: string;
  class?: string;
  bodyClass?: string;
  wrapperClass?: string;
  id?: string;
  // empty state props
  emptyStateTitle?: string;
  emptyStateDescription?: string;
  showClearButton?: boolean;
  clearButtonText?: string;
  clearButtonId?: string;
  clearButtonHref?: string;
  serverSideSort?: boolean;
}

const {
  ariaLabel,
  minWidthClass = "min-w-max md:min-w-full",
  headerGridClass,
  rowGridClass,
  class: className = "",
  bodyClass = "",
  wrapperClass = "rounded-box border border-base-300 bg-base-200/70 shadow-md overflow-x-auto",
  id,
  emptyStateTitle,
  emptyStateDescription,
  showClearButton = false,
  clearButtonText,
  clearButtonId,
  clearButtonHref,
  serverSideSort = false,
} = Astro.props;
---

<section
  id={id}
  class:list={["relative w-full", className]}
  aria-label={ariaLabel}
  data-table-sort-root
  data-table-row-grid-class={rowGridClass}
  data-server-side-sort={serverSideSort ? "true" : undefined}
>
  <div class:list={wrapperClass} data-table-wrapper>
    <div class:list={[minWidthClass]}>
      <div
        class:list={[
          "grid border-b border-secondary/40 bg-secondary px-4 py-2.5 text-secondary-content shadow-sm uppercase font-mono",
          headerGridClass,
        ]}
        data-table-header
      >
        <slot name="header" />
      </div>

      <div class:list={bodyClass} data-table-sort-body>
        <slot />
      </div>
    </div>
  </div>

  <SearchEmptyState
    id={id ? `${id}-empty-state` : undefined}
    title={emptyStateTitle}
    description={emptyStateDescription}
    showClearButton={showClearButton}
    clearButtonText={clearButtonText}
    clearButtonId={clearButtonId}
    clearButtonHref={clearButtonHref}
  />
</section>

<script>
  import { initTableSortObserver } from "@lib/clientTableSort";

  initTableSortObserver();

  document.addEventListener("astro:page-load", () => {
    initTableSortObserver();
  });
</script>
