---
import SearchEmptyState from "./SearchEmptyState.astro";

interface Props {
  ariaLabel: string;
  minWidthClass?: string;
  headerGridClass: string;
  rowGridClass: string;
  class?: string;
  bodyClass?: string;
  id?: string;
  // empty state props
  emptyStateTitle?: string;
  emptyStateDescription?: string;
  showClearButton?: boolean;
  clearButtonText?: string;
  clearButtonId?: string;
  clearButtonHref?: string;
}

const {
  ariaLabel,
  minWidthClass = "min-w-max md:min-w-full",
  headerGridClass,
  rowGridClass,
  class: className = "",
  bodyClass = "",
  id,
  emptyStateTitle,
  emptyStateDescription,
  showClearButton = false,
  clearButtonText,
  clearButtonId,
  clearButtonHref,
} = Astro.props;
---

<section
  id={id}
  class:list={[
    "relative w-full",
    className,
  ]}
  aria-label={ariaLabel}
  data-table-sort-root
  data-table-row-grid-class={rowGridClass}
>
  <div class:list={["overflow-x-auto rounded-box border border-base-300 bg-base-200/70 shadow-md", minWidthClass]} data-table-wrapper>
    <div
      class:list={[
        "grid border-b border-secondary/40 bg-secondary px-4 py-2.5 text-secondary-content shadow-sm uppercase font-mono",
        headerGridClass,
      ]}
      data-table-header
    >
      <slot name="header" />
    </div>

    <div class:list={bodyClass} data-table-sort-body>
      <slot />
    </div>
  </div>

  <SearchEmptyState
    id={id ? `${id}-empty-state` : undefined}
    title={emptyStateTitle}
    description={emptyStateDescription}
    showClearButton={showClearButton}
    clearButtonText={clearButtonText}
    clearButtonId={clearButtonId}
    clearButtonHref={clearButtonHref}
  />
</section>

<script>
  import { bindClientTableSort } from "@lib/clientTableSort";

  bindClientTableSort();
</script>
