---
import type { HTMLAttributes } from "astro/types";
import { Icon } from "astro-icon/components";
import FormLegend from "@components/ui/forms/FormLegend.astro";

interface Props extends HTMLAttributes<"input"> {
  id: string;
  name: string;
  label: string;
  helpText?: string;
  inputClass?: string;
  icon?: string;
}

const {
  id,
  name,
  label,
  helpText,
  type = "text",
  inputClass = "",
  icon,
  class: className = "",
  ...rest
} = Astro.props;
---

<fieldset class:list={["fieldset", className]}>
  <FormLegend class="font-bold tracking-wider">
    {label}
    {rest.required && <span class="text-error">*</span>}
  </FormLegend>
  {
    type === "file" ? (
      <div class="flex items-center gap-4">
        <slot name="preview" />
        <input
          type="file"
          id={id}
          name={name}
          class="file-input file-input-bordered w-full"
          {...rest}
        />
      </div>
    ) : icon ? (
      <label class:list={["input input-bordered w-full flex items-center gap-2", inputClass]}>
        <Icon name={icon} size={16} class="opacity-50 shrink-0" />
        <input
          type={type}
          id={id}
          name={name}
          class="grow"
          {...rest}
        />
      </label>
    ) : (
      <input
        type={type}
        id={id}
        name={name}
        class:list={["input input-bordered w-full", inputClass]}
        {...rest}
      />
    )
  }
  {
    helpText && (
      <p class="fieldset-label text-xs text-base-content/50">{helpText}</p>
    )
  }
</fieldset>
