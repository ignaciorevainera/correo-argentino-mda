---
import { Icon } from "astro-icon/components";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  id: string;
  name: string;
  label?: string;
  confirmPassword?: boolean;
  confirmLabel?: string;
  inputClass?: string;
  icon?: string;
}

const {
  id,
  name,
  label = "Contraseña inicial",
  confirmPassword = false,
  confirmLabel = "Repetir contraseña",
  inputClass = "",
  icon,
  class: className = "",
  required = false,
  ...rest
} = Astro.props;
---

<div data-password-field-container class:list={["space-y-4", className]}>
  <fieldset class="fieldset">
    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider flex items-center gap-1">
      {label}
      {required && <span class="text-error">*</span>}
    </legend>
    {
      icon ? (
        <label class:list={["input input-bordered w-full flex items-center gap-2", inputClass]}>
          <Icon name={icon} size={16} class="opacity-50 shrink-0" />
          <input
            type="password"
            id={id}
            name={name}
            required={required}
            class="grow pwd-input-validate"
            {...rest}
          />
        </label>
      ) : (
        <input
          type="password"
          id={id}
          name={name}
          required={required}
          class:list={["input input-bordered w-full pwd-input-validate", inputClass]}
          {...rest}
        />
      )
    }
    <div class="pwd-error hidden mt-2 alert alert-error alert-soft text-xs">
      <Icon name="boxicons:alert-circle-filled" size={16} class="shrink-0" />
      <span class="pwd-error-msg"></span>
    </div>
    <ul class="text-xs mt-2 space-y-1 pwd-req-list">
      <li data-req="len" class="text-base-content/50 transition-colors">
        Mínimo 8 caracteres
      </li>
      <li data-req="up" class="text-base-content/50 transition-colors">
        Al menos una mayúscula
      </li>
      <li data-req="low" class="text-base-content/50 transition-colors">
        Al menos una minúscula
      </li>
      <li data-req="num" class="text-base-content/50 transition-colors">
        Al menos un número
      </li>
    </ul>
  </fieldset>

  {
    confirmPassword && (
      <fieldset class="fieldset">
        <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider">
          {confirmLabel}
        </legend>
        <input
          type="password"
          id={`${id}-repeat`}
          required={required}
          autocomplete="new-password"
          class="input input-bordered w-full pwd-input-repeat"
        />
      </fieldset>
    )
  }
</div>

<script>
  const pwdRegex = {
    up: /[A-Z]/,
    low: /[a-z]/,
    num: /[0-9]/,
  };

  const validatePassword = (pwd: string) => {
    return {
      len: pwd.length >= 8,
      up: pwdRegex.up.test(pwd),
      low: pwdRegex.low.test(pwd),
      num: pwdRegex.num.test(pwd),
    };
  };

  const initPasswordField = () => {
    const containers = document.querySelectorAll(
      "[data-password-field-container]"
    );
    containers.forEach((container) => {
      if (container.getAttribute("data-initialized") === "true") return;
      container.setAttribute("data-initialized", "true");

      const inputEl = container.querySelector(
        ".pwd-input-validate"
      ) as HTMLInputElement | null;
      const repeatInputEl = container.querySelector(
        ".pwd-input-repeat"
      ) as HTMLInputElement | null;
      const reqList = container.querySelector(".pwd-req-list");
      const reqItems = {
        len: reqList?.querySelector('[data-req="len"]'),
        up: reqList?.querySelector('[data-req="up"]'),
        low: reqList?.querySelector('[data-req="low"]'),
        num: reqList?.querySelector('[data-req="num"]'),
      };
      const errorContainer = container.querySelector(".pwd-error");
      const errorMsgEl = container.querySelector(".pwd-error-msg");
      const form = container.closest("form");

      if (!inputEl) return;

      inputEl.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        const status = validatePassword(val);

        if (errorContainer) {
          errorContainer.classList.add("hidden");
        }

        Object.keys(status).forEach((key) => {
          const li = reqItems[key as keyof typeof reqItems];
          if (li) {
            if (val.length === 0) {
              li.className = "text-base-content/50 transition-colors";
            } else if (status[key as keyof typeof status]) {
              li.className = "text-success font-medium transition-colors";
            } else {
              li.className = "text-error transition-colors";
            }
          }
        });
      });

      form?.addEventListener("submit", (e) => {
        const val = inputEl.value;
        const status = validatePassword(val);

        let errorMsg = "";
        if (!status.len)
          errorMsg = "La contraseña debe tener al menos 8 caracteres.";
        else if (!status.up)
          errorMsg = "La contraseña debe contener al menos una mayúscula.";
        else if (!status.low)
          errorMsg = "La contraseña debe contener al menos una minúscula.";
        else if (!status.num)
          errorMsg = "La contraseña debe contener al menos un número.";
        else if (repeatInputEl && val !== repeatInputEl.value)
          errorMsg = "Las contraseñas no coinciden.";

        if (errorMsg) {
          e.preventDefault();
          if (errorContainer && errorMsgEl) {
            errorMsgEl.textContent = errorMsg;
            errorContainer.classList.remove("hidden");
          }
        }
      });
    });
  };

  initPasswordField();
  document.addEventListener("astro:page-load", initPasswordField);
</script>
