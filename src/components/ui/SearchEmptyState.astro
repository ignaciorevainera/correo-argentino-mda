---
import { Icon } from "astro-icon/components";

interface Props {
  id?: string;
  title?: string;
  description?: string;
  icon?: string;
  showClearButton?: boolean;
  clearButtonText?: string;
  clearButtonId?: string;
  clearButtonHref?: string;
  class?: string;
  useDualIcons?: boolean;
  notFoundIcon?: string;
}

const {
  id,
  title = "Sin resultados",
  description = "No se encontraron coincidencias para tu búsqueda. Probá de nuevo con otros términos.",
  icon = "boxicons:search",
  showClearButton = false,
  clearButtonText = "Restablecer búsqueda",
  clearButtonId,
  clearButtonHref,
  class: className = "",
  useDualIcons = false,
  notFoundIcon = "boxicons:user-minus-filled",
} = Astro.props;
---

<div
  id={id}
  class:list={[
    "min-h-80 flex-col items-center justify-center text-center p-8 rounded-2xl border border-dashed border-base-300 bg-base-200/40 shadow-inner animate-in fade-in slide-in-from-bottom-4 duration-500",
    !className.includes("flex") && !className.includes("hidden") && "hidden",
    className,
  ]}
  role="status"
  aria-live="polite"
  data-table-empty-state-root
>
  <div class="relative size-20 mb-6 group" id={id ? `${id}-icon-container` : undefined}>
    <!-- Ecos de fondo del ícono con gradientes suaves -->
    <div
      id={id ? `${id}-icon-glow-1` : undefined}
      class="absolute inset-0 bg-primary/10 rounded-3xl blur-md group-hover:bg-primary/20 transition-all duration-300"
    >
    </div>
    <div
      id={id ? `${id}-icon-glow-2` : undefined}
      class="absolute inset-1.5 bg-secondary/15 rounded-2xl blur-sm group-hover:scale-105 transition-all duration-300"
    >
    </div>
    <div
      id={id ? `${id}-icon-bg` : undefined}
      class="relative flex items-center justify-center w-full h-full bg-base-100/90 backdrop-blur-sm rounded-2xl border border-base-300/80 shadow-lg group-hover:-translate-y-1 transition-all duration-300"
    >
      {useDualIcons ? (
        <>
          <div id={id ? `${id}-icon-search` : "empty-icon-search"}>
            <Icon
              name={icon}
              class="size-9 text-base-content/40 group-hover:text-primary transition-colors duration-300"
            />
          </div>
          <div id={id ? `${id}-icon-notfound` : "empty-icon-notfound"} class="hidden">
            <Icon
              name={notFoundIcon}
              class="size-9 text-error/60 group-hover:text-error transition-colors duration-300"
            />
          </div>
        </>
      ) : (
        <Icon
          name={icon}
          class="size-9 text-base-content/40 group-hover:text-primary transition-colors duration-300"
        />
      )}
    </div>
  </div>

  <h3 class="text-xl font-bold text-base-content tracking-tight mb-2 font-mono" id={id ? `${id}-title` : undefined}>
    {title}
  </h3>
  <p class="text-sm text-base-content/60 max-w-sm mb-6" id={id ? `${id}-desc` : undefined}>
    {description}
  </p>

  {
    showClearButton && (
      clearButtonHref ? (
        <a
          href={clearButtonHref}
          id={clearButtonId}
          class="btn btn-primary rounded-full px-6 py-2 shadow-lg shadow-primary/20 hover:shadow-primary/30 hover:-translate-y-0.5 transition-all duration-300"
        >
          <Icon name="boxicons:refresh-ccw-filled" class="size-4 mr-2" />
          {clearButtonText}
        </a>
      ) : (
        <button
          id={clearButtonId}
          type="button"
          class="btn btn-primary rounded-full px-6 py-2 shadow-lg shadow-primary/20 hover:shadow-primary/30 hover:-translate-y-0.5 transition-all duration-300"
        >
          <Icon name="boxicons:refresh-ccw-filled" class="size-4 mr-2" />
          {clearButtonText}
        </button>
      )
    )
  }
</div>
