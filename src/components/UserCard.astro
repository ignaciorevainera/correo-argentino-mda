---
import { Icon } from "astro-icon/components";
import CopyButton from "@components/ui/CopyButton.astro";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ActionNetUserButton from "@components/ui/ActionNetUserButton.astro";
---

<template id="user-card-template">
  <div
    class="card bg-base-100 border border-base-300 shadow-md hover:border-base-content/20 transition-all duration-300 overflow-hidden"
  >
    <div class="card-body p-4 gap-4">
      {/* Cabecera: Avatar y Nombre */}
      <div class="flex items-center gap-3 min-w-0">
        <div class="avatar placeholder shrink-0">
          <div
            class="rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg"
            data-user-avatar-bg
            data-user-initials
          >
            ??
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <h3
            class="font-bold text-base truncate text-base-content"
            data-user-nombre
          >
            Nombre Completo
          </h3>
          <div class="flex items-center gap-1.5 mt-1">
            <span
              class="invgate-badge inline-flex items-center gap-1 px-1.5 py-0.5 rounded-md text-[10px] font-semibold leading-none"
              data-invgate-badge
            ></span>
          </div>
        </div>
      </div>

      {/* Grid de 2 columnas para Usuario, DNI, Interno y Teléfono */}
      <div class="grid grid-cols-2 gap-3 py-3 border-y border-base-200">
        <div class="flex flex-col gap-1">
          <span
            class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
            >Usuario</span
          >
          <CopyButton
            value=""
            variant="value"
            size="xs"
            appearance="surface"
            monospace={true}
            fullWidth={true}
            class="user-card-username-btn w-full justify-between"
          />
        </div>
        <div class="flex flex-col gap-1">
          <span
            class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
            >DNI</span
          >
          <CopyButton
            value=""
            variant="value"
            size="xs"
            appearance="surface"
            monospace={true}
            fullWidth={true}
            class="user-card-dni-btn w-full justify-between"
          />
        </div>
        <div class="flex flex-col gap-1">
          <span
            class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
            >Interno</span
          >
          <CopyButton
            value=""
            variant="value"
            size="xs"
            appearance="surface"
            monospace={true}
            fullWidth={true}
            class="user-card-interno-btn w-full justify-between"
          />
        </div>
        <div class="flex flex-col gap-1">
          <span
            class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
            >Teléfono</span
          >
          <CopyButton
            value=""
            variant="value"
            size="xs"
            appearance="surface"
            monospace={true}
            fullWidth={true}
            class="user-card-telefono-btn w-full justify-between"
          />
        </div>
      </div>

      {/* Email */}
      <div class="flex flex-col gap-1">
        <span
          class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
          >Email</span
        >
        <CopyButton
          value=""
          variant="value"
          size="xs"
          appearance="surface"
          monospace={true}
          fullWidth={true}
          class="user-card-email-btn w-full justify-between"
        />
      </div>

      {/* Barra de Acciones (CTAs) */}
      <div
        class="card-actions justify-end mt-2 pt-3 border-t border-base-200 w-full flex items-center gap-2"
      >
        <ActionNetUserButton
          data-net-user-btn
          ariaLabel="Ver grupos de red"
        />
        <ActionEditButton
          data-edit-user-btn
          ariaLabel="Editar contacto"
        />
      </div>
    </div>
  </div>
</template>
