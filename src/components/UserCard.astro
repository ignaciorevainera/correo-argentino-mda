---
/* ARCHIVO: src/components/UserCard.astro */
import { Icon } from "astro-icon/components";
---

<template id="user-card-template">
  <div class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-base-content/20 transition-all duration-300 group overflow-hidden">
    <div class="card-body p-4 gap-4">
      <div class="flex items-center gap-3">
        <div class="avatar placeholder">
          <div class="rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg transition-transform group-hover:scale-105" data-user-avatar-bg data-user-initials>
            ??
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-bold text-base truncate leading-tight mb-1" data-user-nombre>Nombre Completo</h3>
          <div class="tooltip tooltip-right tooltip-neutral" data-tip="Copiar DNI">
            <button class="text-xs text-base-content/60 hover:text-base-content transition-colors flex items-center gap-1 cursor-pointer" data-copy-dni aria-label="Copiar DNI">
              <Icon name="boxicons:user-id-card-filled" class="size-3.5" />
              <span data-user-dni>00000000</span>
            </button>
          </div>
        </div>
      </div>
 
      <div class="grid grid-cols-3 gap-2 py-3 border-y border-base-200">
        <div class="flex flex-col gap-0.5">
          <span class="text-[10px] uppercase font-bold text-base-content/40 tracking-wider">Usuario</span>
          <div class="tooltip tooltip-bottom tooltip-neutral" data-tip="Copiar Usuario">
            <button class="w-full text-left font-mono text-[11px] bg-base-200/50 hover:bg-base-200 hover:text-base-content px-1.5 py-0.5 rounded transition-colors truncate" data-copy-user data-user-id aria-label="Copiar Usuario">-</button>
          </div>
        </div>
        <div class="flex flex-col gap-0.5">
          <span class="text-[10px] uppercase font-bold text-base-content/40 tracking-wider">Interno</span>
          <div class="tooltip tooltip-bottom tooltip-neutral" data-tip="Copiar Interno">
            <button class="w-full text-left font-mono text-[11px] bg-base-200/50 hover:bg-base-200 hover:text-base-content px-1.5 py-0.5 rounded transition-colors" data-copy-interno data-user-interno aria-label="Copiar Interno">-</button>
          </div>
        </div>
        <div class="flex flex-col gap-0.5">
          <span class="text-[10px] uppercase font-bold text-base-content/40 tracking-wider">Teléfono</span>
          <div class="tooltip tooltip-bottom tooltip-neutral" data-tip="Copiar Teléfono">
            <button class="w-full text-left font-mono text-[11px] bg-base-200/50 hover:bg-base-200 hover:text-base-content px-1.5 py-0.5 rounded transition-colors truncate" data-copy-telefono data-user-telefono aria-label="Copiar Teléfono">-</button>
          </div>
        </div>
      </div>
 
      <div class="space-y-2">
        <div class="tooltip tooltip-top tooltip-neutral w-full" data-tip="Copiar Email">
          <button class="flex items-center gap-2 w-full p-2 rounded-lg bg-base-200/30 hover:bg-base-200 hover:text-base-content transition-all text-xs border border-transparent hover:border-base-content/10" data-copy-email aria-label="Copiar Email">
            <Icon name="boxicons:envelope-filled" class="size-4 opacity-50" />
            <span class="truncate font-medium" data-user-email>email@correo.com.ar</span>
          </button>
        </div>
        <div class="flex items-start gap-2 p-2 rounded-lg bg-base-100 text-[11px] text-base-content/70">
          <Icon name="boxicons:building-house-filled" class="size-4 opacity-40 shrink-0 mt-0.5" />
          <span class="leading-relaxed" data-user-sucursal>Sucursal / Área No especificada</span>
        </div>
      </div>
    </div>
  </div>
</template>
