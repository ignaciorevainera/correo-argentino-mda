---
import CopyButton from "@components/ui/CopyButton.astro";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ActionInvGateButton from "@components/ui/ActionInvGateButton.astro";
import ActionNetUserButton from "@components/ui/ActionNetUserButton.astro";
---

<template id="user-card-template">
  <div
    class="card bg-base-100 border border-base-300 shadow-md hover:border-base-content/20 transition-all duration-300"
  >
    <div class="card-body p-4 gap-4">
      {/* Cabecera: Avatar y Nombre */}
      <div class="flex items-center gap-4 min-w-0">
        <div class="avatar placeholder shrink-0">
          <div
            class="rounded-full size-12 flex items-center justify-center font-bold text-lg"
            data-user-avatar-bg
            data-user-initials
          >
            ??
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <h3
            class="font-bold text-base truncate text-base-content"
            data-user-nombre
          >
            Nombre Completo
          </h3>
          <div class="flex items-center gap-1.5 mt-1">
            <span data-invgate-badge></span>
          </div>
        </div>
      </div>

      <div class="flex flex-col grow gap-4">
        {/* Grid de 2 columnas para Usuario, DNI, Interno y Teléfono */}
        <div class="grid grid-cols-2 gap-4 py-3 border-y border-base-200">
          <div class="flex flex-col gap-1">
            <span
              class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
              >Usuario</span
            >
            <CopyButton
              value=""
              variant="value"
              size="xs"
              appearance="surface"
              monospace={true}
              fullWidth={true}
              class="user-card-username-btn w-full justify-between"
            />
          </div>
          <div class="flex flex-col gap-1">
            <span
              class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
              >DNI</span
            >
            <CopyButton
              value=""
              variant="value"
              size="xs"
              appearance="surface"
              monospace={true}
              fullWidth={true}
              class="user-card-dni-btn w-full justify-between"
            />
          </div>
          <div class="flex flex-col gap-1">
            <span
              class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
              >Interno</span
            >
            <CopyButton
              value=""
              variant="value"
              size="xs"
              appearance="surface"
              monospace={true}
              fullWidth={true}
              class="user-card-interno-btn w-full justify-between"
            />
          </div>
          <div class="flex flex-col gap-1">
            <span
              class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
              >Teléfono</span
            >
            <CopyButton
              value=""
              variant="value"
              size="xs"
              appearance="surface"
              monospace={true}
              fullWidth={true}
              class="user-card-telefono-btn w-full justify-between"
            />
          </div>
        </div>

        {/* Email */}
        <div class="flex flex-col gap-1">
          <span
            class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
            >Email</span
          >
          <CopyButton
            value=""
            variant="value"
            size="xs"
            appearance="surface"
            monospace={true}
            fullWidth={true}
            class="user-card-email-btn w-full justify-between"
          />
        </div>

        {/* Ubicación */}
        <div class="flex flex-col gap-1">
          <span
            class="text-xxs uppercase font-bold text-base-content/40 tracking-wider"
            >Ubicación</span
          >
          <CopyButton
            value=""
            variant="value"
            size="xs"
            appearance="surface"
            monospace={true}
            fullWidth={true}
            class="user-card-sucursal-btn w-full justify-between"
          />
        </div>
      </div>

      {/* Barra de Acciones (CTAs) */}
      <div
        class="card-actions justify-end mt-2 pt-3 border-t border-base-200 w-full flex items-center gap-2"
      >
        <ActionNetUserButton data-net-user-btn ariaLabel="Ver grupos de red" />
        <ActionEditButton data-edit-user-btn ariaLabel="Editar contacto" />
        <ActionInvGateButton
          data-invgate-copy-btn
          ariaLabel="Agregar a InvGate"
        />
      </div>
    </div>
  </div>
</template>
