---
import { Icon } from "astro-icon/components";

interface NavItem {
  href: string;
  label: string;
  icon: string;
}

const currentPath = Astro.url.pathname;

const navItems: NavItem[] = [
  { href: "/", label: "Home", icon: "heroicons:home" },
  {
    href: "/titulos-tickets",
    label: "Títulos de Tickets",
    icon: "heroicons:queue-list",
  },
  {
    href: "/documentacion",
    label: "Documentación",
    icon: "heroicons:document-text",
  },
  {
    href: "/guia-soportes",
    label: "Guía de Soportes",
    icon: "heroicons:lifebuoy",
  },
  {
    href: "/buscador-usuarios",
    label: "Buscador de Usuarios",
    icon: "heroicons:users",
  },
  {
    href: "/oficinas-telegrafia",
    label: "Oficinas Telegrafía",
    icon: "heroicons:building-office-2",
  },
  { href: "/cubics", label: "Cubics", icon: "heroicons:computer-desktop" },
  {
    href: "/configuracion",
    label: "Configuración",
    icon: "heroicons:cog-6-tooth",
  },
  {
    href: "/login",
    label: "Login",
    icon: "heroicons:arrow-right-on-rectangle",
  },
];

const isActiveRoute = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<aside class="w-64 shrink-0 border-r border-base-300 bg-secondary p-4">
  <nav
    aria-label="Navegación principal"
    class="menu w-full gap-1 rounded-box p-0"
  >
    {
      navItems.map((item) => {
        const isActive = isActiveRoute(item.href);

        return (
          <a
            href={item.href}
            class:list={[
              "flex items-center gap-3 rounded-box px-3 py-2 text-sm transition-colors",
              isActive
                ? "bg-primary text-primary-content"
                : "text-secondary-content hover:bg-secondary/70",
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            <Icon name={item.icon} class="size-5" aria-hidden="true" />
            <span>{item.label}</span>
          </a>
        );
      })
    }
  </nav>
</aside>
