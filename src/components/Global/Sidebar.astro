---
import { Icon } from "astro-icon/components";

interface NavItem {
  href: string;
  label: string;
  icon: string;
}

const currentPath = Astro.url.pathname;

const navItems: NavItem[] = [
  { href: "/", label: "Home", icon: "heroicons:home" },
  { href: "/titulos-tickets", label: "Títulos de Tickets", icon: "heroicons:queue-list"},
  { href: "/documentacion", label: "Documentación", icon: "heroicons:document-text"},
  { href: "/guia-soportes", label: "Guía de Soportes", icon: "heroicons:lifebuoy"},
  { href: "/buscador-usuarios", label: "Buscador de Usuarios", icon: "heroicons:users"},
  { href: "/oficinas-telegrafia", label: "Oficinas Telegrafía", icon: "heroicons:building-office-2"},
  { href: "/cubics", label: "Cubics", icon: "heroicons:computer-desktop"},
  { href: "/configuracion", label: "Configuración", icon: "heroicons:cog-6-tooth"},
  { href: "/login", label: "Login", icon: "heroicons:arrow-right-on-rectangle"},
];

const isActiveRoute = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<aside id="sidebar" class="h-screen w-64 bg-secondary flex flex-col transition-all duration-300">
  <!-- 🔝 HEADER -->
  <div class="flex items-center justify-between h-14 px-3 border-b border-neutral-200/20">
    <span class="font-semibold text-sm sidebar-label text-neutral-100">Portal MDA</span>
    
    <!-- Remplazar con componente botón en cuanto se añada la variable "ID" dentro del componente Button -->
    <button 
      id="sidebar-toggle"
      class="p-2 rounded-md text-neutral-100 hover:bg-black/5 transition cursor-pointer"
    >
      <Icon name="heroicons:bars-3" class="size-5" />
    </button>
  </div>

  <nav class="flex-1 p-2 space-y-1">
    <!-- Crear comoponente NavItem -->
    {
      navItems.map((item) => {
        const isActive = isActiveRoute(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              "group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-all",
              isActive
                ? "bg-primary text-neutral-800"
                : "text-neutral-100/80 hover:bg-black/5",
            ]}
          >
            <Icon
              name={item.icon}
              class="size-5 shrink-0 opacity-80 group-hover:opacity-100"
            />
            <span class="sidebar-label truncate">{item.label}</span>
          </a>
        );
      })
    }
  </nav>
</aside>


<script is:inline>
  const sidebar = document.getElementById("sidebar");
  const toggleBtn = document.getElementById("sidebar-toggle");

  const STORAGE_KEY = "sidebar-collapsed";

  const isCollapsed = localStorage.getItem(STORAGE_KEY) === "true";

  if (isCollapsed) {
    sidebar.classList.add("collapsed");
  }

  toggleBtn?.addEventListener("click", () => {
    sidebar.classList.toggle("collapsed");

    const collapsed = sidebar.classList.contains("collapsed");

    localStorage.setItem(STORAGE_KEY, collapsed);
  });
</script>

<style>
  .collapsed {
    width: 4rem; /* w-16 */
  }
  .collapsed .sidebar-label {
    display: none;
  }
  .collapsed a {
    justify-content: center;
  }
  .collapsed #sidebar-toggle {
    margin-left: auto;
  }
</style>