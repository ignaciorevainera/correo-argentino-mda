---
// RulesSettingsModal.astro
---

<!-- Rules Settings Modal -->
<dialog id="rules-settings-modal" class="modal modal-bottom sm:modal-middle z-[200]">
  <div class="modal-box max-w-3xl w-11/12 bg-base-100 border border-base-300 shadow-2xl">
    <h3 class="font-black text-lg mb-4 text-base-content">Parámetros del Cronograma</h3>
    
    <div class="space-y-6">
      <div class="form-control">
        <label class="label">
          <span class="label-text font-bold">Cobertura Presencial Mínima (%)</span>
          <span class="label-text-alt font-black text-secondary" id="min-coverage-val">40%</span>
        </label>
        <input type="range" id="min-coverage-input" min="0" max="100" value="40" class="range range-secondary range-xs" />
        <label class="label">
          <span class="label-text-alt text-base-content/50">Si la presencialidad cae por debajo de este valor, el día se marcará en rojo.</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label">
          <span class="label-text font-bold">Límite HO Consecutivos</span>
        </label>
        <input type="number" id="max-ho-input" value="5" min="1" max="10" class="input input-bordered input-sm font-bold w-32 focus:outline-none focus:border-secondary" />
        <label class="label">
          <span class="label-text-alt text-base-content/50">Máximo de días seguidos de Home Office permitidos antes de generar alerta.</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label">
          <span class="label-text font-bold">Días Presenciales Mínimos (Por Semana)</span>
        </label>
        <input type="number" id="min-p-week-input" value="2" min="0" max="7" class="input input-bordered input-sm font-bold w-32 focus:outline-none focus:border-secondary" />
        <label class="label">
          <span class="label-text-alt text-base-content/50">Si el operador asiste menos de esta cantidad a la oficina en 7 días, se marcará la alerta en su fila.</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label">
          <span class="label-text font-bold">Límite de Solapamiento de Licencias</span>
        </label>
        <input type="number" id="max-license-overlap-input" value="2" min="1" max="10" class="input input-bordered input-sm font-bold w-32 focus:outline-none focus:border-secondary" />
        <label class="label">
          <span class="label-text-alt text-base-content/50">Número máximo de operadores permitidos de Licencia/Vacaciones el mismo día antes de marcar alerta.</span>
        </label>
      </div>
    </div>
    
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-sm btn-ghost hover:bg-base-200">Cancelar</button>
        <button class="btn btn-sm btn-secondary ml-2" id="save-rules-btn" type="button">Guardar Reglas</button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
