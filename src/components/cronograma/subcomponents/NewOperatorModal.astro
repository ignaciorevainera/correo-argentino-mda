---
// NewOperatorModal.astro
import { Icon } from "astro-icon/components";
---

<dialog id="new-operator-modal" class="modal modal-bottom sm:modal-middle z-[200]">
  <div class="modal-box max-w-md bg-base-100 border border-base-300 shadow-2xl rounded-3xl">
    <h3 class="font-black text-lg mb-4 text-base-content uppercase tracking-tight flex items-center gap-2">
      <Icon name="boxicons:user-plus" class="text-secondary" size={22} />
      Agregar Nuevo Operador
    </h3>
    
    <div class="space-y-4">
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-bold text-xs uppercase text-base-content/60">Nombre Completo</span>
        </label>
        <input 
          type="text" 
          id="new-op-name" 
          placeholder="Ej: Juan Pérez"
          class="input input-bordered input-sm font-bold w-full focus:outline-none focus:border-secondary bg-base-100" 
        />
      </div>

      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-bold text-xs uppercase text-base-content/60">Nombre de Usuario (Red)</span>
        </label>
        <input 
          type="text" 
          id="new-op-username" 
          placeholder="Ej: jperez"
          class="input input-bordered input-sm font-mono font-bold w-full focus:outline-none focus:border-secondary bg-base-100" 
        />
      </div>

      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-bold text-xs uppercase text-base-content/60">Sede Principal</span>
        </label>
        <select id="new-op-location" class="select select-bordered select-sm font-bold w-full focus:outline-none focus:border-secondary bg-base-100">
          <option value="Monte Grande">Monte Grande</option>
          <option value="Parque Patricios">Parque Patricios</option>
        </select>
      </div>

      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-bold text-xs uppercase text-base-content/60">Turno Base Planificado</span>
        </label>
        <input 
          type="text" 
          id="new-op-schedule" 
          placeholder="Ej: 08:00 - 17:00"
          value="08:00 - 17:00"
          class="input input-bordered input-sm font-mono font-bold w-full focus:outline-none focus:border-secondary bg-base-100" 
        />
      </div>
    </div>
    
    <div class="modal-action mt-6 flex justify-end gap-2">
      <form method="dialog" class="flex gap-2">
        <button class="btn btn-sm btn-ghost hover:bg-base-200 text-xs font-black uppercase" id="cancel-new-op" type="button">Cancelar</button>
        <button class="btn btn-sm btn-secondary text-xs font-black uppercase" id="confirm-new-op" type="button">Agregar Operador</button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
