---
// MonthlyTableSkeleton.astro
export interface Props {
  part: "thead" | "tbody";
}
const { part } = Astro.props;

// Determine dates for current month to generate matching column count
const today = new Date();
const year = today.getFullYear();
const month = today.getMonth(); // 0-indexed
const daysInMonth = new Date(year, month + 1, 0).getDate();
const datesArray = Array.from({ length: daysInMonth });
---

{
  part === "thead" ? (
    <tr>
      <th class="sticky top-0 left-0 bg-base-100 z-50 w-[200px] min-w-[200px] border-r border-b border-base-200 px-6 py-4 font-black text-xs uppercase tracking-widest text-base-content/50">Operador</th>
      <th class="sticky top-0 left-[200px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center" title="Presencial">P</th>
      <th class="sticky top-0 left-[240px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center" title="Home Office">HO</th>
      <th class="sticky top-0 left-[280px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]" title="Licencia/Vacaciones">L</th>
      {datesArray.map((_, i) => {
        const d = new Date(year, month, i + 1);
        const day = d.getDay();
        const isWeekend = day === 0 || day === 6;
        return (
          <th class={`sticky top-0 z-40 text-center min-w-16 px-0 border-r border-b border-base-200 p-0 ${isWeekend ? 'bg-base-200/50' : 'bg-base-100 text-base-content/70'}`}>
            <div class="w-full h-full flex flex-col items-center justify-center py-2 gap-1.5 select-none">
              <div class="h-2.5 w-6 skeleton rounded opacity-40"></div>
              <div class="h-3.5 w-4 skeleton rounded opacity-60"></div>
            </div>
          </th>
        );
      })}
    </tr>
  ) : (
    Array.from({ length: 6 }).map((_, rowIndex) => (
      <tr class="group border-b border-base-200/50 last:border-0">
        <td class="sticky left-0 bg-base-100 z-40 w-[200px] min-w-[200px] font-bold py-3 px-6 text-xs border-r border-b border-base-200/70">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-base-200 skeleton"></span>
            <div class="flex flex-col gap-1.5 flex-1 min-w-0">
              <div class="h-3 w-28 skeleton rounded"></div>
            </div>
          </div>
        </td>
        <td class="sticky left-[200px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center border-r border-b border-base-200/70 text-secondary">
          <div class="h-3 w-4 mx-auto skeleton rounded opacity-40"></div>
        </td>
        <td class="sticky left-[240px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center border-r border-b border-base-200/70 text-amber-600 dark:text-amber-400">
          <div class="h-3 w-4 mx-auto skeleton rounded opacity-40"></div>
        </td>
        <td class="sticky left-[280px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center border-r border-b border-base-200/70 text-error shadow-[4px_0_10px_-5px_rgba(0,0,0,0.05)]">
          <div class="h-3 w-4 mx-auto skeleton rounded opacity-40"></div>
        </td>
        {datesArray.map((_, i) => {
          const d = new Date(year, month, i + 1);
          const day = d.getDay();
          const isWeekend = day === 0 || day === 6;
          return (
            <td class={`p-1 border-r border-b border-base-200/60 ${isWeekend ? 'bg-base-200/30' : 'bg-base-50/5 dark:bg-base-200/2'}`}>
              <div class="h-6 w-full skeleton rounded-md opacity-25"></div>
            </td>
          );
        })}
      </tr>
    ))
  )
}
