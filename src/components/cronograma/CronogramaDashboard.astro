      if (!activeDetailTrigger || !detailEntradaInput || !detailSalidaInput) return;

      if (realTimeIndicator) {
        realTimeIndicator.innerText = "Guardando...";
        realTimeIndicator.classList.remove('text-success/70', 'text-error', 'opacity-0');
        realTimeIndicator.classList.add('text-warning/70', 'opacity-100');
      }

      const opName = activeDetailTrigger.dataset.operator;
      const dateVal = activeDetailTrigger.dataset.date;
      const entradaVal = detailEntradaInput.value;
      const salidaVal = detailSalidaInput.value;

      try {
        if (!opName || !dateVal) return;

        const res = await fetch('/api/cronograma', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            edits: [
              {
                agentName: opName,
                date: dateVal,
                entradaReal: entradaVal,
                salidaReal: salidaVal
              }
            ]
          })
        });

        if (!res.ok) throw new Error("Error saving real times");

        // Update local cronoData state
        const op = cronoData.find(o => o.nombre === opName);
        if (op) {
          if (!op.entradas_reales) op.entradas_reales = {};
          if (!op.salidas_reales) op.salidas_reales = {};
          op.entradas_reales[dateVal] = entradaVal;
          op.salidas_reales[dateVal] = salidaVal;
        }

        // Re-render monthly matrix to apply all colors and totals
        renderMonthly();

        // Restore trigger references after re-render (since the DOM elements were recreated)
        const newTrigger = document.querySelector(`[data-operator="${opName.replace(/"/g, '\\"')}"][data-date="${dateVal}"]`) as HTMLElement | null;
        if (newTrigger) {
          activeDetailTrigger = newTrigger;
        }

        if (realTimeIndicator) {
          realTimeIndicator.innerText = "Guardado";
          realTimeIndicator.classList.remove('text-warning/70');
          realTimeIndicator.classList.add('text-success/70');
          setTimeout(() => {
            if (realTimeIndicator.innerText === "Guardado") {
              realTimeIndicator.classList.remove('opacity-100');
              realTimeIndicator.classList.add('opacity-0');
            }
          }, 1500);
        }
      } catch (err) {
        console.error("Error auto-saving real times:", err);
        if (realTimeIndicator) {
          realTimeIndicator.innerText = "Error";
          realTimeIndicator.classList.remove('text-warning/70', 'text-success/70');
          realTimeIndicator.classList.add('text-error');
        }
      }
    }

    function formatTimeInput(val: string): string {
      val = val.trim();
      if (!val) return '';
      // Support patterns like "0800" or "830"
      if (/^\d{3,4}$/.test(val)) {
        const pad = val.padStart(4, '0');
        const hh = parseInt(pad.slice(0, 2), 10);
        const mm = parseInt(pad.slice(2, 4), 10);
        if (hh >= 0 && hh <= 23 && mm >= 0 && mm <= 59) {
          return `${hh.toString().padStart(2, '0')}:${mm.toString().padStart(2, '0')}`;
        }
      }
      // Support patterns like "8" -> "08:00"
      if (/^\d{1,2}$/.test(val)) {
        const num = parseInt(val, 10);
        if (num >= 0 && num <= 23) {
          return `${num.toString().padStart(2, '0')}:00`;
        }
      }
      // Support patterns like "8:30" or "08:30"
      const parts = val.split(':');
      if (parts.length === 2) {
        const hh = parseInt(parts[0], 10);
        const mm = parseInt(parts[1], 10);
        if (!isNaN(hh) && !isNaN(mm) && hh >= 0 && hh <= 23 && mm >= 0 && mm <= 59) {
          return `${hh.toString().padStart(2, '0')}:${mm.toString().padStart(2, '0')}`;
        }
      }
      return '';
    }

