      e.preventDefault();
      const year = parseInt((document.getElementById('new-month-year') as HTMLInputElement).value);
      const month = parseInt((document.getElementById('new-month-month') as HTMLSelectElement).value);
      
      const newMonthStr = `${year}-${(month + 1).toString().padStart(2, '0')}`;
      const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
      const uniqueMonths = [...new Set(allDates.map(d => d.slice(0, 7)))];
      
      if (uniqueMonths.includes(newMonthStr)) {
        alert("El mes seleccionado ya existe en los registros. No se puede volver a crear para evitar pérdida de datos.");
        return;
      }

      const res = await fetch('/api/cronograma/months', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ year, month })
      });
      if (res.ok) {
        modal.close();
        const freshRes = await fetch('/api/cronograma');
        cronoData = await freshRes.json();
        const dateInput = document.getElementById('date-input') as HTMLInputElement;
        if (dateInput) {
          dateInput.value = `${year}-${(month + 1).toString().padStart(2, '0')}-01`;
          const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
          const uniqueDates = [...new Set(allDates)].sort();
          if (uniqueDates.length > 0) {
            dateInput.min = uniqueDates[0];
            dateInput.max = uniqueDates[uniqueDates.length - 1];
          }
          updateDateInputDisplay();
          updateMonthDisplay();
        }
        renderMonthDropdown();
        renderMonthly();
      }
