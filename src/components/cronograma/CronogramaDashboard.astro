              realTimeIndicator.classList.remove('opacity-100');
              realTimeIndicator.classList.add('opacity-0');
            }
          }, 1500);
        }
      } catch (err) {
        console.error("Error auto-saving real times:", err);
        if (realTimeIndicator) {
          realTimeIndicator.innerText = "Error";
          realTimeIndicator.classList.remove('text-warning/70', 'text-success/70');
          realTimeIndicator.classList.add('text-error');
        }
      }
