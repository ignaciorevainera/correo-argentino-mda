  function setupEventListeners() {
    const modal = document.getElementById('new-month-modal') as HTMLDialogElement & { showModal: () => void, close: () => void };
    document.getElementById('add-month-btn')?.addEventListener('click', () => {
      modal.showModal();
    });

    document.getElementById('cancel-new-month')?.addEventListener('click', () => {
      const yearInput = document.getElementById('new-month-year') as HTMLInputElement;
      const monthInput = document.getElementById('new-month-month') as HTMLSelectElement;
      if (yearInput) yearInput.value = '2026';
      if (monthInput) monthInput.value = '0';
      modal.close();
    });
    document.getElementById('confirm-new-month')?.addEventListener('click', async (e) => {
      e.preventDefault();
      const year = parseInt((document.getElementById('new-month-year') as HTMLInputElement).value);
      const month = parseInt((document.getElementById('new-month-month') as HTMLSelectElement).value);
      
      const newMonthStr = `${year}-${(month + 1).toString().padStart(2, '0')}`;
      const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
      const uniqueMonths = [...new Set(allDates.map(d => d.slice(0, 7)))];
      
      if (uniqueMonths.includes(newMonthStr)) {
        alert("El mes seleccionado ya existe en los registros. No se puede volver a crear para evitar pérdida de datos.");
        return;
      }

      const res = await fetch('/api/cronograma/months', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ year, month })
      });
      if (res.ok) {
        modal.close();
        const freshRes = await fetch('/api/cronograma');
        cronoData = await freshRes.json();
        const dateInput = document.getElementById('date-input') as HTMLInputElement;
        if (dateInput) {
          dateInput.value = `${year}-${(month + 1).toString().padStart(2, '0')}-01`;
          const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
          const uniqueDates = [...new Set(allDates)].sort();
          if (uniqueDates.length > 0) {
            dateInput.min = uniqueDates[0];
            dateInput.max = uniqueDates[uniqueDates.length - 1];
          }
          updateDateInputDisplay();
          updateMonthDisplay();
        }
        renderMonthDropdown();
        renderMonthly();
      }
    });
    document.getElementById('delete-month-btn')?.addEventListener('click', async () => {
      const dateInput = document.getElementById('date-input') as HTMLInputElement;
      if (!dateInput || !dateInput.value) return;

      const [yearStr, monthStr] = dateInput.value.split('-');
      const year = parseInt(yearStr);
      const month = parseInt(monthStr) - 1; // 0-indexed month

      const formatter = new Intl.DateTimeFormat('es-AR', { month: 'long', year: 'numeric' });
      const monthName = formatter.format(new Date(year, month, 15)).toUpperCase();

      if (!confirm(`¿Estás seguro de que deseas eliminar el mes de ${monthName}? Esta acción borrará permanentemente todos los registros de asistencia y comentarios para este periodo y no se puede deshacer.`)) {
        return;
      }

      const deleteBtn = document.getElementById('delete-month-btn') as HTMLButtonElement | null;
      const originalText = deleteBtn ? deleteBtn.innerHTML : '';
      if (deleteBtn) {
        deleteBtn.disabled = true;
        deleteBtn.innerHTML = `<span class="loading loading-spinner loading-xs"></span> Borrando...`;
      }

      try {
        const res = await fetch('/api/cronograma/months', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ year, month })
        });

        if (res.ok) {
          // Re-fetch data
          const freshRes = await fetch('/api/cronograma');
          cronoData = await freshRes.json();

          const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
          const uniqueDates = [...new Set(allDates)].sort();

          if (uniqueDates.length > 0) {
            // Find closest month or fallback to latest
            const targetDate = uniqueDates[uniqueDates.length - 1];
            dateInput.value = targetDate;
            dateInput.min = uniqueDates[0];
            dateInput.max = targetDate;
          } else {
            // No data left
            const todayStr = formatYMD(new Date());
            dateInput.value = todayStr;
            dateInput.removeAttribute('min');
            dateInput.removeAttribute('max');
          }

          updateDateInputDisplay();
          updateMonthDisplay();
          renderMonthDropdown();
          renderDaily();
          renderMonthly();
          alert(`El mes de ${monthName} ha sido eliminado correctamente.`);
        } else {
          alert('Error al intentar eliminar el mes.');
        }
      } catch (err) {
        console.error("Error deleting month:", err);
        alert('Ocurrió un error al intentar eliminar el mes.');
      } finally {
        if (deleteBtn) {
          deleteBtn.disabled = false;
          deleteBtn.innerHTML = originalText;
        }
      }
    });

    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    if (dateInput) {
      dateInput.addEventListener('change', () => {
        updateDateInputDisplay();
        renderDaily();
        renderMonthly(); 
      });
    }

    const monthlyBody = document.getElementById('monthly-tbody');
    const monthlyThead = document.getElementById('monthly-thead');
    const detailOverlay = document.getElementById('monthly-detail-overlay');
    const detailClose = document.getElementById('monthly-detail-close');
    const backToMonthlyBtn = document.getElementById('back-to-monthly-btn');

    // (Legacy) Click on specific day inside Monthly Matrix header was removed to favor inline Hourly View
    // Go back to full month view from daily view
    backToMonthlyBtn?.addEventListener('click', () => {
      showMonthlyView();
    });

    // Month Navigator Buttons
    document.getElementById('prev-month-btn')?.addEventListener('click', () => {
      changeMonth(-1);
    });

    document.getElementById('next-month-btn')?.addEventListener('click', () => {
      changeMonth(1);
    });

    // Minimize Coverage Summary Footer
    document.getElementById('monthly-tfoot')?.addEventListener('click', (event) => {
      const btn = (event.target as HTMLElement).closest<HTMLButtonElement>('#toggle-coverage-btn');
      if (!btn) return;
      isCoverageMinimized = !isCoverageMinimized;
