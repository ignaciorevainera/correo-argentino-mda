    async function saveDetailRealTimes() {
      if (!activeDetailTrigger || !detailEntradaInput || !detailSalidaInput) return;

      if (realTimeIndicator) {
        realTimeIndicator.innerText = "Guardando...";
        realTimeIndicator.classList.remove('text-success/70', 'text-error', 'opacity-0');
