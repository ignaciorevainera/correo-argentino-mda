  function isWorkingAtHour(horario: string, hourStr: string) {
    if (!horario || horario === '-' || horario === 'Franco') return false;
    const parts = horario.split(' - ');
    if (parts.length !== 2) return false;
    const start = parts[0];
    const end = parts[1];

    const hS = parseInt(start.split(':')[0]);
    const hE = parseInt(end.split(':')[0]);
    const hC = parseInt(hourStr.split(':')[0]);

    if (hS <= hE) {
       return hC >= hS && hC < hE;
    } else {
       return hC >= hS || hC < hE;
    }
  }

