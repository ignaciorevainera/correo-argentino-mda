        const btn = e.currentTarget as HTMLButtonElement;
        
        // Consolida todos los cambios: pendingEdits (pincel) y modifiedSchedules (quick edits)
        const mergedEditsMap = new Map<string, { agentName: string, date: string, status: string }>();
        
        // Primero agregamos los cambios de Quick Edit
        modifiedSchedules.forEach(m => {
           mergedEditsMap.set(`${m.agentName}_${m.date}`, { agentName: m.agentName, date: m.date, status: m.status });
        });
        
        // Luego los de Modo Editar (pincel), que sobrescriben si hay duplicados
        Object.values(pendingEdits).forEach(p => {
           mergedEditsMap.set(`${p.agentName}_${p.date}`, { agentName: p.agentName, date: p.date, status: p.status });
        });
        
        const editsToSave = Array.from(mergedEditsMap.values());
        
        if (editsToSave.length === 0) return;
        
        btn.disabled = true;
        btn.innerHTML = `<span class="loading loading-spinner loading-xs"></span>`;
        
        try {
          const res = await fetch('/api/cronograma', {
             method: 'POST',
             headers: { 'Content-Type': 'application/json' },
             body: JSON.stringify({ edits: editsToSave })
          });
          if (!res.ok) throw new Error("Error saving bulk edits");
          
          pendingEdits = {};
          modifiedSchedules = []; // Limpieza absoluta de quick edits
          updatePendingEditsUI();
          
          // Ocultar indicador flotante definitivamente
          const saveIndicator = document.getElementById('save-indicator');
          if (saveIndicator) saveIndicator.classList.add('hidden');
          
          btn.innerText = "Guardado!";
          setTimeout(() => { btn.innerText = "Guardar"; }, 2000);
        } catch (err) {
