---
// CronogramaDashboard.astro
import { Icon } from "astro-icon/components";
import ActionButton from "@components/ui/ActionButton.astro";
import FilterButtonBar from "@components/ui/FilterButtonBar.astro";
import SortDropdown from "@components/ui/SortDropdown.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import MonthSelect from "@components/ui/MonthSelect.astro";

import OperatorDrawer from "./subcomponents/OperatorDrawer.astro";
import MonthlyDetailModal from "./subcomponents/MonthlyDetailModal.astro";
import RulesSettingsModal from "./subcomponents/RulesSettingsModal.astro";
import NewMonthModal from "./subcomponents/NewMonthModal.astro";
import OperatorFormModal from "./subcomponents/OperatorFormModal.astro";
import HolidaysModal from "./subcomponents/HolidaysModal.astro";
import GroupCard from "./subcomponents/GroupCard.astro";


interface Props {
  userRole?: string;
}

const { userRole = "agent" } = Astro.props;
---

<div id="cronograma-app-container" data-user-role={userRole} class="flex-1 flex flex-col min-h-0 w-full">
  <div
    id="cronograma-container"
    class="animate-in fade-in duration-700 w-full flex-1 flex flex-col min-h-0 pb-2"
  >
    <div class="w-full flex-1 flex flex-col min-h-0 gap-4">
      <div
        class="flex flex-col md:flex-row md:items-center justify-between gap-4"
      >
        <div
          id="view-switcher"
          class="flex flex-wrap items-center gap-3 shrink-0"
        >
          <!-- Vistas de Calendario -->
          <div
            class="flex bg-base-200/60 p-1 rounded-xl border border-base-300 shadow-sm shrink-0"
          >
            <button
              type="button"
              id="switch-to-monthly-btn"
              class="btn btn-xs btn-secondary font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg shadow-sm shadow-secondary/15 transition-all duration-200"
            >
              Mensual
            </button>
            <button
              type="button"
              id="switch-to-daily-btn"
              class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
            >
              Diario
            </button>
          </div>

          <!-- Vistas de Configuración y Turnos -->
          <div
            class="flex bg-base-200/60 p-1 rounded-xl border border-base-300 shadow-sm shrink-0"
          >
            <button
              type="button"
              id="switch-to-groups-btn"
              class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
            >
              Grupos
            </button>
            <button
              type="button"
              id="switch-to-overtime-btn"
              class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
            >
              Extras
            </button>
            <button
              type="button"
              id="switch-to-pasiva-btn"
              class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
            >
              Pasivas
            </button>
          </div>
        </div>

        <!-- Date Picker (hidden by default) -->
        <div
          id="date-picker-container"
          class="relative min-w-40 items-center gap-2.5 bg-base-100 px-4 py-2.5 rounded-xl border border-base-300 shadow-sm hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20 hidden is-faded"
        >
          <Icon
            name="boxicons:calendar"
            size={18}
            class="text-base-content/40"
          />
          <label for="date-input" class="sr-only">Seleccionar fecha</label>
          <span
            id="date-input-display"
            class="text-sm font-semibold tabular-nums text-base-content pointer-events-none"
          >
          </span>
          <input
            type="date"
            id="date-input"
            class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 opacity-0"
          />
        </div>
      </div>

      <!-- Daily View Section (Hidden by default) -->
      <div
        id="daily-view"
        class="animate-in slide-in-from-bottom-2 fade-in duration-500 hidden flex-1 min-h-0"
      >
        <div
          class="bg-base-100 rounded-2xl border border-base-300 shadow-md h-full flex flex-col overflow-hidden"
        >
          <div class="relative z-60 bg-base-200 border-b border-base-300">
            <div
              class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 py-3.5 px-6"
            >
              <!-- Left: Title -->
              <div class="flex items-center gap-3 shrink-0 flex-wrap">
                <h3
                  class="text-sm flex items-center gap-2.5 font-bold uppercase tracking-wide text-base-content select-none"
                >
                  <Icon name="boxicons:group" size={18} />
                  Estado de operadores
                </h3>
              </div>

              <!-- Center: Search & Sort inputs -->
              <div class="flex-1 max-w-md w-full mx-0 lg:mx-4 flex gap-2">
                <SearchBar id="daily-search" />
                <SortDropdown id="daily-sort" current="alphabetical" />
              </div>

              <!-- Right: Date Display & Maximize button -->
              <div
                class="flex flex-wrap items-center gap-2.5 justify-start lg:justify-end shrink-0"
              >
                <div
                  class="flex items-center gap-2 bg-base-100 px-3.5 py-1 rounded-lg border border-base-300 shadow-sm text-base-content/75 h-7"
                >
                  <Icon
                    name="boxicons:calendar-check"
                    size={16}
                    class="text-secondary"
                  />
                  <span
                    class="text-xs font-semibold tabular-nums"
                    id="daily-date-display"></span>
                </div>

                <!-- Maximize Button Removed -->
              </div>
            </div>
          </div>
          <div class="p-3 flex-1 min-h-0 flex flex-col">
            <div
              class="overflow-x-auto flex-1 min-h-0 overflow-y-auto scrollbar-thin rounded-xl border border-base-200 bg-base-100"
            >
              <!-- Simplified container skeleton -- removed by renderDaily() on first call -->
              <div id="daily-view-skeleton" class="skeleton-debounced flex flex-col gap-2 p-4">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 skeleton rounded-full shrink-0"></div>
                  <div class="flex flex-col gap-1.5 flex-1">
                    <div class="h-3.5 w-28 skeleton rounded"></div>
                    <div class="h-2.5 w-16 skeleton rounded opacity-60"></div>
                  </div>
                </div>
                <div class="flex items-center gap-3 opacity-70">
                  <div class="h-10 w-10 skeleton rounded-full shrink-0"></div>
                  <div class="flex flex-col gap-1.5 flex-1">
                    <div class="h-3.5 w-32 skeleton rounded"></div>
                    <div class="h-2.5 w-20 skeleton rounded opacity-60"></div>
                  </div>
                </div>
                <div class="flex items-center gap-3 opacity-50">
                  <div class="h-10 w-10 skeleton rounded-full shrink-0"></div>
                  <div class="flex flex-col gap-1.5 flex-1">
                    <div class="h-3.5 w-28 skeleton rounded"></div>
                    <div class="h-2.5 w-18 skeleton rounded opacity-60"></div>
                  </div>
                </div>
                <div class="flex items-center gap-3 opacity-70">
                  <div class="h-10 w-10 skeleton rounded-full shrink-0"></div>
                  <div class="flex flex-col gap-1.5 flex-1">
                    <div class="h-3.5 w-32 skeleton rounded"></div>
                    <div class="h-2.5 w-16 skeleton rounded opacity-60"></div>
                  </div>
                </div>
                <div class="flex items-center gap-3 opacity-50">
                  <div class="h-10 w-10 skeleton rounded-full shrink-0"></div>
                  <div class="flex flex-col gap-1.5 flex-1">
                    <div class="h-3.5 w-28 skeleton rounded"></div>
                    <div class="h-2.5 w-20 skeleton rounded opacity-60"></div>
                  </div>
                </div>
              </div>
              <table
                class="w-full text-sm text-left border-separate border-spacing-0"
              >
                <thead
                  class="sticky top-0 z-50 bg-base-100/98 backdrop-blur-sm shadow-sm text-xs uppercase font-bold text-base-content/50 tracking-widest border-b border-base-300"
                >
                  <tr>
                    <th
                      class="sticky left-0 bg-base-100 z-50 w-64 min-w-[16rem] py-3 px-6 border-r border-b border-base-200/70"
                      >Operador</th
                    >
                    <th
                      class="sticky left-64 bg-base-100 z-50 w-44 min-w-44 py-3 px-4 border-r border-b border-base-200/70 shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]"
                      >Modalidad</th
                    >
                    <th class="py-3 px-6 border-b border-base-200/70">
                      <div
                        class="flex justify-between w-full text-xxs font-black text-base-content/40 px-2 select-none"
                      >
                        <span>00:00</span>
                        <span>02:00</span>
                        <span>04:00</span>
                        <span>06:00</span>
                        <span>08:00</span>
                        <span>10:00</span>
                        <span>12:00</span>
                        <span>14:00</span>
                        <span>16:00</span>
                        <span>18:00</span>
                        <span>20:00</span>
                        <span>22:00</span>
                        <span>24:00</span>
                      </div>
                    </th>
                  </tr>
                </thead>
                <tbody
                  id="operators-table-body"
                  class="divide-y divide-base-200 bg-base-100"
                >
                </tbody>
              </table>
            </div>
          </div>
          <!-- Daily View Footer / Status Filters -->
          <div
            class="bg-base-200/40 border-t border-base-300 px-6 py-3 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 no-print"
          >
            <div class="flex flex-wrap items-center gap-4">
              <!-- Status Filters -->
              <FilterButtonBar
                id="filter-daily-status"
                options={[
                  { value: "Presencial Monte Grande", label: "Presencial MG", color: "primary", dotColor: "bg-amber-500" },
                  { value: "Presencial Parque Patricios", label: "Presencial PP", color: "primary", dotColor: "bg-purple-500" },
                  { value: "Home Office", label: "HO", color: "secondary", dotColor: "bg-secondary" },
                  { value: "Licencia", label: "Licencia", color: "error", dotColor: "bg-error" },
                  { value: "Vacaciones", label: "Vacaciones", color: "success", dotColor: "bg-success" },
                ]}
                prefix="Estado:"
                allLabel="Todos"
                attribute="data-filter"
                showDots
              />

              <!-- Location Filters -->
              <FilterButtonBar
                id="filter-daily-location"
                options={[
                  { value: "Monte Grande", label: "Monte Grande" },
                  { value: "Parque Patricios", label: "Parque Patricios" },
                ]}
                prefix="Sede:"
                allLabel="Todas"
                attribute="data-location"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Monthly View Section (Shown by default) -->
      <div
        id="monthly-view"
        class="animate-in slide-in-from-bottom-2 fade-in duration-500 flex-1 min-h-0"
      >
        <div
          class="bg-base-100 rounded-2xl border border-base-300 shadow-md h-full flex flex-col overflow-hidden"
        >
          <div class="relative z-60 bg-base-200 border-b border-base-300">
            <div
              class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 py-3.5 px-6"
            >
              <!-- Left: Title, Navigation & Maximize button -->
              <div class="flex items-center gap-3 shrink-0 flex-wrap">
                <!-- Month Navigator -->
                <div class="flex items-center gap-1 ml-2">
                  <button
                    type="button"
                    id="prev-month-btn"
                    class="btn btn-xs btn-ghost p-1"
                    title="Mes anterior"
                    aria-label="Mes anterior"
                  >
                    <Icon name="boxicons:chevron-left" size={14} />
                  </button>
                  <MonthSelect id="month-selector" />
                  <button
                    type="button"
                    id="next-month-btn"
                    class="btn btn-xs btn-ghost p-1"
                    title="Mes siguiente"
                    aria-label="Mes siguiente"
                  >
                    <Icon name="boxicons:chevron-right" size={14} />
                  </button>
                </div>

                <!-- Agregar nuevo mes -->
                <ActionButton id="add-month-btn" icon="boxicons:calendar-plus" label="Agregar nuevo mes" title="Agregar nuevo mes" class="ml-2" />

                <!-- Borrar mes actual -->
                <ActionButton id="delete-month-btn" icon="boxicons:calendar-minus" label="Borrar mes actual" title="Borrar mes actual" color="btn-error" class="ml-2" />
              </div>

              <!-- Center: Search & Sort inputs -->
              <div class="flex-1 max-w-md w-full mx-0 lg:mx-4 flex gap-2">
                <SearchBar id="monthly-search" />
                <SortDropdown id="monthly-sort" current="alphabetical" />
              </div>

              <div
                class="flex flex-wrap items-center gap-2.5 justify-start lg:justify-end shrink-0"
              >
                <!-- Edit Mode Button -->
                <ActionButton id="toggle-edit-mode-btn" icon="boxicons:edit-alt" label="Editar" labelId="edit-mode-text" title="Modo Edición" />

                <!-- Maximize Button Removed -->
              </div>
            </div>
          </div>
          <div class="p-3 flex-1 min-h-0 flex flex-col">
            <div
              class="overflow-x-auto flex-1 min-h-0 overflow-y-auto scrollbar-thin rounded-xl border border-base-200 bg-base-100"
            >
              <!-- Simplified container skeleton -- removed by renderMonthly() on first call -->
              <div id="monthly-view-skeleton" class="skeleton-debounced flex flex-col gap-2 p-4">
                <div class="h-8 w-full skeleton rounded-lg"></div>
                <div class="h-12 w-full skeleton rounded-lg opacity-70"></div>
                <div class="h-12 w-full skeleton rounded-lg opacity-50"></div>
                <div class="h-12 w-full skeleton rounded-lg opacity-70"></div>
                <div class="h-12 w-full skeleton rounded-lg opacity-50"></div>
                <div class="h-12 w-full skeleton rounded-lg opacity-70"></div>
                <div class="h-12 w-full skeleton rounded-lg opacity-50"></div>
              </div>
              <table
                class="w-full text-sm text-left border-separate border-spacing-0"
                id="monthly-table"
              >
                <thead class="bg-base-100" id="monthly-thead">
                </thead>
                <tbody id="monthly-tbody">
                </tbody>
                <tfoot
                  id="monthly-tfoot"
                  class="sticky bottom-0 z-40 bg-base-100/95 backdrop-blur-md border-t-2 border-base-300"
                >
                  <!-- Coverage stats injected here -->
                </tfoot>
              </table>
            </div>
          </div>
          <div
            class="bg-base-200/40 border-t border-base-300 px-6 py-3 flex flex-col xl:flex-row justify-between items-stretch xl:items-center gap-4 no-print"
          >
            <div class="flex flex-wrap items-center gap-4">
              <!-- Status Filters Container -->
              <FilterButtonBar
                id="filter-monthly-status"
                options={[
                  { value: "Presencial Monte Grande", label: "Presencial MG", color: "primary", dotColor: "bg-amber-500" },
                  { value: "Presencial Parque Patricios", label: "Presencial PP", color: "primary", dotColor: "bg-purple-500" },
                  { value: "Home Office", label: "HO", color: "secondary", dotColor: "bg-secondary" },
                  { value: "Licencia", label: "Licencia", color: "error", dotColor: "bg-error" },
                  { value: "Vacaciones", label: "Vacaciones", color: "success", dotColor: "bg-success" },
                ]}
                prefix="Estado:"
                allLabel="Todos"
                attribute="data-filter"
                showDots
              />

              <!-- Location Filters Container -->
              <FilterButtonBar
                id="filter-monthly-location"
                options={[
                  { value: "Monte Grande", label: "Monte Grande" },
                  { value: "Parque Patricios", label: "Parque Patricios" },
                ]}
                prefix="Sede:"
                allLabel="Todas"
                attribute="data-location"
              />
            </div>
            <div
              class="flex flex-wrap gap-2 justify-start xl:justify-end shrink-0"
            >
              <div class="relative">
                <input
                  type="file"
                  id="import-csv-input"
                  accept=".csv"
                  class="hidden"
                />
                <ActionButton id="import-csv-btn" icon="boxicons:folder-up-arrow" label="Importar CSV" />
              </div>
              <ActionButton id="export-csv-btn" icon="boxicons:file" label="Exportar CSV" />
              <ActionButton id="export-image-btn" icon="boxicons:image" label="Exportar Imagen (PNG)" color="btn-primary" />
            </div>
          </div>
        </div>
      </div>

      <div
        id="groups-view"
        class="animate-in slide-in-from-bottom-2 fade-in duration-500 hidden"
      >
        <div
          class="bg-base-100 rounded-2xl border border-base-300 shadow-md p-6 space-y-6"
        >
          <div
            class="flex items-center justify-between border-b border-base-300 pb-3"
          >
            <div>
              <h2
                class="text-base font-black text-base-content uppercase tracking-wide"
              >
                Configuración de Grupos
              </h2>
              <p class="text-xs text-base-content/50">
                Establece la rotación y horarios de sábados aplicados únicamente
                al mes seleccionado.
              </p>
            </div>
            <MonthSelect id="groups-month-selector" class="shrink-0" />
          </div>
          <!-- Configuration form -->
          <div
            id="rotation-config-card"
            class="flex flex-col lg:flex-row lg:items-end justify-between gap-4 p-4 bg-base-200/50 rounded-xl border border-base-300/60 shadow-sm"
          >
            <form
              id="rotation-config-form"
              class="w-full flex flex-col md:flex-row md:items-end gap-4"
            >
              <div class="flex flex-col gap-1.5 shrink-0">
                <label
                  class="label-xxs text-base-content/40"
                  >Fecha de Inicio (Sábado)</label
                >
                <div
                  id="rotation-start-date-wrapper"
                  class="relative flex h-8 min-w-36 items-center gap-2 bg-base-100 px-3 py-1.5 rounded-lg border border-base-300 shadow-sm hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20 cursor-pointer"
                >
                  <Icon
                    name="boxicons:calendar"
                    size={14}
                    class="text-base-content/40 pointer-events-none"
                  />
                  <span
                    id="rotation-start-date-display"
                    class="text-xs font-semibold tabular-nums text-base-content pointer-events-none"
                    >dd/mm/yy</span
                  >
                  <input
                    type="date"
                    id="rotation-start-date"
                    class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 opacity-0"
                    required
                  />
                </div>
              </div>
              <div class="flex flex-col gap-1.5 shrink-0">
                <label
                  class="label-xxs text-base-content/40"
                  >Grupo Inicial</label
                >
                <select
                  id="rotation-start-group"
                  class="select select-sm select-bordered font-bold cursor-pointer text-base-content"
                  required
                >
                  <option value="A">Grupo A</option>
                  <option value="B">Grupo B</option>
                  <option value="C">Grupo C</option>
                  <option value="D">Grupo D</option>
                </select>
              </div>
              <div class="flex flex-col gap-1.5 flex-1">
                <label
                  class="label-xxs text-base-content/40"
                  >Orden de Rotación (Ej: A,B,C,D o D,C,B,A)</label
                >
                <input
                  type="text"
                  id="rotation-order"
                  class="input input-sm input-bordered font-bold text-base-content"
                  placeholder="A,B,C,D"
                  required
                />
              </div>
              <button
                type="submit"
                id="save-rotation-config-btn"
                class="btn btn-sm btn-primary shrink-0 gap-1.5 uppercase font-bold text-xxs"
              >
                <Icon name="boxicons:save" size={14} />
                Guardar Configuración
              </button>
            </form>
          </div>

          <!-- Groups Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <GroupCard letter="A" color="success" />
            <GroupCard letter="B" color="error" />
            <GroupCard letter="C" color="warning" />
            <GroupCard letter="D" color="info" />
          </div>
        </div>

        <!-- Saturday Rotation Timeline Card -->
        <div
          id="saturday-rotation-card"
          class="bg-base-100 rounded-2xl border border-base-300 shadow-md p-6 space-y-6 mt-6"
        >
          <div
            class="flex flex-col md:flex-row md:items-center justify-between gap-4"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-8 h-8 rounded-xl bg-secondary/15 flex items-center justify-center"
              >
                <Icon
                  name="boxicons:calendar"
                  size={18}
                  class="text-secondary"
                />
              </div>
              <div>
                <h2
                  class="font-black text-sm uppercase tracking-wider text-base-content"
                >
                  Horarios de Guardia – Sábados 7 a 13
                </h2>
                <p class="text-small text-base-content/50">
                  Línea de tiempo de guardias del grupo activo
                </p>
              </div>
            </div>

            <!-- Saturday selector + Active group display -->
            <div class="flex flex-col sm:flex-row sm:items-center gap-4">
              <!-- New Copy to Clipboard Button -->
              <div class="flex flex-col gap-1 no-export">
                <span class="label-xxs text-base-content/40 select-none">&nbsp;</span>
                <button
                  type="button"
                  id="copy-rotation-image-btn"
                  class="btn btn-sm btn-outline btn-secondary gap-2 h-8 min-h-8 px-3 cursor-pointer"
                  title="Copiar tabla de guardia al portapapeles como imagen"
                >
                  <Icon name="boxicons:clipboard" size={14} />
                  <span>Copiar Tabla</span>
                </button>
              </div>

              <div class="flex flex-col gap-1">
                <label
                  class="label-xxs text-base-content/40"
                  >Sábado de Guardia</label
                >
                <div
                  id="rotation-timeline-date-wrapper"
                  class="relative flex h-8 min-w-44 items-center gap-2 bg-base-100 px-3 py-1.5 rounded-lg border border-base-300 shadow-sm hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20 cursor-pointer"
                >
                  <Icon
                    name="boxicons:calendar"
                    size={14}
                    class="text-base-content/40 pointer-events-none"
                  />
                  <span
                    id="rotation-timeline-date-display"
                    class="text-xs font-semibold tabular-nums text-base-content pointer-events-none"
                    >Seleccionar sábado...</span
                  >
                  <input
                    type="date"
                    id="rotation-timeline-date"
                    class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 opacity-0"
                  />
                </div>
              </div>

              <div class="flex flex-col gap-1">
                <label
                  class="label-xxs text-base-content/40"
                  >Grupo Activo</label
                >
                <div
                  class="flex h-8 items-center px-3 py-1.5 rounded-lg bg-secondary/10 border border-secondary/20 font-bold text-xs text-secondary shadow-sm select-none"
                  id="rotation-active-group-display"
                >
                  Grupo -
                </div>
              </div>
            </div>
          </div>

          <!-- Visual timeline grid -->
          <div class="space-y-2">
            <div
              id="rotation-timeline-wrapper"
              class="overflow-x-auto rounded-xl border border-base-300 bg-base-200/30"
            >
              <table
                class="table table-compact w-full min-w-[600px] border-collapse"
                id="rotation-timeline-table"
              >
                <thead>
                  <tr class="bg-base-200/60 border-b border-base-300">
                    <th
                      class="w-44 px-3 py-2 label-xxs text-base-content/40 border-r border-base-300 text-left"
                    >
                      Operador
                    </th>
                    <th
                      class="px-2 py-2 label-xxs text-base-content/40 border-r border-base-300 text-center w-24"
                      >7:00 hs</th
                    >
