<style is:global>
  #edit-mode-toolbar {
    scrollbar-width: none;
  }
  #edit-mode-toolbar::-webkit-scrollbar {
    display: none;
  }
  /* --- Maximize Mode Styles --- */
  html.cronograma-maximized nav,
  html.cronograma-maximized footer,
  html.cronograma-maximized [data-crono-hide-on-maximize] {
    display: none !important;
  }

  html.cronograma-maximized .mx-auto.max-w-6xl,
  html.cronograma-maximized .mx-auto.max-w-7xl {
    max-width: 98% !important;
    width: 98% !important;
    margin-top: 1.5rem !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }

  html.cronograma-maximized #cronograma-container {
    padding-bottom: 2rem !important;
  }

  #date-picker-container {
    display: flex;
    transition:
      opacity 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  #date-picker-container.hidden {
    display: none !important;
  }

  #date-picker-container.is-faded {
    opacity: 0;
  }

  /* Prevent browser native date input text, highlights, or selection fields from showing */
  #date-input {
    color-scheme: light dark;
  }

  #date-input::-webkit-datetime-edit,
  #date-input::-webkit-datetime-edit-fields-wrapper,
  #date-input::-webkit-datetime-edit-month-field,
  #date-input::-webkit-datetime-edit-day-field,
  #date-input::-webkit-datetime-edit-year-field {
    display: none !important;
    opacity: 0 !important;
    -webkit-appearance: none !important;
  }

  #date-input::-webkit-calendar-picker-indicator {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    opacity: 0 !important;
    cursor: pointer;
    -webkit-appearance: none !important;
  }

  @media print {
    @page {
      size: landscape;
      margin: 8mm;
    }

    /* Force background colors to print */
    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    /* Hide elements that shouldn't appear in the printout */
    .no-print,
    nav,
    footer,
    #view-switcher,
    #date-picker-container,
    #monthly-search,
    .btn,
    button,
    #monthly-detail-overlay,
    #edit-mode-toolbar,
    #pasiva-edit-toolbar,
    #save-indicator,
    .op-checkbox {
      display: none !important;
    }

    #cronograma-container {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    #monthly-view {
      display: block !important;
      width: 100% !important;
    }

    /* Unbound scroll containers for print flow */
    .overflow-x-auto,
    .overflow-y-auto,
    .max-h-\[580px\],
    .max-h-\[740px\] {
      max-height: none !important;
      overflow: visible !important;
      height: auto !important;
      width: 100% !important;
      border: none !important;
    }

    /* Reset sticky styles so everything flows normally in print grid */
    th.sticky,
    td.sticky {
      position: static !important;
      background-color: transparent !important;
      box-shadow: none !important;
      left: auto !important;
      right: auto !important;
      z-index: 1 !important;
    }

    /* Print table optimizations */
    table {
      width: 100% !important;
      border-collapse: collapse !important;
      table-layout: fixed !important;
    }

    /* Set default widths for operator and stats columns in printout */
    th:nth-child(1),
    td:nth-child(1) {
      width: 130px !important;
      min-width: 130px !important;
      max-width: 130px !important;
      font-size: 9px !important;
    }
    /* P, HO, L status columns */
    th:nth-child(2),
    td:nth-child(2),
    th:nth-child(3),
