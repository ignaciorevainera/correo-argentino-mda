<script>
  interface OperatorData {
    nombre: string;
    horario: string;
    asistencia: Record<string, string>;
    comentarios?: Record<string, string>;
  }

  const icons = {
    briefcase: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1"/><path d="M4 7h16v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z"/><path d="M4 12h16"/></svg></span>`,
    home: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10.5V20h14v-9.5"/><path d="M10 20v-5h4v5"/></svg></span>`,
    firstAid: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M10 4h4v4h4v4h-4v-4H6V8h4V4Z"/><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"/></svg></span>`,
    sun: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg></span>`,
    help: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.7 2.7 0 0 1 5.1 1.2c0 1.8-1.7 2.3-2.3 3.2"/><path d="M12 17h.01"/></svg></span>`,
    timer: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>`
  };

  let cronoData: OperatorData[] = [];
  let isCoverageMinimized = false;
  let modifiedSchedules: { agentName: string; date: string; status: string }[] = [];
  let searchQuery = '';
  let activeFilter = 'all'; // 'all', 'Presencial', 'Home Office', 'Licencia', 'Vacaciones'
  let activeDetailTrigger: HTMLElement | null = null;
  let focusedDateStr: string | null = null;

  function getDaysInMonth(year: number, month: number) {
    return new Date(year, month + 1, 0).getDate();
  }

  function formatYMD(date: Date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function formatDMY(dateStr: string) {
    const [year, month, day] = dateStr.split('-');
    return `${day}/${month}/${year.slice(-2)}`;
  }

  function formatDetailDate(dateStr: string) {
    return new Intl.DateTimeFormat('es-AR', {
      weekday: 'long',
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    }).format(new Date(dateStr + 'T12:00:00'));
  }

  function getDatesArrayForCurrentMonth() {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    if (!dateInput || !dateInput.value) return [];

    const [year, month] = dateInput.value.split('-').map(Number);
    const totalDays = getDaysInMonth(year, month - 1);
    const dates: string[] = [];
    for (let i = 1; i <= totalDays; i++) {
      const dStr = `${year}-${String(month).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      dates.push(dStr);
    }
    return dates;
  }

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getUsername(nombre: string) {
    const nameParts = nombre.toLowerCase().split(' ');
    return nameParts[0][0] + (nameParts[1] || '');
  }

  function updateDateInputDisplay() {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    const dateDisplay = document.getElementById('date-input-display');

    if (dateInput && dateDisplay && dateInput.value) {
      dateDisplay.innerText = formatDMY(dateInput.value);
    }
  }

  function isCurrentlyWorking(horario: string) {
    if (!horario || horario === '-') return { status: 'offline', text: 'Fuera de horario' };
    
    const now = new Date();
    const [start, end] = horario.split(' - ');
    if (!start || !end) return { status: 'offline', text: 'Sin horario' };

    const [hS, mS] = start.split(':').map(Number);
    const [hE, mE] = end.split(':').map(Number);

    const startTime = new Date(now);
    startTime.setHours(hS, mS, 0);
    
    const endTime = new Date(now);
    endTime.setHours(hE, mE, 0);

    if (now >= startTime && now <= endTime) {
      const shiftDuration = endTime.getTime() - startTime.getTime();
      const breakStart = new Date(startTime.getTime() + shiftDuration / 2 - 30 * 60000);
      const breakEnd = new Date(breakStart.getTime() + 60 * 60000);

      if (now >= breakStart && now <= breakEnd) {
        return { status: 'break', text: 'En descanso' };
      }
      return { status: 'online', text: 'En servicio' };
    }
    
    return { status: 'offline', text: 'Fuera de horario' };
  }

  function updateMonthDisplay() {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    const display = document.getElementById('current-month-display');
    if (!dateInput || !display) return;

    const [yearStr, monthStr] = dateInput.value.split('-');
    const year = parseInt(yearStr);
    const month = parseInt(monthStr) - 1;

    const dateObj = new Date(year, month, 15);
    const formatter = new Intl.DateTimeFormat('es-AR', { month: 'long', year: 'numeric' });
    display.innerText = formatter.format(dateObj);
  }

  function changeMonth(offset: number) {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    if (!dateInput) return;

    const [yearStr, monthStr, dayStr] = dateInput.value.split('-');
    let year = parseInt(yearStr);
    let month = parseInt(monthStr) - 1; // 0-indexed month
    let day = parseInt(dayStr);

    month += offset;
    if (month > 11) {
      month = 0;
      year += 1;
    } else if (month < 0) {
      month = 11;
      year -= 1;
    }

    const daysInNewMonth = getDaysInMonth(year, month);
    if (day > daysInNewMonth) {
      day = daysInNewMonth;
    }

    const newDateStr = `${year}-${(month + 1).toString().padStart(2, '0')}-${day.toString().padStart(2, '0')}`;
    
    // Constraints according to uniqueDates
    const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
    const uniqueDates = [...new Set(allDates)].sort();
    if (uniqueDates.length > 0) {
      const minDate = uniqueDates[0];
      const maxDate = uniqueDates[uniqueDates.length - 1];
      
      if (newDateStr < minDate) {
        dateInput.value = minDate;
      } else if (newDateStr > maxDate) {
        dateInput.value = maxDate;
      } else {
        dateInput.value = newDateStr;
      }
    } else {
      dateInput.value = newDateStr;
    }

    updateDateInputDisplay();
    updateMonthDisplay();
    renderDaily();
    renderMonthly();
  }

  async function init() {
    try {
      const res = await fetch('/api/cronograma');
      cronoData = await res.json();

      const dateInput = document.getElementById('date-input') as HTMLInputElement;

      const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
      const uniqueDates = [...new Set(allDates)].sort();
      const latestDate = uniqueDates[uniqueDates.length - 1]; 

      const todayStr = formatYMD(new Date());
      const hasDataForToday = cronoData.some(op => op.asistencia[todayStr]);
      const initialDate = hasDataForToday ? todayStr : latestDate;

      if (dateInput) {
        dateInput.value = initialDate;
        updateDateInputDisplay();
        updateMonthDisplay();
        if (uniqueDates.length > 0) {
          dateInput.min = uniqueDates[0];
          dateInput.max = latestDate;
        }
      }

      renderDaily();
      renderMonthly();
      setupEventListeners();
    } catch (err) {
      console.error("Error loading data:", err);
    }
  }

  function getStatusStyles(type: string | undefined) {
    switch (type) {
      case 'Presencial':
        return {
          badge: 'bg-secondary/10 text-secondary border border-secondary/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.briefcase,
          color: 'var(--color-secondary)',
          bgClass: 'bg-secondary/10 text-secondary'
        };
      case 'Home Office':
        return {
          badge: 'bg-primary/10 text-amber-600 dark:text-amber-400 border border-primary/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase shadow-sm',
          icon: icons.home,
          color: 'var(--color-primary)',
          bgClass: 'bg-primary/10 text-amber-600 dark:text-amber-400 border border-primary/25 shadow-sm'
        };
      case 'Licencia':
        return {
          badge: 'bg-error/10 text-error border border-error/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.firstAid,
          color: 'var(--color-error)',
          bgClass: 'bg-error/10 text-error'
        };
      case 'Vacaciones':
        return {
          badge: 'bg-success/10 text-success border border-success/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.sun,
          color: 'var(--color-success)',
          bgClass: 'bg-success/10 text-success'
        };
      default:
        return {
          badge: 'bg-base-200 text-base-content/60 px-3 py-1.5 rounded-full text-xs font-bold tracking-wide uppercase border border-base-300/50',
          icon: icons.help,
          color: 'var(--fallback-bc,oklch(var(--bc)/0.4))',
          bgClass: 'bg-base-200/50 text-base-content/50'
        };
    }
  }

  function renderDaily() {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    const selectedDateStr = dateInput?.value || formatYMD(new Date());
    const tableBody = document.getElementById('operators-table-body');
    const statsContainer = document.getElementById('stats-container');
    const dateDisplay = document.getElementById('daily-date-display');

    if (dateDisplay) {
      const formatter = new Intl.DateTimeFormat('es-AR', { weekday: 'long', day: 'numeric', month: 'long' });
      const dateObj = new Date(selectedDateStr + 'T12:00:00');
      dateDisplay.innerText = formatter.format(dateObj);
    }

    const stats = { presencial: 0, homeOffice: 0, licencia: 0, vacaciones: 0 };
    cronoData.forEach(op => {
      const status = op.asistencia[selectedDateStr];
      if (status === 'Presencial') stats.presencial++;
      else if (status === 'Home Office') stats.homeOffice++;
      else if (status === 'Licencia') stats.licencia++;
      else if (status === 'Vacaciones') stats.vacaciones++;
    });

    const statItems = [
      { label: 'Presencial', value: stats.presencial, icon: icons.briefcase, borderClass: 'border-l-secondary', textClass: 'text-secondary' },
      { label: 'Home Office', value: stats.homeOffice, icon: icons.home, borderClass: 'border-l-amber-500', textClass: 'text-amber-600 dark:text-amber-400' },
      { label: 'Licencia', value: stats.licencia, icon: icons.firstAid, borderClass: 'border-l-error', textClass: 'text-error' },
      { label: 'Vacaciones', value: stats.vacaciones, icon: icons.sun, borderClass: 'border-l-success', textClass: 'text-success' },
    ];

    if (statsContainer) {
      statsContainer.innerHTML = statItems.map((stat) => `
        <div class="bg-base-100 rounded-xl border border-l-4 ${stat.borderClass} border-base-300 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-shadow duration-200 relative overflow-hidden">
          <div class="p-4 flex flex-col gap-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-sm ${stat.textClass}">${stat.icon}</span>
              <span class="text-xs font-bold uppercase tracking-wide text-base-content/60">${stat.label}</span>
            </div>
            <span class="text-4xl font-black text-base-content tracking-tight leading-none">${stat.value}</span>
            <span class="text-xs text-base-content/40 font-medium mt-0.5">operadores hoy</span>
          </div>
        </div>
      `).join('');
    }

    let rowsHtml = '';
    cronoData.forEach(op => {
      const status = op.asistencia[selectedDateStr];
      if (!status) return;
      
      const styles = getStatusStyles(status);
      const isAbsent = status === 'Licencia' || status === 'Vacaciones';
      const initials = op.nombre.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();
      const username = getUsername(op.nombre);
      const liveStatus = isCurrentlyWorking(op.horario);
      
      let liveIndicatorClass = "bg-base-content/10";
      if (liveStatus.status === 'online') liveIndicatorClass = "bg-success shadow-[0_0_8px_rgba(6,132,68,0.4)]";
      else if (liveStatus.status === 'break') liveIndicatorClass = "bg-warning shadow-[0_0_8px_rgba(226,173,31,0.4)]";

      let ringClass = "bg-base-200/50 text-base-content/60 ring-base-200 border border-base-300";
      if (status === 'Presencial') ringClass = "bg-secondary/10 text-secondary ring-secondary/30 border border-secondary/20 shadow-sm";
      else if (status === 'Home Office') ringClass = "bg-primary/10 text-amber-600 dark:text-amber-400 ring-primary/30 border border-primary/20 shadow-sm";

      rowsHtml += `
        <tr class="hover:bg-base-200/40 transition-all duration-200 group border-b border-base-200/50 last:border-0">
          <td class="px-6 py-4">
            <div class="flex items-center gap-4">
              <div class="relative w-10 h-10 shrink-0">
                <div class="absolute inset-0 rounded-full blur-[2px] opacity-0 group-hover:opacity-30 transition-opacity duration-300 ${status === 'Presencial' ? 'bg-secondary' : (status === 'Home Office' ? 'bg-amber-500' : 'bg-primary')}"></div>
                <div class="relative w-10 h-10 rounded-full flex items-center justify-center text-[11px] font-black ring-1 ring-base-300 transition-all duration-300 group-hover:scale-110 group-hover:ring-offset-2 group-hover:ring-offset-base-100 ${ringClass}">
                  ${initials}
                </div>
                <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full border-2 border-base-100 ${liveIndicatorClass}" title="${liveStatus.text}"></div>
              </div>
              <div class="flex flex-col min-w-0">
                <button 
                  class="font-bold text-sm text-base-content truncate group-hover:text-secondary transition-colors text-left hover:underline underline-offset-4"
                  data-op-profile="${op.nombre}"
                >
                  ${op.nombre}
                </button>
                <span class="text-[10px] text-base-content/40 font-black tracking-widest uppercase truncate">${username}@correoargentino.com.ar</span>
              </div>
            </div>
          </td>
          <td class="px-4 py-4">
            <div class="flex items-center gap-3">
               <div class="w-8 h-8 rounded-lg flex items-center justify-center text-base border border-base-300/30 ${styles.bgClass}">
                  ${styles.icon}
               </div>
               <span class="${styles.badge}">${status}</span>
            </div>
          </td>
          <td class="px-4 py-4">
            <div class="flex flex-col gap-1">
              <span class="font-mono text-sm font-bold ${isAbsent ? 'text-base-content/20 italic' : 'text-base-content/80'}">${isAbsent ? 'Ausente' : op.horario}</span>
              <div class="flex items-center gap-1.5">
                <span class="text-[9px] font-black uppercase tracking-wider ${liveStatus.status === 'online' ? 'text-success' : liveStatus.status === 'break' ? 'text-warning' : 'text-base-content/30'}">${liveStatus.text}</span>
              </div>
            </div>
          </td>
          <td class="px-4 py-4 font-mono text-sm font-bold">
            ${isAbsent ? '<span class="text-base-content/20">-</span>' : '<span class="text-base-content/60 bg-base-200/50 px-2 py-0.5 rounded text-[11px] border border-base-300/20">1 hr</span>'}
          </td>
          <td class="px-6 py-4 text-right">
            <code class="text-[10px] font-black bg-base-300/20 px-2.5 py-1.5 rounded text-base-content/40 border border-base-300/20 tracking-widest uppercase transition-all duration-200 group-hover:bg-base-300 group-hover:text-base-content/60">${username}</code>
          </td>
        </tr>
      `;
    });
    
    if (tableBody) tableBody.innerHTML = rowsHtml;
  }

  function isWorkingAtHour(horario: string, hourStr: string) {
    if (!horario || horario === '-' || horario === 'Franco') return false;
    const parts = horario.split(' - ');
    if (parts.length !== 2) return false;
    const start = parts[0];
    const end = parts[1];

    const hS = parseInt(start.split(':')[0]);
    const hE = parseInt(end.split(':')[0]);
    const hC = parseInt(hourStr.split(':')[0]);

    if (hS <= hE) {
       return hC >= hS && hC < hE;
    } else {
       return hC >= hS || hC < hE;
    }
  }

  function renderHourly(dateStr: string) {
    const thead = document.getElementById('monthly-thead');
    const tbody = document.getElementById('monthly-tbody');
    const tfoot = document.getElementById('monthly-tfoot');
    
    const hours = Array.from({length: 16}, (_, i) => `${(i+7).toString().padStart(2, '0')}:00`);
    const formatter = new Intl.DateTimeFormat('es-AR', { weekday: 'long', day: '2-digit', month: 'long' });
    const formattedDate = formatter.format(new Date(dateStr + 'T12:00:00')).toUpperCase();

    let theadHtml = `
      <tr>
        <th rowspan="2" class="sticky left-0 bg-base-100 z-50 w-[200px] min-w-[200px] border-r border-b border-base-200 px-6 py-4 font-black text-xs uppercase tracking-widest text-base-content/50">Operador</th>
        <th colspan="${hours.length}" class="text-center py-3 bg-secondary/5 text-secondary border-b border-base-200 relative group">
           <button type="button" data-close-hourly class="absolute left-4 top-1/2 -translate-y-1/2 btn btn-xs btn-outline hover:bg-secondary/10 border-secondary/20 hover:border-secondary/40 text-secondary h-8 px-3 rounded-lg transition-all shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left mr-1"><path d="m15 18-6-6 6-6"/></svg>
              Volver al mes
           </button>
           <span class="font-black tracking-widest uppercase text-sm">Vista Diaria: ${formattedDate}</span>
        </th>
      </tr>
      <tr>
    `;
    
    hours.forEach(hour => {
      theadHtml += `<th class="text-center min-w-[3rem] px-0 border-r border-b border-base-200 py-2 bg-base-200/20">
        <span class="font-extrabold text-[10px] tracking-wide text-base-content/60">${hour}</span>
      </th>`;
    });
    theadHtml += `</tr>`;
    if (thead) thead.innerHTML = theadHtml;

    const filteredOps = cronoData.filter(op => {
      const matchesSearch = !searchQuery || op.nombre.toLowerCase().includes(searchQuery.toLowerCase());
      if (!matchesSearch) return false;
      if (activeFilter === 'all') return true;
      const status = op.asistencia[dateStr];
      if (activeFilter === 'Licencia') {
        return status === 'Licencia' || status === 'Vacaciones';
      }
      return status === activeFilter;
    });

    let tbodyHtml = '';
    if (filteredOps.length === 0) {
       tbodyHtml = `<tr><td colspan="${hours.length + 1}" class="py-16 text-center text-base-content/40 font-bold bg-base-100/50">Sin resultados</td></tr>`;
    } else {
       filteredOps.forEach(op => {
          const status = op.asistencia[dateStr] || 'Franco';
          const horario = op.horario;
          const styles = getStatusStyles(status);
          const isAbsent = status === 'Licencia' || status === 'Vacaciones';
          const isFranco = status === 'Franco';
          
          tbodyHtml += `<tr class="group hover:bg-base-200/40 transition-all border-b border-base-200/50">
             <td class="sticky left-0 bg-base-100 z-40 w-[200px] min-w-[200px] font-bold py-3 px-6 text-xs border-r border-base-200/70 group-hover:bg-base-200 transition-colors">
                <div class="flex flex-col min-w-0">
                  <button class="hover:text-secondary hover:underline underline-offset-2 transition-all text-left truncate" data-op-profile="${op.nombre}">${op.nombre}</button>
                  <span class="text-[9px] ${isAbsent ? 'text-error' : isFranco ? 'text-base-content/40' : 'text-base-content/60'} font-black tracking-widest uppercase truncate mt-0.5">${horario} - ${status}</span>
                </div>
             </td>
          `;

          hours.forEach(hour => {
             const working = isWorkingAtHour(horario, hour);
             if (working && !isFranco) {
                tbodyHtml += `<td class="border-r border-base-200/50 p-1 bg-base-200/10">
                   <div class="w-full h-full rounded ${styles.bgClass} flex items-center justify-center opacity-90 group-hover:opacity-100 transition-opacity min-h-[1.75rem] shadow-sm">
                   </div>
                </td>`;
             } else {
                tbodyHtml += `<td class="border-r border-b border-base-200/50 bg-base-100/50"></td>`;
             }
          });
          tbodyHtml += `</tr>`;
       });
    }
    if (tbody) tbody.innerHTML = tbodyHtml;
    
    if (tfoot) tfoot.innerHTML = `<tr><td colspan="${hours.length + 1}" class="bg-base-200 py-3 text-center border-t border-base-300 text-[10px] font-black text-base-content/30 uppercase tracking-[0.2em]">Fin del reporte diario</td></tr>`;
  }

  function renderMonthly() {
    if (focusedDateStr) {
      renderHourly(focusedDateStr);
      return;
    }

    const thead = document.getElementById('monthly-thead');
    const tbody = document.getElementById('monthly-tbody');
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    const selectedDateStr = dateInput?.value || formatYMD(new Date());
    
    const [yearStr, monthStr] = selectedDateStr.split('-');
    const year = parseInt(yearStr);
    const month = parseInt(monthStr) - 1;
    const daysInMonth = getDaysInMonth(year, month);
    const currentMonthPrefix = `${yearStr}-${monthStr}`;
    
    const dates = Array.from({length: daysInMonth}, (_, i) => `${currentMonthPrefix}-${(i + 1).toString().padStart(2, '0')}`);
    const todayStr = formatYMD(new Date());

    // --- RULE: Coverage Pre-calculation ---
    const coveragePerDay: Record<string, { total: number, licenses: number }> = {};
    dates.forEach(d => {
      let active = 0;
      let lics = 0;
      cronoData.forEach(op => {
        const s = op.asistencia[d];
        if (s === 'Presencial' || s === 'Home Office') active++;
        if (s === 'Licencia' || s === 'Vacaciones') lics++;
      });
      coveragePerDay[d] = { total: active, licenses: lics };
    });

    const teamSize = cronoData.length;
    let totalInconsistencies = 0;

    let theadHtml = `<tr>
      <th class="sticky left-0 bg-base-100 z-50 w-[200px] min-w-[200px] border-r border-b border-base-200 px-6 py-4 font-black text-xs uppercase tracking-widest text-base-content/50">Operador</th>
      <th class="sticky left-[200px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center" title="Presencial">P</th>
      <th class="sticky left-[240px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center" title="Home Office">HO</th>
      <th class="sticky left-[280px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]" title="Licencia/Vacaciones">L</th>
`;
    
    dates.forEach(date => {
      const d = new Date(date + 'T12:00:00');
      const isToday = date === todayStr;
      const isWeekend = d.getDay() === 0 || d.getDay() === 6;
      const isCritical = (coveragePerDay[date].total / teamSize) < 0.4;
      
      let thClass = "text-center min-w-[3rem] px-0 border-r border-b border-base-200 transition-colors";
      if (isToday) thClass += " bg-secondary text-secondary-content border-b-secondary border-b-2";
      else if (isWeekend) thClass += " bg-base-200/50 text-base-content/30";
      else if (isCritical) thClass += " bg-error/10 text-error";
      else thClass += " text-base-content/70";
      
      const formatter = new Intl.DateTimeFormat('es-AR', { weekday: 'short' });
      const dayName = formatter.format(d).substring(0, 2).toUpperCase();
      
      theadHtml += `
        <th class="${thClass} p-0">
          <button
            type="button"
            class="w-full h-full flex flex-col items-center justify-center py-2 gap-0.5 cursor-pointer hover:bg-base-content/5 active:bg-base-content/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40 rounded-none border-0"
            data-click-day="${date}"
            aria-label="Ver detalle del día ${d.getDate()} de ${new Intl.DateTimeFormat('es-AR', { month: 'long' }).format(d)}"
          >
            <span class="font-extrabold text-[10px] tracking-wide ${isToday ? 'opacity-90' : 'opacity-60'}">${dayName}</span>
            <div class="flex items-center gap-1">
               <span class="font-black text-xs ${isToday ? 'scale-110' : ''}">${d.getDate()}</span>
               ${isCritical ? '<div class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></div>' : ''}
            </div>
            ${isToday ? `<span class="text-[7px] font-black tracking-wide uppercase opacity-80">HOY</span>` : ''}
          </button>
        </th>
      `;
    });
    theadHtml += `</tr>`;
    if (thead) thead.innerHTML = theadHtml;

    let tbodyHtml = '';
    const filteredOps = cronoData.filter(op => {
      // 1. Search Query filter (case-insensitive name check)
      const matchesSearch = !searchQuery || op.nombre.toLowerCase().includes(searchQuery.toLowerCase());
      if (!matchesSearch) return false;

      // 2. Status Filter
      if (activeFilter === 'all') return true;
      
      // Check if the operator has at least one occurrence of the selected status in the current month
      return dates.some(d => {
        const status = op.asistencia[d];
        if (activeFilter === 'Licencia') {
          return status === 'Licencia' || status === 'Vacaciones';
        }
        return status === activeFilter;
      });
    });

    if (filteredOps.length === 0) {
      tbodyHtml = `<tr>
        <td colspan="${dates.length + 4}" class="py-16 text-center text-base-content/40 font-bold bg-base-100/50 border border-dashed border-base-300/40">
          <div class="flex flex-col items-center justify-center gap-3 py-6">
            <div class="w-12 h-12 rounded-2xl bg-base-200/50 flex items-center justify-center text-base-content/30 border border-base-300/40">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-xs uppercase tracking-widest font-black text-base-content/70">Sin resultados</span>
              <span class="text-[10px] text-base-content/40 font-medium normal-case mt-0.5">Ningún operador coincide con tu búsqueda o filtro.</span>
            </div>
          </div>
        </td>
      </tr>`;
    } else {
      filteredOps.forEach(op => {
        const stats = { P: 0, HO: 0, L: 0 };
        dates.forEach(d => {
          const s = op.asistencia[d];
          if (s === 'Presencial') stats.P++;
          else if (s === 'Home Office') stats.HO++;
          else if (s === 'Licencia' || s === 'Vacaciones') stats.L++;
        });

        // --- RULE: Consecutive HO Check ---
        let maxConsecutiveHO = 0;
        let currentHO = 0;
        dates.forEach(d => {
          if (op.asistencia[d] === 'Home Office') {
            currentHO++;
            maxConsecutiveHO = Math.max(maxConsecutiveHO, currentHO);
          } else if (op.asistencia[d] !== 'Franco' && op.asistencia[d]) {
            currentHO = 0;
          }
        });
        const hoViolation = maxConsecutiveHO > 5;
        if (hoViolation) totalInconsistencies++;

        tbodyHtml += `<tr class="group ${hoViolation ? 'bg-error/[0.02]' : ''}" data-op-name="${op.nombre.toLowerCase()}">
          <td class="sticky left-0 bg-base-100 z-40 w-[200px] min-w-[200px] font-bold py-3 px-6 text-xs border-r border-b border-base-200/70 group-hover:bg-base-200 transition-colors">
            <div class="flex items-center gap-3">
              <div class="w-1.5 h-1.5 rounded-full ${hoViolation ? 'bg-error animate-pulse' : 'bg-base-300 group-hover:bg-amber-500'} transition-colors shadow-sm"></div>
              <div class="flex flex-col min-w-0">
                 <button class="hover:text-secondary hover:underline underline-offset-2 transition-all text-left truncate" data-op-profile="${op.nombre}">
                  ${op.nombre}
                </button>
                ${hoViolation ? `<span class="text-[7px] font-black text-error uppercase tracking-tighter">⚠️ Exceso de HO (${maxConsecutiveHO}d)</span>` : ''}
              </div>
            </div>
          </td>
          <td class="sticky left-[200px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center text-[10px] font-black border-r border-b border-base-200/70 text-secondary group-hover:bg-base-200 transition-colors">${stats.P}</td>
          <td class="sticky left-[240px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center text-[10px] font-black border-r border-b border-base-200/70 text-amber-600 dark:text-amber-400 group-hover:bg-base-200 transition-colors">${stats.HO}</td>
          <td class="sticky left-[280px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center text-[10px] font-black border-r border-b border-base-200/70 text-error group-hover:bg-base-200 transition-colors shadow-[4px_0_10px_-5px_rgba(0,0,0,0.05)]">${stats.L}</td>
  `;
          
        dates.forEach(date => {
          const status = op.asistencia[date];
          const styles = getStatusStyles(status);
          const isTodayCell = date === todayStr;
          const safeName = escapeHtml(op.nombre);
          const safeDate = escapeHtml(date);
          const safeStatus = escapeHtml(status || 'Franco');
          const safeHorario = escapeHtml(op.horario);
          const username = getUsername(op.nombre);
          
          // --- RULE: License Overlap Check ---
          const isLicenseOverlap = (status === 'Licencia' || status === 'Vacaciones') && coveragePerDay[date].licenses > 2;
          if (isLicenseOverlap) totalInconsistencies++;

          let cellClass = `p-1.5 border-r border-b border-base-200/50 text-center transition-all duration-300`;
          if (isTodayCell) cellClass += ' bg-secondary/10';
          if (isLicenseOverlap) cellClass += ' ring-1 ring-inset ring-error/30 bg-error/[0.03]';
          
          const hasComment = !!(op.comentarios && op.comentarios[date]);
          if (status === 'Franco' || !status) {
            tbodyHtml += `<td class="${cellClass}">
              <button
                type="button"
                class="monthly-cell-button h-8 flex items-center justify-center relative ${isTodayCell ? 'bg-secondary/15 border border-secondary/30' : 'bg-base-200/20 border border-base-300/20'}"
                data-monthly-detail
                data-operator="${safeName}"
                data-date="${safeDate}"
                data-status="Franco"
                data-horario="${safeHorario}"
                data-username="${escapeHtml(username)}"
                data-comment="${escapeHtml(op.comentarios?.[date] || '')}"
                aria-label="Ver detalle de ${safeName} el ${safeDate}: Franco"
              >
                ${hasComment ? '<div class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" title="Tiene comentario"></div>' : ''}
              </button>
            </td>`;
            return;
          }

          let initials = "";
          if (status === 'Presencial') initials = "P";
          else if (status === 'Home Office') initials = "HO";
          else if (status === 'Licencia') initials = "L";
          else if (status === 'Vacaciones') initials = "V";

          tbodyHtml += `
            <td class="${cellClass}">
              <button
                type="button"
                class="monthly-cell-button h-8 flex items-center justify-center transition-all duration-300 cursor-pointer hover:scale-110 hover:z-10 relative border ${isTodayCell ? 'border-secondary/40 ring-1 ring-secondary/30 shadow-[0_0_10px_rgba(37,72,136,0.1)]' : 'border-base-300/30'} ${styles.bgClass} shadow-sm hover:shadow-lg ${isLicenseOverlap ? 'border-error/40' : ''}"
                title="${op.nombre} - ${date}: ${status} ${isLicenseOverlap ? '(Solapamiento Crítico)' : ''}"
                data-monthly-detail
                data-operator="${safeName}"
                data-date="${safeDate}"
                data-status="${safeStatus}"
                data-horario="${safeHorario}"
                data-username="${escapeHtml(username)}"
                data-comment="${escapeHtml(op.comentarios?.[date] || '')}"
                aria-label="Ver detalle de ${safeName} el ${safeDate}: ${safeStatus}"
              >
                <span class="font-black text-xs leading-none tracking-tight">${initials}</span>
                ${isLicenseOverlap ? '<div class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-error border border-base-100"></div>' : ''}
                ${hasComment ? '<div class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-amber-500 border border-base-100" title="Tiene comentario"></div>' : ''}
              </button>
            </td>
          `;
        });
        tbodyHtml += `</tr>`;
      });
    }

    if (tbody) tbody.innerHTML = tbodyHtml;

    // Update Global Alert Badge
    const alertBadge = document.getElementById('compliance-alert-badge');
    const alertText = document.getElementById('compliance-alert-text');
    if (alertBadge && alertText) {
      if (totalInconsistencies > 0) {
        alertBadge.classList.remove('hidden');
        alertText.innerText = `${totalInconsistencies} Inconsistencia${totalInconsistencies > 1 ? 's' : ''} detectada${totalInconsistencies > 1 ? 's' : ''}`;
      } else {
        alertBadge.classList.add('hidden');
      }
    }

    // --- FEATURE: Coverage Visualizer (Heatmap Footer) ---
    const dailyCoverage = dates.map(date => {
      let p = 0, ho = 0;
      cronoData.forEach(op => {
        const s = op.asistencia[date];
        if (s === 'Presencial') p++;
        else if (s === 'Home Office') ho++;
      });
      return { p, ho, total: p + ho };
    });

    const pyClass = isCoverageMinimized ? 'py-1.5' : 'py-3.5';
    const chevronIcon = isCoverageMinimized ? 
      `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-up transition-transform duration-200"><path d="m18 15-6-6-6 6"/></svg>` : 
      `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>`;

    let tfootHtml = `<tr>
      <td class="sticky left-0 bg-base-200 z-50 w-[200px] min-w-[200px] ${pyClass} px-6 border-r border-base-300">
        <div class="flex items-center justify-between gap-2">
          <span class="text-[10px] font-black uppercase tracking-[0.1em] text-base-content/60">Resumen Cobertura</span>
          <button
            type="button"
            id="toggle-coverage-btn"
            class="btn btn-xs btn-ghost p-0.5 rounded hover:bg-base-300 text-base-content/50 hover:text-base-content transition-all"
            title="${isCoverageMinimized ? 'Maximizar resumen de cobertura' : 'Minimizar resumen de cobertura'}"
            aria-label="${isCoverageMinimized ? 'Maximizar resumen de cobertura' : 'Minimizar resumen de cobertura'}"
          >
            ${chevronIcon}
          </button>
        </div>
      </td>
      <td class="sticky left-[200px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center ${pyClass} text-[10px] font-black border-r border-base-300 text-base-content/40" title="Total Operadores">${teamSize}</td>
      <td class="sticky left-[240px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center ${pyClass} text-[10px] font-black border-r border-base-300 text-base-content/20">-</td>
      <td class="sticky left-[280px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center ${pyClass} text-[10px] font-black border-r border-base-300 text-base-content/20 shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]">-</td>
    `;

    dailyCoverage.forEach(c => {
      const hoPercent = (c.ho / teamSize) * 100;
      const pPercent = (c.p / teamSize) * 100;
      const totalPercent = ((c.p + c.ho) / teamSize) * 100;
      const isLowCoverage = totalPercent < 40;

      const cellPyClass = isCoverageMinimized ? 'py-1 px-1' : 'py-2 px-1';

      tfootHtml += `
        <td class="${cellPyClass} border-r border-base-200/50 min-w-[3rem] ${isLowCoverage ? 'bg-error/5' : ''}">
          <div class="flex flex-col items-center gap-1.5">
             ${isCoverageMinimized ? '' : `
             <div class="flex flex-col w-2.5 h-12 bg-base-300/30 rounded-full overflow-hidden justify-end shadow-[inset_0_1px_2px_rgba(0,0,0,0.1)]">
                <div class="bg-amber-500 w-full transition-all duration-500" style="height: ${hoPercent}%" title="HO: ${c.ho}"></div>
                <div class="bg-secondary w-full transition-all duration-500" style="height: ${pPercent}%" title="Presencial: ${c.p}"></div>
             </div>
             `}
             <div class="flex flex-col items-center leading-none">
                <span class="text-[10px] font-black ${isLowCoverage ? 'text-error' : 'text-base-content/60'}">${c.p + c.ho}</span>
                <span class="text-[7px] font-black uppercase opacity-30">Activos</span>
             </div>
          </div>
        </td>
      `;
    });
    tfootHtml += `</tr>`;

    const tfoot = document.getElementById('monthly-tfoot');
    if (tfoot) tfoot.innerHTML = tfootHtml;
  }

  function updateCellStatus(cell: HTMLElement, newStatus: string) {
    const operator = cell.dataset.operator;
    const date = cell.dataset.date;
    if (!operator || !date) return;

    // Track the changes in our pending changes array
    const existingIndex = modifiedSchedules.findIndex(e => e.agentName === operator && e.date === date);
    if (existingIndex !== -1) {
      modifiedSchedules[existingIndex].status = newStatus;
    } else {
      modifiedSchedules.push({ agentName: operator, date, status: newStatus });
    }

    // Update in-memory data
    const opIndex = cronoData.findIndex(o => o.nombre === operator);
    if (opIndex !== -1) {
      cronoData[opIndex].asistencia[date] = newStatus;
      renderMonthly(); // Full re-render to update stats and colors
    }
  }

  async function discardChanges() {
    try {
      const res = await fetch('/api/cronograma');
      cronoData = await res.json();
      modifiedSchedules = [];
      
      const saveIndicator = document.getElementById('save-indicator');
      if (saveIndicator) saveIndicator.classList.add('hidden');

      renderDaily();
      renderMonthly();
    } catch (err) {
      console.error("Error discarding/reloading data:", err);
    }
  }

  async function saveChangesToServer() {
    const saveBtn = document.getElementById('save-confirm-btn') as HTMLButtonElement | null;
    const discardBtn = document.getElementById('save-discard-btn') as HTMLButtonElement | null;
    const indicatorText = document.getElementById('save-indicator-text');

    if (saveBtn) {
      saveBtn.disabled = true;
      saveBtn.innerHTML = `<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Guardando...`;
    }
    if (discardBtn) discardBtn.disabled = true;

    try {
      const response = await fetch('/api/cronograma', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ edits: modifiedSchedules })
      });

      if (!response.ok) throw new Error("Error al guardar cambios");

      // Success visual feedback
      if (indicatorText) {
        indicatorText.innerText = "¡Cambios guardados con éxito!";
      }

      // Complete reset
      modifiedSchedules = [];
      
      // Fetch latest merged data to be absolutely sure
      const res = await fetch('/api/cronograma');
      cronoData = await res.json();

      setTimeout(() => {
        const saveIndicator = document.getElementById('save-indicator');
        if (saveIndicator) saveIndicator.classList.add('hidden');
        
        // Restore buttons
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerText = "Guardar";
        }
        if (discardBtn) discardBtn.disabled = false;
        
        if (indicatorText) {
          indicatorText.innerText = "Edición en progreso: Cambios pendientes";
        }

        renderDaily();
        renderMonthly();
      }, 1500);

    } catch (error) {
      console.error("Error saving changes:", error);
      if (indicatorText) {
        indicatorText.innerText = "Error al guardar en el servidor";
      }
      if (saveBtn) {
        saveBtn.disabled = false;
        saveBtn.innerText = "Reintentar";
      }
      if (discardBtn) discardBtn.disabled = false;
    }
  }

  function getDetailStatusClass(status: string) {
    if (status === 'Presencial') return 'text-secondary';
    if (status === 'Home Office') return 'text-amber-600 dark:text-amber-400';
    if (status === 'Licencia') return 'text-error';
    if (status === 'Vacaciones') return 'text-success';
    return 'text-base-content/40';
  }

  function getDetailIndicatorClass(status: string) {
    if (status === 'Presencial') return 'bg-secondary';
    if (status === 'Home Office') return 'bg-amber-500';
    if (status === 'Licencia') return 'bg-error';
    if (status === 'Vacaciones') return 'bg-success';
    return 'bg-base-300';
  }

  function openMonthlyDetail(trigger: HTMLElement) {
    const overlay = document.getElementById('monthly-detail-overlay') as HTMLElement;
    const modal = document.getElementById('monthly-detail-modal') as HTMLElement;
    const closeButton = document.getElementById('monthly-detail-close') as HTMLButtonElement | null;
    const title = document.getElementById('monthly-detail-title') as HTMLElement;
    const date = document.getElementById('monthly-detail-date') as HTMLElement;
    const status = document.getElementById('monthly-detail-status') as HTMLElement;
    const indicator = document.getElementById('modal-status-indicator') as HTMLElement;
    const schedule = document.getElementById('monthly-detail-schedule') as HTMLElement;
    const user = document.getElementById('monthly-detail-user') as HTMLElement;
    const pointer = document.getElementById('modal-pointer') as HTMLElement;

    activeDetailTrigger = trigger;
    const commentValue = trigger.dataset.comment || '';
    const commentTextarea = document.getElementById('monthly-detail-comment') as HTMLTextAreaElement | null;
    if (commentTextarea) {
      commentTextarea.value = commentValue;
    }
    const commentIndicator = document.getElementById('monthly-comment-indicator');
    if (commentIndicator) {
      commentIndicator.classList.remove('opacity-100');
      commentIndicator.classList.add('opacity-0');
    }

    const operatorName = trigger.dataset.operator || '';
    const dateValue = trigger.dataset.date || '';
    const statusValue = trigger.dataset.status || 'Franco';
    const horario = trigger.dataset.horario || '-';
    const username = trigger.dataset.username || '';
    const isAbsent = statusValue === 'Licencia' || statusValue === 'Vacaciones' || statusValue === 'Franco';

    title.innerText = operatorName;
    date.innerText = formatDetailDate(dateValue);
    status.innerText = statusValue;
    status.className = `inline-block text-[11px] font-black uppercase tracking-wider ${getDetailStatusClass(statusValue)}`;
    indicator.className = `w-2.5 h-2.5 rounded-full animate-pulse ${getDetailIndicatorClass(statusValue)}`;
    schedule.innerText = isAbsent ? 'Ausente' : horario;
    user.innerText = username ? `${username}@correoargentino.com.ar` : '-';

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    
    const rect = trigger.getBoundingClientRect();
    const modalWidth = 288;
    const modalHeight = modal.offsetHeight || 320; 
    const padding = 20;
    
    if (window.innerWidth > 768) {
      overlay.classList.remove('items-start', 'justify-center');
      overlay.style.backgroundColor = 'transparent';
      overlay.style.pointerEvents = 'none';
      modal.style.pointerEvents = 'auto';
      modal.style.position = 'absolute';
      
      const left = Math.max(20, Math.min(window.innerWidth - modalWidth - 20, rect.left + rect.width/2 - modalWidth/2));
      
      const spaceBelow = window.innerHeight - rect.bottom;
      const showAbove = spaceBelow < (modalHeight + padding);
      
      if (showAbove) {
        modal.style.top = `${rect.top - modalHeight - 12}px`;
        modal.style.transformOrigin = 'bottom center';
        pointer.className = "absolute w-5 h-5 bg-base-100 border-r-2 border-b-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -bottom-2.5";
      } else {
        modal.style.top = `${rect.bottom + 12}px`;
        modal.style.transformOrigin = 'top center';
        pointer.className = "absolute w-5 h-5 bg-base-100 border-l-2 border-t-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -top-2.5";
      }
      
      modal.style.left = `${left}px`;
      modal.style.margin = '0';
      
      const pointerOffset = rect.left + rect.width/2 - left;
      pointer.style.left = `${pointerOffset}px`;
    } else {
      overlay.classList.add('items-start', 'justify-center');
      overlay.style.backgroundColor = '';
      overlay.style.pointerEvents = '';
      modal.style.pointerEvents = '';
      modal.style.position = '';
      modal.style.left = '';
      modal.style.top = '';
      modal.style.margin = '4rem auto';
      pointer.style.left = '50%';
      pointer.className = "absolute w-5 h-5 bg-base-100 border-l-2 border-t-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -top-2.5";
    }

    overlay.setAttribute('aria-hidden', 'false');
    closeButton?.focus();
  }

