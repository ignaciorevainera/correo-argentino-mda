                >
                  ${op.nombre}
                </button>
                <span class="text-[10px] text-base-content/40 font-black tracking-widest uppercase truncate">${username}@correoargentino.com.ar</span>
              </div>
            </div>
          </td>
          <td class="px-4 py-4">
            <div class="flex items-center gap-3">
               <div class="w-8 h-8 rounded-lg flex items-center justify-center text-base border border-base-300/30 ${styles.bgClass}">
