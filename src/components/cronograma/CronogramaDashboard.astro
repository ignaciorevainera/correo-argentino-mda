---
// CronogramaDashboard.astro
import { Icon } from "astro-icon/components";
---

<div id="cronograma-container" class="animate-in fade-in duration-700 w-full pb-12 space-y-8">
  
  <!-- Stats Summary -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" id="stats-container">
    <!-- Stats will be injected here -->
  </div>

  <div class="w-full flex flex-col gap-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      
      <!-- Modern Segmented Control -->
      <div class="flex bg-base-200 p-1 rounded-xl border border-base-300" id="view-switcher">
        <button 
          data-view="daily"
          aria-label="Cambiar a Vista Diaria"
          class="view-btn flex items-center gap-2 px-5 py-2 rounded-lg transition-colors duration-200 text-sm font-semibold bg-secondary text-secondary-content shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40"
        >
          <Icon name="boxicons:calendar-event" size={18} />
          <span>Vista Diaria</span>
        </button>
        <button 
          data-view="monthly"
          aria-label="Cambiar a Vista Mensual"
          class="view-btn flex items-center gap-2 px-5 py-2 rounded-lg transition-colors duration-200 text-sm font-medium text-base-content/50 hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40"
        >
          <Icon name="boxicons:calendar-alt" size={18} />
          <span>Mes Completo</span>
        </button>
      </div>

      <!-- Date Picker -->
      <div id="date-picker-container" class="relative flex min-w-40 items-center gap-2.5 bg-base-100 px-4 py-2.5 rounded-xl border border-base-300 shadow-sm hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20">
        <Icon name="boxicons:calendar" size={18} class="text-base-content/40" />
        <label for="date-input" class="sr-only">Seleccionar fecha</label>
        <span id="date-input-display" class="text-sm font-semibold tabular-nums text-base-content pointer-events-none">
        </span>
        <input 
          type="date" 
          id="date-input"
          class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 bg-transparent text-transparent caret-transparent"
        />
      </div>
    </div>

    <!-- Daily View Section -->
    <div id="daily-view" class="animate-in slide-in-from-bottom-2 fade-in duration-500">
      <div class="bg-base-100 rounded-2xl border border-base-300 shadow-sm overflow-hidden">
        <div class="bg-base-200/70 border-b border-base-300">
          <div class="flex flex-col sm:flex-row justify-between items-center py-3.5 px-6 gap-3">
            <h3 class="text-sm flex items-center gap-2.5 font-bold uppercase tracking-wide text-base-content">
              <Icon name="boxicons:group" size={18} />
              Estado de operadores
            </h3>
            <div class="flex items-center gap-2 bg-base-100 px-3.5 py-1.5 rounded-lg border border-base-300 shadow-sm text-base-content/75">
               <Icon name="boxicons:calendar-check" size={16} class="text-secondary" />
               <span class="text-sm font-semibold tabular-nums" id="daily-date-display"></span>
            </div>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead class="bg-base-200/60 text-xs uppercase font-bold text-base-content/50 tracking-widest border-b border-base-300">
              <tr>
                <th class="py-3 px-6 w-72">Operador</th>
                <th class="py-3 px-4">Modalidad</th>
                <th class="py-3 px-4">Horario</th>
                <th class="py-3 px-4">Break</th>
                <th class="py-3 px-6 text-right">Usuario</th>
              </tr>
            </thead>
            <tbody id="operators-table-body" class="divide-y divide-base-200">
              <!-- Rows will be injected here -->
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Monthly View Section (Hidden by default) -->
    <div id="monthly-view" class="hidden animate-in slide-in-from-bottom-2 fade-in duration-500">
      <div class="bg-base-100 rounded-2xl border border-base-300 shadow-sm overflow-hidden">
        <div class="bg-base-200/70 border-b border-base-300">
          <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-3 py-3.5 px-6">
            <h3 class="text-sm flex items-center gap-2.5 font-bold uppercase tracking-wide text-base-content">
              <Icon name="boxicons:calendar-star" size={18} />
              Matriz Mensual
            </h3>
            <div class="flex flex-1 max-w-xs mx-4">
              <div class="relative w-full">
                <Icon name="boxicons:search" size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/30" />
                <input 
                  type="text" 
                  id="monthly-search"
                  placeholder="Buscar operador..." 
                  class="w-full bg-base-100 border border-base-300 rounded-lg py-1.5 pl-9 pr-3 text-xs focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all outline-none"
                />
              </div>
            </div>
            <div class="flex flex-wrap items-center gap-4">
              <div id="compliance-alert-badge" class="hidden">
                 <div class="flex items-center gap-2 px-3 py-1 bg-error/10 text-error rounded-full border border-error/20 animate-pulse">
                    <Icon name="boxicons:alert-triangle" size={14} />
                    <span class="text-[10px] font-black uppercase tracking-tighter" id="compliance-alert-text">0 Inconsistencias</span>
                 </div>
              </div>
              <div class="flex items-center gap-1.5 text-xs font-semibold text-base-content/70">
                <div class="w-3 h-3 rounded bg-primary"></div> HO
              </div>
              <div class="flex items-center gap-1.5 text-xs font-semibold text-base-content/70">
                <div class="w-3 h-3 rounded bg-secondary"></div> Presencial
              </div>
              <div class="flex items-center gap-1.5 text-xs font-semibold text-base-content/70">
                <div class="w-3 h-3 rounded bg-error"></div> Licencia
              </div>
              <div class="flex items-center gap-1.5 text-xs font-semibold text-base-content/70">
                <div class="w-3 h-3 rounded bg-success"></div> Vacaciones
              </div>
            </div>
          </div>
        </div>
        <div class="p-3">
          <div class="overflow-x-auto max-h-[580px] overflow-y-auto scrollbar-thin rounded-xl border border-base-200 bg-base-100">
            <table class="w-full text-sm text-left border-separate border-spacing-0" id="monthly-table">
              <thead class="sticky top-0 z-30 bg-base-100/98 backdrop-blur-sm shadow-sm" id="monthly-thead">
                <!-- Headers injected here -->
              </thead>
              <tbody id="monthly-tbody">
                <!-- Matrix injected here -->
              </tbody>
              <tfoot id="monthly-tfoot" class="sticky bottom-0 z-40 bg-base-100/95 backdrop-blur-md border-t-2 border-base-300">
                <!-- Coverage stats injected here -->
              </tfoot>
            </table>
          </div>
        </div>
        <div class="bg-base-200/40 border-t border-base-300 px-6 py-3 flex justify-between items-center">
          <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Supervisor Panel v1.0</p>
          <div class="flex gap-2">
            <button class="btn btn-xs btn-outline gap-1 border-base-300 hover:bg-base-300 hover:border-base-300">
              <Icon name="boxicons:file" size={14} />
              Exportar CSV
            </button>
            <button class="btn btn-xs btn-secondary gap-1">
              <Icon name="boxicons:printer" size={14} />
              Imprimir Reporte
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Quick Edit Context Menu -->
<div 
  id="quick-edit-menu" 
  class="fixed z-[100] hidden min-w-[160px] bg-base-100/90 backdrop-blur-xl border border-base-300 rounded-xl shadow-2xl p-1.5 animate-in fade-in zoom-in-95 duration-100"
>
  <div class="px-3 py-2 border-b border-base-200 mb-1">
    <p class="text-[9px] font-black uppercase tracking-widest text-base-content/40" id="quick-edit-target-name">Cambiar Estado</p>
  </div>
  <div class="space-y-0.5" id="quick-edit-options">
    <button data-status="Presencial" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-secondary/10 hover:text-secondary transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-secondary"></div> Presencial
    </button>
    <button data-status="Home Office" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 hover:text-primary transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-primary"></div> Home Office
    </button>
    <button data-status="Licencia" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-error/10 hover:text-error transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-error"></div> Licencia
    </button>
    <button data-status="Vacaciones" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-success/10 hover:text-success transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-success"></div> Vacaciones
    </button>
    <button data-status="Franco" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-300 transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-base-300"></div> Franco
    </button>
  </div>
</div>

<!-- Floating Save Alert -->
<div id="save-indicator" class="fixed bottom-6 right-6 z-50 hidden animate-in slide-in-from-right-10 fade-in duration-300">
  <div class="bg-secondary text-secondary-content px-5 py-3 rounded-2xl shadow-xl flex items-center gap-4 border border-secondary/20">
    <Icon name="boxicons:info-circle" size={20} class="animate-pulse" />
    <div class="flex flex-col">
       <span class="text-xs font-black uppercase tracking-tight">Cambios no guardados</span>
       <span class="text-[10px] opacity-80">La edición es local para esta sesión</span>
    </div>
    <button id="save-confirm-btn" class="btn btn-xs btn-ghost bg-base-100/20 hover:bg-base-100/40 border-none ml-2">Descartar</button>
  </div>
</div>

<!-- Operator Profile Modal -->
<div 
  id="operator-drawer-overlay" 
  class="fixed inset-0 z-[110] hidden items-center justify-center bg-base-content/40 backdrop-blur-md transition-all duration-300 p-4"
>
  <div 
    id="operator-drawer" 
    class="relative w-full max-w-2xl bg-base-100 rounded-[2rem] shadow-2xl border border-base-300 flex flex-col overflow-hidden opacity-0 scale-95 transition-all duration-300"
  >
    <!-- Header with Background Gradient -->
    <div class="p-8 border-b border-base-200 relative overflow-hidden bg-gradient-to-br from-base-200/50 to-transparent">
      <div class="flex items-center justify-between relative z-10">
        <div class="flex items-center gap-6">
          <div class="w-16 h-16 rounded-3xl bg-secondary text-secondary-content flex items-center justify-center shadow-lg shadow-secondary/20">
            <Icon name="boxicons:user" size={32} />
          </div>
          <div class="flex flex-col">
            <h2 id="drawer-op-name" class="text-2xl font-black uppercase tracking-tight text-base-content"></h2>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-success"></span>
              <span id="drawer-op-email" class="text-xs font-bold text-base-content/50 lowercase"></span>
            </div>
          </div>
        </div>
        <button id="close-drawer" class="btn btn-ghost btn-circle hover:bg-base-300">
          <Icon name="boxicons:x" size={28} />
        </button>
      </div>
    </div>

    <!-- Content -->
    <div class="flex-1 overflow-y-auto p-8 space-y-8 scrollbar-thin max-h-[70vh]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Stats Column -->
        <div class="space-y-6">
          <section>
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30 mb-4">Rendimiento Mensual</h3>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-primary/5 rounded-3xl p-5 border border-primary/10 flex flex-col items-center text-center">
                <span class="text-3xl font-black text-primary" id="drawer-stat-ho">0</span>
                <span class="text-[9px] font-black uppercase tracking-widest text-primary/60 mt-1">Home Office</span>
              </div>
              <div class="bg-secondary/5 rounded-3xl p-5 border border-secondary/10 flex flex-col items-center text-center">
                <span class="text-3xl font-black text-secondary" id="drawer-stat-p">0</span>
                <span class="text-[9px] font-black uppercase tracking-widest text-secondary/60 mt-1">Presencial</span>
              </div>
            </div>
          </section>

          <section>
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30 mb-4">Notas de Supervisión</h3>
            <textarea 
              placeholder="Añadir seguimiento..." 
              class="textarea textarea-bordered w-full bg-base-200/30 border-base-300 text-sm focus:ring-2 focus:ring-secondary/20 h-32 rounded-2xl p-4"
            ></textarea>
          </section>
        </div>

        <!-- History Column -->
        <section>
          <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30 mb-4">Historial de Asistencia</h3>
          <div class="space-y-2" id="drawer-history-list">
            <!-- Items -->
          </div>
        </section>
      </div>
    </div>

    <!-- Footer -->
    <div class="p-6 border-t border-base-200 bg-base-200/30 flex justify-end gap-3">
       <button class="btn btn-ghost text-xs font-black uppercase">Cerrar</button>
       <button class="btn btn-secondary px-8 font-black uppercase tracking-widest text-xs rounded-xl shadow-lg shadow-secondary/20">Descargar Reporte</button>
    </div>
  </div>
</div>

<div
  id="monthly-detail-overlay"
  class="fixed inset-0 z-50 hidden items-start justify-center bg-base-content/10 p-4 backdrop-blur-[2px] transition-all duration-200"
  aria-hidden="true"
>
  <section
    id="monthly-detail-modal"
    class="monthly-detail-modal relative w-full max-w-72 border-2 border-base-300 bg-base-100 shadow-[0_20px_50px_rgba(0,0,0,0.2)] dark:shadow-[0_20px_50px_rgba(0,0,0,0.4)]"
    role="dialog"
    aria-modal="true"
    aria-labelledby="monthly-detail-title"
  >
    <!-- Chat Bubble Tail (Pointer) -->
    <div id="modal-pointer" class="absolute left-1/2 -translate-x-1/2 w-5 h-5 bg-base-100 border-base-300 z-[-1] transition-all duration-200"></div>

    <div class="flex items-center justify-between gap-3 bg-base-200/50 px-4 py-3 border-b border-base-200">
      <div class="flex items-center gap-2">
        <div id="modal-status-indicator" class="w-2 h-2 rounded-full animate-pulse"></div>
        <h3 class="truncate text-xs font-black uppercase tracking-widest text-base-content/70" id="monthly-detail-title"></h3>
      </div>
      <button
        type="button"
        id="monthly-detail-close"
        class="btn btn-ghost btn-xs btn-square shrink-0 hover:bg-error/10 hover:text-error transition-colors"
        aria-label="Cerrar detalle"
      >
        <Icon name="boxicons:x" size={16} />
      </button>
    </div>

    <div class="p-5 space-y-5">
      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30 mb-1" id="monthly-detail-date-label">Fecha del servicio</p>
        <p class="text-sm font-bold text-base-content" id="monthly-detail-date"></p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="space-y-1">
          <p class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30">Modalidad</p>
          <span id="monthly-detail-status" class="inline-block text-[11px] font-black uppercase tracking-wider"></span>
        </div>
        <div class="space-y-1">
          <p class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30">Horario</p>
          <p class="font-mono text-xs font-bold text-base-content" id="monthly-detail-schedule"></p>
        </div>
      </div>

      <div class="pt-4 border-t border-dashed border-base-300">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0">
             <p class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/30 mb-1">ID Operador</p>
             <code id="monthly-detail-user" class="block truncate font-mono text-[10px] font-bold text-base-content/50"></code>
          </div>
          <Icon name="boxicons:info-circle" size={20} class="text-base-content/20 shrink-0" />
        </div>
      </div>
    </div>
  </section>
</div>

<style is:global>
  #date-picker-container {
    transition: opacity 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
  }

  #date-picker-container.is-faded {
    opacity: 0;
  }

  @media print {
    .no-print, 
    nav, 
    footer, 
    #view-switcher, 
    #date-picker-container,
    #monthly-search,
    .btn,
    #monthly-detail-overlay {
      display: none !important;
    }
    
    #cronograma-container {
      margin: 0 !important;
      padding: 0 !important;
    }
    
    #monthly-view {
      display: block !important;
    }
    
    .bg-base-100 {
      background-color: white !important;
      color: black !important;
    }
    
    .border {
      border-color: #eee !important;
    }
  }

  .crono-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .crono-icon svg {
    width: 1em;
    height: 1em;
    stroke-width: 2.2;
  }

  .monthly-cell-button {
    width: 100%;
    border-radius: 0.5rem;
    outline: none;
  }

  .monthly-cell-button:focus-visible {
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--color-secondary) 35%, transparent);
  }

  .monthly-detail-modal {
    animation: bubble-in 200ms cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: top center;
  }

  #operator-drawer.is-active {
    opacity: 1 !important;
    scale: 1 !important;
  }

  @keyframes bubble-in {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(5px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .pointer-top {
    top: -0.65rem;
    border-left-width: 2px;
    border-top-width: 2px;
    transform: translateX(-50%) rotate(45deg);
  }

  .pointer-bottom {
    bottom: -0.65rem;
    border-right-width: 2px;
    border-bottom-width: 2px;
    transform: translateX(-50%) rotate(45deg);
  }

  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background-color: color-mix(in oklab, var(--color-base-content) 20%, transparent);
    border-radius: 20px;
  }
</style>

<script>
  interface OperatorData {
    nombre: string;
    horario: string;
    asistencia: Record<string, string>;
  }

  const icons = {
    briefcase: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1"/><path d="M4 7h16v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z"/><path d="M4 12h16"/></svg></span>`,
    home: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10.5V20h14v-9.5"/><path d="M10 20v-5h4v5"/></svg></span>`,
    firstAid: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M10 4h4v4h4v4h-4v4h-4v-4H6V8h4V4Z"/><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"/></svg></span>`,
    sun: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg></span>`,
    help: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.7 2.7 0 0 1 5.1 1.2c0 1.8-1.7 2.3-2.3 3.2"/><path d="M12 17h.01"/></svg></span>`,
    timer: `<span class="crono-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>`
  };

  let cronoData: OperatorData[] = [];

  function getDaysInMonth(year: number, month: number) {
    return new Date(year, month + 1, 0).getDate();
  }

  function formatYMD(date: Date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function formatDMY(dateStr: string) {
    const [year, month, day] = dateStr.split('-');
    return `${day}/${month}/${year.slice(-2)}`;
  }

  function formatDetailDate(dateStr: string) {
    return new Intl.DateTimeFormat('es-AR', {
      weekday: 'long',
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    }).format(new Date(dateStr + 'T12:00:00'));
  }

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getUsername(nombre: string) {
    const nameParts = nombre.toLowerCase().split(' ');
    return nameParts[0][0] + (nameParts[1] || '');
  }

  function updateDateInputDisplay() {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    const dateDisplay = document.getElementById('date-input-display');

    if (dateInput && dateDisplay && dateInput.value) {
      dateDisplay.innerText = formatDMY(dateInput.value);
    }
  }

  function isCurrentlyWorking(horario: string) {
    if (!horario || horario === '-') return { status: 'offline', text: 'Fuera de horario' };
    
    const now = new Date();
    const [start, end] = horario.split(' - ');
    if (!start || !end) return { status: 'offline', text: 'Sin horario' };

    const [hS, mS] = start.split(':').map(Number);
    const [hE, mE] = end.split(':').map(Number);

    const startTime = new Date(now);
    startTime.setHours(hS, mS, 0);
    
    const endTime = new Date(now);
    endTime.setHours(hE, mE, 0);

    if (now >= startTime && now <= endTime) {
      const shiftDuration = endTime.getTime() - startTime.getTime();
      const breakStart = new Date(startTime.getTime() + shiftDuration / 2 - 30 * 60000);
      const breakEnd = new Date(breakStart.getTime() + 60 * 60000);

      if (now >= breakStart && now <= breakEnd) {
        return { status: 'break', text: 'En descanso' };
      }
      return { status: 'online', text: 'En servicio' };
    }
    
    return { status: 'offline', text: 'Fuera de horario' };
  }

  async function init() {
    try {
      const res = await fetch('/data/cronograma.json');
      cronoData = await res.json();

      const dateInput = document.getElementById('date-input') as HTMLInputElement;

      const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
      const uniqueDates = [...new Set(allDates)].sort();
      const latestDate = uniqueDates[uniqueDates.length - 1]; 

      const todayStr = formatYMD(new Date());
      const hasDataForToday = cronoData.some(op => op.asistencia[todayStr]);
      const initialDate = hasDataForToday ? todayStr : latestDate;

      if (dateInput) {
        dateInput.value = initialDate;
        updateDateInputDisplay();
        if (uniqueDates.length > 0) {
          dateInput.min = uniqueDates[0];
          dateInput.max = latestDate;
        }
      }

      renderDaily();
      renderMonthly();
      setupEventListeners();
    } catch (err) {
      console.error("Error loading data:", err);
    }
  }

  function getStatusStyles(type: string | undefined) {
    switch (type) {
      case 'Presencial':
        return {
          badge: 'bg-secondary/10 text-secondary border border-secondary/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.briefcase,
          color: 'var(--color-secondary)',
          bgClass: 'bg-secondary/10 text-secondary'
        };
      case 'Home Office':
        return {
          badge: 'bg-primary text-primary-content font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.home,
          color: 'var(--color-primary)',
          bgClass: 'bg-primary text-primary-content'
        };
      case 'Licencia':
        return {
          badge: 'bg-error/10 text-error border border-error/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.firstAid,
          color: 'var(--color-error)',
          bgClass: 'bg-error/10 text-error'
        };
      case 'Vacaciones':
        return {
          badge: 'bg-success/10 text-success border border-success/20 font-bold px-3 py-1.5 rounded-full text-xs tracking-wide uppercase',
          icon: icons.sun,
          color: 'var(--color-success)',
          bgClass: 'bg-success/10 text-success'
