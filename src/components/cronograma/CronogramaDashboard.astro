    // Supervisor Notes auto-save implementation
    let saveTimeout: number | undefined;
    const notesTextarea = document.getElementById('drawer-op-notes') as HTMLTextAreaElement | null;
    const notesIndicator = document.getElementById('notes-status-indicator');

    notesTextarea?.addEventListener('input', () => {
      const opName = document.getElementById('drawer-op-name')?.textContent?.trim();
      if (!opName) return;

      if (notesIndicator) {
        notesIndicator.innerText = "Guardando...";
        notesIndicator.classList.remove('opacity-0', 'text-success/70', 'text-error');
        notesIndicator.classList.add('opacity-100', 'text-warning/70');
      }

      clearTimeout(saveTimeout);
      saveTimeout = window.setTimeout(async () => {
        try {
          const res = await fetch('/api/cronograma/notes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ agentName: opName, notes: notesTextarea.value })
          });

          if (!res.ok) throw new Error("Failed to save notes");

          if (notesIndicator) {
            notesIndicator.innerText = "Guardado";
            notesIndicator.classList.remove('text-warning/70');
            notesIndicator.classList.add('text-success/70');
            
            setTimeout(() => {
              if (notesIndicator.innerText === "Guardado") {
                notesIndicator.classList.add('opacity-0');
                notesIndicator.classList.remove('opacity-100');
              }
            }, 1500);
          }
        } catch (err) {
          console.error("Error saving notes:", err);
          if (notesIndicator) {
            notesIndicator.innerText = "Error";
            notesIndicator.classList.remove('text-warning/70', 'text-success/70');
            notesIndicator.classList.add('text-error');
          }
        }
      }, 500);
    });

    notesTextarea?.addEventListener('blur', () => {
      if (saveTimeout) {
        clearTimeout(saveTimeout);
        const opName = document.getElementById('drawer-op-name')?.textContent?.trim();
        if (opName) {
          fetch('/api/cronograma/notes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ agentName: opName, notes: notesTextarea.value })
          }).then(() => {
            if (notesIndicator) {
              notesIndicator.innerText = "Guardado";
              notesIndicator.classList.remove('text-warning/70');
              notesIndicator.classList.add('text-success/70', 'opacity-100');
              setTimeout(() => {
                if (notesIndicator.innerText === "Guardado") {
                  notesIndicator.classList.add('opacity-0');
                  notesIndicator.classList.remove('opacity-100');
                }
              }, 1500);
            }
          });
        }
      }
    });

    const commentTextarea = document.getElementById('monthly-detail-comment') as HTMLTextAreaElement | null;
    const commentIndicator = document.getElementById('monthly-comment-indicator');
    let commentTimeout: number | null = null;

    commentTextarea?.addEventListener('input', () => {
      if (!activeDetailTrigger) return;
      
      if (commentIndicator) {
        commentIndicator.innerText = "Guardando...";
        commentIndicator.classList.remove('text-success/70', 'text-error', 'opacity-0');
        commentIndicator.classList.add('text-warning/70', 'opacity-100');
      }

      const opName = activeDetailTrigger.dataset.operator;
      const dateVal = activeDetailTrigger.dataset.date;
      const currentVal = commentTextarea.value.trim();

      if (commentTimeout) clearTimeout(commentTimeout);
      
      commentTimeout = window.setTimeout(async () => {
        try {
          if (!opName || !dateVal) return;
          
          const res = await fetch('/api/cronograma', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              edits: [
                {
                  agentName: opName,
                  date: dateVal,
                  comment: currentVal
                }
              ]
            })
          });

          if (!res.ok) throw new Error("Error saving comment");

          // Update local cronoData state too!
          const op = cronoData.find(o => o.nombre === opName);
          if (op) {
            if (!op.comentarios) op.comentarios = {};
            op.comentarios[dateVal] = currentVal;
          }

          // Update trigger button dataset
          if (activeDetailTrigger) {
            activeDetailTrigger.dataset.comment = currentVal;
            
            const indicatorEl = activeDetailTrigger.querySelector('.rounded-full');
            const hasStatus = activeDetailTrigger.dataset.status !== 'Franco';
            
            if (currentVal) {
              if (hasStatus) {
                if (!indicatorEl) {
                  activeDetailTrigger.insertAdjacentHTML('beforeend', '<div class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-amber-500 border border-base-100" title="Tiene comentario"></div>');
                }
              } else {
                if (!indicatorEl) {
                  activeDetailTrigger.innerHTML = '<div class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" title="Tiene comentario"></div>';
                }
              }
            } else {
              if (indicatorEl) {
                indicatorEl.remove();
              }
            }
          }

          if (commentIndicator) {
            commentIndicator.innerText = "Guardado";
            commentIndicator.classList.remove('text-warning/70');
            commentIndicator.classList.add('text-success/70');
            setTimeout(() => {
              if (commentIndicator.innerText === "Guardado") {
                commentIndicator.classList.remove('opacity-100');
                commentIndicator.classList.add('opacity-0');
              }
            }, 1500);
          }
        } catch (err) {
          console.error("Error auto-saving comment:", err);
          if (commentIndicator) {
            commentIndicator.innerText = "Error";
            commentIndicator.classList.remove('text-warning/70', 'text-success/70');
            commentIndicator.classList.add('text-error');
          }
        }
      }, 500);
    });

    commentTextarea?.addEventListener('blur', () => {
      if (!activeDetailTrigger || !commentTimeout) return;
      clearTimeout(commentTimeout);
      
      const opName = activeDetailTrigger.dataset.operator;
      const dateVal = activeDetailTrigger.dataset.date;
      const currentVal = commentTextarea.value.trim();
      
      if (opName && dateVal) {
        fetch('/api/cronograma', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            edits: [
              {
                agentName: opName,
                date: dateVal,
                comment: currentVal
              }
            ]
          })
        }).then((res) => {
          if (!res.ok) return;
          const op = cronoData.find(o => o.nombre === opName);
          if (op) {
            if (!op.comentarios) op.comentarios = {};
            op.comentarios[dateVal] = currentVal;
          }
          if (activeDetailTrigger) {
            activeDetailTrigger.dataset.comment = currentVal;
            const indicatorEl = activeDetailTrigger.querySelector('.rounded-full');
            const hasStatus = activeDetailTrigger.dataset.status !== 'Franco';
            if (currentVal) {
              if (hasStatus) {
                if (!indicatorEl) {
                  activeDetailTrigger.insertAdjacentHTML('beforeend', '<div class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-amber-500 border border-base-100" title="Tiene comentario"></div>');
                }
              } else {
                if (!indicatorEl) {
                  activeDetailTrigger.innerHTML = '<div class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" title="Tiene comentario"></div>';
                }
              }
            } else {
              if (indicatorEl) {
                indicatorEl.remove();
              }
            }
          }
          if (commentIndicator) {
            commentIndicator.innerText = "Guardado";
            commentIndicator.classList.remove('text-warning/70');
            commentIndicator.classList.add('text-success/70', 'opacity-100');
            setTimeout(() => {
              if (commentIndicator.innerText === "Guardado") {
                commentIndicator.classList.remove('opacity-100');
                commentIndicator.classList.add('opacity-0');
              }
            }, 1500);
          }
        });
      }
    });
  }

  init();
</script>
