                  <div class="flex flex-col items-center justify-center h-full gap-0.5 leading-tight py-1">
                    <span class="text-[10.5px] font-mono font-bold leading-none ${timeTextClass} tabular-nums">${entradaReal || '--'}</span>
                    <span class="text-[10.5px] font-mono font-bold leading-none ${timeTextClass} tabular-nums">${salidaReal || '--'}</span>
                  </div>
                ` : (hasComment ? '<div class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" title="Tiene comentario"></div>' : '')}
              </button>
            </td>`;
            return;
          }

          let initials = "";
          if (status === 'Presencial') initials = "P";
          else if (status === 'Home Office') initials = "HO";
          else if (status === 'Licencia') initials = "L";
          else if (status === 'Vacaciones') initials = "V";
          else if (status === 'Horas Extras') initials = "HE";

          tbodyHtml += `
            <td class="${cellClass}">
              <button
                type="button"
                class="monthly-cell-button h-12 flex items-center justify-center transition-all duration-300 cursor-pointer hover:scale-110 hover:z-10 relative border ${isTodayCell ? 'border-secondary/40 ring-1 ring-secondary/30 shadow-[0_0_10px_rgba(37,72,136,0.1)]' : 'border-base-300/30'} ${styles.bgClass} shadow-sm hover:shadow-lg ${isLicenseOverlap ? 'border-error/40' : ''} ${alertClass}"
                title="${op.nombre} - ${date}: ${status} ${isLicenseOverlap ? '(Solapamiento Crítico)' : ''}"
                data-monthly-detail
                data-operator="${safeName}"
                data-date="${safeDate}"
                data-status="${safeStatus}"
                data-horario="${safeHorario}"
                data-username="${escapeHtml(username)}"
                data-comment="${escapeHtml(op.comentarios?.[date] || '')}"
                data-entrada-real="${escapeHtml(entradaReal)}"
                data-salida-real="${escapeHtml(salidaReal)}"
                data-break-inicio="${escapeHtml(breakInicio)}"
                data-break-fin="${escapeHtml(breakFin)}"
                aria-label="Ver detalle de ${safeName} el ${safeDate}: ${safeStatus}"
              >
                ${hasRealTimes ? `
                  <div class="flex flex-col items-center justify-center h-full gap-0.5 leading-tight py-1">
                    <span class="font-black text-[9px] leading-none tracking-wider opacity-90">${initials}</span>
                    <span class="text-[10.5px] font-mono font-bold leading-none ${timeTextClass} tabular-nums">${entradaReal || '--'}</span>
                    <span class="text-[10.5px] font-mono font-bold leading-none ${timeTextClass} tabular-nums">${salidaReal || '--'}</span>
                  </div>
                ` : `<span class="font-black text-xs leading-none tracking-tight">${initials}</span>`}
                ${isLicenseOverlap ? '<div class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-error border border-base-100"></div>' : ''}
                ${hasComment ? '<div class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-amber-500 border border-base-100" title="Tiene comentario"></div>' : ''}
              </button>
            </td>
          `;
        });
        tbodyHtml += `</tr>`;
      });
    }

    if (tbody) tbody.innerHTML = tbodyHtml;

    // Update Global Alert Badge
    const alertBadge = document.getElementById('compliance-alert-badge');
    const alertText = document.getElementById('compliance-alert-text');
    if (alertBadge && alertText) {
      if (totalInconsistencies > 0) {
        alertBadge.classList.remove('hidden');
        alertText.innerText = `${totalInconsistencies} Inconsistencia${totalInconsistencies > 1 ? 's' : ''} detectada${totalInconsistencies > 1 ? 's' : ''}`;
      } else {
        alertBadge.classList.add('hidden');
      }
    }

    // --- FEATURE: Coverage Visualizer (Heatmap Footer) ---
    const dailyCoverage = dates.map(date => {
      let p = 0, ho = 0;
      cronoData.forEach(op => {
        const s = op.asistencia[date];
        if (s === 'Presencial') p++;
        else if (s === 'Home Office') ho++;
      });
      return { p, ho, total: p + ho };
    });

    const pyClass = isCoverageMinimized ? 'py-1.5' : 'py-3.5';
    const chevronIcon = isCoverageMinimized ? 
      `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-up transition-transform duration-200"><path d="m18 15-6-6-6 6"/></svg>` : 
      `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>`;

    let tfootHtml = `<tr>
      <td class="sticky left-0 bg-base-200 z-50 w-[200px] min-w-[200px] ${pyClass} px-6 border-r border-base-300">
        <div class="flex items-center justify-between gap-2">
          <span class="text-[10px] font-black uppercase tracking-[0.1em] text-base-content/60">Resumen Cobertura</span>
          <button
            type="button"
            id="toggle-coverage-btn"
            class="btn btn-xs btn-ghost p-0.5 rounded hover:bg-base-300 text-base-content/50 hover:text-base-content transition-all"
            title="${isCoverageMinimized ? 'Maximizar resumen de cobertura' : 'Minimizar resumen de cobertura'}"
            aria-label="${isCoverageMinimized ? 'Maximizar resumen de cobertura' : 'Minimizar resumen de cobertura'}"
          >
            ${chevronIcon}
          </button>
        </div>
      </td>
      <td class="sticky left-[200px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center ${pyClass} text-[10px] font-black border-r border-base-300 text-base-content/40" title="Total Operadores">${teamSize}</td>
      <td class="sticky left-[240px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center ${pyClass} text-[10px] font-black border-r border-base-300 text-base-content/20">-</td>
      <td class="sticky left-[280px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center ${pyClass} text-[10px] font-black border-r border-base-300 text-base-content/20 shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]">-</td>
    `;

    dailyCoverage.forEach(c => {
      const hoPercent = (c.ho / teamSize) * 100;
      const pPercent = (c.p / teamSize) * 100;
      const totalPercent = ((c.p + c.ho) / teamSize) * 100;
      const isLowCoverage = totalPercent < 40;

      const cellPyClass = isCoverageMinimized ? 'py-1 px-1' : 'py-2 px-1';

      tfootHtml += `
        <td class="${cellPyClass} border-r border-base-200/50 min-w-[4rem] ${isLowCoverage ? 'bg-error/5' : ''}">
          <div class="flex flex-col items-center gap-1.5">
             ${isCoverageMinimized ? '' : `
             <div class="flex flex-col w-2.5 h-12 bg-base-300/30 rounded-full overflow-hidden justify-end shadow-[inset_0_1px_2px_rgba(0,0,0,0.1)]">
                <div class="bg-amber-500 w-full transition-all duration-500" style="height: ${hoPercent}%" title="HO: ${c.ho}"></div>
                <div class="bg-secondary w-full transition-all duration-500" style="height: ${pPercent}%" title="Presencial: ${c.p}"></div>
             </div>
             `}
             <div class="flex flex-col items-center leading-none">
                <span class="text-[10px] font-black ${isLowCoverage ? 'text-error' : 'text-base-content/60'}">${c.p + c.ho}</span>
                <span class="text-[7px] font-black uppercase opacity-30">Activos</span>
             </div>
          </div>
        </td>
      `;
    });
    tfootHtml += `</tr>`;

    const tfoot = document.getElementById('monthly-tfoot');
    if (tfoot) tfoot.innerHTML = tfootHtml;
  }

  function updateCellStatus(cell: HTMLElement, newStatus: string) {
    const operator = cell.dataset.operator;
    const date = cell.dataset.date;
    if (!operator || !date) return;

    // Track the changes in our pending changes array
    const existingIndex = modifiedSchedules.findIndex(e => e.agentName === operator && e.date === date);
    if (existingIndex !== -1) {
      modifiedSchedules[existingIndex].status = newStatus;
    } else {
      modifiedSchedules.push({ agentName: operator, date, status: newStatus });
    }

    // Update in-memory data
    const opIndex = cronoData.findIndex(o => o.nombre === operator);
    if (opIndex !== -1) {
      cronoData[opIndex].asistencia[date] = newStatus;
      renderMonthly(); // Full re-render to update stats and colors
    }

    // Update toolbar pending edits if we are in general edit mode
    if (isEditMode) {
      updatePendingEditsUI();
    }
  }

  function updatePendingEditsUI() {
     const uniqueKeys = new Set<string>();
     Object.keys(pendingEdits).forEach(k => uniqueKeys.add(k));
     modifiedSchedules.forEach(m => uniqueKeys.add(`${m.agentName}_${m.date}`));
     
     const count = uniqueKeys.size;
     const countEl = document.getElementById('pending-edits-count');
     const saveBtn = document.getElementById('save-edits-btn') as HTMLButtonElement | null;
     const discardBtn = document.getElementById('discard-edits-btn') as HTMLButtonElement | null;
     
     if (countEl) countEl.innerText = `${count} cambios`;
     if (saveBtn) saveBtn.disabled = count === 0;
     if (discardBtn) discardBtn.disabled = count === 0;
  }

  async function discardChanges() {
    try {
      const res = await fetch('/api/cronograma');
      cronoData = await res.json();
      modifiedSchedules = [];
      
      const saveIndicator = document.getElementById('save-indicator');
      if (saveIndicator) saveIndicator.classList.add('hidden');

      renderDaily();
      renderMonthly();
    } catch (err) {
      console.error("Error discarding/reloading data:", err);
    }
  }

  async function saveChangesToServer() {
    const saveBtn = document.getElementById('save-confirm-btn') as HTMLButtonElement | null;
    const discardBtn = document.getElementById('save-discard-btn') as HTMLButtonElement | null;
    const indicatorText = document.getElementById('save-indicator-text');

    if (saveBtn) {
      saveBtn.disabled = true;
      saveBtn.innerHTML = `<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Guardando...`;
    }
    if (discardBtn) discardBtn.disabled = true;

    try {
      const response = await fetch('/api/cronograma', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ edits: modifiedSchedules })
      });

      if (!response.ok) throw new Error("Error al guardar cambios");

      // Success visual feedback
      if (indicatorText) {
        indicatorText.innerText = "¡Cambios guardados con éxito!";
      }

      // Complete reset
      modifiedSchedules = [];
      
      // Fetch latest merged data to be absolutely sure
      const res = await fetch('/api/cronograma');
      cronoData = await res.json();

      setTimeout(() => {
        const saveIndicator = document.getElementById('save-indicator');
        if (saveIndicator) saveIndicator.classList.add('hidden');
        
        // Restore buttons
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerText = "Guardar";
        }
        if (discardBtn) discardBtn.disabled = false;
        
        if (indicatorText) {
          indicatorText.innerText = "Edición en progreso: Cambios pendientes";
        }

        renderDaily();
        renderMonthly();
      }, 1500);

    } catch (error) {
      console.error("Error saving changes:", error);
      if (indicatorText) {
        indicatorText.innerText = "Error al guardar en el servidor";
      }
      if (saveBtn) {
        saveBtn.disabled = false;
        saveBtn.innerText = "Reintentar";
      }
      if (discardBtn) discardBtn.disabled = false;
    }
  }

  function getDetailStatusClass(status: string) {
    if (status === 'Presencial') return 'text-secondary';
    if (status === 'Home Office') return 'text-amber-600 dark:text-amber-400';
    if (status === 'Licencia') return 'text-error';
    if (status === 'Vacaciones') return 'text-success';
    if (status === 'Horas Extras') return 'text-sky-600 dark:text-sky-400';
    return 'text-base-content/40';
  }

  function getDetailIndicatorClass(status: string) {
    if (status === 'Presencial') return 'bg-secondary';
    if (status === 'Home Office') return 'bg-amber-500';
    if (status === 'Licencia') return 'bg-error';
    if (status === 'Vacaciones') return 'bg-success';
    if (status === 'Horas Extras') return 'bg-sky-500';
    return 'bg-base-300';
  }

  function openMonthlyDetail(trigger: HTMLElement) {
    const overlay = document.getElementById('monthly-detail-overlay') as HTMLElement;
    const modal = document.getElementById('monthly-detail-modal') as HTMLElement;
    const closeButton = document.getElementById('monthly-detail-close') as HTMLButtonElement | null;
    const title = document.getElementById('monthly-detail-title') as HTMLElement;
    const date = document.getElementById('monthly-detail-date') as HTMLElement;
    const status = document.getElementById('monthly-detail-status') as HTMLElement;
    const indicator = document.getElementById('modal-status-indicator') as HTMLElement;
    const schedule = document.getElementById('monthly-detail-schedule') as HTMLElement;
    const user = document.getElementById('monthly-detail-user') as HTMLElement;
    const pointer = document.getElementById('modal-pointer') as HTMLElement;

    activeDetailTrigger = trigger;
    const commentValue = trigger.dataset.comment || '';
    const commentTextarea = document.getElementById('monthly-detail-comment') as HTMLTextAreaElement | null;
    if (commentTextarea) {
      commentTextarea.value = commentValue;
    }
    const commentIndicator = document.getElementById('monthly-comment-indicator');
    if (commentIndicator) {
      commentIndicator.classList.remove('opacity-100');
      commentIndicator.classList.add('opacity-0');
    }

    const entradaRealValue = trigger.dataset.entradaReal || '';
    const salidaRealValue = trigger.dataset.salidaReal || '';
    const detailEntradaInput = document.getElementById('monthly-detail-entrada') as HTMLInputElement | null;
    const detailSalidaInput = document.getElementById('monthly-detail-salida') as HTMLInputElement | null;
    if (detailEntradaInput) detailEntradaInput.value = entradaRealValue;
    if (detailSalidaInput) detailSalidaInput.value = salidaRealValue;
    const realTimeIndicator = document.getElementById('monthly-real-time-indicator');
    if (realTimeIndicator) {
      realTimeIndicator.classList.remove('opacity-100');
      realTimeIndicator.classList.add('opacity-0');
    }

    const breakInicioValue = trigger.dataset.breakInicio || '';
    const breakFinValue = trigger.dataset.breakFin || '';
    const detailBreakInicioInput = document.getElementById('monthly-detail-break-inicio') as HTMLInputElement | null;
    const detailBreakFinInput = document.getElementById('monthly-detail-break-fin') as HTMLInputElement | null;
    if (detailBreakInicioInput) detailBreakInicioInput.value = breakInicioValue;
    if (detailBreakFinInput) detailBreakFinInput.value = breakFinValue;
    const breakTimeIndicator = document.getElementById('monthly-break-time-indicator');
    if (breakTimeIndicator) {
      breakTimeIndicator.classList.remove('opacity-100');
      breakTimeIndicator.classList.add('opacity-0');
    }

    const operatorName = trigger.dataset.operator || '';
    const dateValue = trigger.dataset.date || '';
    const statusValue = trigger.dataset.status || 'Franco';
    const horario = trigger.dataset.horario || '-';
    const username = trigger.dataset.username || '';
    const isAbsent = statusValue === 'Licencia' || statusValue === 'Vacaciones' || statusValue === 'Franco';

    title.innerText = operatorName;
    date.innerText = formatDetailDate(dateValue);
    status.innerText = statusValue;
    status.className = `inline-block text-[11px] font-black uppercase tracking-wider ${getDetailStatusClass(statusValue)}`;
    indicator.className = `w-2.5 h-2.5 rounded-full animate-pulse ${getDetailIndicatorClass(statusValue)}`;
    if (schedule instanceof HTMLInputElement) { schedule.value = isAbsent ? '' : horario; } else { schedule.innerText = isAbsent ? 'Ausente' : horario; }
    const scheduleText = document.getElementById('monthly-detail-schedule-text');
    if (scheduleText) {
      scheduleText.innerText = isAbsent ? 'Franco' : (horario || '-');
      scheduleText.classList.remove('hidden');
      schedule.classList.add('hidden');
    }
    user.innerText = username ? `${username}@correoargentino.com.ar` : '-';

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    
    const rect = trigger.getBoundingClientRect();
    const modalWidth = 288;
    const modalHeight = modal.offsetHeight || 320; 
    const padding = 20;
    
    if (window.innerWidth > 768) {
      overlay.classList.remove('items-start', 'items-center', 'justify-center');
      modal.style.position = 'absolute';
      
      const left = Math.max(20, Math.min(window.innerWidth - modalWidth - 20, rect.left + rect.width/2 - modalWidth/2));
      
      const spaceBelow = window.innerHeight - rect.bottom;
      const showAbove = spaceBelow < (modalHeight + padding);
      
      let top = 0;
      if (showAbove) {
        top = rect.top - modalHeight - 12;
        modal.style.transformOrigin = 'bottom center';
        pointer.className = "absolute w-5 h-5 bg-base-100 border-r-2 border-b-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -bottom-2.5";
      } else {
        top = rect.bottom + 12;
        modal.style.transformOrigin = 'top center';
        pointer.className = "absolute w-5 h-5 bg-base-100 border-l-2 border-t-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -top-2.5";
      }
      
      const clampedTop = Math.max(12, Math.min(window.innerHeight - modalHeight - 12, top));
      modal.style.top = `${clampedTop}px`;
      
      modal.style.left = `${left}px`;
      modal.style.margin = '0';
      
      const pointerOffset = rect.left + rect.width/2 - left;
      pointer.style.left = `${pointerOffset}px`;
    } else {
      overlay.classList.remove('items-start');
      overlay.classList.add('items-center', 'justify-center');
      modal.style.position = '';
      modal.style.left = '';
      modal.style.top = '';
      modal.style.margin = '0';
      pointer.style.left = '50%';
      pointer.className = "absolute w-5 h-5 bg-base-100 border-l-2 border-t-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -top-2.5 hidden";
    }

    overlay.setAttribute('aria-hidden', 'false');
    closeButton?.focus();
  }

  function closeMonthlyDetail() {
    const overlay = document.getElementById('monthly-detail-overlay');
    if (!overlay) return;

    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    overlay.setAttribute('aria-hidden', 'true');
  }

  function updateViewSwitcherUI(activeView: 'monthly' | 'daily') {
    const switchToMonthlyBtn = document.getElementById('switch-to-monthly-btn');
    const switchToDailyBtn = document.getElementById('switch-to-daily-btn');
    
    const activeClasses = ['btn-secondary', 'shadow-sm', 'shadow-secondary/15'];
    const inactiveClasses = ['btn-outline', 'border-transparent', 'text-base-content/60', 'hover:bg-base-200/50'];
    
    if (activeView === 'monthly') {
      switchToMonthlyBtn?.classList.add(...activeClasses);
      switchToMonthlyBtn?.classList.remove(...inactiveClasses);
      
      switchToDailyBtn?.classList.add(...inactiveClasses);
      switchToDailyBtn?.classList.remove(...activeClasses);
    } else {
      switchToDailyBtn?.classList.add(...activeClasses);
      switchToDailyBtn?.classList.remove(...inactiveClasses);
      
      switchToMonthlyBtn?.classList.add(...inactiveClasses);
      switchToMonthlyBtn?.classList.remove(...activeClasses);
    }
  }

  function showDailyView() {
    const dailyView = document.getElementById('daily-view');
    const monthlyView = document.getElementById('monthly-view');
    const datePickerContainer = document.getElementById('date-picker-container');
    
    renderDaily();
    updateViewSwitcherUI('daily');
    
    if (dailyView) dailyView.classList.remove('hidden');
    if (monthlyView) monthlyView.classList.add('hidden');
    
    if (datePickerContainer) {
      datePickerContainer.classList.remove('hidden');
      setTimeout(() => {
        datePickerContainer.classList.remove('is-faded');
      }, 50);
    }
  }

  function showMonthlyView() {
    const dailyView = document.getElementById('daily-view');
    const monthlyView = document.getElementById('monthly-view');
    const datePickerContainer = document.getElementById('date-picker-container');
    
    updateViewSwitcherUI('monthly');
    
    if (dailyView) dailyView.classList.add('hidden');
    if (monthlyView) monthlyView.classList.remove('hidden');
    
    if (datePickerContainer) {
      datePickerContainer.classList.add('is-faded');
      setTimeout(() => {
        datePickerContainer.classList.add('hidden');
      }, 300);
    }
  }

  function setupEventListeners() {
    // --- New Operator Modal Handlers ---
    const newOpModal = document.getElementById('new-operator-modal') as HTMLDialogElement & { showModal: () => void, close: () => void };
    const openNewOpBtn = document.getElementById('open-new-op-modal');
    const cancelNewOpBtn = document.getElementById('cancel-new-op');
    const confirmNewOpBtn = document.getElementById('confirm-new-op') as HTMLButtonElement | null;

    openNewOpBtn?.addEventListener('click', () => {
      newOpModal.showModal();
    });

    cancelNewOpBtn?.addEventListener('click', () => {
      const nameInput = document.getElementById('new-op-name') as HTMLInputElement;
      const usernameInput = document.getElementById('new-op-username') as HTMLInputElement;
      const locSelect = document.getElementById('new-op-location') as HTMLSelectElement;
      const scheduleInput = document.getElementById('new-op-schedule') as HTMLInputElement;
      
      if (nameInput) nameInput.value = '';
      if (usernameInput) usernameInput.value = '';
      if (locSelect) locSelect.value = 'Monte Grande';
      if (scheduleInput) scheduleInput.value = '08:00 - 17:00';
      newOpModal.close();
    });

    confirmNewOpBtn?.addEventListener('click', async (e) => {
      e.preventDefault();
      const nameInput = document.getElementById('new-op-name') as HTMLInputElement;
      const usernameInput = document.getElementById('new-op-username') as HTMLInputElement;
      const locSelect = document.getElementById('new-op-location') as HTMLSelectElement;
      const scheduleInput = document.getElementById('new-op-schedule') as HTMLInputElement;

      const name = nameInput?.value?.trim();
      const username = usernameInput?.value?.trim();
      const location = locSelect?.value;
      const horarioDefault = scheduleInput?.value?.trim();

      if (!name) {
        alert("El nombre completo es requerido.");
        return;
      }

      if (confirmNewOpBtn) confirmNewOpBtn.disabled = true;

      try {
        const response = await fetch('/api/cronograma/operators', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, username, location, horarioDefault })
        });

        const data = await response.json();
        if (!response.ok) {
          throw new Error(data.error || "Error al agregar operador");
        }

        // Fetch fresh data
        const freshRes = await fetch('/api/cronograma');
        cronoData = await freshRes.json();

        // Clear and close
        if (nameInput) nameInput.value = '';
        if (usernameInput) usernameInput.value = '';
        if (locSelect) locSelect.value = 'Monte Grande';
        if (scheduleInput) scheduleInput.value = '08:00 - 17:00';
        newOpModal.close();

        // Re-render
        renderMonthly();
        renderDaily();
        
        alert(`Operador "${name}" agregado con éxito.`);
      } catch (err: any) {
        console.error("Error creating operator:", err);
        alert(err.message || "Error al intentar crear operador.");
      } finally {
        if (confirmNewOpBtn) confirmNewOpBtn.disabled = false;
      }
    });

    // --- Edit Operator Modal Handlers ---
    const editOpModal = document.getElementById('edit-operator-modal') as HTMLDialogElement & { showModal: () => void, close: () => void };
    const cancelEditOpBtn = document.getElementById('cancel-edit-op');
    const confirmEditOpBtn = document.getElementById('confirm-edit-op') as HTMLButtonElement | null;

    cancelEditOpBtn?.addEventListener('click', () => {
      editOpModal.close();
    });

    confirmEditOpBtn?.addEventListener('click', async (e) => {
      e.preventDefault();
      const originalNameInput = document.getElementById('edit-op-original-name') as HTMLInputElement;
      const nameInput = document.getElementById('edit-op-name') as HTMLInputElement;
      const usernameInput = document.getElementById('edit-op-username') as HTMLInputElement;
      const locSelect = document.getElementById('edit-op-location') as HTMLSelectElement;
      const scheduleInput = document.getElementById('edit-op-schedule') as HTMLInputElement;

      const originalName = originalNameInput?.value;
      const name = nameInput?.value?.trim();
      const username = usernameInput?.value?.trim();
      const location = locSelect?.value;
