  function renderMonthly() {
    const thead = document.getElementById('monthly-thead');
    const tbody = document.getElementById('monthly-tbody');
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    const selectedDateStr = dateInput?.value || formatYMD(new Date());
    
    const [yearStr, monthStr] = selectedDateStr.split('-');
    const year = parseInt(yearStr);
    const month = parseInt(monthStr) - 1;
    const daysInMonth = getDaysInMonth(year, month);
    const currentMonthPrefix = `${yearStr}-${monthStr}`;
    
    const dates = Array.from({length: daysInMonth}, (_, i) => `${currentMonthPrefix}-${(i + 1).toString().padStart(2, '0')}`);
    const todayStr = formatYMD(new Date());

    // --- RULE: Coverage Pre-calculation ---
    const coveragePerDay: Record<string, { total: number, licenses: number }> = {};
    dates.forEach(d => {
      let active = 0;
      let lics = 0;
      cronoData.forEach(op => {
        const s = op.asistencia[d];
        if (s === 'Presencial' || s === 'Home Office') active++;
        if (s === 'Licencia' || s === 'Vacaciones') lics++;
      });
      coveragePerDay[d] = { total: active, licenses: lics };
    });

    const teamSize = cronoData.length;
    let totalInconsistencies = 0;

    let theadHtml = `<tr>
      <th class="sticky left-0 bg-base-100 z-50 w-[200px] min-w-[200px] border-r border-b border-base-200 px-6 py-4 font-black text-xs uppercase tracking-widest text-base-content/50">Operador</th>
      <th class="sticky left-[200px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center" title="Presencial">P</th>
      <th class="sticky left-[240px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center" title="Home Office">HO</th>
      <th class="sticky left-[280px] bg-base-100 z-50 w-[40px] min-w-[40px] border-r border-b border-base-200 px-1 py-4 font-black text-[9px] uppercase tracking-widest text-base-content/40 text-center shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]" title="Licencia/Vacaciones">L</th>
`;
    
    dates.forEach(date => {
      const d = new Date(date + 'T12:00:00');
      const isToday = date === todayStr;
      const isWeekend = d.getDay() === 0 || d.getDay() === 6;
      const isCritical = (coveragePerDay[date].total / teamSize) < 0.4;
      
      let thClass = "text-center min-w-[3rem] px-0 border-r border-b border-base-200 transition-colors";
      if (isToday) thClass += " bg-secondary text-secondary-content border-b-secondary border-b-2";
      else if (isWeekend) thClass += " bg-base-200/50 text-base-content/30";
      else if (isCritical) thClass += " bg-error/10 text-error";
      else thClass += " text-base-content/70";
      
      const formatter = new Intl.DateTimeFormat('es-AR', { weekday: 'short' });
      const dayName = formatter.format(d).substring(0, 2).toUpperCase();
      
      theadHtml += `
        <th class="${thClass}">
          <div class="flex flex-col items-center py-2 gap-0.5">
            <span class="font-extrabold text-xs tracking-wide ${isToday ? 'opacity-80' : 'opacity-60'}">${dayName}</span>
            <div class="flex items-center gap-1">
               <span class="font-black text-sm ${isToday ? 'scale-125' : ''}">${d.getDate()}</span>
               ${isCritical ? '<div class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></div>' : ''}
            </div>
            ${isToday ? `<span class="text-[8px] font-black tracking-wide uppercase opacity-70">HOY</span>` : ''}
          </div>
        </th>
      `;
    });
    theadHtml += `</tr>`;
    if (thead) thead.innerHTML = theadHtml;

    let tbodyHtml = '';
    cronoData.forEach(op => {
      const stats = { P: 0, HO: 0, L: 0 };
      dates.forEach(d => {
        const s = op.asistencia[d];
        if (s === 'Presencial') stats.P++;
        else if (s === 'Home Office') stats.HO++;
        else if (s === 'Licencia' || s === 'Vacaciones') stats.L++;
      });

      // --- RULE: Consecutive HO Check ---
      let maxConsecutiveHO = 0;
      let currentHO = 0;
      dates.forEach(d => {
        if (op.asistencia[d] === 'Home Office') {
          currentHO++;
          maxConsecutiveHO = Math.max(maxConsecutiveHO, currentHO);
        } else if (op.asistencia[d] !== 'Franco' && op.asistencia[d]) {
          currentHO = 0;
        }
      });
      const hoViolation = maxConsecutiveHO > 5;
      if (hoViolation) totalInconsistencies++;

      tbodyHtml += `<tr class="group ${hoViolation ? 'bg-error/[0.02]' : ''}" data-op-name="${op.nombre.toLowerCase()}">
        <td class="sticky left-0 bg-base-100 z-40 w-[200px] min-w-[200px] font-bold py-3 px-6 text-xs border-r border-b border-base-200/70 group-hover:bg-base-200 transition-colors">
          <div class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full ${hoViolation ? 'bg-error animate-pulse' : 'bg-base-300 group-hover:bg-primary'} transition-colors shadow-sm"></div>
            <div class="flex flex-col min-w-0">
               <button class="hover:text-secondary hover:underline underline-offset-2 transition-all text-left truncate" data-op-profile="${op.nombre}">
                ${op.nombre}
              </button>
              ${hoViolation ? `<span class="text-[7px] font-black text-error uppercase tracking-tighter">⚠️ Exceso de HO (${maxConsecutiveHO}d)</span>` : ''}
            </div>
          </div>
        </td>
        <td class="sticky left-[200px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center text-[10px] font-black border-r border-b border-base-200/70 text-secondary group-hover:bg-base-200 transition-colors">${stats.P}</td>
        <td class="sticky left-[240px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center text-[10px] font-black border-r border-b border-base-200/70 text-primary group-hover:bg-base-200 transition-colors">${stats.HO}</td>
        <td class="sticky left-[280px] bg-base-100 z-40 w-[40px] min-w-[40px] py-3 px-1 text-center text-[10px] font-black border-r border-b border-base-200/70 text-error group-hover:bg-base-200 transition-colors shadow-[4px_0_10px_-5px_rgba(0,0,0,0.05)]">${stats.L}</td>
`;
        
      dates.forEach(date => {
        const status = op.asistencia[date];
        const styles = getStatusStyles(status);
        const isTodayCell = date === todayStr;
        const safeName = escapeHtml(op.nombre);
        const safeDate = escapeHtml(date);
        const safeStatus = escapeHtml(status || 'Franco');
        const safeHorario = escapeHtml(op.horario);
        const username = getUsername(op.nombre);
        
        // --- RULE: License Overlap Check ---
        const isLicenseOverlap = (status === 'Licencia' || status === 'Vacaciones') && coveragePerDay[date].licenses > 2;
        if (isLicenseOverlap) totalInconsistencies++;

        let cellClass = `p-1.5 border-r border-b border-base-200/50 text-center transition-all duration-300`;
        if (isTodayCell) cellClass += ' bg-secondary/10';
        if (isLicenseOverlap) cellClass += ' ring-1 ring-inset ring-error/30 bg-error/[0.03]';
        
        if (status === 'Franco' || !status) {
          tbodyHtml += `<td class="${cellClass}">
            <button
              type="button"
              class="monthly-cell-button h-8 ${isTodayCell ? 'bg-secondary/15 border border-secondary/30' : 'bg-base-200/20 border border-base-300/20'}"
              data-monthly-detail
              data-operator="${safeName}"
              data-date="${safeDate}"
              data-status="Franco"
              data-horario="${safeHorario}"
              data-username="${escapeHtml(username)}"
              aria-label="Ver detalle de ${safeName} el ${safeDate}: Franco"
            ></button>
          </td>`;
          return;
        }

        let initials = "";
        if (status === 'Presencial') initials = "P";
        else if (status === 'Home Office') initials = "HO";
        else if (status === 'Licencia') initials = "L";
        else if (status === 'Vacaciones') initials = "V";

        tbodyHtml += `
          <td class="${cellClass}">
            <button
              type="button"
              class="monthly-cell-button h-8 flex items-center justify-center transition-all duration-300 cursor-pointer hover:scale-110 hover:z-10 relative border ${isTodayCell ? 'border-secondary/40 ring-1 ring-secondary/30 shadow-[0_0_10px_rgba(37,72,136,0.1)]' : 'border-base-300/30'} ${styles.bgClass} shadow-sm hover:shadow-lg ${isLicenseOverlap ? 'border-error/40' : ''}"
              title="${op.nombre} - ${date}: ${status} ${isLicenseOverlap ? '(Solapamiento Crítico)' : ''}"
              data-monthly-detail
              data-operator="${safeName}"
              data-date="${safeDate}"
              data-status="${safeStatus}"
              data-horario="${safeHorario}"
              data-username="${escapeHtml(username)}"
              aria-label="Ver detalle de ${safeName} el ${safeDate}: ${safeStatus}"
            >
              <span class="font-black text-xs leading-none tracking-tight">${initials}</span>
              ${isLicenseOverlap ? '<div class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-error border border-base-100"></div>' : ''}
            </button>
          </td>
        `;
      });
      tbodyHtml += `</tr>`;
    });

    if (tbody) tbody.innerHTML = tbodyHtml;

    // Update Global Alert Badge
    const alertBadge = document.getElementById('compliance-alert-badge');
    const alertText = document.getElementById('compliance-alert-text');
    if (alertBadge && alertText) {
      if (totalInconsistencies > 0) {
        alertBadge.classList.remove('hidden');
        alertText.innerText = `${totalInconsistencies} Inconsistencia${totalInconsistencies > 1 ? 's' : ''} detectada${totalInconsistencies > 1 ? 's' : ''}`;
      } else {
        alertBadge.classList.add('hidden');
      }
    }

    // --- FEATURE: Coverage Visualizer (Heatmap Footer) ---
    const dailyCoverage = dates.map(date => {
      let p = 0, ho = 0;
      cronoData.forEach(op => {
        const s = op.asistencia[date];
        if (s === 'Presencial') p++;
        else if (s === 'Home Office') ho++;
      });
      return { p, ho, total: p + ho };
    });

    let tfootHtml = `<tr>
      <td class="sticky left-0 bg-base-200 z-50 w-[200px] min-w-[200px] py-4 px-6 text-[10px] font-black uppercase tracking-[0.2em] text-base-content/50 border-r border-base-300">Resumen Cobertura</td>
      <td class="sticky left-[200px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center py-4 text-[10px] font-black border-r border-base-300 text-base-content/40" title="Total Operadores">${teamSize}</td>
      <td class="sticky left-[240px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center py-4 text-[10px] font-black border-r border-base-300 text-base-content/20">-</td>
      <td class="sticky left-[280px] bg-base-200 z-50 w-[40px] min-w-[40px] text-center py-4 text-[10px] font-black border-r border-base-300 text-base-content/20 shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]">-</td>
    `;

    dailyCoverage.forEach(c => {
      const hoPercent = (c.ho / teamSize) * 100;
      const pPercent = (c.p / teamSize) * 100;
      const totalPercent = ((c.p + c.ho) / teamSize) * 100;
      const isLowCoverage = totalPercent < 40;

      tfootHtml += `
        <td class="py-2 px-1 border-r border-base-200/50 min-w-[3rem] ${isLowCoverage ? 'bg-error/5' : ''}">
          <div class="flex flex-col items-center gap-1.5">
             <div class="flex flex-col w-2.5 h-12 bg-base-300/30 rounded-full overflow-hidden justify-end shadow-[inset_0_1px_2px_rgba(0,0,0,0.1)]">
                <div class="bg-primary w-full transition-all duration-500" style="height: ${hoPercent}%" title="HO: ${c.ho}"></div>
                <div class="bg-secondary w-full transition-all duration-500" style="height: ${pPercent}%" title="Presencial: ${c.p}"></div>
             </div>
             <div class="flex flex-col items-center leading-none">
                <span class="text-[10px] font-black ${isLowCoverage ? 'text-error' : 'text-base-content/60'}">${c.p + c.ho}</span>
                <span class="text-[7px] font-black uppercase opacity-30">Activos</span>
             </div>
          </div>
        </td>
      `;
    });
    tfootHtml += `</tr>`;

    const tfoot = document.getElementById('monthly-tfoot');
    if (tfoot) tfoot.innerHTML = tfootHtml;
  }

  function updateCellStatus(cell: HTMLElement, newStatus: string) {
    const operator = cell.dataset.operator;
    const date = cell.dataset.date;
    if (!operator || !date) return;

    // Update in-memory data
    const opIndex = cronoData.findIndex(o => o.nombre === operator);
    if (opIndex !== -1) {
      cronoData[opIndex].asistencia[date] = newStatus;
      renderMonthly(); // Full re-render to update stats and colors
    }
  }

  function getDetailStatusClass(status: string) {
    if (status === 'Presencial') return 'text-secondary';
    if (status === 'Home Office') return 'text-primary';
    if (status === 'Licencia') return 'text-error';
    if (status === 'Vacaciones') return 'text-success';
    return 'text-base-content/40';
  }

  function getDetailIndicatorClass(status: string) {
    if (status === 'Presencial') return 'bg-secondary';
    if (status === 'Home Office') return 'bg-primary';
    if (status === 'Licencia') return 'bg-error';
    if (status === 'Vacaciones') return 'bg-success';
    return 'bg-base-300';
  }

  function openMonthlyDetail(trigger: HTMLElement) {
    const overlay = document.getElementById('monthly-detail-overlay');
    const modal = document.getElementById('monthly-detail-modal');
    const closeButton = document.getElementById('monthly-detail-close') as HTMLButtonElement | null;
    const title = document.getElementById('monthly-detail-title');
    const date = document.getElementById('monthly-detail-date');
    const status = document.getElementById('monthly-detail-status');
    const indicator = document.getElementById('modal-status-indicator');
    const schedule = document.getElementById('monthly-detail-schedule');
    const user = document.getElementById('monthly-detail-user');
    const pointer = document.getElementById('modal-pointer');

    if (!overlay || !modal || !title || !date || !status || !indicator || !schedule || !user || !pointer) return;

    const operatorName = trigger.dataset.operator || '';
    const dateValue = trigger.dataset.date || '';
    const statusValue = trigger.dataset.status || 'Franco';
    const horario = trigger.dataset.horario || '-';
    const username = trigger.dataset.username || '';
    const isAbsent = statusValue === 'Licencia' || statusValue === 'Vacaciones' || statusValue === 'Franco';

    title.innerText = operatorName;
    date.innerText = formatDetailDate(dateValue);
    status.innerText = statusValue;
    status.className = `inline-block text-[11px] font-black uppercase tracking-wider ${getDetailStatusClass(statusValue)}`;
    indicator.className = `w-2.5 h-2.5 rounded-full animate-pulse ${getDetailIndicatorClass(statusValue)}`;
    schedule.innerText = isAbsent ? 'Ausente' : horario;
    user.innerText = username ? `${username}@correoargentino.com.ar` : '-';

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    
    const rect = trigger.getBoundingClientRect();
    const modalWidth = 288;
    const modalHeight = modal.offsetHeight || 320; 
    const padding = 20;
    
    if (window.innerWidth > 768) {
      overlay.classList.remove('items-start', 'justify-center');
      overlay.style.backgroundColor = 'transparent';
      overlay.style.pointerEvents = 'none';
      modal.style.pointerEvents = 'auto';
      modal.style.position = 'absolute';
      
      const left = Math.max(20, Math.min(window.innerWidth - modalWidth - 20, rect.left + rect.width/2 - modalWidth/2));
      
      const spaceBelow = window.innerHeight - rect.bottom;
      const showAbove = spaceBelow < (modalHeight + padding);
      
      if (showAbove) {
        modal.style.top = `${rect.top - modalHeight - 12}px`;
        modal.style.transformOrigin = 'bottom center';
        pointer.className = "absolute w-5 h-5 bg-base-100 border-r-2 border-b-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -bottom-2.5";
      } else {
        modal.style.top = `${rect.bottom + 12}px`;
        modal.style.transformOrigin = 'top center';
        pointer.className = "absolute w-5 h-5 bg-base-100 border-l-2 border-t-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -top-2.5";
      }
      
      modal.style.left = `${left}px`;
      modal.style.margin = '0';
      
      const pointerOffset = rect.left + rect.width/2 - left;
      pointer.style.left = `${pointerOffset}px`;
    } else {
      overlay.classList.add('items-start', 'justify-center');
      overlay.style.backgroundColor = '';
      overlay.style.pointerEvents = '';
      modal.style.pointerEvents = '';
      modal.style.position = '';
      modal.style.left = '';
      modal.style.top = '';
      modal.style.margin = '4rem auto';
      pointer.style.left = '50%';
      pointer.className = "absolute w-5 h-5 bg-base-100 border-l-2 border-t-2 border-base-300 rotate-45 z-[-1] transition-all duration-200 -top-2.5";
    }

    overlay.setAttribute('aria-hidden', 'false');
    closeButton?.focus();
  }

  function closeMonthlyDetail() {
    const overlay = document.getElementById('monthly-detail-overlay');
    if (!overlay) return;

    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    overlay.setAttribute('aria-hidden', 'true');
  }

  function setupEventListeners() {
    const dateInput = document.getElementById('date-input') as HTMLInputElement;
    if (dateInput) {
      dateInput.addEventListener('change', () => {
        updateDateInputDisplay();
        renderDaily();
        renderMonthly(); 
      });
    }

    const viewBtns = document.querySelectorAll('.view-btn');
    const datePickerContainer = document.getElementById('date-picker-container');
    const dailyView = document.getElementById('daily-view');
    const monthlyView = document.getElementById('monthly-view');
    const monthlyBody = document.getElementById('monthly-tbody');
    const detailOverlay = document.getElementById('monthly-detail-overlay');
    const detailClose = document.getElementById('monthly-detail-close');

    monthlyBody?.addEventListener('click', (event) => {
      const trigger = (event.target as HTMLElement).closest<HTMLElement>('[data-monthly-detail]');
      if (!trigger) return;
      openMonthlyDetail(trigger);
    });

    detailClose?.addEventListener('click', closeMonthlyDetail);

    detailOverlay?.addEventListener('click', (event) => {
      if (event.target === detailOverlay) closeMonthlyDetail();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMonthlyDetail();
    });

    viewBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.getAttribute('data-view');
        const statsContainer = document.getElementById('stats-container');
        
        if (dailyView) dailyView.classList.toggle('hidden', view !== 'daily');
        if (monthlyView) monthlyView.classList.toggle('hidden', view !== 'monthly');
        if (statsContainer) statsContainer.classList.toggle('hidden', view === 'monthly');
        
        if (datePickerContainer) {
          datePickerContainer.classList.toggle('is-faded', view === 'monthly');
          setTimeout(() => {
              datePickerContainer.classList.toggle('hidden', view === 'monthly');
          }, view === 'monthly' ? 300 : 0);
        }

        viewBtns.forEach(b => {
          b.classList.remove('bg-secondary', 'text-secondary-content', 'shadow-sm');
          b.classList.add('text-base-content/50');
        });
        
        btn.classList.add('bg-secondary', 'text-secondary-content', 'shadow-sm');
        btn.classList.remove('text-base-content/50');
      });
    });

    const searchInput = document.getElementById('monthly-search') as HTMLInputElement;
    searchInput?.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase();
      const rows = document.querySelectorAll('#monthly-tbody tr');
      rows.forEach(row => {
        const name = (row as HTMLElement).dataset.opName || '';
        (row as HTMLElement).style.display = name.includes(term) ? '' : 'none';
      });
    });

    const quickEditMenu = document.getElementById('quick-edit-menu');
    const saveIndicator = document.getElementById('save-indicator');
    let activeCell: HTMLElement | null = null;

    monthlyBody?.addEventListener('contextmenu', (e) => {
      const trigger = (e.target as HTMLElement).closest<HTMLElement>('[data-monthly-detail]');
      if (!trigger || !quickEditMenu) return;
      
      e.preventDefault();
      activeCell = trigger;
      
      const targetName = document.getElementById('quick-edit-target-name');
      if (targetName) targetName.innerText = trigger.dataset.operator || 'Operador';
      
      quickEditMenu.classList.remove('hidden');
      quickEditMenu.style.left = `${e.clientX}px`;
      quickEditMenu.style.top = `${e.clientY}px`;
    });

    document.getElementById('quick-edit-options')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button');
      if (!btn || !activeCell || !quickEditMenu) return;
      
      const newStatus = btn.dataset.status;
      if (newStatus) {
        updateCellStatus(activeCell, newStatus);
        saveIndicator?.classList.remove('hidden');
        quickEditMenu.classList.add('hidden');
      }
    });

    document.addEventListener('click', (e) => {
      if (quickEditMenu && !quickEditMenu.contains(e.target as Node)) {
        quickEditMenu.classList.add('hidden');
      }
    });

    document.getElementById('save-confirm-btn')?.addEventListener('click', () => {
        saveIndicator?.classList.add('hidden');
        renderMonthly(); // Reset changes
    });


    const printBtn = document.querySelector('.btn-secondary.gap-1');
    printBtn?.addEventListener('click', () => window.print());

    const exportBtn = document.querySelector('.btn-outline.gap-1');
    exportBtn?.addEventListener('click', () => {
      // ... export logic
    });

    // --- FEATURE: Operator Profile Drawer ---
    const drawerOverlay = document.getElementById('operator-drawer-overlay');
    const drawer = document.getElementById('operator-drawer');
    const closeDrawerBtn = document.getElementById('close-drawer');

    const openDrawer = (opName: string) => {
      const op = cronoData.find(o => o.nombre === opName);
      if (!op || !drawerOverlay || !drawer) return;

      document.getElementById('drawer-op-name')!.innerText = op.nombre;
      document.getElementById('drawer-op-email')!.innerText = `${getUsername(op.nombre)}@correoargentino.com.ar`;

      // Stats
      let p = 0, ho = 0;
      Object.values(op.asistencia).forEach(s => {
        if (s === 'Presencial') p++;
        else if (s === 'Home Office') ho++;
      });
      document.getElementById('drawer-stat-p')!.innerText = p.toString();
      document.getElementById('drawer-stat-ho')!.innerText = ho.toString();

      // History list
      const historyList = document.getElementById('drawer-history-list');
      if (historyList) {
        const sortedDates = Object.keys(op.asistencia).sort().reverse().slice(0, 10);
        historyList.innerHTML = sortedDates.map(date => {
          const status = op.asistencia[date];
          const styles = getStatusStyles(status);
          return `
            <div class="flex items-center justify-between p-3 bg-base-200/30 rounded-xl border border-base-300/50">
              <span class="text-xs font-bold text-base-content/60">${formatDMY(date)}</span>
              <span class="${styles.badge} scale-90">${status}</span>
            </div>
          `;
        }).join('');
      }

      drawerOverlay.classList.remove('hidden');
      drawerOverlay.classList.add('flex');
      
      setTimeout(() => {
        if (drawer) drawer.classList.add('is-active');
      }, 10);
      
      document.body.style.overflow = 'hidden';
    };

    const closeDrawer = () => {
      if (!drawer || !drawerOverlay) return;
      drawer.classList.remove('is-active');
      setTimeout(() => {
        drawerOverlay.classList.add('hidden');
        drawerOverlay.classList.remove('flex');
        document.body.style.overflow = '';
      }, 300);
    };

    document.addEventListener('click', (e) => {
      const profileBtn = (e.target as HTMLElement).closest<HTMLElement>('[data-op-profile]');
      if (profileBtn) {
        openDrawer(profileBtn.dataset.opProfile!);
      }
    });

    closeDrawerBtn?.addEventListener('click', closeDrawer);
    drawerOverlay?.addEventListener('click', (e) => {
      if (e.target === drawerOverlay) closeDrawer();
    });
  }

  init();
</script>
