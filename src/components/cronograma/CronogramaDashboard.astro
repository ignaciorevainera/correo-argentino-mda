    // --- FEATURE: Premium Exporters ---
    function exportCSV() {
      const dates = getDatesArrayForCurrentMonth();
      const headers = ["Operador", "Presencial (P)", "Home Office (HO)", "Licencia/Vacaciones (L)"];
      dates.forEach(d => {
        headers.push(d);
      });
      
      let csvRows = [headers.join(",")];
      
      cronoData.forEach(op => {
        const stats = { P: 0, HO: 0, L: 0 };
        dates.forEach(d => {
          const s = op.asistencia[d];
          if (s === 'Presencial') stats.P++;
          else if (s === 'Home Office') stats.HO++;
          else if (s === 'Licencia' || s === 'Vacaciones') stats.L++;
        });
        
        const row = [
          `"${op.nombre}"`,
          stats.P,
          stats.HO,
          stats.L
        ];
        
        dates.forEach(d => {
          const status = op.asistencia[d] || 'Franco';
          const comment = op.comentarios?.[d] || '';
          const cellValue = comment ? `${status} (${comment})` : status;
          row.push(`"${cellValue.replace(/"/g, '""')}"`);
        });
        
        csvRows.push(row.join(","));
      });
      
      const blob = new Blob(["\uFEFF" + csvRows.join("\n")], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      
      const dateInput = document.getElementById('date-input') as HTMLInputElement | null;
      let monthName = 'reporte';
      if (dateInput && dateInput.value) {
        const d = new Date(dateInput.value + 'T12:00:00');
        monthName = new Intl.DateTimeFormat('es-AR', { month: 'long', year: 'numeric' }).format(d);
      }
      
      link.setAttribute("download", `cronograma_${monthName.toLowerCase().replace(/\s+/g, '_')}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    async function exportAsImage() {
      const tableContainer = document.querySelector('#monthly-table')?.parentElement;
      if (!tableContainer) return;

      const imgBtn = document.getElementById('export-image-btn') as HTMLButtonElement | null;
      const originalText = imgBtn ? imgBtn.innerHTML : '';
      if (imgBtn) {
        imgBtn.disabled = true;
        imgBtn.innerHTML = `<span class="loading loading-spinner loading-xs mr-1"></span> Procesando...`;
      }

      try {
        const originalMaxHeight = tableContainer.style.maxHeight;
        const originalOverflow = tableContainer.style.overflow;
        tableContainer.style.maxHeight = 'none';
        tableContainer.style.overflow = 'visible';

        const { toPng } = await import('html-to-image');
        
        const dataUrl = await toPng(tableContainer, {
          backgroundColor: 'var(--color-base-100, #ffffff)',
          style: {
            transform: 'scale(1)',
            transformOrigin: 'top left',
            width: tableContainer.scrollWidth + 'px',
            height: tableContainer.scrollHeight + 'px'
          },
          quality: 1.0,
          pixelRatio: 2
        });

        tableContainer.style.maxHeight = originalMaxHeight;
        tableContainer.style.overflow = originalOverflow;

        const link = document.createElement('a');
        const dateInput = document.getElementById('date-input') as HTMLInputElement | null;
        let monthName = 'reporte';
        if (dateInput && dateInput.value) {
          const d = new Date(dateInput.value + 'T12:00:00');
          monthName = new Intl.DateTimeFormat('es-AR', { month: 'long', year: 'numeric' }).format(d);
        }
        
        link.download = `cronograma_${monthName.toLowerCase().replace(/\s+/g, '_')}.png`;
        link.href = dataUrl;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

      } catch (error) {
        console.error('Error generating image:', error);
        alert('Hubo un error al generar la imagen. Intenta imprimir el reporte.');
      } finally {
        if (imgBtn) {
          imgBtn.disabled = false;
          imgBtn.innerHTML = originalText;
        }
      }
    }

