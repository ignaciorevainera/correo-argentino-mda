              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    document.getElementById('weekly-template-select')?.addEventListener('change', (e) => {
      const name = (e.target as HTMLSelectElement).value;
      const customActions = document.getElementById('template-custom-actions');
      
      if (name && weeklyTemplates[name]) {
        currentWeeklyScheme = { ...weeklyTemplates[name].dias };
        currentWeeklyScheduleTimes = { ...weeklyTemplates[name].horarios };
        currentWeeklyBreakInicioTimes = { ...(weeklyTemplates[name].breaks_inicio || { Lunes: "", Martes: "", Miercoles: "", Jueves: "", Viernes: "", Sabado: "", Domingo: "" }) };
        currentWeeklyBreakFinTimes = { ...(weeklyTemplates[name].breaks_fin || { Lunes: "", Martes: "", Miercoles: "", Jueves: "", Viernes: "", Sabado: "", Domingo: "" }) };
        renderWeeklyDaysList();
        
        if (customActions) {
          customActions.classList.remove('hidden');
          const nameInput = document.getElementById('new-template-name') as HTMLInputElement | null;
          if (nameInput) nameInput.value = name;
        }
      } else {
        if (customActions) customActions.classList.add('hidden');
      }
    });

    document.getElementById('weekly-template-create-btn')?.addEventListener('click', () => {
      const customActions = document.getElementById('template-custom-actions');
      if (customActions) {
        customActions.classList.remove('hidden');
        const nameInput = document.getElementById('new-template-name') as HTMLInputElement | null;
        if (nameInput) {
          nameInput.value = "";
          nameInput.focus();
        }
      }
    });

    document.getElementById('new-template-save-btn')?.addEventListener('click', () => {
      const nameInput = document.getElementById('new-template-name') as HTMLInputElement | null;
      const name = nameInput?.value?.trim();
      if (!name) {
        alert("Por favor, ingresa un nombre para la plantilla.");
        return;
      }
      
      weeklyTemplates[name] = {
        dias: { ...currentWeeklyScheme },
        horarios: { ...currentWeeklyScheduleTimes },
        breaks_inicio: { ...currentWeeklyBreakInicioTimes },
        breaks_fin: { ...currentWeeklyBreakFinTimes }
      };
      localStorage.setItem('cronoWeeklyTemplatesV2', JSON.stringify(weeklyTemplates));
      
      populateWeeklyTemplatesDropdown();
      const select = document.getElementById('weekly-template-select') as HTMLSelectElement | null;
      if (select) select.value = name;
      
      alert(`¡Plantilla "${name}" guardada con éxito!`);
    });

    document.getElementById('new-template-delete-btn')?.addEventListener('click', () => {
      const select = document.getElementById('weekly-template-select') as HTMLSelectElement | null;
      const name = select?.value;
      if (!name || !weeklyTemplates[name]) {
        alert("Selecciona una plantilla válida para eliminar.");
        return;
      }
      
      if (confirm(`¿Estás seguro de que deseas eliminar la plantilla "${name}"?`)) {
        delete weeklyTemplates[name];
        localStorage.setItem('cronoWeeklyTemplatesV2', JSON.stringify(weeklyTemplates));
        
        populateWeeklyTemplatesDropdown();
        document.getElementById('template-custom-actions')?.classList.add('hidden');
        alert(`Plantilla "${name}" eliminada.`);
      }
    });

    document.getElementById('weekly-template-duplicate-btn')?.addEventListener('click', () => {
      const select = document.getElementById('weekly-template-select') as HTMLSelectElement | null;
      const name = select?.value;
      if (!name || !weeklyTemplates[name]) {
        alert("Selecciona una plantilla para duplicar.");
        return;
      }
      
      const newName = prompt("Ingresa el nombre del duplicado:", `${name} (Copia)`);
      if (!newName || !newName.trim()) return;
      
      weeklyTemplates[newName.trim()] = { ...weeklyTemplates[name] };
      localStorage.setItem('cronoWeeklyTemplatesV2', JSON.stringify(weeklyTemplates));
      
      populateWeeklyTemplatesDropdown();
      if (select) select.value = newName.trim();
      
      select?.dispatchEvent(new Event('change'));
      alert(`¡Plantilla duplicada como "${newName.trim()}"!`);
    });

    document.getElementById('weekly-days-list')?.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.classList.contains('weekly-schedule-input')) {
        const day = target.getAttribute('data-day');
        if (day) {
          currentWeeklyScheduleTimes[day] = target.value;
        }
      }
      if (target.classList.contains('weekly-break-inicio-input')) {
        const day = target.getAttribute('data-day');
        if (day) {
          currentWeeklyBreakInicioTimes[day] = target.value;
        }
      }
      if (target.classList.contains('weekly-break-fin-input')) {
        const day = target.getAttribute('data-day');
        if (day) {
          currentWeeklyBreakFinTimes[day] = target.value;
        }
      }
    });

    document.getElementById('weekly-days-list')?.addEventListener('focusout', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.classList.contains('weekly-break-inicio-input') || target.classList.contains('weekly-break-fin-input')) {
        const formatted = formatTimeInput(target.value);
        target.value = formatted;
        const day = target.getAttribute('data-day');
        if (day) {
          if (target.classList.contains('weekly-break-inicio-input')) {
            currentWeeklyBreakInicioTimes[day] = formatted;
          } else {
            currentWeeklyBreakFinTimes[day] = formatted;
          }
        }
      }
    });

    document.getElementById('weekly-days-list')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-weekly-option]');
      if (!btn) return;
      
      const day = btn.parentElement?.dataset.weeklyDay;
      const option = btn.dataset.weeklyOption;
      if (!day || !option) return;
      
      currentWeeklyScheme[day] = option;
      
      btn.parentElement.querySelectorAll('[data-weekly-option]').forEach(other => {
        other.className = "weekly-day-opt-btn btn btn-xs font-black text-[9px] uppercase px-3 py-1.5 h-auto rounded-lg transition-all duration-200 bg-base-100 hover:bg-base-200 text-base-content/60 border border-base-300/40";
      });
      
      let activeClass = '';
      if (option === 'Presencial') activeClass = 'bg-secondary text-secondary-content shadow-md';
      else if (option === 'Home Office') activeClass = 'bg-amber-500 text-white shadow-md';
      else if (option === 'Vacaciones') activeClass = 'bg-success text-white shadow-md';
      else if (option === 'Licencia') activeClass = 'bg-error text-white shadow-md';
      else if (option === 'Horas Extras') activeClass = 'bg-sky-500 text-white shadow-md';
      else if (option === 'Franco') activeClass = 'bg-base-300 text-base-content shadow-md';
      
      btn.className = `weekly-day-opt-btn btn btn-xs font-black text-[9px] uppercase px-3 py-1.5 h-auto rounded-lg transition-all duration-200 ${activeClass}`;
      
      const select = document.getElementById('weekly-template-select') as HTMLSelectElement | null;
      if (select) select.value = "";
      document.getElementById('template-custom-actions')?.classList.add('hidden');
    });

    document.getElementById('save-operator-weekly-btn')?.addEventListener('click', async () => {
      const opName = document.getElementById('drawer-op-name')?.textContent?.trim();
      if (!opName) return;
      
      const saveBtn = document.getElementById('save-operator-weekly-btn') as HTMLButtonElement | null;
      if (saveBtn) {
        saveBtn.disabled = true;
        saveBtn.innerText = "Guardando...";
      }
      
      try {
        const dateInput = document.getElementById('date-input') as HTMLInputElement | null;
        const activeDateStr = dateInput?.value || formatYMD(new Date());
        const [yearStr, monthStr] = activeDateStr.split('-');
        const year = parseInt(yearStr);
        const month = parseInt(monthStr) - 1; // 0-indexed

        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const monthPrefix = `${yearStr}-${monthStr}`;
        const dayNames = ["Domingo", "Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado"];

        const edits = [];
        for (let d = 1; d <= daysInMonth; d++) {
          const dateStr = `${monthPrefix}-${String(d).padStart(2, '0')}`;
          const dateObj = new Date(year, month, d);
          const dayName = dayNames[dateObj.getDay()];

          const status = currentWeeklyScheme[dayName] || "Franco";
          let horario = "";
          if (currentWeeklyScheduleTimes[dayName]) {
            horario = currentWeeklyScheduleTimes[dayName];
          } else if (status !== "Franco") {
            const op = cronoData.find(o => o.nombre === opName);
            horario = op?.horario || "08:00 - 17:00";
          }

          const breakInicio = currentWeeklyBreakInicioTimes[dayName] || "";
          const breakFin = currentWeeklyBreakFinTimes[dayName] || "";

          edits.push({
            agentName: opName,
            date: dateStr,
            status,
            comment: "",
            horario,
            breakInicio,
            breakFin
          });
        }

        const res = await fetch('/api/cronograma', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            weeklySchedules: [{
              agentName: opName,
              esquema_semanal: currentWeeklyScheme,
              esquema_horario: currentWeeklyScheduleTimes,
              esquema_break_inicio: currentWeeklyBreakInicioTimes,
              esquema_break_fin: currentWeeklyBreakFinTimes
            }],
            edits
          })
        });
        
        const data = await res.json();
        if (data.success) {
          const opIndex = cronoData.findIndex(o => o.nombre === opName);
          if (opIndex !== -1) {
            cronoData[opIndex].esquema_semanal = { ...currentWeeklyScheme };
            cronoData[opIndex].esquema_horario = { ...currentWeeklyScheduleTimes };
            cronoData[opIndex].esquema_break_inicio = { ...currentWeeklyBreakInicioTimes };
            cronoData[opIndex].esquema_break_fin = { ...currentWeeklyBreakFinTimes };
          }
          
          const freshRes = await fetch('/api/cronograma');
          cronoData = await freshRes.json();
          renderMonthly();
          
          alert("¡Esquema semanal guardado y aplicado con éxito al mes activo!");
        } else {
          alert(`Error al guardar: ${data.message || 'Error desconocido'}`);
        }
      } catch (err) {
        console.error("Error saving weekly schedule:", err);
        alert("Ocurrió un error de red al intentar guardar.");
      } finally {
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerText = "Aplicar Esquema a Operador";
        }
      }
    });

    // Edit-in-place interaction for monthly-detail schedule
    const detailScheduleText = document.getElementById('monthly-detail-schedule-text');
    const detailScheduleInput = document.getElementById('monthly-detail-schedule') as HTMLInputElement | null;
    const scheduleContainer = document.getElementById('monthly-detail-schedule-container');

    if (scheduleContainer && detailScheduleText && detailScheduleInput) {
      scheduleContainer.addEventListener('click', () => {
        if (detailScheduleInput.classList.contains('hidden')) {
          detailScheduleText.classList.add('hidden');
          detailScheduleInput.classList.remove('hidden');
          detailScheduleInput.focus();
          detailScheduleInput.select();
        }
      });

      detailScheduleInput.addEventListener('blur', () => {
        detailScheduleText.innerText = detailScheduleInput.value || '-';
        detailScheduleInput.classList.add('hidden');
        detailScheduleText.classList.remove('hidden');
      });

      // Press Enter to submit/blur
      detailScheduleInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          detailScheduleInput.blur();
        }
      });
    }
  }

  init();
</script>
