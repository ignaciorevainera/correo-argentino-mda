    document.getElementById('delete-month-btn')?.addEventListener('click', async () => {
      const dateInput = document.getElementById('date-input') as HTMLInputElement;
      if (!dateInput || !dateInput.value) return;

      const [yearStr, monthStr] = dateInput.value.split('-');
      const year = parseInt(yearStr);
      const month = parseInt(monthStr) - 1; // 0-indexed month

      const formatter = new Intl.DateTimeFormat('es-AR', { month: 'long', year: 'numeric' });
      const monthName = formatter.format(new Date(year, month, 15)).toUpperCase();

      if (!confirm(`¿Estás seguro de que deseas eliminar el mes de ${monthName}? Esta acción borrará permanentemente todos los registros de asistencia y comentarios para este periodo y no se puede deshacer.`)) {
        return;
      }

      const deleteBtn = document.getElementById('delete-month-btn') as HTMLButtonElement | null;
      const originalText = deleteBtn ? deleteBtn.innerHTML : '';
      if (deleteBtn) {
        deleteBtn.disabled = true;
        deleteBtn.innerHTML = `<span class="loading loading-spinner loading-xs"></span> Borrando...`;
      }

      try {
        const res = await fetch('/api/cronograma/months', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ year, month })
        });

        if (res.ok) {
          // Re-fetch data
          const freshRes = await fetch('/api/cronograma');
          cronoData = await freshRes.json();

          const allDates = cronoData.flatMap(op => Object.keys(op.asistencia));
          const uniqueDates = [...new Set(allDates)].sort();

          if (uniqueDates.length > 0) {
            // Find closest month or fallback to latest
            const targetDate = uniqueDates[uniqueDates.length - 1];
            dateInput.value = targetDate;
            dateInput.min = uniqueDates[0];
            dateInput.max = targetDate;
          } else {
            // No data left
            const todayStr = formatYMD(new Date());
            dateInput.value = todayStr;
            dateInput.removeAttribute('min');
            dateInput.removeAttribute('max');
          }

          updateDateInputDisplay();
          updateMonthDisplay();
          renderMonthDropdown();
          renderDaily();
          renderMonthly();
          alert(`El mes de ${monthName} ha sido eliminado correctamente.`);
        } else {
          alert('Error al intentar eliminar el mes.');
        }
      } catch (err) {
        console.error("Error deleting month:", err);
        alert('Ocurrió un error al intentar eliminar el mes.');
      } finally {
        if (deleteBtn) {
          deleteBtn.disabled = false;
          deleteBtn.innerHTML = originalText;
        }
      }
    });

