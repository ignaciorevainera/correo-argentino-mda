---
// CronogramaDashboard.astro
import { Icon } from "astro-icon/components";

import OperatorDrawer from "./subcomponents/OperatorDrawer.astro";
import MonthlyDetailModal from "./subcomponents/MonthlyDetailModal.astro";
import RulesSettingsModal from "./subcomponents/RulesSettingsModal.astro";
import NewMonthModal from "./subcomponents/NewMonthModal.astro";
import OperatorFormModal from "./subcomponents/OperatorFormModal.astro";
import HolidaysModal from "./subcomponents/HolidaysModal.astro";
import DailyTableSkeleton from "./subcomponents/DailyTableSkeleton.astro";
import MonthlyTableSkeleton from "./subcomponents/MonthlyTableSkeleton.astro";

interface Props {
  userRole?: string;
}

const { userRole = "agent" } = Astro.props;
---

<div id="cronograma-app-container" data-user-role={userRole}>
  <div
    id="cronograma-container"
    class="animate-in fade-in duration-700 w-full pb-12 space-y-8"
  >
  <div class="w-full flex flex-col gap-6">
    <div
      class="flex flex-col md:flex-row md:items-center justify-between gap-4"
    >
      <div
        id="view-switcher"
        class="flex flex-wrap items-center gap-3 shrink-0"
      >
        <!-- Vistas de Calendario -->
        <div
          class="flex bg-base-200/60 p-1 rounded-xl border border-base-300 shadow-sm shrink-0"
        >
          <button
            type="button"
            id="switch-to-monthly-btn"
            class="btn btn-xs btn-secondary font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg shadow-sm shadow-secondary/15 transition-all duration-200"
          >
            Mensual
          </button>
          <button
            type="button"
            id="switch-to-daily-btn"
            class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
          >
            Diario
          </button>
        </div>

        <!-- Vistas de Configuración y Turnos -->
        <div
          class="flex bg-base-200/60 p-1 rounded-xl border border-base-300 shadow-sm shrink-0"
        >
          <button
            type="button"
            id="switch-to-groups-btn"
            class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
          >
            Grupos
          </button>
          <button
            type="button"
            id="switch-to-overtime-btn"
            class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
          >
            Extras
          </button>
          <button
            type="button"
            id="switch-to-pasiva-btn"
            class="btn btn-xs btn-outline border-transparent text-base-content/60 hover:bg-base-200/50 font-black uppercase tracking-widest text-tiny px-3.5 h-7 rounded-lg transition-all duration-200"
          >
            Pasivas
          </button>
        </div>
      </div>

      <!-- Date Picker (hidden by default) -->
      <div
        id="date-picker-container"
        class="relative min-w-40 items-center gap-2.5 bg-base-100 px-4 py-2.5 rounded-xl border border-base-300 shadow-sm hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20 hidden is-faded"
      >
        <Icon name="boxicons:calendar" size={18} class="text-base-content/40" />
        <label for="date-input" class="sr-only">Seleccionar fecha</label>
        <span
          id="date-input-display"
          class="text-sm font-semibold tabular-nums text-base-content pointer-events-none"
        >
        </span>
        <input
          type="date"
          id="date-input"
          class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 opacity-0"
        />
      </div>
    </div>

    <!-- Daily View Section (Hidden by default) -->
    <div
      id="daily-view"
      class="animate-in slide-in-from-bottom-2 fade-in duration-500 hidden"
    >
      <div
        class="bg-base-100 rounded-2xl border border-base-300 shadow-md overflow-hidden"
      >
        <div class="relative z-[60] bg-base-200/70 border-b border-base-300">
          <div
            class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 py-3.5 px-6"
          >
            <!-- Left: Title -->
            <div class="flex items-center gap-3 shrink-0 flex-wrap">
              <h3
                class="text-sm flex items-center gap-2.5 font-bold uppercase tracking-wide text-base-content select-none"
              >
                <Icon name="boxicons:group" size={18} />
                Estado de operadores
              </h3>
            </div>

            <!-- Center: Search & Sort inputs -->
            <div class="flex-1 max-w-md w-full mx-0 lg:mx-4 flex gap-2">
              <div class="relative flex-1">
                <Icon
                  name="boxicons:search"
                  size={16}
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/30"
                />
                <input
                  type="text"
                  id="daily-search"
                  placeholder="Buscar operador..."
                  class="w-full bg-base-100 border border-base-300 rounded-lg py-1.5 pl-9 pr-3 text-xs focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all outline-none h-8"
                />
              </div>
              <div class="dropdown dropdown-bottom dropdown-end w-40 shrink-0" id="daily-sort-container">
                <div
                  tabindex={0}
                  role="button"
                  id="daily-sort-btn"
                  class="btn btn-sm btn-outline border-base-300 hover:bg-base-200 justify-between w-full h-8 min-h-8 text-xs font-bold text-base-content rounded-lg px-2.5"
                  title="Ordenar operadores"
                >
                  <div class="flex items-center gap-1.5">
                    <Icon name="boxicons:arrow-down-up" size={14} />
                    <span id="daily-sort-label">Ordenar: A-Z</span>
                  </div>
                  <Icon name="boxicons:chevron-down" size={12} class="opacity-60" />
                </div>
                <ul
                  tabindex={0}
                  class="dropdown-content menu p-1.5 shadow-lg bg-base-100 rounded-box w-48 z-50 border border-base-200 text-xs mt-1"
                >
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="alphabetical"
                    >
                      <Icon name="boxicons:arrow-down-a-z" size={14} />
                      <span>Alfabético (A-Z)</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="alphabetical-za"
                    >
                      <Icon name="boxicons:arrow-up-a-z" size={14} />
                      <span>Alfabético (Z-A)</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="entry-time"
                    >
                      <Icon name="boxicons:clock-5" size={14} />
                      <span>Entrada (Horario)</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="location"
                    >
                      <Icon name="boxicons:location-pin" size={14} />
                      <span>Sede / Ubicación</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="inconsistencies"
                    >
                      <Icon name="boxicons:alert-triangle" size={14} />
                      <span>Inconsistencias</span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Right: Date Display & Maximize button -->
            <div
              class="flex flex-wrap items-center gap-2.5 justify-start lg:justify-end shrink-0"
            >
              <div
                class="flex items-center gap-2 bg-base-100 px-3.5 py-1 rounded-lg border border-base-300 shadow-sm text-base-content/75 h-7"
              >
                <Icon
                  name="boxicons:calendar-check"
                  size={16}
                  class="text-secondary"
                />
                <span
                  class="text-xs font-semibold tabular-nums"
                  id="daily-date-display"></span>
              </div>

              <!-- Maximize Button Removed -->
            </div>
          </div>
        </div>
        <div class="p-3">
          <div
            class="overflow-x-auto max-h-[580px] overflow-y-auto scrollbar-thin rounded-xl border border-base-200 bg-base-100"
          >
            <table
              class="w-full text-sm text-left border-separate border-spacing-0"
            >
              <thead
                class="sticky top-0 z-50 bg-base-100/98 backdrop-blur-sm shadow-sm text-xs uppercase font-bold text-base-content/50 tracking-widest border-b border-base-300"
              >
                <tr>
                  <th
                    class="sticky left-0 bg-base-100 z-50 w-64 min-w-[16rem] py-3 px-6 border-r border-b border-base-200/70"
                    >Operador</th
                  >
                  <th
                    class="sticky left-64 bg-base-100 z-50 w-44 min-w-44 py-3 px-4 border-r border-b border-base-200/70 shadow-[4px_0_10px_-5px_rgba(0,0,0,0.1)]"
                    >Modalidad</th
                  >
                  <th class="py-3 px-6 border-b border-base-200/70">
                    <div
                      class="flex justify-between w-full text-xxs font-black text-base-content/40 px-2 select-none"
                    >
                      <span>00:00</span>
                      <span>02:00</span>
                      <span>04:00</span>
                      <span>06:00</span>
                      <span>08:00</span>
                      <span>10:00</span>
                      <span>12:00</span>
                      <span>14:00</span>
                      <span>16:00</span>
                      <span>18:00</span>
                      <span>20:00</span>
                      <span>22:00</span>
                      <span>24:00</span>
                    </div>
                  </th>
                </tr>
              </thead>
              <tbody
                id="operators-table-body"
                class="divide-y divide-base-200 bg-base-100"
              >
                <DailyTableSkeleton />
              </tbody>
            </table>
          </div>
        </div>
        <!-- Daily View Footer / Status Filters -->
        <div
          class="bg-base-200/40 border-t border-base-300 px-6 py-3 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 no-print"
        >
          <div class="flex flex-wrap items-center gap-4">
            <!-- Status Filters -->
            <div
              class="flex items-center gap-1 bg-base-100/50 p-0.5 rounded-lg border border-base-300/60 shadow-sm flex-wrap"
            >
              <span
                class="text-tiny font-black uppercase tracking-wider text-base-content/40 px-2 select-none"
                >Estado:</span
              >

              <button
                type="button"
                id="filter-all-btn-daily"
                class="btn btn-xs btn-secondary font-black uppercase tracking-widest text-tiny px-2.5 h-6 rounded-md shadow-sm shadow-secondary/15 transition-all duration-200"
              >
                Todos
              </button>

              <button
                type="button"
                id="filter-presencial-mg-btn-daily"
                data-filter="Presencial Monte Grande"
                class="btn btn-xs btn-outline gap-1 font-black text-tiny uppercase tracking-wider border-transparent hover:bg-primary/10 hover:text-amber-600 dark:hover:text-amber-400 hover:border-primary/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                <div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> Presencial
                MG
              </button>

              <button
                type="button"
                id="filter-presencial-pp-btn-daily"
                data-filter="Presencial Parque Patricios"
                class="btn btn-xs btn-outline gap-1 font-black text-tiny uppercase tracking-wider border-transparent hover:bg-purple-500/10 hover:text-purple-600 dark:hover:text-purple-400 hover:border-purple-500/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                <div class="w-1.5 h-1.5 rounded-full bg-purple-500"></div> Presencial
                PP
              </button>

              <button
                type="button"
                id="filter-ho-btn-daily"
                data-filter="Home Office"
                class="btn btn-xs btn-outline gap-1 font-black text-tiny uppercase tracking-wider border-transparent hover:bg-secondary/10 hover:text-secondary hover:border-secondary/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div> HO
              </button>

              <button
                type="button"
                id="filter-licencia-btn-daily"
                data-filter="Licencia"
                class="btn btn-xs btn-outline gap-1 font-black text-tiny uppercase tracking-wider border-transparent hover:bg-error/10 hover:text-error hover:border-error/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                <div class="w-1.5 h-1.5 rounded-full bg-error"></div> Licencia
              </button>

              <button
                type="button"
                id="filter-vacaciones-btn-daily"
                data-filter="Vacaciones"
                class="btn btn-xs btn-outline gap-1 font-black text-tiny uppercase tracking-wider border-transparent hover:bg-success/10 hover:text-success hover:border-success/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                <div class="w-1.5 h-1.5 rounded-full bg-success"></div> Vacaciones
              </button>
            </div>

            <!-- Location Filters -->
            <div
              class="flex items-center gap-1 bg-base-100/50 p-0.5 rounded-lg border border-base-300/60 shadow-sm flex-wrap"
            >
              <span
                class="text-tiny font-black uppercase tracking-wider text-base-content/40 px-2 select-none"
                >Sede:</span
              >
              <button
                type="button"
                id="filter-location-all-btn-daily"
                class="btn btn-xs btn-secondary font-black uppercase tracking-widest text-tiny px-2.5 h-6 rounded-md shadow-sm shadow-secondary/15 transition-all duration-200"
              >
                Todas
              </button>
              <button
                type="button"
                id="filter-location-mg-btn-daily"
                data-location="Monte Grande"
                class="btn btn-xs btn-outline font-black text-tiny uppercase tracking-wider border-transparent hover:bg-secondary/10 hover:text-secondary hover:border-secondary/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                Monte Grande
              </button>
              <button
                type="button"
                id="filter-location-pp-btn-daily"
                data-location="Parque Patricios"
                class="btn btn-xs btn-outline font-black text-tiny uppercase tracking-wider border-transparent hover:bg-secondary/10 hover:text-secondary hover:border-secondary/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
              >
                Parque Patricios
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Monthly View Section (Shown by default) -->
    <div
      id="monthly-view"
      class="animate-in slide-in-from-bottom-2 fade-in duration-500"
    >
      <div
        class="bg-base-100 rounded-2xl border border-base-300 shadow-md overflow-hidden"
      >
        <div class="relative z-[60] bg-base-200/70 border-b border-base-300">
          <div
            class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 py-3.5 px-6"
          >
            <!-- Left: Title, Navigation & Maximize button -->
            <div class="flex items-center gap-3 shrink-0 flex-wrap">
              <!-- Month Navigator -->
              <div
                class="flex items-center gap-1 bg-base-100 rounded-lg p-0.5 border border-base-300 shadow-sm ml-2"
              >
                <button
                  type="button"
                  id="prev-month-btn"
                  class="btn btn-xs btn-ghost p-1 rounded hover:bg-base-200 text-base-content/70 hover:text-base-content transition-all"
                  title="Mes anterior"
                  aria-label="Mes anterior"
                >
                  <Icon name="boxicons:chevron-left" size={14} />
                </button>

                <!-- Dropdown Month Selector -->
                <div
                  class="dropdown dropdown-bottom dropdown-end"
                  id="month-selector-dropdown"
                >
                  <div
                    tabindex="0"
                    role="button"
                    class="text-xxs font-black uppercase tracking-wider px-2 py-1 text-base-content min-w-[120px] text-center select-none hover:bg-base-200 rounded-lg cursor-pointer flex items-center justify-center gap-1.5 border border-base-300/50 bg-base-50/50 shadow-sm transition-all"
                  >
                    <span id="current-month-display">-</span>
                    <svg
                      class="w-2.5 h-2.5 opacity-60 ml-0.5"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M19 9l-7 7-7-7"></path></svg
                    >
                  </div>
                  <ul
                    tabindex="0"
                    id="month-dropdown-list"
                    class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-xl z-100 w-48 border border-base-200 max-h-60 overflow-y-auto mt-1"
                  >
                    <!-- Dynamic months list here -->
                  </ul>
                </div>

                <button
                  type="button"
                  id="next-month-btn"
                  class="btn btn-xs btn-ghost p-1 rounded hover:bg-base-200 text-base-content/70 hover:text-base-content transition-all"
                  title="Mes siguiente"
                  aria-label="Mes siguiente"
                >
                  <Icon name="boxicons:chevron-right" size={14} />
                </button>
              </div>

              <!-- Agregar nuevo mes -->
              <button
                type="button"
                id="add-month-btn"
                class="btn btn-xs btn-outline gap-1.5 px-2.5 border border-base-300 hover:bg-secondary hover:text-secondary-content transition-all font-bold uppercase tracking-wider text-tiny rounded-lg shadow-sm h-7 ml-2"
                title="Agregar nuevo mes"
              >
                <Icon name="boxicons:calendar-plus" size={13} />
                <span>Agregar nuevo mes</span>
              </button>

              <!-- Borrar mes actual -->
              <button
                type="button"
                id="delete-month-btn"
                class="btn btn-xs btn-outline btn-error gap-1.5 px-2.5 hover:bg-error hover:text-error-content transition-all font-bold uppercase tracking-wider text-tiny rounded-lg shadow-sm h-7 ml-2"
                title="Borrar mes actual"
              >
                <Icon name="boxicons:calendar-minus" size={13} />
                <span>Borrar mes actual</span>
              </button>
            </div>

            <!-- Center: Search & Sort inputs -->
            <div class="flex-1 max-w-md w-full mx-0 lg:mx-4 flex gap-2">
              <div class="relative flex-1">
                <Icon
                  name="boxicons:search"
                  size={16}
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/30"
                />
                <input
                  type="text"
                  id="monthly-search"
                  placeholder="Buscar operador..."
                  class="w-full bg-base-100 border border-base-300 rounded-lg py-1.5 pl-9 pr-3 text-xs focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all outline-none h-8"
                />
              </div>
              <div class="dropdown dropdown-bottom dropdown-end w-40 shrink-0" id="monthly-sort-container">
                <div
                  tabindex={0}
                  role="button"
                  id="monthly-sort-btn"
                  class="btn btn-sm btn-outline border-base-300 hover:bg-base-200 justify-between w-full h-8 min-h-8 text-xs font-bold text-base-content rounded-lg px-2.5"
                  title="Ordenar operadores"
                >
                  <div class="flex items-center gap-1.5">
                    <Icon name="boxicons:arrow-down-up" size={14} />
                    <span id="monthly-sort-label">Ordenar: A-Z</span>
                  </div>
                  <Icon name="boxicons:chevron-down" size={12} class="opacity-60" />
                </div>
                <ul
                  tabindex={0}
                  class="dropdown-content menu p-1.5 shadow-lg bg-base-100 rounded-box w-48 z-50 border border-base-200 text-xs mt-1"
                >
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="alphabetical"
                    >
                      <Icon name="boxicons:arrow-down-a-z" size={14} />
                      <span>Alfabético (A-Z)</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="alphabetical-za"
                    >
                      <Icon name="boxicons:arrow-up-a-z" size={14} />
                      <span>Alfabético (Z-A)</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="entry-time"
                    >
                      <Icon name="boxicons:clock-5" size={14} />
                      <span>Entrada (Horario)</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="location"
                    >
                      <Icon name="boxicons:location-pin" size={14} />
                      <span>Sede / Ubicación</span>
                    </button>
                  </li>
                  <li>
                    <button
                      type="button"
                      class="sort-option flex items-center gap-2 py-2 px-2.5 rounded-lg active:bg-secondary active:text-secondary-content text-left"
                      data-value="inconsistencies"
                    >
                      <Icon name="boxicons:alert-triangle" size={14} />
                      <span>Inconsistencias</span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>

            <div
              class="flex flex-wrap items-center gap-2.5 justify-start lg:justify-end shrink-0"
            >
              <!-- Edit Mode Button -->
              <button
                type="button"
                id="toggle-edit-mode-btn"
                class="btn btn-xs btn-outline gap-1.5 px-2.5 border border-base-300/80 hover:bg-secondary hover:text-secondary-content transition-all font-bold uppercase tracking-wider text-tiny rounded-lg shadow-sm h-7"
                title="Modo Edición"
              >
                <Icon name="boxicons:edit-alt" size={13} />
                <span id="edit-mode-text">Editar</span>
              </button>

              <!-- Maximize Button Removed -->
            </div>
          </div>
        </div>
        <div class="p-3">
          <div
            class="overflow-x-auto max-h-[580px] overflow-y-auto scrollbar-thin rounded-xl border border-base-200 bg-base-100"
          >
            <table
              class="w-full text-sm text-left border-separate border-spacing-0"
              id="monthly-table"
            >
              <thead class="bg-base-100" id="monthly-thead">
                <MonthlyTableSkeleton part="thead" />
              </thead>
              <tbody id="monthly-tbody">
                <MonthlyTableSkeleton part="tbody" />
              </tbody>
              <tfoot
                id="monthly-tfoot"
                class="sticky bottom-0 z-40 bg-base-100/95 backdrop-blur-md border-t-2 border-base-300"
              >
                <!-- Coverage stats injected here -->
              </tfoot>
            </table>
          </div>
        </div>
        <div
          class="bg-base-200/40 border-t border-base-300 px-6 py-3 flex flex-col xl:flex-row justify-between items-stretch xl:items-center gap-4 no-print"
        >
          <div class="flex flex-wrap items-center gap-4">
            <!-- Status Filters Container -->
            <div
