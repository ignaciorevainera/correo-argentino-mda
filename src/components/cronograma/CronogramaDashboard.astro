---
// CronogramaDashboard.astro
import { Icon } from "astro-icon/components";
---

<div id="cronograma-container" class="animate-in fade-in duration-700 w-full pb-12 space-y-8">
  
  <!-- Stats Summary (hidden by default) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 hidden" id="stats-container">
    <!-- Stats will be injected here -->
  </div>

  <div class="w-full flex flex-col gap-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <!-- Left side spacer replaces Segmented Control -->
      <div></div>

      <!-- Date Picker (hidden by default) -->
      <div id="date-picker-container" class="relative flex min-w-40 items-center gap-2.5 bg-base-100 px-4 py-2.5 rounded-xl border border-base-300 shadow-sm hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20 hidden is-faded">
        <Icon name="boxicons:calendar" size={18} class="text-base-content/40" />
        <label for="date-input" class="sr-only">Seleccionar fecha</label>
        <span id="date-input-display" class="text-sm font-semibold tabular-nums text-base-content pointer-events-none">
        </span>
        <input 
          type="date" 
          id="date-input"
          class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 bg-transparent text-transparent caret-transparent"
        />
      </div>
    </div>

    <!-- Daily View Section (Hidden by default) -->
    <div id="daily-view" class="animate-in slide-in-from-bottom-2 fade-in duration-500 hidden">
      <div class="bg-base-100 rounded-2xl border border-base-300 shadow-md overflow-hidden">
        <div class="bg-base-200/70 border-b border-base-300">
          <div class="flex flex-col sm:flex-row justify-between items-center py-3.5 px-6 gap-3">
            <div class="flex items-center gap-4">
              <button 
                id="back-to-monthly-btn" 
                type="button"
                class="btn btn-xs btn-ghost gap-1.5 px-2.5 py-1.5 rounded-lg border border-base-300/60 hover:bg-base-300 text-base-content/75 hover:text-base-content transition-all font-bold uppercase tracking-wider text-[10px]"
                aria-label="Volver al Mes Completo"
              >
                <Icon name="boxicons:chevron-left" size={14} />
                Volver al Mes
              </button>
              <h3 class="text-sm flex items-center gap-2.5 font-bold uppercase tracking-wide text-base-content border-l border-base-300 pl-4">
                <Icon name="boxicons:group" size={18} />
                Estado de operadores
              </h3>
            </div>
            <div class="flex items-center gap-2 bg-base-100 px-3.5 py-1.5 rounded-lg border border-base-300 shadow-sm text-base-content/75">
               <Icon name="boxicons:calendar-check" size={16} class="text-secondary" />
               <span class="text-sm font-semibold tabular-nums" id="daily-date-display"></span>
            </div>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead class="bg-base-200/60 text-xs uppercase font-bold text-base-content/50 tracking-widest border-b border-base-300">
              <tr>
                <th class="py-3 px-6 w-72">Operador</th>
                <th class="py-3 px-4">Modalidad</th>
                <th class="py-3 px-4">Horario</th>
                <th class="py-3 px-4">Break</th>
                <th class="py-3 px-6 text-right">Usuario</th>
              </tr>
            </thead>
            <tbody id="operators-table-body" class="divide-y divide-base-200">
              <!-- Rows will be injected here -->
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Monthly View Section (Shown by default) -->
    <div id="monthly-view" class="animate-in slide-in-from-bottom-2 fade-in duration-500">
      <div class="bg-base-100 rounded-2xl border border-base-300 shadow-md overflow-hidden">
        <div class="bg-base-200/70 border-b border-base-300">
          <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 py-3.5 px-6">
            <!-- Left: Title, Navigation & Maximize button -->
            <div class="flex items-center gap-3 shrink-0 flex-wrap">
              <h3 class="text-xs flex items-center gap-2 font-black uppercase tracking-wider text-base-content select-none">
                <Icon name="boxicons:calendar-star" size={18} class="text-secondary" />
                Matriz Mensual
              </h3>
              
              <!-- Month Navigator -->
              <div class="flex items-center gap-1 bg-base-100 rounded-lg p-0.5 border border-base-300 shadow-sm ml-2">
                <button
                  type="button"
                  id="prev-month-btn"
                  class="btn btn-xs btn-ghost p-1 rounded hover:bg-base-200 text-base-content/70 hover:text-base-content transition-all"
                  title="Mes anterior"
                  aria-label="Mes anterior"
                >
                  <Icon name="boxicons:chevron-left" size={14} />
                </button>
                
                <!-- Dropdown Month Selector -->
                <div class="dropdown dropdown-bottom dropdown-end" id="month-selector-dropdown">
                  <div tabindex="0" role="button" class="text-[10px] font-black uppercase tracking-wider px-2 py-1 text-base-content min-w-[120px] text-center select-none hover:bg-base-200 rounded-lg cursor-pointer flex items-center justify-center gap-1.5 border border-base-300/50 bg-base-50/50 shadow-sm transition-all">
                    <span id="current-month-display">-</span>
                    <svg class="w-2.5 h-2.5 opacity-60 ml-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                  </div>
                  <ul tabindex="0" id="month-dropdown-list" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-xl z-[100] w-48 border border-base-200 max-h-60 overflow-y-auto mt-1">
                    <!-- Dynamic months list here -->
                  </ul>
                </div>

                <button
                  type="button"
                  id="next-month-btn"
                  class="btn btn-xs btn-ghost p-1 rounded hover:bg-base-200 text-base-content/70 hover:text-base-content transition-all"
                  title="Mes siguiente"
                  aria-label="Mes siguiente"
                >
                  <Icon name="boxicons:chevron-right" size={14} />
                </button>
              </div>

              <!-- Agregar nuevo mes -->
              <button
                type="button"
                id="add-month-btn"
                class="btn btn-xs btn-outline gap-1.5 px-2.5 border border-base-300 hover:bg-secondary hover:text-secondary-content transition-all font-bold uppercase tracking-wider text-[9px] rounded-lg shadow-sm h-7 ml-2"
                title="Agregar nuevo mes"
              >
                <Icon name="boxicons:calendar-plus" size={13} />
                <span>Agregar nuevo mes</span>
              </button>

              <!-- Borrar mes actual -->
              <button
                type="button"
                id="delete-month-btn"
                class="btn btn-xs btn-outline btn-error gap-1.5 px-2.5 hover:bg-error hover:text-error-content transition-all font-bold uppercase tracking-wider text-[9px] rounded-lg shadow-sm h-7 ml-2"
                title="Borrar mes actual"
              >
                <Icon name="boxicons:calendar-minus" size={13} />
                <span>Borrar mes actual</span>
              </button>


            </div>

            <!-- Center: Search input -->
            <div class="flex-1 max-w-sm w-full mx-0 lg:mx-4">
              <div class="relative w-full">
                <Icon name="boxicons:search" size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/30" />
                <input 
                  type="text" 
                  id="monthly-search"
                  placeholder="Buscar operador..." 
                  class="w-full bg-base-100 border border-base-300 rounded-lg py-1.5 pl-9 pr-3 text-xs focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all outline-none h-8"
                />
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-2.5 justify-start lg:justify-end shrink-0">
              <div id="compliance-alert-badge" class="hidden">
                 <div class="flex items-center gap-1.5 px-2.5 py-1 bg-error/10 text-error rounded-full border border-error/20 animate-pulse">
                    <Icon name="boxicons:alert-triangle" size={13} />
                    <span class="text-[9px] font-black uppercase tracking-tighter" id="compliance-alert-text">0 Inconsistencias</span>
                 </div>
              </div>
              
              <!-- Edit Mode Button -->
              <button
                type="button"
                id="toggle-edit-mode-btn"
                class="btn btn-xs btn-outline gap-1.5 px-2.5 border border-base-300/80 hover:bg-secondary hover:text-secondary-content transition-all font-bold uppercase tracking-wider text-[9px] rounded-lg shadow-sm h-7"
                title="Modo Edición"
              >
                <Icon name="boxicons:edit-alt" size={13} />
                <span id="edit-mode-text">Editar</span>
              </button>

              <!-- Maximize Button -->
              <button
                type="button"
                id="maximize-cronograma-btn"
                class="btn btn-xs btn-ghost gap-1.5 px-2.5 border border-base-300/80 hover:bg-base-300 text-base-content/75 hover:text-base-content transition-all font-bold uppercase tracking-wider text-[9px] rounded-lg shadow-sm h-7"
                title="Maximizar cronograma"
                aria-label="Maximizar cronograma"
              >
                <span class="flex items-center gap-1 font-bold" id="maximize-icon-wrapper">
                  <Icon name="boxicons:maximize" size={13} class="max-icon" />
                  <Icon name="boxicons:minimize" size={13} class="min-icon hidden" />
                </span>
                <span id="maximize-text">Maximizar</span>
              </button>
            </div>

          </div>
        </div>
        <div class="p-3">
          <div class="overflow-x-auto max-h-[580px] overflow-y-auto scrollbar-thin rounded-xl border border-base-200 bg-base-100">
            <table class="w-full text-sm text-left border-separate border-spacing-0" id="monthly-table">
              <thead class="sticky top-0 z-30 bg-base-100/98 backdrop-blur-sm shadow-sm" id="monthly-thead">
                <!-- Headers injected here -->
              </thead>
              <tbody id="monthly-tbody">
                <!-- Matrix injected here -->
              </tbody>
              <tfoot id="monthly-tfoot" class="sticky bottom-0 z-40 bg-base-100/95 backdrop-blur-md border-t-2 border-base-300">
                <!-- Coverage stats injected here -->
              </tfoot>
            </table>
          </div>
        </div>
        <div class="bg-base-200/40 border-t border-base-300 px-6 py-3 flex justify-between items-center no-print">
          <!-- Status Filters Container -->
          <div class="flex items-center gap-1 bg-base-100/50 p-0.5 rounded-lg border border-base-300/60 shadow-sm flex-wrap">
            <span class="text-[9px] font-black uppercase tracking-wider text-base-content/40 px-2 select-none">Filtrar:</span>
            
            <button
              type="button"
              id="filter-all-btn"
              class="btn btn-xs btn-secondary font-black uppercase tracking-widest text-[9px] px-2.5 h-6 rounded-md shadow-sm shadow-secondary/15 transition-all duration-200"
            >
              Todos
            </button>
            
            <button
              type="button"
              id="filter-presencial-btn"
              data-filter="Presencial"
              class="btn btn-xs btn-outline gap-1 font-black text-[9px] uppercase tracking-wider border-transparent hover:bg-secondary/10 hover:text-secondary hover:border-secondary/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
            >
              <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div> Presencial
            </button>
            
            <button
              type="button"
              id="filter-ho-btn"
              data-filter="Home Office"
              class="btn btn-xs btn-outline gap-1 font-black text-[9px] uppercase tracking-wider border-transparent hover:bg-primary/10 hover:text-amber-600 dark:hover:text-amber-400 hover:border-primary/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
            >
              <div class="w-1.5 h-1.5 rounded-full bg-primary"></div> HO
            </button>
            
            <button
              type="button"
              id="filter-licencia-btn"
              data-filter="Licencia"
              class="btn btn-xs btn-outline gap-1 font-black text-[9px] uppercase tracking-wider border-transparent hover:bg-error/10 hover:text-error hover:border-error/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
            >
              <div class="w-1.5 h-1.5 rounded-full bg-error"></div> Licencia
            </button>
            
            <button
              type="button"
              id="filter-vacaciones-btn"
              data-filter="Vacaciones"
              class="btn btn-xs btn-outline gap-1 font-black text-[9px] uppercase tracking-wider border-transparent hover:bg-success/10 hover:text-success hover:border-success/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
            >
              <div class="w-1.5 h-1.5 rounded-full bg-success"></div> Vacaciones
            </button>
            <button
              type="button"
              id="filter-he-btn"
              data-filter="Horas Extras"
              class="btn btn-xs btn-outline gap-1 font-black text-[9px] uppercase tracking-wider border-transparent hover:bg-sky-600/10 hover:text-sky-600 hover:border-sky-600/20 text-base-content/60 px-2.5 h-6 rounded-md transition-all duration-200"
            >
              <div class="w-1.5 h-1.5 rounded-full bg-sky-500"></div> Horas Extras
            </button>
          </div>
          <div class="flex gap-2">
            <button id="export-csv-btn" class="btn btn-xs btn-outline gap-1.5 border-base-300 hover:bg-base-300 hover:border-base-300 font-bold text-[10px] uppercase rounded-lg">
              <Icon name="boxicons:file" size={14} />
              Exportar CSV
            </button>
            <button id="export-image-btn" class="btn btn-xs btn-primary gap-1.5 font-bold text-[10px] uppercase rounded-lg shadow-sm shadow-primary/10">
              <Icon name="boxicons:image" size={14} />
              Exportar Imagen (PNG)
            </button>
            <button id="print-report-btn" class="btn btn-xs btn-secondary gap-1.5 font-bold text-[10px] uppercase rounded-lg shadow-sm shadow-secondary/10">
              <Icon name="boxicons:printer" size={14} />
              Imprimir Reporte
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Quick Edit Context Menu -->
<div 
  id="quick-edit-menu" 
  class="fixed z-[100] hidden min-w-[160px] bg-base-100/90 backdrop-blur-xl border border-base-300 rounded-xl shadow-2xl p-1.5 animate-in fade-in zoom-in-95 duration-100"
>
  <div class="px-3 py-2 border-b border-base-200 mb-1">
    <p class="text-[9px] font-black uppercase tracking-widest text-base-content/40" id="quick-edit-target-name">Cambiar Estado</p>
  </div>
  <div class="space-y-0.5" id="quick-edit-options">
    <button data-status="Presencial" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-secondary/10 hover:text-secondary transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-secondary"></div> Presencial
    </button>
    <button data-status="Home Office" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-primary/10 hover:text-amber-600 dark:hover:text-amber-400 transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-amber-500"></div> Home Office
    </button>
    <button data-status="Licencia" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-error/10 hover:text-error transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-error"></div> Licencia
    </button>
    <button data-status="Vacaciones" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-success/10 hover:text-success transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-success"></div> Vacaciones
    </button>
    <button data-status="Horas Extras" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-info/10 hover:text-info transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-info"></div> Horas Extras
    </button>
    <button data-status="Franco" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-300 transition-colors text-xs font-bold text-base-content/70 group">
      <div class="w-2 h-2 rounded-full bg-base-300"></div> Franco
    </button>
  </div>
</div>

<!-- Floating Save Alert -->
<div id="save-indicator" class="fixed bottom-6 right-6 z-50 hidden animate-in slide-in-from-right-10 fade-in duration-300">
  <div class="bg-base-100/95 border-2 border-secondary/30 backdrop-blur-xl text-base-content px-6 py-4 rounded-3xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] flex items-center gap-5 min-w-[380px] max-w-md">
    <div class="w-10 h-10 rounded-2xl bg-secondary/15 flex items-center justify-center text-secondary shrink-0 animate-pulse border border-secondary/20">
      <Icon name="boxicons:save" size={22} />
    </div>
    <div class="flex-1 min-w-0">
       <span class="text-[10px] font-black uppercase tracking-wider text-secondary">Base de Datos Activa</span>
       <h4 id="save-indicator-text" class="text-xs font-black text-base-content uppercase tracking-tight truncate mt-0.5">
         Edición en progreso: Cambios pendientes
       </h4>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <button 
        type="button" 
        id="save-discard-btn" 
        class="btn btn-xs btn-ghost hover:bg-error/15 hover:text-error text-[10px] font-black uppercase tracking-wider rounded-lg px-2.5 transition-colors"
      >
        Descartar
      </button>
      <button 
        type="button" 
        id="save-confirm-btn" 
        class="btn btn-xs btn-secondary text-[10px] font-black uppercase tracking-wider rounded-lg px-4 shadow-lg shadow-secondary/15 transition-all"
      >
        Guardar
      </button>
    </div>
  </div>
</div>

<!-- Operator Profile Modal -->
<div 
  id="operator-drawer-overlay" 
  class="fixed inset-0 z-[110] hidden items-center justify-center bg-base-content/40 backdrop-blur-md transition-all duration-300 p-4"
>
  <div 
    id="operator-drawer" 
    class="relative w-full max-w-2xl bg-base-100 rounded-[2rem] shadow-2xl border border-base-300 flex flex-col overflow-hidden opacity-0 scale-95 transition-all duration-300 h-[680px] max-h-[85vh]"
  >
    <!-- Header with Background Gradient -->
    <div class="p-8 border-b border-base-200 relative overflow-hidden bg-gradient-to-br from-base-200/50 to-transparent shrink-0">
      <div class="flex items-center justify-between relative z-10">
        <div class="flex items-center gap-6">
          <div class="w-16 h-16 rounded-2xl bg-secondary/15 border border-secondary/20 text-secondary flex items-center justify-center shadow-md shrink-0 select-none">
            <span id="drawer-op-avatar-initials" class="text-xl font-black tracking-wider"></span>
          </div>
          <div class="flex flex-col">
            <h2 id="drawer-op-name" class="text-2xl font-black uppercase tracking-tight text-base-content"></h2>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="w-2 h-2 rounded-full bg-success"></span>
              <span id="drawer-op-email" class="text-xs font-bold text-base-content/50 lowercase"></span>
            </div>
          </div>
        </div>
        <button id="close-drawer" class="btn btn-ghost btn-circle hover:bg-base-300" type="button">
          <Icon name="boxicons:x" size={28} />
        </button>
      </div>
    </div>

    <!-- Tabs Header -->
    <div class="flex border-b border-base-200 bg-base-50/50 shrink-0">
      <button 
        type="button"
        id="tab-profile-btn" 
        class="px-6 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-secondary text-secondary transition-all"
      >
        Perfil e Historial
      </button>
      <button 
        type="button"
        id="tab-weekly-btn" 
        class="px-6 py-3 text-xs font-black uppercase tracking-wider border-b-2 border-transparent text-base-content/60 hover:text-base-content transition-all"
      >
        Esquema Semanal Base
      </button>
    </div>

    <!-- Content: Profile e Historial tab -->
    <div id="drawer-profile-tab-content" class="flex-1 p-6 md:p-8 min-h-0 flex flex-col bg-base-50/10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 flex-1 min-h-0 overflow-y-auto md:overflow-y-hidden md:h-full">
        <!-- Stats & Notes Column -->
        <div class="space-y-6 flex flex-col min-h-0 md:h-full">
          <section class="shrink-0">
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/40 mb-3 flex items-center gap-1.5">
              <Icon name="boxicons:chart-line" size={14} class="text-base-content/50" />
              Rendimiento Mensual
            </h3>
            <div class="grid grid-cols-2 gap-4">
              <!-- Home Office Card -->
              <div class="bg-amber-500/5 dark:bg-amber-400/5 rounded-2xl p-4 border border-amber-500/10 flex flex-col items-center text-center relative overflow-hidden group">
                <div class="absolute -right-2 -bottom-2 opacity-5 text-amber-500 group-hover:scale-110 transition-transform duration-300 pointer-events-none">
                  <Icon name="boxicons:home" size={64} />
                </div>
                <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-600 dark:text-amber-400 mb-2">
                  <Icon name="boxicons:home" size={18} />
                </div>
                <span class="text-3xl font-black text-amber-600 dark:text-amber-400" id="drawer-stat-ho">0</span>
                <span class="text-[9px] font-black uppercase tracking-widest text-amber-600/70 dark:text-amber-400/70 mt-1">Home Office</span>
              </div>
              <!-- Presencial Card -->
              <div class="bg-secondary/5 rounded-2xl p-4 border border-secondary/10 flex flex-col items-center text-center relative overflow-hidden group">
                <div class="absolute -right-2 -bottom-2 opacity-5 text-secondary group-hover:scale-110 transition-transform duration-300 pointer-events-none">
                  <Icon name="boxicons:building" size={64} />
                </div>
                <div class="w-8 h-8 rounded-lg bg-secondary/10 flex items-center justify-center text-secondary mb-2">
                  <Icon name="boxicons:building" size={18} />
                </div>
                <span class="text-3xl font-black text-secondary" id="drawer-stat-p">0</span>
                <span class="text-[9px] font-black uppercase tracking-widest text-secondary/70 mt-1">Presencial</span>
              </div>
            </div>
          </section>

          <!-- Notas de Supervisión -->
          <section class="flex-1 flex flex-col min-h-0">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/40 flex items-center gap-1.5">
                <Icon name="boxicons:edit-alt" size={14} class="text-base-content/50" />
                Notas de Supervisión
              </h3>
              <span id="notes-status-indicator" class="text-[8px] font-black uppercase tracking-widest text-success/70 opacity-0 transition-opacity duration-300">Guardado</span>
            </div>
            <textarea 
              id="drawer-op-notes"
              placeholder="Escribe notas de seguimiento para el operador..." 
              class="textarea textarea-bordered w-full flex-1 bg-base-200/20 border-base-300/80 text-sm focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all resize-none min-h-[140px] rounded-2xl p-4 bg-base-100 placeholder:text-base-content/30"
            ></textarea>
          </section>
        </div>

        <!-- History Column -->
        <section class="flex flex-col min-h-0 md:h-full">
          <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-base-content/40 mb-4 shrink-0 flex items-center gap-1.5">
            <Icon name="boxicons:history" size={14} class="text-base-content/50" />
            Historial de Asistencia
          </h3>
