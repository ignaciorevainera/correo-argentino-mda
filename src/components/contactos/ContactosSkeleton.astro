---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
---

<PageContainer width="xl">
  <div class="skeleton-debounced">
    <PageHeader
      description="Directorio operativo para ubicar teléfonos, correos y accesos clave sin salir del flujo de soporte."
    />

    <div class="w-full max-w-xl">
      <div class="h-12 w-full skeleton rounded-lg"></div>
    </div>

    <section
      class="flex flex-col gap-5 mt-6"
      aria-label="Directorio de contactos (cargando)"
    >
      {
        Array.from({ length: 3 }).map(() => (
          <article class="card overflow-hidden border border-t-4 border-base-300 bg-base-100 shadow-md">
            <header class="flex items-center justify-between gap-3 border-b border-base-300 p-4 bg-base-200/20">
              <div class="flex min-w-0 items-center gap-3">
                <div class="size-10 shrink-0 rounded-lg skeleton"></div>
                <div class="min-w-0 space-y-2">
                  <div class="h-4 w-32 skeleton rounded"></div>
                  <div class="h-3 w-20 skeleton rounded"></div>
                </div>
              </div>
            </header>

            <div class="card-body p-0">
              <div class="p-4 space-y-4">
                <div class="flex gap-4">
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                </div>
                <div class="flex gap-4">
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                  <div class="h-4 w-1/5 skeleton rounded"></div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </div>
</PageContainer>
