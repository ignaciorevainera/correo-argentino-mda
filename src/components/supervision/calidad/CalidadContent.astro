---
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchInput from "@components/ui/SearchInput.astro";
import FormField from "@components/ui/forms/FormField.astro";
import FormTextarea from "@components/ui/forms/FormTextarea.astro";
import Modal from "@components/ui/Modal.astro";
import { db } from "@db/index";
import {
  agents,
  qualityAudits,
  auditParameters,
  auditScores,
  monthlySummaries,
} from "@db/schema";
import { eq, inArray } from "drizzle-orm";
import { getResolvedSearchParams } from "@lib/navigation";
import { getCleanBase } from "@lib/baseUrl";

const searchParams = getResolvedSearchParams(Astro.request, Astro.url);

const currentActualMonth = (() => {
  const now = new Date();
  const mm = (now.getMonth() + 1).toString().padStart(2, "0");
  const yyyy = now.getFullYear();
  return `${mm}-${yyyy}`;
})();

const selectedMonth = searchParams.get("month") || currentActualMonth;

// Generate the last 6 months based on the selected month
const getDynamicMonths = (baseMonthStr: string) => {
  const [mm, yyyy] = baseMonthStr.split("-");
  let m = parseInt(mm, 10);
  let y = parseInt(yyyy, 10);
  const res = [];
  for (let i = 0; i < 6; i++) {
    res.push(`${m.toString().padStart(2, "0")}-${y}`);
    m--;
    if (m === 0) {
      m = 12;
      y--;
    }
  }
  return res;
};

const dynamicMonthsList = getDynamicMonths(selectedMonth);

const monthLabels: Record<string, string> = {
  "01": "Enero",
  "02": "Febrero",
  "03": "Marzo",
  "04": "Abril",
  "05": "Mayo",
  "06": "Junio",
  "07": "Julio",
  "08": "Agosto",
  "09": "Septiembre",
  "10": "Octubre",
  "11": "Noviembre",
  "12": "Diciembre",
};

const formatMonthLabel = (monthStr: string) => {
  const [mm, yyyy] = monthStr.split("-");
  return `${monthLabels[mm] || mm} ${yyyy}`;
};


const selectorMonthsList = getDynamicMonths(currentActualMonth);
if (!selectorMonthsList.includes(selectedMonth)) {
  selectorMonthsList.push(selectedMonth);
  selectorMonthsList.sort((a, b) => {
    const [mA, yA] = a.split("-").map(Number);
    const [mB, yB] = b.split("-").map(Number);
    if (yA !== yB) return yB - yA;
    return mB - mA;
  });
}

// Fetch all agents (small table, ~30 rows)
const allAgents = await db.select().from(agents).orderBy(agents.name);

// Fetch all parameters (small table, ~20 rows)
const allParameters = await db.select().from(auditParameters);

// Fetch audits filtered by dynamic months
const allAudits = await db
  .select()
  .from(qualityAudits)
  .where(inArray(qualityAudits.month, dynamicMonthsList));

// Fetch scores only for loaded audits
const auditIds = allAudits.map((a) => a.id);
const allScores =
  auditIds.length > 0
    ? await db
        .select()
        .from(auditScores)
        .where(inArray(auditScores.auditId, auditIds))
    : [];

// Fetch monthly summaries only for selected month
const allMonthlySummaries = await db
  .select()
  .from(monthlySummaries)
  .where(eq(monthlySummaries.month, selectedMonth));

// Pre-indexar auditorías por agentId
const auditsByAgent = new Map<number, typeof allAudits>();
for (const audit of allAudits) {
  if (!auditsByAgent.has(audit.agentId)) {
    auditsByAgent.set(audit.agentId, []);
  }
  auditsByAgent.get(audit.agentId)!.push(audit);
}

// Pre-indexar scores por auditId
const scoresByAudit = new Map<number, typeof allScores>();
for (const score of allScores) {
  if (!scoresByAudit.has(score.auditId)) {
    scoresByAudit.set(score.auditId, []);
  }
  scoresByAudit.get(score.auditId)!.push(score);
}

// Pre-indexar summaries por agentId
const summariesByAgent = new Map<number, (typeof allMonthlySummaries)[0]>();
for (const s of allMonthlySummaries) {
  summariesByAgent.set(s.agentId, s);
}

import { normalizeRole } from "@lib/rbac";

const user = Astro.locals.user;
const role = normalizeRole(user.role);
const isAgent = role === "agent";

let finalAgents = allAgents;
let agentNotFound = false;

if (isAgent) {
  const matched = allAgents.find(
    (a) => a.username?.toLowerCase().trim() === user.username.toLowerCase().trim()
  );
  if (matched) {
    finalAgents = [matched];
  } else {
    finalAgents = [];
    agentNotFound = true;
  }
}

const operatorsQuality = finalAgents.map((agent) => {
  const agentAudits = auditsByAgent.get(agent.id) || [];
  const currentMonthAudits = agentAudits.filter(
    (a) => a.month === selectedMonth,
  );

  const monthSummaryRec = summariesByAgent.get(agent.id);
  const monthSummary = monthSummaryRec ? monthSummaryRec.summary : "";

  const averageScore =
    currentMonthAudits.length > 0
      ? Math.round(
          currentMonthAudits.reduce((sum, audit) => sum + audit.totalScore, 0) /
            currentMonthAudits.length,
        )
      : 0;

  const history = dynamicMonthsList
    .slice()
    .reverse()
    .map((m) => {
      const monthAudits = agentAudits.filter((a) => a.month === m);
      return monthAudits.length > 0
        ? Math.round(
            monthAudits.reduce((sum, audit) => sum + audit.totalScore, 0) /
              monthAudits.length,
          )
        : 0;
    });

  const calls = currentMonthAudits.map((audit) => {
    const auditScoresList = scoresByAudit.get(audit.id) || [];
    const section1Details: Record<string, boolean> = {};
    const section2Details: Record<string, boolean> = {};

    auditScoresList.forEach(scoreObj => {
      const param = allParameters.find(p => p.id === scoreObj.parameterId);
      if (param) {
        if (param.category === "Interacción con Usuario") {
          section1Details[param.code] = scoreObj.score;
        } else if (param.category === "Gestión del Ticket") {
          section2Details[param.code] = scoreObj.score;
        }
      }
    });

    return {
      id: audit.id,
      callId: audit.callId,
      ticketId: audit.ticketId,
      duration: audit.duration,
      date: audit.date,
      month: audit.month,
      notes: audit.notes || "",
      isCriticalFailure: audit.isCriticalFailure || false,
      section1: {
        score: audit.section1Score,
        maxScore: 100,
        details: section1Details,
      },
      section2: {
        score: audit.section2Score,
        maxScore: 100,
        details: section2Details,
      },
      totalScore: audit.totalScore,
    };
  });

  const prevMonth = dynamicMonthsList[1];
  const prevMonthAudits = prevMonth ? agentAudits.filter((a) => a.month === prevMonth) : [];
  const prevAverageScore = prevMonthAudits.length > 0
    ? Math.round(
        prevMonthAudits.reduce((sum, audit) => sum + audit.totalScore, 0) /
          prevMonthAudits.length,
      )
    : 0;
  const prevCallsCount = prevMonthAudits.length;
  const prevCriticalCount = prevMonthAudits.filter((a) => a.isCriticalFailure).length;

  return {
    id: agent.id.toString(),
    name: agent.name,
    username: agent.username || "",
    month: selectedMonth,
    monthSummary,
    calls,
    history,
    averageScore,
    prevAverageScore,
    prevCallsCount,
    prevCriticalCount,
  };
});

const operatorsDataMap = Object.fromEntries(
  operatorsQuality.map((op) => [op.id, op]),
);

const auditedOperators = operatorsQuality.filter((op) => op.calls.length > 0);
const totalOperators = operatorsQuality.length;

const avgScore =
  auditedOperators.length > 0
    ? Math.round(
        auditedOperators.reduce((acc, op) => acc + op.averageScore, 0) /
          auditedOperators.length,
      )
    : 0;

const excellentOperators = auditedOperators.filter(
  (op) => op.averageScore >= 90,
).length;

const needsImprovement = auditedOperators.filter(
  (op) => op.averageScore > 0 && op.averageScore < 80,
).length;

const allCalls = operatorsQuality.flatMap((op) => op.calls);
const totalCalls = allCalls.length;

const avgSection1 =
  totalCalls > 0
    ? Math.round(
        allCalls.reduce((acc, c) => acc + c.section1.score, 0) / totalCalls,
      )
    : 0;

const avgSection2 =
  totalCalls > 0
    ? Math.round(
        allCalls.reduce((acc, c) => acc + c.section2.score, 0) / totalCalls,
      )
    : 0;

const cleanBase = getCleanBase();
---

<div
  id="audit-parameters-data"
  data-parameters={JSON.stringify(allParameters)}
  class="hidden"
>
</div>
<div
  id="operators-data"
  data-operators={JSON.stringify(operatorsDataMap)}
  class="hidden"
>
</div>
<PageContainer class="max-w-7xl mx-auto" data-is-agent={isAgent} data-agent-not-found={agentNotFound}>
  <PageHeader
    description="Evaluación de llamadas, métricas y validaciones de la calidad de atención del equipo de operaciones de Mesa de Ayuda."
  />

  <!-- Selector de Período -->
  <div
    class="mt-4 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between bg-base-200/50 p-4 rounded-xl border border-base-300 shadow-md"
  >
    <div class="flex items-center gap-2 text-base-content/80 mb-3 sm:mb-0">
      <Icon name="boxicons:calendar" size={24} class="text-primary" />
      <span class="font-semibold">Período de evaluación:</span>
    </div>
    <div class="flex items-center gap-2">
      <button
        id="btn-prev-month"
        class="btn btn-sm btn-square btn-ghost"
        title="Mes anterior"
      >
        <Icon name="boxicons:chevron-left" size={24} />
      </button>
      <select
        id="month-selector"
        class="select select-bordered select-sm w-full sm:w-48 bg-base-100 font-bold text-center"
      >
        {
          selectorMonthsList.map((m) => (
            <option value={m} selected={selectedMonth === m}>
              {formatMonthLabel(m)}
            </option>
          ))
        }
      </select>
      <button
        id="btn-next-month"
        class="btn btn-sm btn-square btn-ghost"
        title="Mes siguiente"
      >
        <Icon name="boxicons:chevron-right" size={24} />
      </button>
      <div class="divider divider-horizontal mx-1 hidden sm:flex"></div>
      {!isAgent && (
        <button
          id="btn-configure-parameters"
          class="btn btn-sm btn-outline btn-secondary gap-1.5 font-bold uppercase text-xs"
          title="Configurar Parámetros de Calidad"
        >
          <Icon name="boxicons:cog" size={18} />
          <span>Parámetros</span>
        </button>
      )}
    </div>
  </div>

  {
    agentNotFound ? (
      <div class="alert alert-warning shadow-md rounded-2xl p-6 mb-6 flex gap-4">
        <Icon name="boxicons:alert-circle-filled" size={24} class="shrink-0 text-amber-600" />
        <div>
          <h3 class="font-bold text-sm uppercase tracking-wide">Ficha de Operador no encontrada</h3>
          <p class="text-xs mt-1">
            No se encontró tu ficha de operador vinculada a tu nombre de usuario (@{user.username}).
            Por favor, solicita a tu supervisor que cree tu ficha en el sistema.
          </p>
        </div>
      </div>
    ) : (
      <div
        class="mt-2 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start relative"
      >
    <!-- Panel Izquierdo: Lista Navegable -->
    <aside
      class:list={[
        "flex flex-col gap-4 lg:sticky lg:top-6 lg:h-[calc(100vh-8rem)]",
        isAgent ? "hidden" : "lg:col-span-4"
      ]}
    >
      <div
        class="card border border-base-300 bg-base-100 shadow-md flex-1 flex flex-col overflow-hidden"
      >
        <div
          class="p-4 border-b border-base-200 bg-base-200/30 flex flex-col gap-3"
        >
          <h2 class="font-bold text-base-content flex items-center gap-2">
            <Icon name="boxicons:group" class="text-primary" size={24} />
            Operadores Evaluados
          </h2>
          <div class="flex flex-col gap-2">
            <SearchInput
              id="operator-search"
              label="Buscar operador"
              placeholder="Buscar por nombre o legajo..."
            />
            <div class="flex gap-2">
              <select
                id="operator-sort"
                class="select select-bordered select-sm w-full font-medium text-base-content/70"
              >
                <option value="name">Nombre: A → Z</option>
                <option value="name-desc">Nombre: Z → A</option>
                <option value="score-desc">Score: Mayor primero</option>
                <option value="score-asc">Score: Menor primero</option>
                <option value="calls-desc">Auditorías: Más evaluados</option>
                <option value="calls-asc">Auditorías: Menos evaluados</option>
                <option value="critical">Falla Crítica primero</option>
              </select>
            </div>
          </div>
        </div>

        <div class="flex-1 overflow-y-auto p-2" id="operator-list">
          {
            operatorsQuality.map((op) => (
              <button
                class="operator-item group w-full text-left p-4 mb-2 rounded-xl bg-base-100 border border-base-200 border-l-4 border-l-transparent hover:border-l-secondary transition-all flex items-center justify-between"
                data-name={op.name.toLowerCase()}
                data-id={op.id.toLowerCase()}
                data-operator={JSON.stringify({
                  id: op.id,
                  name: op.name,
                  averageScore: op.averageScore,
                  callsCount: op.calls.length,
                  hasCriticalFailure: op.calls.some(
                    (c) => c.isCriticalFailure,
                  ),
                })}
              >
                <div class="flex items-center gap-4">
                  <div class="relative">
                    <div class="flex size-10 items-center justify-center rounded-full bg-base-200 group-hover:bg-secondary group-hover:text-secondary-content text-base-content/70 font-bold transition-colors shadow-sm">
                      {op.name
                        .split(" ")
                        .map((n) => n[0])
                        .join("")
                        .substring(0, 2)}
                    </div>
                  </div>
                  <div>
                    <div class="font-bold text-sm text-base-content group-hover:text-base-content transition-colors tracking-tight flex items-center gap-1">
                      {op.name}
                      {op.averageScore >= 90 && (
                        <Icon
                          name="boxicons:badge-check"
                          class="text-secondary"
                          size={24}
                          title="Insignia de Excelencia"
                        />
                      )}
                    </div>
                    <div class="font-mono text-xs lowercase text-base-content/50 mt-0.5">
                      @{op.username || op.id}
                    </div>
                  </div>
                </div>
                <div
                  class={`text-sm font-black ${op.averageScore >= 90 ? "text-success" : op.averageScore >= 80 ? "text-warning" : "text-error"}`}
                >
                  {op.averageScore}%
                </div>
              </button>
            ))
          }
          <div
            id="no-results-msg"
            class="hidden py-8 text-center text-base-content/50"
          >
            <Icon
              name="boxicons:search"
              class="mx-auto mb-2 opacity-40"
              size={48}
            />
            <p class="text-sm font-medium">Sin resultados</p>
          </div>
        </div>
      </div>
    </aside>

    <!-- Panel Derecho: Información / Detalle -->
    <main class:list={["h-full", isAgent ? "lg:col-span-12" : "lg:col-span-8"]}>
      <!-- Estado 1: Información General (Default) -->
      <div id="general-info-panel" class:list={["space-y-6 animate-fade-in", isAgent && "hidden"]}>
        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Hero Stat: Promedio General (Takes 2 cols/2 rows) -->
          <div
            class="col-span-2 row-span-2 bg-secondary text-secondary-content rounded-3xl p-8 flex flex-col justify-between shadow-md relative overflow-hidden"
          >
            <div
              class="absolute inset-0 opacity-5"
              style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 24px 24px;"
            >
            </div>
            <div
              class="absolute -right-8 -top-8 opacity-10 transition-all duration-700"
            >
              <Icon name="boxicons:check-shield" size={256} />
            </div>
            <div class="flex justify-between items-start relative z-10">
              <h3
                class="font-bold uppercase tracking-widest text-xs opacity-80"
              >
                Calidad Global
              </h3>
              <Icon
                name="boxicons:chart-bar-columns"
                size={24}
                class="opacity-80"
              />
            </div>
            <div class="mt-12 relative z-10">
              <div
                class="text-7xl lg:text-8xl font-black tracking-tighter"
              >
                {avgScore}<span class="ml-2 text-4xl lg:text-5xl opacity-70"
                  >%</span
                >
              </div>
              <p
                class="text-sm font-medium opacity-90 mt-4 max-w-xs"
              >
                Promedio general del equipo de Mesa de Ayuda en el período
                seleccionado.
              </p>
            </div>
          </div>

          <!-- Evaluados -->
          <div
            class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-md flex flex-col justify-between"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
            >
              <Icon name="boxicons:group" size={18} /> Evaluados
            </h3>
            <div>
              <div
                class="text-4xl font-black text-base-content tracking-tight"
              >
                {totalOperators}
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1">
                Operadores activos
              </div>
            </div>
          </div>

          <!-- Llamadas Auditadas -->
          <div
            class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-md flex flex-col justify-between"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
            >
              <Icon name="boxicons:phone-ring" size={18} /> Auditorías
            </h3>
            <div>
              <div
                class="text-4xl font-black text-base-content tracking-tight"
              >
                {totalCalls}
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1">
                Llamadas aleatorias
              </div>
            </div>
          </div>

          <!-- Excelente -->
          <div
            class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-md flex flex-col justify-between"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
            >
              <Icon name="boxicons:star" size={18} /> Excelencia
            </h3>
            <div>
              <div class="text-4xl font-black text-success tracking-tight">
                {excellentOperators}
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1">
                Operadores &gt; 90%
              </div>
            </div>
          </div>

          <!-- Bajo Rendimiento -->
          <div
            class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-md flex flex-col justify-between"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
            >
              <Icon name="boxicons:alert-circle" size={18} /> Alerta
            </h3>
            <div>
              <div class="text-4xl font-black text-error tracking-tight">
                {needsImprovement}
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1">
                Operadores &lt; 80%
              </div>
            </div>
          </div>

          <!-- Promedio Interacción -->
          <div
            class="col-span-2 lg:col-span-2 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-md flex flex-col justify-between"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
            >
              <Icon name="boxicons:discussion" size={18} /> Interacción
            </h3>
            <div>
              <div
                class="text-4xl font-black text-base-content tracking-tight"
              >
                {avgSection1}%
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1">
                Trato al usuario y habilidades blandas
              </div>
            </div>
          </div>

          <!-- Promedio Gestión -->
          <div
            class="col-span-2 lg:col-span-2 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-md flex flex-col justify-between"
          >
            <h3
              class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-4 flex items-center gap-1.5"
            >
              <Icon name="boxicons:task" size={18} /> Gestión
            </h3>
            <div>
              <div
                class="text-4xl font-black text-base-content tracking-tight"
              >
                {avgSection2}%
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1">
                Eficiencia técnica y resolución de tickets
              </div>
            </div>
          </div>
        </div>

        <!-- Empty State CTA -->
        <div
          class="rounded-3xl bg-base-200/50 flex-1 min-h-64 flex flex-col items-center justify-center text-center p-8 mt-4 border border-base-300 shadow-inner"
        >
          <div
            class="rounded-full bg-base-100 p-6 shadow-sm mb-6 border border-base-200"
          >
            <Icon
              name="boxicons:cursor-click"
              size={48}
              class="text-secondary/40"
            />
          </div>
          <h3
            class="text-2xl font-black text-base-content tracking-tight mb-3"
          >
            Análisis Individual
          </h3>
          <p
            class="max-w-md text-sm text-base-content/60 font-medium"
          >
            Seleccione un operador de la lista lateral para visualizar su
            rendimiento detallado y el desglose de cada llamada.
          </p>
        </div>
      </div>

      <!-- Estado 2: Detalle del Operador (Oculto por defecto) -->
      <div
        id="operator-details-panel"
        class:list={[
          "animate-fade-in pb-8",
          !isAgent && "hidden space-y-6",
          isAgent && "grid grid-cols-1 lg:grid-cols-12 gap-6 items-start"
        ]}
      >
        <div class:list={[isAgent ? "col-span-full" : "w-full"]}>
          <div class="flex justify-between items-center mb-2 no-print">
            <button
              id="btn-back-to-summary"
              class="btn btn-sm btn-ghost w-fit pl-2 text-base-content/70 hover:text-base-content hover:bg-base-200"
            >
              <Icon name="boxicons:arrow-to-left" size={18} />
              Volver al resumen
            </button>
            <div class="flex items-center gap-2">
              <button
                id="btn-export-csv"
                class="btn btn-xs btn-outline btn-secondary gap-1.5 font-bold uppercase text-xxs"
                title="Exportar Reporte de Operador a CSV"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-3.5 shrink-0">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                <span>Exportar CSV</span>
              </button>
              <button
                class="btn btn-xs btn-outline btn-secondary gap-1.5 font-bold uppercase text-xxs"
                onclick="window.print()"
              >
                <Icon name="boxicons:printer" size={14} />
                Exportar Reporte
              </button>
            </div>
          </div>

          <!-- Header del Detalle -->
          {isAgent ? (
