<script>
  import { actions } from "astro:actions";
  import { calculateAuditScores } from "@lib/qualityCalculator";
  import type {
    QualityCall,
    OperatorQuality,
    AuditParameter,
  } from "@/types/quality";

  const ICON_CHECK = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="m10 15.586-3.293-3.293-1.414 1.414L10 18.414l9.707-9.707-1.414-1.414z"></path></svg>`;
  const ICON_X = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="m16.192 6.344-4.243 4.242-4.242-4.242-1.414 1.414L10.535 12l-4.242 4.242 1.414 1.414 4.242-4.242 4.243 4.242 1.414-1.414L13.364 12l4.242-4.242z"></path></svg>`;
  const ICON_ARROW = `<svg class="size-4 text-warning" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M10.707 17.707 16.414 12l-5.707-5.707-1.414 1.414L13.586 12l-4.293 4.293z"></path></svg>`;
  const ICON_STAR = `<svg class="size-4 text-success" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M21.947 9.179a1.001 1.001 0 0 0-.868-.676l-5.701-.453-2.467-5.461a.998.998 0 0 0-1.822-.001L8.622 8.05l-5.701.453a1 1 0 0 0-.619 1.713l4.214 4.107-1.29 5.71a1.001 1.001 0 0 0 1.451 1.054L12 18.26l5.324 2.827a1.002 1.002 0 0 0 1.45-1.054l-1.29-5.71 4.214-4.107a1 1 0 0 0 .249-1.037z"></path></svg>`;

  function escapeHtml(str: string | null | undefined): string {
    if (str == null) return "";
    const div = document.createElement("div");
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  const formatMonthLabel = (monthStr: string): string => {
    const labels: Record<string, string> = {
      "01": "Enero",
      "02": "Febrero",
      "03": "Marzo",
      "04": "Abril",
      "05": "Mayo",
      "06": "Junio",
      "07": "Julio",
      "08": "Agosto",
      "09": "Septiembre",
      "10": "Octubre",
      "11": "Noviembre",
      "12": "Diciembre",
    };
    const [mm, yyyy] = monthStr.split("-");
    return `${labels[mm] || mm} ${yyyy}`;
  };

  const getAuditParameters = () => {
    const el = document.getElementById("audit-parameters-data");
    if (!el) return [];
    try {
      return JSON.parse(el.getAttribute("data-parameters") || "[]");
    } catch (e) {
      return [];
    }
  };

  const getOperatorFullData = (id: string) => {
    const el = document.getElementById("operators-data");
    if (!el) return null;
    try {
      const map = JSON.parse(el.getAttribute("data-operators") || "{}");
      return map[id] || null;
    } catch (e) {
      return null;
    }
  };

  function renderCallCard(call: QualityCall, index: number) {
    const isUserAgent = document.querySelector("[data-is-agent]")?.getAttribute("data-is-agent") === "true";
    const s1ScoreColor =
      call.section1.score >= 90
        ? "text-success"
        : call.section1.score >= 70
          ? "text-warning"
          : "text-error";
    const s2ScoreColor =
      call.section2.score >= 90
        ? "text-success"
        : call.section2.score >= 70
          ? "text-warning"
          : "text-error";
    const badgeClass =
      call.totalScore >= 90
        ? "badge-success"
        : call.totalScore >= 80
          ? "badge-warning"
          : "badge-error";

    // Filtrar parámetros dinámicos
    const params: AuditParameter[] = getAuditParameters();
    const s1Params = params.filter((p) => p.category === "Interacción con Usuario" && call.section1.details.hasOwnProperty(p.code));
    const s2Params = params.filter((p) => p.category === "Gestión del Ticket" && call.section2.details.hasOwnProperty(p.code));

    const s1ListHTML = s1Params
      .map((param) => {
        const isChecked = call.section1.details[param.code] || false;
        return `
        <li class="flex items-center justify-between group/item">
          <span class="text-base-content/70 font-medium group-hover/item:text-base-content transition-colors">
            ${escapeHtml(param.name)}
            <span class="text-xs opacity-50 font-normal ml-1.5">(${param.weight})</span>
          </span>
          <span class="${isChecked ? "text-success" : "text-error"}" title="${isChecked ? "Cumple" : "No Cumple"}">${isChecked ? ICON_CHECK : ICON_X}</span>
        </li>
      `;
      })
      .join("");

    const s2ListHTML = s2Params
      .map((param) => {
        const isChecked = call.section2.details[param.code] || false;
        return `
        <li class="flex items-center justify-between group/item">
          <span class="text-base-content/70 font-medium group-hover/item:text-base-content transition-colors">
            ${escapeHtml(param.name)}
            <span class="text-xs opacity-50 font-normal ml-1.5">(${param.weight})</span>
          </span>
          <span class="${isChecked ? "text-success" : "text-error"}" title="${isChecked ? "Cumple" : "No Cumple"}">${isChecked ? ICON_CHECK : ICON_X}</span>
        </li>
      `;
      })
      .join("");

    const criticalFailureBadge = call.isCriticalFailure
      ? `
        <div class="col-span-full bg-error/10 border border-error/20 rounded-2xl p-4 flex items-center gap-3 text-error mt-2">
          <svg class="size-6 text-error shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"></path></svg>
          <div>
            <div class="font-black text-sm uppercase">Falla Crítica de Proceso</div>
            <div class="text-xs opacity-90">Esta llamada presenta un incumplimiento crítico del proceso de atención.</div>
          </div>
        </div>
      `
      : "";

    const notesSection = call.notes
      ? `
        <div class="col-span-full border-t border-base-200/50 pt-4 mt-4">
          <div class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-1">Notas / Observaciones de la llamada</div>
          <p class="text-sm text-base-content/70 whitespace-pre-line">${escapeHtml(call.notes)}</p>
        </div>
      `
      : "";

    return `
      <div class="call-card-container rounded-3xl border border-base-300 bg-base-100 overflow-hidden shadow-md relative group">
        
        <!-- Decoration Left Border -->
        <div class="absolute left-0 top-0 bottom-0 w-2 ${badgeClass.replace("badge-", "bg-")} opacity-80 group-hover:opacity-100 transition-opacity"></div>
        
        <!-- Card Header -->
        <div class="flex flex-wrap items-center justify-between border-b border-base-200 bg-base-100 p-6 pl-8">
          <div class="flex items-center gap-5">
            <div class="flex size-12 items-center justify-center rounded-2xl bg-base-200 font-black text-base-content/70 border border-base-300 shadow-inner">
              #${index + 1}
            </div>
            <div>
              <div class="flex items-center gap-2">
                <span class="font-mono text-lg font-black tracking-tight text-base-content">${escapeHtml(call.callId)}</span>
                ${call.isCriticalFailure ? '<span class="badge badge-error badge-sm font-bold uppercase tracking-wider text-xxs px-2 py-1.5 shadow-sm">Falla Crítica</span>' : ""}
              </div>
              <div class="text-xs font-medium text-base-content/50 mt-1 uppercase tracking-widest">Ticket: <span class="font-mono text-base-content/70">${escapeHtml(call.ticketId)}</span></div>
            </div>
          </div>
          <div class="flex items-center gap-8 mt-4 sm:mt-0">
            <div class="text-right">
              <div class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-1">Duración</div>
              <div class="text-base font-mono font-bold text-base-content/80">${escapeHtml(call.duration)}</div>
            </div>
            <div class="text-right">
              <div class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-1">Score Total</div>
              <div class="badge ${badgeClass} font-black shadow-sm text-sm py-3 px-3">
                ${call.totalScore}%
              </div>
            </div>
            ${isUserAgent ? "" : `
            <button 
              class="btn btn-circle btn-ghost btn-sm text-base-content/50 hover:text-secondary ml-2 edit-audit-btn" 
              data-call-id="${call.id}"
              title="Editar Auditoría"
            >
              <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="fill: currentColor;"><path d="m18.988 2.012-3 3L19.988 9.012l3-3zM3.988 17.012v4h4l12.75-12.75-4-4z"></path></svg>
            </button>
            `}
            <button 
              class="btn btn-circle btn-ghost btn-sm text-base-content/50 hover:text-base-content hover:bg-base-200 ml-1" 
              onclick="this.closest('.call-card-container').querySelector('.call-card-details').classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');"
              title="Expandir / Minimizar detalles"
            >
              <svg class="size-6 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M16.293 9.293 12 13.586 7.707 9.293l-1.414 1.414L12 16.414l5.707-5.707z"></path></svg>
            </button>
          </div>
        </div>
        
        <!-- Details Grid -->
        <div class="call-card-details hidden grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-base-200 bg-base-200/20">
          
          <!-- Section 1 -->
          <div class="p-6 pl-8">
            <div class="mb-6 flex items-center justify-between border-b border-base-300/50 pb-3">
              <h5 class="font-bold text-xs uppercase tracking-widest text-base-content/70">Interacción con Usuario</h5>
              <div class="flex items-baseline gap-1">
                <span class="text-xl font-black ${s1ScoreColor}">${call.section1.score}</span>
                <span class="text-xs font-bold text-base-content/30">/${call.section1.maxScore}</span>
              </div>
            </div>
            <ul class="space-y-3.5 text-sm">
              ${s1ListHTML}
            </ul>
          </div>
          
          <!-- Section 2 -->
          <div class="p-6">
            <div class="mb-6 flex items-center justify-between border-b border-base-300/50 pb-3">
              <h5 class="font-bold text-xs uppercase tracking-widest text-base-content/70">Gestión del Ticket</h5>
              <div class="flex items-baseline gap-1">
                <span class="text-xl font-black ${s2ScoreColor}">${call.section2.score}</span>
                <span class="text-xs font-bold text-base-content/30">/${call.section2.maxScore}</span>
              </div>
            </div>
            <ul class="space-y-3.5 text-sm">
              ${s2ListHTML}
            </ul>
          </div>

          <div class="col-span-full p-6 pl-8 border-t border-base-200 bg-base-200/40">
            ${criticalFailureBadge}
            ${notesSection}
            ${!call.isCriticalFailure && !call.notes ? '<p class="text-xs text-base-content/40 italic">Sin observaciones o notas registradas.</p>' : ""}
          </div>

        </div>
      </div>
    `;
  }

  function initQualityMasterDetail() {
    const generalPanel = document.getElementById("general-info-panel");
    const detailsPanel = document.getElementById("operator-details-panel");

    const dAvatar = document.getElementById("detail-avatar");
    const dName = document.getElementById("detail-name");
    const dId = document.getElementById("detail-id");
    const dMonth = document.getElementById("detail-month");
    const dScore = document.getElementById("detail-score");
    const dStatDiff = document.getElementById("detail-stat-diff");
    const dStatAht = document.getElementById("detail-stat-aht");
    const dStatInteraction = document.getElementById("detail-stat-interaction");
    const dStatManagement = document.getElementById("detail-stat-management");
    const dMonthSummary = document.getElementById("detail-month-summary");
    const dMonthSummaryEmpty = document.getElementById(
      "detail-month-summary-empty",
    );
    const callsContainer = document.getElementById("detail-calls-container");
    const btnBack = document.getElementById("btn-back-to-summary");

    // Modal elements
    const auditModal = document.getElementById(
      "audit-modal",
    ) as HTMLDialogElement;
    const auditForm = document.getElementById("audit-form") as HTMLFormElement;
    const modalTitle = document.getElementById("modal-title");
    const formAuditId = document.getElementById(
      "form-audit-id",
    ) as HTMLInputElement;
    const formAgentId = document.getElementById(
      "form-agent-id",
    ) as HTMLInputElement;
    const formCallId = document.getElementById(
      "form-call-id",
    ) as HTMLInputElement;
    const formTicketId = document.getElementById(
      "form-ticket-id",
    ) as HTMLInputElement;
    const formDuration = document.getElementById(
      "form-duration",
    ) as HTMLInputElement;
    const formDate = document.getElementById("form-date") as HTMLInputElement;
    const btnDeleteAudit = document.getElementById(
      "btn-delete-audit",
    ) as HTMLButtonElement;
    const btnCloseModal = document.getElementById(
      "btn-close-modal",
    ) as HTMLButtonElement;

    // Additional field elements
    const formNotes = document.getElementById(
      "form-notes",
    ) as HTMLTextAreaElement;
    const formIsCriticalFailure = document.getElementById(
      "form-is-critical-failure",
    ) as HTMLInputElement;

    // Month Summary Modal elements
    const summaryModal = document.getElementById(
      "month-summary-modal",
    ) as HTMLDialogElement;
    const summaryForm = document.getElementById(
      "month-summary-form",
    ) as HTMLFormElement;
    const summaryAgentId = document.getElementById(
      "summary-agent-id",
    ) as HTMLInputElement;
    const summaryContent = document.getElementById(
      "summary-content",
    ) as HTMLTextAreaElement;
    const btnCloseSummaryModal = document.getElementById(
      "btn-close-summary-modal",
    ) as HTMLButtonElement;
    const btnEditMonthSummary = document.getElementById(
      "btn-edit-month-summary",
    ) as HTMLButtonElement;

    let activeAgentId = "";
    let activeAgentSummary = "";

    function clearFormErrors(form: HTMLFormElement) {
      form
        .querySelectorAll(".input, .textarea, .checkbox, .select")
        .forEach((el) => {
          el.classList.remove(
            "input-error",
            "textarea-error",
            "checkbox-error",
            "select-error",
          );
        });
      form.querySelectorAll(".field-error-msg").forEach((el) => el.remove());
    }

    interface FormValidationError {
      issues?: Array<{
        path: Array<string | number>;
        message: string;
      }>;
      message?: string;
    }

    function showFormErrors(
      form: HTMLFormElement,
      error: FormValidationError | null | undefined,
    ) {
      clearFormErrors(form);
      if (!error) return;

      const issues = error.issues || [];
      let firstErrorElement: HTMLElement | null = null;

      issues.forEach((issue) => {
        const fieldName = issue.path[0];
        if (!fieldName) return;

        const input = form.querySelector(
          `[name="${fieldName}"]`,
        ) as HTMLElement;
        if (input) {
          if (input.classList.contains("textarea")) {
            input.classList.add("textarea-error");
          } else if (input.classList.contains("checkbox")) {
            input.classList.add("checkbox-error");
          } else if (input.classList.contains("select")) {
            input.classList.add("select-error");
          } else {
            input.classList.add("input-error");
          }

          const errContainer = input.closest(".form-control");
          if (errContainer) {
            const errMsg = document.createElement("span");
            errMsg.className =
              "text-error text-xs font-bold mt-1 field-error-msg";
            errMsg.textContent = issue.message;
            errContainer.appendChild(errMsg);
          }

          if (!firstErrorElement) {
            firstErrorElement = input;
          }
        }
      });

      if (firstErrorElement) {
        (firstErrorElement as HTMLElement).focus();
      } else {
        alert(error.message || "Error de validación en el formulario.");
      }
    }

    // helper to calculate and update scores in modal using weights
    const updateModalScorePreview = () => {
      const checkboxes = auditForm.querySelectorAll(
        ".audit-checkbox",
      ) as NodeListOf<HTMLInputElement>;
      const checkedIdsOrCodes = new Set<number | string>();

      checkboxes.forEach((cb) => {
        if (cb.checked) {
          const paramIdStr = cb.getAttribute("data-param-id");
          if (paramIdStr) {
            checkedIdsOrCodes.add(parseInt(paramIdStr, 10));
          }
        }
      });

      const params = getAuditParameters();
      const isCriticalFailure = formIsCriticalFailure
        ? formIsCriticalFailure.checked
        : false;

      const { section1Score, section2Score, totalScore } = calculateAuditScores(
        params,
        checkedIdsOrCodes,
        isCriticalFailure,
      );

      const p1 = document.getElementById("preview-s1");
      const p2 = document.getElementById("preview-s2");
      const pt = document.getElementById("preview-total");

      if (p1) p1.textContent = `${section1Score}%`;
      if (p2) p2.textContent = `${section2Score}%`;
      if (pt) {
        pt.textContent = `${totalScore}%`;
        pt.classList.remove(
          "text-secondary",
          "text-success",
          "text-warning",
          "text-error",
        );
        if (totalScore >= 90) {
          pt.classList.add("text-success");
        } else if (totalScore >= 70) {
          pt.classList.add("text-warning");
        } else {
          pt.classList.add("text-error");
        }
      }
    };

    // add checkbox event listeners
    auditForm.querySelectorAll(".audit-checkbox").forEach((cb) => {
      cb.addEventListener("change", updateModalScorePreview);
    });
    if (formIsCriticalFailure) {
      formIsCriticalFailure.addEventListener("change", updateModalScorePreview);
    }

    // open modal for editing
    const openAuditModal = (
      agentId: string,
      callData: QualityCall | null = null,
    ) => {
      activeAgentId = agentId;
      auditForm.reset();
      clearFormErrors(auditForm);
      formAgentId.value = agentId;

      // Filter parameter checkboxes based on mode
      const rows = auditForm.querySelectorAll(".audit-parameter-row") as NodeListOf<HTMLElement>;
      if (callData) {
        rows.forEach(row => {
          const input = row.querySelector("input[type='checkbox']") as HTMLInputElement;
          const code = input ? input.name : "";
          const hasAnswer = callData.section1.details.hasOwnProperty(code) || callData.section2.details.hasOwnProperty(code);
          if (hasAnswer) {
            row.classList.remove("hidden");
          } else {
            row.classList.add("hidden");
          }
        });
      } else {
        rows.forEach(row => {
          const isActive = row.getAttribute("data-active") === "true";
          if (isActive) {
            row.classList.remove("hidden");
          } else {
            row.classList.add("hidden");
          }
        });
      }
      
      if (callData) {
        // Edit mode
        modalTitle!.innerHTML = `<svg class="size-6 text-secondary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="fill: currentColor; margin-right: 0.5rem;"><path d="m18.988 2.012-3 3L19.988 9.012l3-3zM3.988 17.012v4h4l12.75-12.75-4-4z"></path></svg> Editar Auditoría de Calidad`;
        formAuditId.value = String(callData.id);
        formCallId.value = callData.callId;
        formTicketId.value = callData.ticketId;
        formDuration.value = callData.duration;

        // Extract YYYY-MM-DD from ISO date
        formDate.value = callData.date.substring(0, 10);

        // Fill additional fields
        formNotes.value = callData.notes || "";
        formIsCriticalFailure.checked = !!callData.isCriticalFailure;

        // Check checkboxes
        const s1Details = callData.section1.details;
        const s2Details = callData.section2.details;

        Object.entries(s1Details).forEach(([key, val]) => {
          const cb = auditForm.querySelector(
            `[name="${key}"]`,
          ) as HTMLInputElement;
          if (cb) cb.checked = !!val;
        });
        Object.entries(s2Details).forEach(([key, val]) => {
          const cb = auditForm.querySelector(
            `[name="${key}"]`,
          ) as HTMLInputElement;
          if (cb) cb.checked = !!val;
        });

        btnDeleteAudit.classList.remove("hidden");
      } else {
        // New mode
        modalTitle!.innerHTML = `<svg class="size-6 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="fill: currentColor; margin-right: 0.5rem;"><path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z"></path></svg> Nueva Auditoría de Calidad`;
        formAuditId.value = "";

        // Clear fields so placeholders show
        formCallId.value = "";
        formTicketId.value = "";
        formDuration.value = "";

        // Clear additional fields
        formNotes.value = "";
        formIsCriticalFailure.checked = false;

        // Default to today
        const today = new Date().toISOString().substring(0, 10);
        formDate.value = today;

        btnDeleteAudit.classList.add("hidden");
      }

      updateModalScorePreview();
      auditModal.showModal();
    };

    // Close modal triggers
    btnCloseModal.addEventListener("click", () => {
      auditModal.close();
    });

    // Attach "Nueva Auditoría" button listener
    const btnNewAudit = document.getElementById("btn-new-audit");
    if (btnNewAudit) {
      btnNewAudit.addEventListener("click", () => {
        if (activeAgentId) {
          openAuditModal(activeAgentId);
        }
      });
    }

    // Submit form using Astro Actions
    auditForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearFormErrors(auditForm);

      const btnSubmit = auditForm.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const originalText = btnSubmit.innerHTML;
      btnSubmit.disabled = true;
      btnSubmit.innerHTML =
        '<span class="loading loading-spinner loading-xs"></span> Guardando…';

      const formData = new FormData(auditForm);
      // Ensure notes is always present (even if textarea is empty)
      if (!formData.has("notes")) {
        formData.set("notes", "");
      }
      try {
        const result = await actions.saveAudit(formData);
        if (result.error) {
          console.error("Validation error:", result.error);
          showFormErrors(auditForm, result.error);
        } else if (result.data?.success) {
          const url = new URL(window.location.href);
          if (activeAgentId) {
            url.searchParams.set("agentId", activeAgentId);
          }
          url.searchParams.set("toast_msg", "Auditoría guardada con éxito.");
          url.searchParams.set("toast_type", "success");
          window.location.href = url.toString();
        } else {
          (window as any).showToast?.("Error al guardar la auditoría.", "alert-error");
        }
      } catch (error) {
        console.error(error);
        (window as any).showToast?.("Ocurrió un error inesperado al guardar la auditoría.", "alert-error");
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = originalText;
      }
    });

    // Handle Month Summary Modal
    if (btnEditMonthSummary) {
      btnEditMonthSummary.addEventListener("click", () => {
        if (activeAgentId) {
          summaryForm.reset();
          clearFormErrors(summaryForm);
          summaryAgentId.value = activeAgentId;
          summaryContent.value = activeAgentSummary;
          summaryModal.showModal();
        }
      });
    }

    if (btnCloseSummaryModal) {
      btnCloseSummaryModal.addEventListener("click", () => {
        summaryModal.close();
      });
    }

    summaryForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearFormErrors(summaryForm);

      const btnSubmit = summaryForm.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const originalText = btnSubmit.innerHTML;
      btnSubmit.disabled = true;
      btnSubmit.innerHTML =
        '<span class="loading loading-spinner loading-xs"></span> Guardando…';

      const formData = new FormData(summaryForm);
      // Ensure summary is always present (even if textarea is empty)
      if (!formData.has("summary")) {
        formData.set("summary", "");
      }      try {
        const result = await actions.saveMonthSummary(formData);
        if (result.error) {
          console.error("Validation error:", result.error);
          showFormErrors(summaryForm, result.error);
        } else if (result.data?.success) {
          const url = new URL(window.location.href);
          if (activeAgentId) {
            url.searchParams.set("agentId", activeAgentId);
          }
          url.searchParams.set("toast_msg", "Observaciones del mes guardadas con éxito.");
          url.searchParams.set("toast_type", "success");
          window.location.href = url.toString();
        } else {
          (window as any).showToast?.("Error al guardar el resumen.", "alert-error");
        }
      } catch (error) {
        console.error(error);
        (window as any).showToast?.("Ocurrió un error inesperado al guardar el resumen.", "alert-error");
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = originalText;
      }
    });

    // Delete audit using Astro Actions
    btnDeleteAudit.addEventListener("click", async () => {
      const auditId = formAuditId.value;
      if (!auditId) return;

      if (confirm("¿Estás seguro de que querés eliminar esta auditoría?")) {
        const originalText = btnDeleteAudit.innerHTML;
        btnDeleteAudit.disabled = true;
        btnDeleteAudit.innerHTML =
          '<span class="loading loading-spinner loading-xs"></span> Eliminando…';

        try {
          const deleteForm = new FormData();
          deleteForm.append("id", auditId);

          const result = await actions.deleteAudit(deleteForm);
          if (result.data?.success) {
            const url = new URL(window.location.href);
            if (activeAgentId) {
              url.searchParams.set("agentId", activeAgentId);
            }
            url.searchParams.set("toast_msg", "Auditoría eliminada con éxito.");
            url.searchParams.set("toast_type", "success");
            window.location.href = url.toString();
          } else {
            (window as any).showToast?.("Error al eliminar la auditoría.", "alert-error");
            btnDeleteAudit.disabled = false;
            btnDeleteAudit.innerHTML = originalText;
          }
        } catch (error) {
          console.error(error);
          (window as any).showToast?.("Ocurrió un error inesperado al eliminar la auditoría.", "alert-error");
          btnDeleteAudit.disabled = false;
          btnDeleteAudit.innerHTML = originalText;
        }
      }
    });

    if (btnBack) {
      btnBack.addEventListener("click", () => {
        if (generalPanel) generalPanel.classList.remove("hidden");
        if (detailsPanel) detailsPanel.classList.add("hidden");

        document.querySelectorAll(".operator-item").forEach((el) => {
          el.classList.remove(
            "border-l-secondary",
            "bg-secondary/5",
            "shadow-md",
          );
          el.classList.add("border-l-transparent");
        });
      });
    }

    let searchInput = document.getElementById(
      "operator-search",
    ) as HTMLInputElement;
    let operatorSort = document.getElementById(
      "operator-sort",
    ) as HTMLSelectElement;
    const operatorListContainer = document.getElementById("operator-list");
    const noResultsMsg = document.getElementById("no-results-msg");

    const updateOperatorsList = () => {
      const term = searchInput?.value.toLowerCase() || "";
      const sortValue = operatorSort?.value || "name";
      let hasVisibleItems = false;

      // Re-query items to always work with the current live DOM nodes
      const itemsArray = Array.from(
        document.querySelectorAll(".operator-item"),
      ) as HTMLElement[];

      itemsArray.sort((a, b) => {
        if (sortValue === "name") {
          return (a.getAttribute("data-name") || "").localeCompare(
            b.getAttribute("data-name") || "",
          );
        } else if (sortValue === "name-desc") {
          return (b.getAttribute("data-name") || "").localeCompare(
            a.getAttribute("data-name") || "",
          );
        } else if (
          sortValue === "calls-desc" ||
          sortValue === "calls-asc" ||
          sortValue === "critical"
        ) {
          const opA = JSON.parse(a.getAttribute("data-operator") || "{}");
          const opB = JSON.parse(b.getAttribute("data-operator") || "{}");
          if (sortValue === "calls-desc") {
            return (opB.callsCount ?? 0) - (opA.callsCount ?? 0);
          } else if (sortValue === "calls-asc") {
            return (opA.callsCount ?? 0) - (opB.callsCount ?? 0);
          } else {
            // critical failures first, then by score desc
            const aCrit = opA.hasCriticalFailure ? 0 : 1;
            const bCrit = opB.hasCriticalFailure ? 0 : 1;
            if (aCrit !== bCrit) return aCrit - bCrit;
            return opB.averageScore - opA.averageScore;
          }
        } else {
          const opA = JSON.parse(a.getAttribute("data-operator") || "{}");
          const opB = JSON.parse(b.getAttribute("data-operator") || "{}");
          return sortValue === "score-desc"
            ? opB.averageScore - opA.averageScore
            : opA.averageScore - opB.averageScore;
        }
      });

      itemsArray.forEach((item) => {
        const name = item.getAttribute("data-name") || "";
        const id = item.getAttribute("data-id") || "";

        const matchesSearch = name.includes(term) || id.includes(term);

        if (matchesSearch) {
          item.classList.remove("hidden");
          hasVisibleItems = true;
        } else {
          item.classList.add("hidden");
        }

        if (operatorListContainer && noResultsMsg) {
          operatorListContainer.insertBefore(item, noResultsMsg);
        }
      });

      if (!hasVisibleItems && noResultsMsg) {
        noResultsMsg.classList.remove("hidden");
      } else if (noResultsMsg) {
        noResultsMsg.classList.add("hidden");
      }
    };

    let monthSelector = document.getElementById(
      "month-selector",
    ) as HTMLSelectElement;

    const btnPrevMonth = document.getElementById(
      "btn-prev-month",
    ) as HTMLButtonElement;
    const btnNextMonth = document.getElementById(
      "btn-next-month",
    ) as HTMLButtonElement;

    const updateMonthButtonsState = () => {
      if (!monthSelector) return;
      const idx = monthSelector.selectedIndex;
      const totalOptions = monthSelector.options.length;

      if (btnPrevMonth) {
        const canGoPrev = idx < totalOptions - 1;
        btnPrevMonth.disabled = !canGoPrev;
        if (!canGoPrev) {
          btnPrevMonth.classList.add("opacity-50");
        } else {
          btnPrevMonth.classList.remove("opacity-50");
        }
      }

      if (btnNextMonth) {
        const canGoNext = idx > 0;
        btnNextMonth.disabled = !canGoNext;
        if (!canGoNext) {
          btnNextMonth.classList.add("opacity-50");
        } else {
          btnNextMonth.classList.remove("opacity-50");
        }
      }
    };

    if (monthSelector) {
      monthSelector.addEventListener("change", (e) => {
        const select = e.target as HTMLSelectElement;
        const url = new URL(window.location.href);
        url.searchParams.set("month", select.value);
        if (activeAgentId) {
          url.searchParams.set("agentId", activeAgentId);
        } else {
          url.searchParams.delete("agentId");
        }
        window.location.href = url.toString();
      });

      updateMonthButtonsState();

      if (btnPrevMonth) {
        btnPrevMonth.addEventListener("click", () => {
          if (monthSelector.selectedIndex < monthSelector.options.length - 1) {
            monthSelector.selectedIndex += 1;
            monthSelector.dispatchEvent(new Event("change"));
          }
        });
      }

      if (btnNextMonth) {
        btnNextMonth.addEventListener("click", () => {
          if (monthSelector.selectedIndex > 0) {
            monthSelector.selectedIndex -= 1;
            monthSelector.dispatchEvent(new Event("change"));
          }
        });
      }
    }

    if (searchInput) {
      searchInput.addEventListener("input", updateOperatorsList);
    }

    if (operatorSort) {
      operatorSort.addEventListener("change", updateOperatorsList);
    }

    // Attach click listeners to operator items
    document.querySelectorAll(".operator-item").forEach((item) => {
      item.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const operatorData = target.getAttribute("data-operator");
        if (!operatorData) return;

        try {
          const operatorSummary = JSON.parse(operatorData) as {
            id: string;
            name: string;
            averageScore: number;
            callsCount: number;
            hasCriticalFailure: boolean;
          };
          const operator = (getOperatorFullData(operatorSummary.id) ||
            operatorSummary) as OperatorQuality;
          activeAgentId = operator.id;

          document.querySelectorAll(".operator-item").forEach((el) => {
            el.classList.remove(
              "border-l-secondary",
              "bg-secondary/5",
              "shadow-md",
            );
            el.classList.add("border-l-transparent");
          });
          target.classList.remove("border-l-transparent");
          target.classList.add(
            "border-l-secondary",
            "bg-secondary/5",
            "shadow-md",
          );

          if (dAvatar)
            dAvatar.textContent = operator.name
              .split(" ")
              .map((n: string) => n[0])
              .join("")
              .substring(0, 2);
          if (dName) dName.textContent = operator.name;
          if (dId) dId.textContent = `@${operator.username || operator.id}`;
          if (dMonth) dMonth.textContent = formatMonthLabel(operator.month);

          if (dScore) {
            dScore.textContent = `${operator.averageScore}%`;
            dScore.className = `text-5xl font-black tracking-tighter ${operator.averageScore >= 90 ? "text-success" : operator.averageScore >= 80 ? "text-warning" : "text-error"}`;
          }

          if (dStatDiff) {
            const currentScore = operator.averageScore;
            const prevScore = operator.prevAverageScore || 0;
            const hasPrevAudits = (operator.prevCallsCount ?? 0) > 0;
            
            if (hasPrevAudits) {
              const diff = currentScore - prevScore;
              if (diff > 0) {
                dStatDiff.textContent = `+${diff}%`;
                dStatDiff.className = "text-xl font-black text-success";
              } else if (diff < 0) {
                dStatDiff.textContent = `${diff}%`;
                dStatDiff.className = "text-xl font-black text-error";
              } else {
                dStatDiff.textContent = `0%`;
                dStatDiff.className = "text-xl font-black text-base-content/40";
              }
            } else {
              dStatDiff.textContent = "N/A";
              dStatDiff.className = "text-xl font-black text-base-content/40";
            }
          }

          if (dStatAht) {
            const calls = operator.calls || [];
            if (calls.length > 0) {
              const parseDurationToSeconds = (durStr: string) => {
                if (!durStr) return 0;
                const parts = durStr.split(":").map(Number);
                if (parts.length === 2) {
                  return parts[0] * 60 + parts[1];
                } else if (parts.length === 3) {
                  return parts[0] * 3600 + parts[1] * 60 + parts[2];
                }
                return 0;
              };
              const formatSecondsToDuration = (totalSecs: number) => {
                const m = Math.floor(totalSecs / 60);
                const s = Math.round(totalSecs % 60);
                return `${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
              };
              const totalSecs = calls.reduce((acc: number, c: any) => acc + parseDurationToSeconds(c.duration), 0);
              const avgSecs = totalSecs / calls.length;
              dStatAht.textContent = formatSecondsToDuration(avgSecs);
              dStatAht.className = "text-xl font-black text-base-content";
            } else {
              dStatAht.textContent = "--";
              dStatAht.className = "text-xl font-black text-base-content/40";
            }
          }

          if (dStatInteraction) {
            const calls = operator.calls || [];
            if (calls.length > 0) {
              const avgS1 = Math.round(calls.reduce((acc: number, c: any) => acc + c.section1.score, 0) / calls.length);
              dStatInteraction.textContent = `${avgS1}%`;
              dStatInteraction.className = `text-xl font-black ${avgS1 >= 90 ? "text-success" : avgS1 >= 80 ? "text-warning" : "text-error"}`;
            } else {
              dStatInteraction.textContent = "--";
              dStatInteraction.className = "text-xl font-black text-base-content/40";
            }
          }

          if (dStatManagement) {
            const calls = operator.calls || [];
            if (calls.length > 0) {
              const avgS2 = Math.round(calls.reduce((acc: number, c: any) => acc + c.section2.score, 0) / calls.length);
              dStatManagement.textContent = `${avgS2}%`;
              dStatManagement.className = `text-xl font-black ${avgS2 >= 90 ? "text-success" : avgS2 >= 80 ? "text-warning" : "text-error"}`;
            } else {
              dStatManagement.textContent = "--";
              dStatManagement.className = "text-xl font-black text-base-content/40";
            }
          }

          if (dMonthSummary && dMonthSummaryEmpty) {
            activeAgentSummary = operator.monthSummary || "";
            if (activeAgentSummary.trim()) {
              dMonthSummary.textContent = activeAgentSummary;
              dMonthSummary.classList.remove("hidden");
              dMonthSummaryEmpty.classList.add("hidden");
            } else {
              dMonthSummary.textContent = "";
              dMonthSummary.classList.add("hidden");
              dMonthSummaryEmpty.classList.remove("hidden");
            }
          }

          const callsBadge = document.getElementById("calls-count-badge");
          if (callsBadge) {
            callsBadge.textContent = `${operator.calls.length} Aleatorias`;
          }

          const historyContainer = document.getElementById(
            "detail-history-chart",
          );
          if (historyContainer && operator.history) {
            const points = operator.history;
            const width = 300;
            const height = 60;

            const coords = points.map((score: number, i: number) => {
              const x = (i / (points.length - 1)) * width;
              const y = height - (score / 100) * height;
              return { x, y, score };
            });

            const pathD = coords
              .map((c, i) => (i === 0 ? `M ${c.x},${c.y}` : `L ${c.x},${c.y}`))
              .join(" ");

            historyContainer.className = "relative w-full h-16 mt-2 mb-4";
            historyContainer.innerHTML = `
               <svg class="w-full h-full overflow-visible" viewBox="-4 -4 ${width + 8} ${height + 8}" preserveAspectRatio="none">
                 <path d="${pathD}" fill="none" stroke="currentColor" stroke-width="3" class="text-secondary drop-shadow-sm" stroke-linecap="round" stroke-linejoin="round" />
                 ${coords
                   .map(
                     (c, i) => `
                   <circle cx="${c.x}" cy="${c.y}" r="${i === points.length - 1 ? "5" : "4"}" fill="currentColor" class="${i === points.length - 1 ? "text-secondary" : "text-base-100"} stroke-secondary stroke-2 transition-all hover:r-6" />
                 `,
                   )
                   .join("")}
               </svg>
               <div class="absolute w-full flex justify-between -bottom-5 text-xs font-bold text-base-content/50">
                  ${points.map((p: number) => `<span>${p}%</span>`).join("")}
               </div>
             `;
          }

          const insightsContainer = document.getElementById("detail-insights");
          if (insightsContainer && operator.calls) {
            const failures: Record<string, number> = {};

            operator.calls.forEach((c) => {
              Object.entries(c.section1.details).forEach(([key, val]) => {
                if (!val) failures[key] = (failures[key] || 0) + 1;
              });
              Object.entries(c.section2.details).forEach(([key, val]) => {
                if (!val) failures[key] = (failures[key] || 0) + 1;
              });
            });

            const sortedFailures = Object.entries(failures)
              .sort((a, b) => b[1] - a[1])
              .slice(0, 2);

            if (sortedFailures.length > 0) {
              const params: AuditParameter[] = getAuditParameters();
              const paramNameMap = new Map<string, string>(
                params.map((p) => [p.code, p.name]),
              );

              insightsContainer.innerHTML = sortedFailures
                .map(
                  ([key, count]) => `
                 <li class="flex items-center gap-2">
                   ${ICON_ARROW}
                   <span>Falla frecuente en: <strong>${escapeHtml(paramNameMap.get(key) || key)}</strong> <span class="opacity-50">(${count} veces)</span></span>
                 </li>
               `,
                )
                .join("");
            } else {
              insightsContainer.innerHTML = `<li class="text-success flex items-center gap-2">${ICON_STAR} <span class="font-bold">¡Rendimiento impecable!</span> No se detectaron patrones de error frecuentes.</li>`;
            }
          }

          if (callsContainer) {
            callsContainer.innerHTML = operator.calls
              .map((call, index) => renderCallCard(call, index))
              .join("");

            // Attach event listeners to all edit buttons!
            callsContainer
              .querySelectorAll(".edit-audit-btn")
              .forEach((btn) => {
                btn.addEventListener("click", (e) => {
                  e.stopPropagation(); // prevent collapsing/expanding the card
                  const callIdStr = (
                    e.currentTarget as HTMLElement
                  ).getAttribute("data-call-id");
                  if (callIdStr) {
                    const callId = parseInt(callIdStr, 10);
                    const call = operator.calls.find((c) => c.id === callId);
                    if (call) {
                      openAuditModal(operator.id, call);
                    }
                  }
                });
              });
          }

          if (generalPanel) generalPanel.classList.add("hidden");
          if (detailsPanel) {
            detailsPanel.classList.remove("hidden");

            if (window.innerWidth < 1024) {
              detailsPanel.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            }
          }
        } catch (err) {
          console.error("Error displaying operator details", err);
        }
      });
    });

    // --- PARAMETERS CONFIGURATION MODAL ---
    const parametersModal = document.getElementById("parameters-modal") as HTMLDialogElement;
    const btnConfigureParameters = document.getElementById("btn-configure-parameters");
    const btnCloseParametersModal = document.getElementById("btn-close-parameters-modal");
    const btnAddParamS1 = document.getElementById("btn-add-param-s1");
    const btnAddParamS2 = document.getElementById("btn-add-param-s2");
    
    let localParams: any[] = [];
    
    if (btnConfigureParameters) {
      btnConfigureParameters.addEventListener("click", () => {
        localParams = getAuditParameters().map((p: any) => ({ ...p, isDeleted: false }));
        
        // Reset tabs to S1
        const tabs = document.querySelectorAll(".parameter-tab");
        tabs.forEach(t => t.classList.remove("tab-active"));
        tabs[0]?.classList.add("tab-active");
        
        document.getElementById("param-list-s1")?.classList.remove("hidden");
        document.getElementById("param-list-s2")?.classList.add("hidden");
        document.getElementById("btn-add-param-s1")?.classList.remove("hidden");
        document.getElementById("btn-add-param-s2")?.classList.add("hidden");
        
        renderParametersList();
        parametersModal.showModal();
      });
    }
    
    if (btnCloseParametersModal) {
      btnCloseParametersModal.addEventListener("click", () => {
        parametersModal.close();
      });
    }
    
    if (btnAddParamS1) {
      btnAddParamS1.addEventListener("click", () => {
        handleAddParam("Interacción con Usuario");
      });
    }
    
    if (btnAddParamS2) {
      btnAddParamS2.addEventListener("click", () => {
        handleAddParam("Gestión del Ticket");
      });
    }
    
    const handleAddParam = (category: string) => {
      localParams.push({
        id: null,
        name: "",
        weight: 1.0,
        category: category,
        active: true,
        isDeleted: false
      });
      renderParametersList();

      const paneId = category === "Interacción con Usuario" ? "param-list-s1" : "param-list-s2";
      const pane = document.getElementById(paneId);
      if (pane) {
        setTimeout(() => {
          pane.lastElementChild?.scrollIntoView({ behavior: "smooth" });
          (pane.lastElementChild?.querySelector(".param-input-name") as HTMLElement)?.focus();
        }, 50);
      }
    };
    
    function renderParameterRow(param: any, actualIndex: number, displayIndex: number) {
      const isDeleted = param.isDeleted;
      const isNew = !param.id;
      
      return `
        <div class="flex items-center gap-3 bg-base-200/40 p-2 rounded-xl border border-base-300 transition-all ${isDeleted ? 'opacity-40 bg-error/5 border-error/20 line-through' : ''}" data-index="${actualIndex}">
          <div class="flex items-center justify-center size-8 rounded-lg bg-base-100 font-mono text-xs text-base-content/50 border border-base-200 shrink-0">
            ${isNew ? '<span class="text-success font-black">+</span>' : displayIndex}
          </div>
          <input 
            type="text" 
            value="${escapeHtml(param.name)}" 
            placeholder="Nombre del criterio..."
            class="input input-bordered input-sm flex-1 font-semibold bg-base-100 focus:outline-none focus:border-primary param-input-name"
            ${isDeleted ? 'disabled' : ''}
            data-index="${actualIndex}"
          />
          <div class="flex items-center gap-1 shrink-0">
            <span class="text-xs font-bold text-base-content/40 uppercase">Peso:</span>
            <input 
              type="number" 
              step="0.1" 
              min="0"
              value="${param.weight}" 
              class="input input-bordered input-sm w-16 text-center font-bold bg-base-100 focus:outline-none focus:border-primary param-input-weight"
              ${isDeleted ? 'disabled' : ''}
              data-index="${actualIndex}"
            />
          </div>
          <div class="shrink-0">
            ${isDeleted ? `
              <button type="button" class="btn btn-sm btn-circle btn-ghost text-success param-btn-restore animate-fade-in" data-index="${actualIndex}" title="Restaurar">
                <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="fill: currentColor;"><path d="M12.5 8c-2.65 0-5.05 1-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z"/></svg>
              </button>
            ` : `
              <button type="button" class="btn btn-sm btn-circle btn-ghost text-error hover:bg-error/10 param-btn-delete animate-fade-in" data-index="${actualIndex}" title="Eliminar">
                <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="fill: currentColor;"><path d="m20.37 5.91-1 .92a2 2 0 0 1-1.39.57H6A2 2 0 0 1 4.6 6.84l-1-.93L2.24 7.27l1 .93a4 4 0 0 0 2.76 1.14h12A4 4 0 0 0 20.76 8.2l1-.93zm-3.5 4v9a2 2 0 0 1-2 2h-6a2 2 0 0 1-2-2v-9h-2v9a4 4 0 0 0 4 4h6a4 4 0 0 0 4-4v-9zM8.5 3h7V1h-7z"/></svg>
              </button>
            `}
          </div>
        </div>
      `;
    }
    
    function renderParametersList() {
      const s1Container = document.getElementById("param-list-s1");
      const s2Container = document.getElementById("param-list-s2");
      if (!s1Container || !s2Container) return;
      
      let s1Count = 0;
      const s1Html = localParams
        .map((p, i) => ({ p, i }))
        .filter(item => item.p.category === "Interacción con Usuario" && (item.p.active || !item.p.id || item.p.isDeleted))
        .map(item => {
          s1Count++;
          return renderParameterRow(item.p, item.i, s1Count);
        })
        .join("");
        
      let s2Count = 0;
      const s2Html = localParams
        .map((p, i) => ({ p, i }))
        .filter(item => item.p.category === "Gestión del Ticket" && (item.p.active || !item.p.id || item.p.isDeleted))
        .map(item => {
          s2Count++;
          return renderParameterRow(item.p, item.i, s2Count);
        })
        .join("");
        
      s1Container.innerHTML = s1Html || '<p class="text-xs text-base-content/40 italic text-center py-4">No hay parámetros activos en esta categoría.</p>';
      s2Container.innerHTML = s2Html || '<p class="text-xs text-base-content/40 italic text-center py-4">No hay parámetros activos en esta categoría.</p>';
      
      // Attach input change listeners
      s1Container.querySelectorAll(".param-input-name, .param-input-weight").forEach(attachInputListeners);
      s2Container.querySelectorAll(".param-input-name, .param-input-weight").forEach(attachInputListeners);
      
      // Attach delete/restore button listeners
      s1Container.querySelectorAll(".param-btn-delete").forEach(btn => btn.addEventListener("click", handleDeleteParam));
      s1Container.querySelectorAll(".param-btn-restore").forEach(btn => btn.addEventListener("click", handleRestoreParam));
      s2Container.querySelectorAll(".param-btn-delete").forEach(btn => btn.addEventListener("click", handleDeleteParam));
      s2Container.querySelectorAll(".param-btn-restore").forEach(btn => btn.addEventListener("click", handleRestoreParam));
    }
    
    function attachInputListeners(input: Element) {
      input.addEventListener("input", (e) => {
        const target = e.target as HTMLInputElement;
        const idx = parseInt(target.getAttribute("data-index") || "0", 10);
        if (target.classList.contains("param-input-name")) {
          localParams[idx].name = target.value;
        } else if (target.classList.contains("param-input-weight")) {
          localParams[idx].weight = parseFloat(target.value) || 0;
        }
      });
    }
    
    function handleDeleteParam(e: Event) {
      const target = (e.currentTarget as HTMLElement);
      const idx = parseInt(target.getAttribute("data-index") || "0", 10);
      localParams[idx].isDeleted = true;
      renderParametersList();
    }
    
    function handleRestoreParam(e: Event) {
      const target = (e.currentTarget as HTMLElement);
      const idx = parseInt(target.getAttribute("data-index") || "0", 10);
      localParams[idx].isDeleted = false;
      renderParametersList();
    }
    
    // Tab switching in parameters modal
    const paramTabs = document.querySelectorAll(".parameter-tab");
    paramTabs.forEach(tab => {
      tab.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const tabName = target.getAttribute("data-tab");
        
        paramTabs.forEach(t => t.classList.remove("tab-active"));
        target.classList.add("tab-active");
        
        const paneS1 = document.getElementById("param-list-s1");
        const paneS2 = document.getElementById("param-list-s2");
        const btnAddS1 = document.getElementById("btn-add-param-s1");
        const btnAddS2 = document.getElementById("btn-add-param-s2");
        
        if (tabName === "s1") {
          paneS1?.classList.remove("hidden");
          paneS2?.classList.add("hidden");
          btnAddS1?.classList.remove("hidden");
          btnAddS2?.classList.add("hidden");
        } else {
          paneS1?.classList.add("hidden");
          paneS2?.classList.remove("hidden");
          btnAddS1?.classList.add("hidden");
          btnAddS2?.classList.remove("hidden");
        }
      });
    });
    
    const btnSaveParams = document.getElementById("btn-save-parameters");
    btnSaveParams?.addEventListener("click", async () => {
      const emptyParams = localParams.filter(p => !p.isDeleted && !p.name.trim());
      if (emptyParams.length > 0) {
        alert("Por favor, complete el nombre de todos los parámetros.");
        return;
      }
      
      const originalText = btnSaveParams.innerHTML;
      btnSaveParams.setAttribute("disabled", "true");
      btnSaveParams.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Guardando…';
      
      try {
        const payload = {
          parameters: localParams.map(p => ({
            id: p.id,
            name: p.name.trim(),
            weight: p.weight,
            category: p.category,
            isDeleted: p.isDeleted
          }))
        };
        
        const result = await actions.saveParameters(payload);
        if (result.error) {
          console.error(result.error);
          alert("Error al guardar los parámetros: " + result.error.message);
        } else if (result.data?.success) {
          window.location.reload();
        } else {
          alert("Error al guardar los parámetros.");
        }
      } catch (err) {
        console.error(err);
        alert("Ocurrió un error inesperado al guardar los parámetros.");
      } finally {
        btnSaveParams.removeAttribute("disabled");
        btnSaveParams.innerHTML = originalText;
      }
    });

    // --- EXPORT TO CSV ---
    const btnExportCSV = document.getElementById("btn-export-csv");
    if (btnExportCSV) {
      btnExportCSV.addEventListener("click", () => {
        const el = document.getElementById("operators-data");
        if (!el) return;
        let operatorsData: Record<string, any> = {};
        try {
          operatorsData = JSON.parse(el.getAttribute("data-operators") || "{}");
        } catch (e) {
          console.error("Error parsing operators data", e);
          return;
        }

        const selectedOp = operatorsData[activeAgentId || ""];
        if (!selectedOp) {
          alert("Por favor, seleccione un operador.");
          return;
        }

        const monthSelector = document.getElementById("month-selector") as HTMLSelectElement;
        const monthStr = monthSelector ? monthSelector.value : "calidad";

        // Obtener todos los parámetros configurados en el sistema
        const params = getAuditParameters();

        // Headers for CSV
        const headers = [
          "Periodo",
          "Operador",
          "Usuario",
          "Fecha",
          "ID Llamada",
          "ID Ticket",
          "Duracion",
          "Puntaje Secc. 1 (Interaccion)",
          "Puntaje Secc. 2 (Gestion)",
          "Puntaje Total",
          "Falla Critica"
        ];

        // Añadir una columna por cada parámetro dinámico
        params.forEach((param: any) => {
          headers.push(`[${param.code}] ${param.name}`);
        });

        // La columna de observaciones va al final
        headers.push("Observaciones");

        const csvRows = [headers.join(";")];

        selectedOp.calls.forEach((call: any) => {
          const row = [
            call.month,
            selectedOp.name,
            selectedOp.username || "",
            call.date.substring(0, 10),
            call.callId,
            call.ticketId,
            call.duration,
            call.section1.score,
            call.section2.score,
            call.totalScore,
            call.isCriticalFailure ? "Si" : "No"
          ];

          // Determinar cumplimiento para cada parámetro dinámico
          params.forEach((param: any) => {
            let compliance = "N/A";
            
            // Buscar en detalles de Sección 1 (Interacción)
            if (call.section1 && call.section1.details && call.section1.details.hasOwnProperty(param.code)) {
              compliance = call.section1.details[param.code] ? "Cumple" : "No cumple";
            }
            // Buscar en detalles de Sección 2 (Gestión)
            else if (call.section2 && call.section2.details && call.section2.details.hasOwnProperty(param.code)) {
              compliance = call.section2.details[param.code] ? "Cumple" : "No cumple";
            }

            row.push(compliance);
          });

          // Agregar la observación al final de la fila
          row.push(call.notes || "");

          const escapedRow = row.map(val => {
            const valStr = typeof val === "string" ? val : String(val);
            if (valStr.includes(";") || valStr.includes("\n") || valStr.includes("\r") || valStr.includes('"')) {
              return `"${valStr.replace(/"/g, '""')}"`;
            }
            return valStr;
          });
          csvRows.push(escapedRow.join(";"));
        });

        // Add UTF-8 BOM so Excel displays accents correctly
        const csvContent = "\uFEFF" + csvRows.join("\n");
        const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.setAttribute("href", url);
        const fileName = `auditorias_${selectedOp.username || activeAgentId}_${monthStr}.csv`;
        link.setAttribute("download", fileName);
        link.style.visibility = "hidden";
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      });
    }

    // Auto-select operator on page load if agentId is in URL or if user is an agent
    const urlParams = new URLSearchParams(window.location.search);
    const urlAgentId = urlParams.get("agentId");
    const rbacContainer = document.querySelector("[data-is-agent]");
    const isUserAgent = rbacContainer && rbacContainer.getAttribute("data-is-agent") === "true";

    if (isUserAgent) {
      const firstOpBtn = document.querySelector(".operator-item") as HTMLButtonElement | null;
      if (firstOpBtn) {
        firstOpBtn.click();
      }
    } else if (urlAgentId) {
      const opBtn = Array.from(
        document.querySelectorAll(".operator-item"),
      ).find(
        (el) => el.getAttribute("data-id") === urlAgentId,
      ) as HTMLButtonElement | null;
      if (opBtn) {
        opBtn.click();
      }
    }
  }

  initQualityMasterDetail();
</script>
