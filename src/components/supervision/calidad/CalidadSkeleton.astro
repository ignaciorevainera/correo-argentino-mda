---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
---

<PageContainer class="max-w-7xl mx-auto">
  <div class="skeleton-debounced">
    <div class="btn btn-ghost btn-sm mb-2 w-fit pl-2 pointer-events-none opacity-50">
      <div class="size-6 skeleton rounded"></div>
      <div class="h-4 w-28 skeleton rounded ml-2"></div>
    </div>

    <PageHeader
      description="Evaluación de llamadas, métricas y validaciones de la calidad de atención del equipo de operaciones de Mesa de Ayuda."
    />

    <!-- Selector de Período Skeleton -->
    <div class="mt-4 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between bg-base-200/50 p-4 rounded-xl border border-base-300 shadow-md">
      <div class="flex items-center gap-2 text-base-content/80 mb-3 sm:mb-0">
        <div class="size-6 skeleton rounded"></div>
        <div class="h-5 w-40 skeleton rounded"></div>
      </div>
      <div class="flex items-center gap-2">
        <div class="size-8 skeleton rounded"></div>
        <div class="h-8 w-36 sm:w-48 skeleton rounded"></div>
        <div class="size-8 skeleton rounded"></div>
        <div class="divider divider-horizontal mx-1 hidden sm:flex"></div>
        <div class="h-8 w-28 skeleton rounded"></div>
      </div>
    </div>

    <div class="mt-2 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start relative">
      <!-- Panel Izquierdo: Lista Navegable Skeleton -->
      <aside class="lg:col-span-4 flex flex-col gap-4 lg:sticky lg:top-6 lg:h-[calc(100vh-8rem)]">
        <div class="card border border-base-300 bg-base-100 shadow-md flex-1 flex flex-col overflow-hidden">
          <div class="p-4 border-b border-base-200 bg-base-200/30 flex flex-col gap-3">
            <div class="flex items-center gap-2">
              <div class="size-6 skeleton rounded"></div>
              <div class="h-5 w-44 skeleton rounded"></div>
            </div>
            <div class="flex flex-col gap-2">
              <div class="h-10 w-full skeleton rounded-lg"></div>
              <div class="h-8 w-full skeleton rounded-lg"></div>
            </div>
          </div>

          <div class="flex-1 overflow-y-auto p-2 space-y-2">
            {Array.from({ length: 6 }).map(() => (
              <div class="w-full p-4 rounded-xl border border-base-200 flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="size-10 rounded-full skeleton"></div>
                  <div class="space-y-2">
                    <div class="h-4 w-28 skeleton rounded"></div>
                    <div class="h-3 w-16 skeleton rounded"></div>
                  </div>
                </div>
                <div class="h-4 w-10 skeleton rounded"></div>
              </div>
            ))}
          </div>
        </div>
      </aside>

      <!-- Panel Derecho: Información / Detalle Skeleton -->
      <main class="lg:col-span-8 h-full">
        <div class="space-y-6">
          <!-- Stats Grid -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Hero Stat: Promedio General (Takes 2 cols/2 rows) -->
            <div class="col-span-2 row-span-2 bg-base-300/30 border border-base-300 rounded-3xl p-8 flex flex-col justify-between shadow-sm relative overflow-hidden h-[300px]">
              <div class="flex justify-between items-start">
                <div class="h-4 w-24 skeleton rounded"></div>
                <div class="size-6 skeleton rounded"></div>
              </div>
              <div class="mt-12 space-y-4">
                <div class="h-20 w-36 skeleton rounded"></div>
                <div class="h-4 w-64 skeleton rounded"></div>
              </div>
            </div>

            <!-- Evaluados -->
            <div class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between h-[142px]">
              <div class="h-3 w-16 skeleton rounded"></div>
              <div class="space-y-2">
                <div class="h-8 w-12 skeleton rounded"></div>
                <div class="h-3 w-20 skeleton rounded"></div>
              </div>
            </div>

            <!-- Llamadas Auditadas -->
            <div class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between h-[142px]">
              <div class="h-3 w-16 skeleton rounded"></div>
              <div class="space-y-2">
                <div class="h-8 w-12 skeleton rounded"></div>
                <div class="h-3 w-20 skeleton rounded"></div>
              </div>
            </div>

            <!-- Excelente -->
            <div class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between h-[142px]">
              <div class="h-3 w-16 skeleton rounded"></div>
              <div class="space-y-2">
                <div class="h-8 w-12 skeleton rounded"></div>
                <div class="h-3 w-20 skeleton rounded"></div>
              </div>
            </div>

            <!-- Bajo Rendimiento -->
            <div class="col-span-1 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between h-[142px]">
              <div class="h-3 w-16 skeleton rounded"></div>
              <div class="space-y-2">
                <div class="h-8 w-12 skeleton rounded"></div>
                <div class="h-3 w-20 skeleton rounded"></div>
              </div>
            </div>

            <!-- Promedio Interacción -->
            <div class="col-span-2 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between h-[142px]">
              <div class="h-3 w-20 skeleton rounded"></div>
              <div class="space-y-2">
                <div class="h-8 w-12 skeleton rounded"></div>
                <div class="h-3 w-44 skeleton rounded"></div>
              </div>
            </div>

            <!-- Promedio Gestión -->
            <div class="col-span-2 rounded-3xl bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between h-[142px]">
              <div class="h-3 w-20 skeleton rounded"></div>
              <div class="space-y-2">
                <div class="h-8 w-12 skeleton rounded"></div>
                <div class="h-3 w-44 skeleton rounded"></div>
              </div>
            </div>
          </div>

          <!-- Empty State CTA Skeleton -->
          <div class="rounded-3xl bg-base-200/50 flex-1 min-h-64 flex flex-col items-center justify-center text-center p-8 mt-4 border border-base-300 shadow-inner">
            <div class="rounded-full bg-base-100 p-6 shadow-sm mb-6 border border-base-200 size-20 skeleton"></div>
            <div class="h-6 w-40 skeleton rounded mb-3"></div>
            <div class="h-4 w-72 skeleton rounded"></div>
          </div>
        </div>
      </main>
    </div>
  </div>
</PageContainer>
