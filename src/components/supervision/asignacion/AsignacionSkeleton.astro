---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
---

<PageContainer>
  <div class="skeleton-debounced">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6 border-b border-base-200 pb-5">
      <PageHeader
        description="Distribución equitativa y controlada de autogestiones entre operadores técnicos. Utiliza el botón de asignar próximo para rotar de manera circular."
      />
      <div class="flex items-center gap-3 self-end lg:self-center bg-base-200/50 border border-base-300/40 rounded-xl px-4 py-2.5 shadow-sm">
        <div class="h-4 w-32 skeleton rounded"></div>
        <div class="size-6 skeleton rounded-full"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <!-- Card Disponibles Skeleton -->
      <div class="card bg-base-100 border border-base-300 shadow-md overflow-hidden h-44">
        <div class="card-body p-6 justify-between">
          <div class="flex items-center gap-3">
            <div class="size-8 bg-base-200 rounded skeleton"></div>
            <div class="h-4 w-28 skeleton rounded"></div>
          </div>
          <div class="flex items-baseline gap-2">
            <div class="h-10 w-16 skeleton rounded"></div>
            <div class="h-3 w-28 skeleton rounded"></div>
          </div>
          <div class="w-full space-y-2 mt-2">
            <div class="h-3 w-full skeleton rounded"></div>
          </div>
        </div>
      </div>

      <!-- Card No Disponibles Skeleton -->
      <div class="card bg-base-100 border border-base-300 shadow-md overflow-hidden h-44">
        <div class="card-body p-6 justify-between">
          <div class="flex items-center gap-3">
            <div class="size-8 bg-base-200 rounded skeleton"></div>
            <div class="h-4 w-24 skeleton rounded"></div>
          </div>
          <div class="flex items-baseline gap-2">
            <div class="h-10 w-16 skeleton rounded"></div>
            <div class="h-3 w-24 skeleton rounded"></div>
          </div>
          <div class="grid grid-cols-2 gap-2 mt-2">
            <div class="h-6 w-full skeleton rounded"></div>
            <div class="h-6 w-full skeleton rounded"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-4 flex flex-wrap items-center justify-between gap-4">
      <div class="h-10 w-48 skeleton rounded-xl"></div>
      <div class="h-10 w-52 skeleton rounded-xl"></div>
    </div>

    <!-- Table Skeleton -->
    <div class="border border-base-300 rounded-xl overflow-hidden bg-base-100 shadow-sm">
      <div class="grid grid-cols-[1.8fr_1.5fr_1.2fr_minmax(100px,auto)] gap-4 border-b border-base-300 px-4 py-3 bg-base-200/50">
        <div class="h-5 w-20 skeleton rounded"></div>
        <div class="h-5 w-24 skeleton rounded"></div>
        <div class="h-5 w-16 skeleton rounded"></div>
        <div class="h-5 w-16 skeleton rounded justify-self-end"></div>
      </div>

      <div class="divide-y divide-base-300">
        {Array.from({ length: 8 }).map(() => (
          <div class="grid grid-cols-[1.8fr_1.5fr_1.2fr_minmax(100px,auto)] items-center gap-4 px-4 py-4">
            <div class="space-y-2">
              <div class="h-4 w-32 skeleton rounded"></div>
              <div class="h-3 w-24 skeleton rounded"></div>
              <div class="h-3 w-20 skeleton rounded"></div>
            </div>
            <div class="space-y-1">
              <div class="h-3.5 w-28 skeleton rounded"></div>
              <div class="h-3 w-20 skeleton rounded"></div>
            </div>
            <div>
              <div class="h-6 w-20 skeleton rounded-full"></div>
            </div>
            <div class="flex gap-2 justify-end">
              <div class="h-6 w-14 skeleton rounded"></div>
              <div class="h-6 w-6 skeleton rounded-full"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageContainer>
