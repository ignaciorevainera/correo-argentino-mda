---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import DataTable from "@components/ui/DataTable.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import Modal from "@components/ui/Modal.astro";
import FormField from "@components/ui/forms/FormField.astro";
import SelectField from "@components/ui/forms/SelectField.astro";
import { Icon } from "astro-icon/components";
import { db } from "@db/index";
import { agents } from "@db/schema";
import { eq } from "drizzle-orm";
import {
  getDisponibilidadHoy,
  asignarSiguienteAutogestion,
  asignarManual,
  getLockStatus,
} from "@lib/disponibilidad";

import { normalizeRole } from "@lib/rbac";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
const role = normalizeRole(user.role);

const lockStatus = await getLockStatus();
let hasLock = false;
let lockHolderName: string | null = null;
let lockReleaseRequested = false;

if (lockStatus.status === "occupied") {
  hasLock = lockStatus.user.userId === user?.id;
  lockHolderName = lockStatus.user.username;
  lockReleaseRequested = lockStatus.user.releaseRequested;
}

const isReadOnly = role === "agent" || !hasLock;

let flashMessage: { type: "success" | "error"; text: string } | null = null;

if (Astro.request.method === "POST" && !isReadOnly) {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action") as string;

    if (action === "assign_manual") {
      const agentId = Number(formData.get("agentId"));
      if (!isNaN(agentId)) {
        await asignarManual(agentId, user?.username || "Sistema");

        const [ag] = await db
          .select({ name: agents.name })
          .from(agents)
          .where(eq(agents.id, agentId));

        flashMessage = {
          type: "success",
          text: `Autogestión asignada manualmente a ${ag?.name ?? `ID ${agentId}`}.`,
        };
      }
    } else if (action === "assign_cyclic") {
      const res = await asignarSiguienteAutogestion(user?.username || "Sistema");
      if (res.success && res.agent) {
        flashMessage = {
          type: "success",
          text: `Autogestión asignada cíclicamente a ${res.agent.nombre}.`,
        };
      } else {
        flashMessage = {
          type: "error",
          text:
            res.error ||
            "No hay operadores disponibles o dentro de horario operativo para asignar.",
        };
      }
    }
  } catch (e: any) {
    flashMessage = {
      type: "error",
      text: `Ocurrió un error al procesar la acción: ${e.message}`,
    };
  }
}

// Fetch availability calculations
const allOperators = await getDisponibilidadHoy();
allOperators.sort((a, b) => a.nombre.localeCompare(b.nombre));

const disponiblesCount = allOperators.filter((op) => op.disponible).length;
const noDisponiblesList = allOperators.filter((op) => !op.disponible);
const noDisponiblesCount = noDisponiblesList.length;

// Find the operator who was most recently assigned
const maxAssignedTime = Math.max(
  ...allOperators.map((o) => o.lastAutogestionAssignedAt ?? 0),
);
const lastAssignedOperator =
  maxAssignedTime > 0
    ? allOperators.find((o) => o.lastAutogestionAssignedAt === maxAssignedTime)
    : null;
const maxAssignedOperatorId = lastAssignedOperator?.agentId ?? null;

// Find the next suggested operators (up to 4) for the queue
const availableOperators = allOperators.filter((o) => o.disponible);
const nextSuggestedOperators = availableOperators.length > 0
  ? [...availableOperators].sort((a, b) => {
      const tA = a.lastAutogestionAssignedAt ?? 0;
      const tB = b.lastAutogestionAssignedAt ?? 0;
      if (a.lastAutogestionAssignedAt === null && b.lastAutogestionAssignedAt !== null) return -1;
      if (a.lastAutogestionAssignedAt !== null && b.lastAutogestionAssignedAt === null) return 1;
      return tA - tB;
    }).slice(0, 4)
  : [];

const STATUS_LABELS: Record<string, string> = {
  "En break": "En Break",
  "Fuera de horario": "Fuera de Horario",
  Franco: "Franco",
  Licencia: "Licencia",
  Vacaciones: "Vacaciones",
  Excepción: "Excepción",
};

const breakdown: Record<string, number> = {
  "En break": 0,
  "Fuera de horario": 0,
  Franco: 0,
  Licencia: 0,
  Vacaciones: 0,
  Excepción: 0,
};

noDisponiblesList.forEach((op) => {
  const mot = op.motivo || "Franco";
  if (
    ["Devolución Supervisor", "Break Extendido", "Problema Técnico"].includes(
      mot,
    )
  ) {
    breakdown["Excepción"]++;
  } else if (breakdown[mot] !== undefined) {
    breakdown[mot]++;
  } else {
    breakdown["Franco"]++;
  }
});

const getBadgeColor = (status: string, disponible: boolean): string => {
  if (disponible) return "badge-success text-white shadow-sm shadow-success/20";
  switch (status) {
    case "En break":
      return "badge-warning text-warning-content shadow-sm shadow-warning/20";
    case "Fuera de horario":
    case "Franco":
      return "badge-neutral text-neutral-content/75 opacity-70";
    case "Licencia":
      return "badge-error text-error-content shadow-sm shadow-error/20";
    case "Vacaciones":
      return "badge-info text-info-content shadow-sm shadow-info/20";
    case "Devolución Supervisor":
    case "Break Extendido":
    case "Problema Técnico":
      return "badge-secondary text-secondary-content shadow-sm shadow-secondary/20";
    default:
      return "badge-neutral";
  }
};

const breakdownBadge = (status: string): string => {
  switch (status) {
    case "En break":
      return "bg-warning";
    case "Fuera de horario":
    case "Franco":
      return "bg-neutral opacity-50";
    case "Licencia":
      return "bg-error";
    case "Vacaciones":
      return "bg-info";
    case "Excepción":
      return "bg-secondary";
    default:
      return "bg-neutral";
  }
};

const getExcepcionalShortLabel = (tipo: string): string => {
  switch (tipo) {
    case "devolucion_supervisor":
      return "⚠ Dev. Supervisor";
    case "break_extendido":
      return "⚠ Break extendido";
    case "problema_tecnico":
      return "⚠ Prob. técnico";
    default:
      return "⚠ Excepción";
  }
};
---

<PageContainer>
  <Modal id="modal-marcar-excepcion">
    <Fragment slot="content">
      <h3
        class="font-bold text-sm uppercase tracking-wider mb-4 text-base-content flex items-center gap-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="size-5 text-secondary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Marcar Excepción: <span
          id="modal-operador-nombre"
          class="text-secondary font-black"></span>
      </h3>

      <input type="hidden" id="modal-agent-id" />

      <div class="flex flex-col gap-4">
        <SelectField id="modal-select-tipo" name="modal-select-tipo" label="Tipo de Excepción" size="sm">
          <option value="devolucion_supervisor">Devolución Supervisor</option>
          <option value="break_extendido">Break Extendido</option>
          <option value="problema_tecnico">Problema Técnico</option>
        </SelectField>

        <div id="container-tiempo-extra" class="form-control hidden">
          <SelectField id="modal-select-tiempo-extra" name="modal-select-tiempo-extra" label="Tiempo Extra" size="sm">
            <option value="5">5 minutos</option>
            <option value="10">10 minutos</option>
            <option value="15">15 minutos</option>
            <option value="20" selected>20 minutos</option>
            <option value="25">25 minutos</option>
            <option value="30">30 minutos</option>
            <option value="35">35 minutos</option>
            <option value="40">40 minutos</option>
            <option value="45">45 minutos</option>
            <option value="manual">Manual (Sin auto-limpieza)</option>
          </SelectField>
        </div>

        <FormField id="modal-input-motivo" name="modal-input-motivo" label="Comentario (opcional)" placeholder="Ej. Reunión urgente, corte de internet, etc." size="sm" />
      </div>
    </Fragment>
    <Fragment slot="actions">
      <button
        type="button"
        class="btn btn-ghost btn-sm hover:bg-base-200"
        id="btn-close-modal-excepcion"
      >
        Cancelar
      </button>
      <button
        type="button"
        class="btn btn-secondary btn-sm font-bold uppercase tracking-wider"
        id="btn-confirmar-modal-excepcion"
      >
        Confirmar
      </button>
    </Fragment>
  </Modal>

  <div
    class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6 border-b border-base-200 pb-5"
  >
    <PageHeader
      description="Distribución equitativa y controlada de autogestiones entre operadores técnicos. Utiliza el botón de asignar próximo para rotar de manera circular."
    />
    <div
      class="flex items-center gap-3 self-end lg:self-center bg-base-200/50 border border-base-300/40 rounded-xl px-4 py-2.5 shadow-sm"
    >
      <span
        class="text-xs text-base-content/50 font-semibold"
        id="sync-indicator"
      >
        Actualizado hace unos instantes
      </span>
      <button
        id="btn-refresh"
        class="btn btn-xs btn-circle btn-ghost text-base-content/60 hover:text-base-content transition-all duration-200"
        title="Actualizar ahora"
      >
        <Icon name="boxicons:refresh-ccw-filled" size={18} id="refresh-icon" />
      </button>
    </div>
  </div>

  <!-- Lock banner -->
  {
    role !== "agent" && (
      <div
        id="lock-banner"
        data-user-id={user?.id}
        data-user-username={user?.username}
        class="mb-6 rounded-xl border px-4 py-3 flex items-center justify-between gap-3 text-sm font-semibold transition-all duration-300"
        class:list={{
          "bg-success/10 border-success/30 text-success-content": hasLock,
          "bg-warning/10 border-warning/30 text-warning-content": !hasLock && lockStatus.status === "free",
          "bg-error/10 border-error/30 text-error-content": !hasLock && lockStatus.status === "occupied",
          "bg-neutral/10 border-neutral/30 text-neutral-content": !hasLock && lockStatus.status === "expired",
        }}
      >
        <div class="flex items-center gap-2">
          {hasLock && (
            <span>
              Tenés el control de asignación
              {lockReleaseRequested && <span class="text-warning ml-2 font-bold">(Solicitaron que liberes el control)</span>}
            </span>
          )}
          {!hasLock && lockStatus.status === "free" && <span>Sin asignador activo</span>}
          {!hasLock && lockStatus.status === "occupied" && <span><strong>{lockHolderName}</strong> está asignando autogestiones</span>}
          {!hasLock && lockStatus.status === "expired" && <span>La sesión de <strong>{lockHolderName}</strong> expiró</span>}
        </div>
        <div class="flex items-center gap-2">
          {!hasLock && lockStatus.status !== "occupied" && (
            <button type="button" id="btn-acquire-lock" class="btn btn-primary btn-sm font-bold uppercase tracking-wider shadow-sm">Tomar control</button>
          )}
          {!hasLock && lockStatus.status === "occupied" && (
            <button type="button" id="btn-request-release" class="btn btn-ghost btn-sm font-bold uppercase tracking-wider" disabled={lockReleaseRequested}>
              {lockReleaseRequested ? "Solicitud enviada" : "Pedir liberación"}
            </button>
          )}
          {hasLock && (
            <button type="button" id="btn-release-lock" class="btn btn-ghost btn-sm font-bold uppercase tracking-wider text-error">Liberar control</button>
          )}
        </div>
      </div>
    )
  }

  <div id="alert-container">
    {
      flashMessage && (
        <div
          class={`alert mb-6 shadow-md ${flashMessage.type === "success" ? "alert-success" : "alert-error"}`}
          role="alert"
        >
          <Icon
            name={
              flashMessage.type === "success"
                ? "boxicons:check-circle"
                : "boxicons:alert-octagon-filled"
            }
            size={20}
          />
          <span>{flashMessage.text}</span>
        </div>
      )
    }
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
    <!-- Card Disponibles -->
    <div
      class="card bg-base-100 border border-base-300 shadow-md overflow-hidden group hover:border-success/30 transition-all duration-300"
    >
      <div
        class="absolute -top-4 -right-4 p-4 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition-all duration-500 pointer-events-none"
      >
        <Icon name="boxicons:user-check" size={128} />
      </div>
      <div class="card-body p-6">
        <div class="flex items-center gap-3 mb-2">
          <div class="p-2 bg-success/10 rounded-lg text-success">
            <Icon name="boxicons:user-check" size={24} />
          </div>
          <h3
            class="font-bold text-xs uppercase tracking-widest text-base-content/50"
          >
            Disponibilidad Actual
          </h3>
        </div>
        <div class="flex items-baseline gap-2">
          <span
            class="text-5xl font-black text-success tracking-tight"
            id="stat-disponibles-count">{disponiblesCount}</span
          >
          <span
            class="text-base-content/40 font-bold uppercase text-xs tracking-wider"
            >operadores activos</span
          >
        </div>
        <div class="mt-6 flex flex-col gap-2">
          <div
            class="flex justify-between text-xs font-bold uppercase tracking-wider px-0.5"
          >
            <span class="text-base-content/40">Tasa de disponibilidad</span>
            <span class="text-success font-mono font-black" id="stat-percentage"
              >{
                allOperators.length > 0
                  ? Math.round((disponiblesCount / allOperators.length) * 100)
                  : 0
              }%</span
            >
          </div>
          <progress
            class="progress progress-success w-full h-2.5 bg-base-200"
            value={disponiblesCount}
            max={allOperators.length || 1}
            id="stat-progress"></progress>
        </div>
      </div>
    </div>

    <!-- Card No Disponibles -->
    <div
      class="card bg-base-100 border border-base-300 shadow-md overflow-hidden group hover:border-base-content/20 transition-all duration-300"
    >
      <div
        class="absolute -top-4 -right-4 p-4 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition-all duration-500 pointer-events-none"
      >
        <Icon name="boxicons:user-x" size={128} />
      </div>
      <div class="card-body p-6">
        <div class="flex items-center gap-3 mb-2">
          <div class="p-2 bg-base-content/5 rounded-lg text-base-content/50">
            <Icon name="boxicons:user-x" size={24} />
          </div>
          <h3
            class="font-bold text-xs uppercase tracking-widest text-base-content/50"
          >
            Fuera de Servicio
          </h3>
        </div>
        <div class="flex items-baseline gap-2">
          <span
            class="text-5xl font-black text-base-content/80 tracking-tight"
            id="stat-no-disponibles-count">{noDisponiblesCount}</span
          >
          <span
            class="text-base-content/40 font-bold uppercase text-xs tracking-wider"
            >en estados especiales</span
          >
        </div>

        <div class="mt-4 grid grid-cols-2 gap-2">
          {
            Object.entries(breakdown).map(([estado, count]) => (
              <div
                class="flex items-center justify-between p-2 rounded-lg bg-base-200/50 border border-transparent hover:border-base-300 transition-all duration-200 data-[count='0']:opacity-40"
                data-breakdown-container
                data-count={count}
              >
                <div class="flex items-center gap-2 min-w-0">
                  <span
                    class={`size-2 rounded-full shrink-0 ${breakdownBadge(estado)}`}
                  />
                  <span class="text-xs font-bold truncate text-base-content/60 uppercase tracking-tight">
                    {STATUS_LABELS[estado] ?? estado}
                  </span>
                </div>
                <span
                  class="text-xs font-mono font-bold text-base-content/90"
                  data-breakdown-count={estado}
                >
                  {count}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Card Última Asignación -->
    <div
      class="card bg-base-100 border border-base-300 shadow-md overflow-hidden group hover:border-base-content/20 transition-all duration-300"
    >
      <div
        class="absolute -top-4 -right-4 p-4 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition-all duration-500 pointer-events-none"
      >
        <Icon name="boxicons:history" size={128} />
      </div>
      <div class="card-body p-6 flex flex-col justify-between h-full">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <div class="p-2 bg-info/10 rounded-lg text-info">
              <Icon name="boxicons:history" size={24} />
            </div>
            <h3
              class="font-bold text-xs uppercase tracking-widest text-base-content/50"
            >
              Última Asignación
            </h3>
          </div>
          <div id="stat-last-assigned-container" class="mt-2 space-y-2">
            {lastAssignedOperator ? (
              <div>
                <div class="text-sm font-semibold text-base-content">
                  De: <span class="font-black text-info" id="stat-last-assigned-by">{lastAssignedOperator.lastAutogestionAssignedBy || "Sistema"}</span>
                </div>
                <div class="text-sm font-semibold text-base-content mt-1">
                  Para: <span class="font-black text-base-content" id="stat-last-assigned-to">{lastAssignedOperator.nombre}</span>
                </div>
                <div class="text-xs text-base-content/50 font-mono mt-2" id="stat-last-assigned-time">
                  Hora: {new Date(lastAssignedOperator.lastAutogestionAssignedAt!).toLocaleTimeString("es-AR", { hour: "2-digit", minute: "2-digit" })}
                </div>
              </div>
            ) : (
              <span class="text-xs text-base-content/40 italic">Sin asignaciones hoy</span>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Card Cola de Asignación -->
    <div
      class="card bg-base-100 border border-base-300 shadow-md overflow-hidden group hover:border-base-content/20 transition-all duration-300"
      style="min-height: 210px"
    >
      <div
        class="absolute -top-4 -right-4 p-4 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition-all duration-500 pointer-events-none"
      >
        <Icon name="boxicons:sparkles" size={128} />
      </div>
      <div class="card-body p-6 flex flex-col h-full">
        <div class="flex items-center gap-3 mb-3 shrink-0">
          <div class="p-2 bg-primary/10 rounded-lg text-primary">
            <Icon name="boxicons:sparkles" size={24} />
          </div>
          <h3 class="font-bold text-xs uppercase tracking-widest text-base-content/50">
            Próximos en Cola
          </h3>
        </div>
        <div id="queue-container" class="relative flex-1 overflow-hidden">
          {
            nextSuggestedOperators.length > 0 ? (
              nextSuggestedOperators.map((op, idx) => {
                const topStyle = `top: ${idx * 48}px;`;
                return (
                  <div
                    data-agent-id={op.agentId}
                    data-queue-item
                    class="absolute inset-x-0"
                    style={topStyle}
                  >
                    {idx === 0 ? (
                      <div class="flex items-center gap-2 py-1.5">
                        <div class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></div>
                        <div class="min-w-0">
                          <div class="text-lg sm:text-xl font-black text-primary tracking-tight truncate">{op.nombre}</div>
                          <div class="text-xxs font-bold uppercase tracking-wider text-base-content/40">{op.modalidadHoy === "Home Office" ? "Home" : "Presencial"}</div>
                        </div>
                      </div>
                    ) : idx === 1 ? (
                      <div class="flex items-center gap-2 py-1.5">
                        <div class="w-1.5 h-1.5 rounded-full bg-base-content/30 shrink-0"></div>
                        <div class="min-w-0">
                          <div class="text-base font-bold text-base-content/70 truncate">{op.nombre}</div>
                          <div class="text-xxs font-bold uppercase tracking-wider text-base-content/30">{op.modalidadHoy === "Home Office" ? "Home" : "Presencial"}</div>
                        </div>
                      </div>
                    ) : idx === 2 ? (
                      <div class="flex items-center gap-2 py-1.5">
                        <div class="w-1.5 h-1.5 rounded-full bg-base-content/30 shrink-0"></div>
                        <div class="min-w-0">
                          <div class="text-sm font-semibold text-base-content/50 truncate">{op.nombre}</div>
                          <div class="text-xxs font-bold uppercase tracking-wider text-base-content/30">{op.modalidadHoy === "Home Office" ? "Home" : "Presencial"}</div>
                        </div>
                      </div>
                    ) : (
                      <div class="flex items-center gap-2 py-1.5">
                        <div class="w-1.5 h-1.5 rounded-full bg-base-content/30 shrink-0"></div>
                        <div class="min-w-0">
                          <div class="text-xs font-medium text-base-content/35 truncate">{op.nombre}</div>
                          <div class="text-xxs font-bold uppercase tracking-wider text-base-content/30">{op.modalidadHoy === "Home Office" ? "Home" : "Presencial"}</div>
                        </div>
                      </div>
                    )}
                  </div>
                );
              })
            ) : (
              <div class="text-xs text-base-content/40 italic py-2" id="stat-suggested-name-empty">
                No hay operadores disponibles
              </div>
            )
          }
        </div>
      </div>
    </div>

  </div>

  <div class="mb-4 flex flex-wrap items-center justify-between gap-4">
    <div>
      <label
        class="label cursor-pointer justify-start gap-3 bg-base-200/40 hover:bg-base-200/80 px-4 py-2.5 rounded-xl border border-base-300/45 transition-colors duration-250"
      >
        <input
          type="checkbox"
          id="toggle-disponibles"
          class="toggle toggle-primary toggle-sm"
        />
        <span
          class="label-text font-bold text-xs uppercase tracking-wider text-base-content/70"
          >Ver solo disponibles</span
        >
      </label>
    </div>
    {!isReadOnly && (
      <div class="m-0 flex items-center gap-2">
        <button
          id="btn-undo"
          type="button"
          class="btn btn-secondary btn-outline btn-md shadow-sm transition-all duration-300"
          disabled
        >
          <Icon name="boxicons:undo" size={20} aria-hidden="true" />
          <span id="btn-undo-text">Deshacer</span>
        </button>
        <button
          id="btn-assign-cyclic"
          type="button"
          class="btn btn-primary btn-md shadow-lg shadow-primary/20 hover:shadow-primary/30 transition-all duration-300"
        >
          <Icon name="boxicons:user-check" size={20} aria-hidden="true" />
          Asignar Siguiente (Cíclico)
        </button>
      </div>
    )}
  </div>

  <DataTable
    ariaLabel="Lista de operadores para asignación de autogestiones"
    headerGridClass={isReadOnly ? "grid-cols-[1.8fr_1.5fr_1.2fr] gap-2 md:gap-4" : "grid-cols-[1.8fr_1.5fr_1.2fr_minmax(100px,auto)] gap-2 md:gap-4"}
    rowGridClass={isReadOnly ? "grid grid-cols-[1.8fr_1.5fr_1.2fr] items-center gap-2 md:gap-4" : "grid grid-cols-[1.8fr_1.5fr_1.2fr_minmax(100px,auto)] items-center gap-2 md:gap-4"}
  >
    <Fragment slot="header">
      <DataTableHeaderCell sortKey="nombre">Operador</DataTableHeaderCell>
      <DataTableHeaderCell>Horario / Modo</DataTableHeaderCell>
      <DataTableHeaderCell sortKey="estado">Estado</DataTableHeaderCell>
      {!isReadOnly && <DataTableHeaderCell align="right">Acciones</DataTableHeaderCell>}
    </Fragment>

    {
      allOperators.map((op) => {
        const isHighlighted = op.agentId === maxAssignedOperatorId;
        const isExceptional = !!op.estadoExcepcional;

        let rowClasses =
          "group border-b border-base-300 px-4 py-2.5 transition-all duration-300 hover:bg-base-200/50";
        if (isExceptional) {
          rowClasses += " bg-secondary/10 border-l-4 border-l-secondary";
        } else if (isHighlighted) {
          rowClasses += " bg-primary/10 border-l-4 border-l-primary";
        }
        if (!op.disponible && !isExceptional) {
          rowClasses += " opacity-50 grayscale-[30%]";
        }

        return (
          <div
            class={rowClasses}
            data-table-row
            data-op-id={op.agentId}
            data-op-estado={
              op.disponible ? "disponible" : op.motivo || "offline"
            }
            data-sort-nombre={op.nombre}
            data-sort-estado={
              op.disponible ? "disponible" : op.motivo || "offline"
            }
          >
            {/* Nombre + ID + Last Assigned */}
            <div class="flex min-w-0 flex-col">
              <span class="truncate text-xs font-bold text-base-content">
                {op.nombre}
              </span>
              <span class="font-mono text-tiny text-base-content/40 font-semibold leading-normal">
                ID: {op.agentId} {op.username ? `(${op.username})` : ""}
              </span>
              <div data-op-last-assigned-container>
                {op.lastAutogestionAssignedAt ? (
                  <span
                    class="text-tiny text-base-content/75 bg-base-300/50 rounded px-1.5 py-0.5 inline-block font-semibold mt-0.5"
                    data-last-assigned={op.lastAutogestionAssignedAt}
                  >
                    Asignado:{" "}
                    {new Date(op.lastAutogestionAssignedAt).toLocaleTimeString(
                      "es-AR",
                      { hour: "2-digit", minute: "2-digit" },
                    )}
                  </span>
                ) : (
                  <span class="text-tiny text-base-content/40 bg-base-200/40 rounded px-1.5 py-0.5 inline-block italic mt-0.5">
                    Nunca asignado
                  </span>
                )}
              </div>
            </div>

            {/* Horario y Modo */}
            <div class="flex flex-col gap-1 min-w-0">
              <div data-op-horario>
                {op.horarioHoy ? (
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-small text-base-content/70">
                    <span class="flex items-center gap-1 font-semibold">
                      <Icon
                        name="boxicons:clock-dashed-half-filled"
                        size={14}
                        class="opacity-60 shrink-0"
                      />
                      {op.horarioHoy}
                    </span>
                    {op.breakInicioHoy && op.breakFinHoy && (
                      <span class="flex items-center gap-1 opacity-70">
                        <Icon
                          name="boxicons:cup-hot"
                          size={14}
                          class="opacity-60 shrink-0"
                        />
                        {op.breakInicioHoy} - {op.breakFinHoy}
                      </span>
                    )}
                  </div>
                ) : (
                  <span class="text-base-content/40 italic">Sin horario</span>
                )}
              </div>

              <div data-op-modalidad>
                {op.modalidadHoy && op.modalidadHoy !== "Franco" && (
                  <span class="text-xxs font-bold opacity-60 uppercase tracking-tight">
                    {op.modalidadHoy === "Home Office" ? "Home" : "Presencial"}
                  </span>
                )}
              </div>
            </div>

            {/* Badge estado */}
            <div
              data-op-status-cell={op.agentId}
              class="flex flex-col items-start gap-1"
            >
              {op.estadoExcepcional ? (
                <div
                  class="tooltip tooltip-bottom before:text-xxs before:px-2 before:py-1"
                  data-tip={`${op.estadoExcepcionalMotivo || "Sin comentario"} — marcado a las ${op.estadoExcepcionalAt ? new Date(op.estadoExcepcionalAt).toLocaleTimeString("es-AR", { hour: "2-digit", minute: "2-digit" }) : ""}`}
                >
                  <span
                    data-op-status-badge={op.agentId}
                    class={`badge ${getBadgeColor(op.motivo || "", op.disponible)} gap-1.5 badge-xs font-semibold uppercase text-tiny tracking-wider py-2 cursor-help`}
                  >
                    {getExcepcionalShortLabel(op.estadoExcepcional)}
                    {op.estadoExcepcional === "break_extendido" &&
                    op.retornoEstimado
                      ? op.retornoEstimado === "Manual"
                        ? " (Manual)"
                        : ` - vuelve ${op.retornoEstimado}`
                      : ""}
                  </span>
                </div>
              ) : (
                <span
                  data-op-status-badge={op.agentId}
                  class={`badge ${getBadgeColor(op.motivo || "", op.disponible)} gap-1.5 badge-xs font-semibold uppercase text-tiny tracking-wider py-2`}
                >
                  {op.disponible && (
                    <span class="size-1.5 rounded-full bg-white animate-ping" />
                  )}
                  {!op.disponible && op.motivo === "En break" && (
                    <span class="size-1.5 rounded-full bg-warning-content/75 animate-pulse" />
                  )}
                  {op.disponible
                    ? "Disponible"
                    : op.motivo === "En break"
                      ? `En break - vuelve ${op.retornoEstimado || ""}`
                      : op.motivo || "Franco"}
                </span>
              )}
              {op.estadoExcepcional && op.estadoExcepcionalMotivo && (
                <div
                  data-op-exception-comment={op.agentId}
                  class="text-small text-base-content/50 italic font-medium leading-none max-w-[150px] truncate mt-0.5"
                  title={op.estadoExcepcionalMotivo}
                >
                  "{op.estadoExcepcionalMotivo}"
                </div>
              )}
            </div>

            {/* Botones de acción */}
            {!isReadOnly && (
              <div
                class="flex items-center justify-end gap-2"
                data-op-actions={op.agentId}
              >
                <>
                  <div class="m-0">
                    <button
                      type="button"
                      class="btn btn-secondary btn-xs btn-soft font-bold uppercase tracking-wider"
                      data-op-assign-btn={op.agentId}
                      title={`Asignar autogestión a ${op.nombre}`}
                      disabled={!op.disponible}
                    >
                      Asignar
                    </button>
                  </div>

                  <div data-op-exception-container={op.agentId} class="relative">
                    {op.estadoExcepcional ? (
                      <button
                        type="button"
                        class="btn btn-error btn-xs btn-outline font-bold uppercase tracking-wider"
                        data-action-lift-exception={op.agentId}
                        title="Levantar estado excepcional"
                      >
                        Levantar
                      </button>
                    ) : (
                      <button
                        type="button"
                        class="btn btn-ghost btn-xs text-base-content/60 hover:text-secondary hover:bg-secondary/10 px-1"
                        data-action-open-exception-modal={op.agentId}
                        data-op-nombre={op.nombre}
                        title="Marcar estado excepcional"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="size-4"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                          />
                        </svg>
                      </button>
                    )}
                  </div>
                </>
              </div>
            )}
          </div>
        );
      })
    }
  </DataTable>
</PageContainer>

<script>
  const init = () => {
    const escapeHtml = (str: string | null | undefined): string => {
      if (str == null) return "";
      const div = document.createElement("div");
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    };

    const toggle = document.getElementById(
      "toggle-disponibles",
    ) as HTMLInputElement | null;
    if (!toggle) return false;

    const syncIndicator = document.getElementById("sync-indicator");
    const refreshIcon = document.getElementById("refresh-icon");
    const btnRefresh = document.getElementById(
      "btn-refresh",
    ) as HTMLButtonElement | null;
    const modalEl = document.getElementById(
      "modal-marcar-excepcion",
    ) as HTMLDialogElement | null;

    if (modalEl) {
      modalEl.addEventListener("close", () => {
        document.body.classList.remove("overflow-hidden");
        document.documentElement.classList.remove("overflow-hidden");
      });
    }

    const selectTipo = document.getElementById(
      "modal-select-tipo",
    ) as HTMLSelectElement | null;
    const containerTiempoExtra = document.getElementById(
      "container-tiempo-extra",
    );
    if (selectTipo && containerTiempoExtra) {
      selectTipo.addEventListener("change", () => {
        if (selectTipo.value === "break_extendido") {
          containerTiempoExtra.classList.remove("hidden");
        } else {
          containerTiempoExtra.classList.add("hidden");
        }
      });
    }

    let secondsSinceSync = 0;
    let lockExpiresAt = 0;
    let lockTimeoutMs = 300000;
    let countdownInterval: any = null;
    let currentLockStatus: any = null;

    const formatCountdown = (ms: number): string => {
      if (ms <= 0) return "0:00";
      const totalSeconds = Math.floor(ms / 1000);
      const minutes = Math.floor(totalSeconds / 60);
      const seconds = totalSeconds % 60;
      return `${minutes}:${seconds.toString().padStart(2, "0")}`;
    };

    const stopCountdown = () => {
      if (countdownInterval) {
        clearInterval(countdownInterval);
        countdownInterval = null;
      }
    };

    const startCountdown = () => {
      stopCountdown();

      const tick = () => {
        const remaining = lockExpiresAt - Date.now();
        const countdownEl = document.getElementById("lock-countdown");
        if (remaining <= 0) {
          if (countdownEl) {
            countdownEl.innerText = "0:00";
          }
          stopCountdown();
          fetchLockStatus().then(updateLockBanner);
          return;
        }
        if (countdownEl) {
          countdownEl.innerText = formatCountdown(remaining);
        }
      };

      tick();
      countdownInterval = setInterval(tick, 1000);
    };

    // Initialize prevQueueIds from the SSR rendered elements
    let prevQueueIds: number[] = Array.from(document.querySelectorAll("#queue-container [data-agent-id]"))
      .map((el) => Number(el.getAttribute("data-agent-id")))
      .filter((id) => !isNaN(id));

    const updateIndicatorText = () => {
      if (!syncIndicator) return;
      if (secondsSinceSync === 0) {
        syncIndicator.innerText = "Actualizado hace unos instantes";
      } else {
        syncIndicator.innerText = `Actualizado hace ${secondsSinceSync}s`;
      }
    };

    // Increment elapsed seconds since last successful API call
    const timer = setInterval(() => {
      secondsSinceSync++;
      updateIndicatorText();
    }, 1000);

    const updateVisibility = () => {
      const soloDisponibles = toggle.checked;
      const rows = document.querySelectorAll<HTMLElement>("[data-op-id]");
      rows.forEach((row) => {
        const estado = row.getAttribute("data-op-estado") || "";
        if (soloDisponibles && estado !== "disponible") {
          row.classList.add("hidden");
        } else {
          row.classList.remove("hidden");
        }
      });
    };

    toggle.addEventListener("change", updateVisibility);

    // Dynamic UI Update from API Response
    const updateUI = (data: any[]) => {
      // Update Undo button state
      const opWithUndo = data.find(op => op.lastAutogestionUndo !== null && op.lastAutogestionUndo !== undefined);
      const btnUndo = document.getElementById("btn-undo") as HTMLButtonElement | null;
      const btnUndoText = document.getElementById("btn-undo-text") as HTMLElement | null;
      if (btnUndo && btnUndoText) {
        if (opWithUndo) {
          btnUndo.disabled = false;
          btnUndoText.innerText = `Deshacer: ${opWithUndo.nombre}`;
        } else {
          btnUndo.disabled = true;
          btnUndoText.innerText = "Deshacer";
        }
      }

      // 1. Calculate highlights (the one with the latest assignment)
      let maxAssignedTime = 0;
      let maxAgentId: number | null = null;
      data.forEach((op) => {
        if (
          op.lastAutogestionAssignedAt &&
          op.lastAutogestionAssignedAt > maxAssignedTime
        ) {
          maxAssignedTime = op.lastAutogestionAssignedAt;
          maxAgentId = op.agentId;
        }
      });

      // 2. Update summary cards
      const disponiblesCount = data.filter((op) => op.disponible).length;
      const totalCount = data.length || 1;
      const pct = Math.round((disponiblesCount / totalCount) * 100);

      const statDisponibles = document.getElementById("stat-disponibles-count");
      if (statDisponibles)
        statDisponibles.innerText = disponiblesCount.toString();

      const statNoDisponibles = document.getElementById(
        "stat-no-disponibles-count",
      );
      if (statNoDisponibles)
        statNoDisponibles.innerText = (
          data.length - disponiblesCount
        ).toString();

      const statPercentage = document.getElementById("stat-percentage");
      if (statPercentage) statPercentage.innerText = `${pct}%`;

      const statProgress = document.getElementById(
        "stat-progress",
      ) as HTMLProgressElement | null;
      if (statProgress) {
        statProgress.value = disponiblesCount;
        statProgress.max = totalCount;
      }

      // 3. Update breakdown counts
      const breakdown = {
        "En break": 0,
        "Fuera de horario": 0,
        Franco: 0,
        Licencia: 0,
        Vacaciones: 0,
        Excepción: 0,
      };

      data.forEach((op) => {
        if (!op.disponible) {
          const mot = op.motivo || "Franco";
          if (
            [
              "Devolución Supervisor",
              "Break Extendido",
              "Problema Técnico",
            ].includes(mot)
          ) {
            breakdown["Excepción"]++;
          } else if (mot in breakdown) {
            breakdown[mot as keyof typeof breakdown]++;
          }
        }
      });

      for (const [status, count] of Object.entries(breakdown)) {
        const el = document.querySelector(
          `[data-breakdown-count="${status}"]`,
        ) as HTMLElement | null;
        if (el) {
          el.textContent = count.toString();
          const container = el.closest("[data-breakdown-container]");
          if (container) {
            container.setAttribute("data-count", count.toString());
            if (count === 0) {
              container.classList.add("opacity-40");
            } else {
              container.classList.remove("opacity-40");
            }
          }
        }
      }

      // 3b. Update last assigned card and suggested card
      let maxAssignedTimeForCard = 0;
      let lastAssignedOp: any = null;
      for (const op of data) {
        if (
          op.lastAutogestionAssignedAt &&
          op.lastAutogestionAssignedAt > maxAssignedTimeForCard
        ) {
          maxAssignedTimeForCard = op.lastAutogestionAssignedAt;
          lastAssignedOp = op;
        }
      }

      const lastAssignedContainer = document.getElementById("stat-last-assigned-container");
      if (lastAssignedContainer) {
        if (lastAssignedOp && maxAssignedTimeForCard > 0) {
          const timeStr = new Date(maxAssignedTimeForCard).toLocaleTimeString("es-AR", {
            hour: "2-digit",
            minute: "2-digit",
          });
          lastAssignedContainer.innerHTML = `
            <div>
              <div class="text-sm font-semibold text-base-content">
                De: <span class="font-black text-info" id="stat-last-assigned-by">${escapeHtml(lastAssignedOp.lastAutogestionAssignedBy || "Sistema")}</span>
              </div>
              <div class="text-sm font-semibold text-base-content mt-1">
                Para: <span class="font-black text-base-content" id="stat-last-assigned-to">${escapeHtml(lastAssignedOp.nombre)}</span>
              </div>
              <div class="text-xs text-base-content/50 font-mono mt-2" id="stat-last-assigned-time">
                Hora: ${timeStr}
              </div>
            </div>
          `;
        } else {
          lastAssignedContainer.innerHTML = `<span class="text-xs text-base-content/40 italic">Sin asignaciones hoy</span>`;
        }
      }

      const queueContainer = document.getElementById("queue-container");
      if (queueContainer) {
        const available = data.filter((op) => op.disponible);
        const sortedQueue = [...available].sort((a, b) => {
          const tA = a.lastAutogestionAssignedAt ?? 0;
          const tB = b.lastAutogestionAssignedAt ?? 0;
          if (a.lastAutogestionAssignedAt === null && b.lastAutogestionAssignedAt !== null) return -1;
          if (a.lastAutogestionAssignedAt !== null && b.lastAutogestionAssignedAt === null) return 1;
          return tA - tB;
        }).slice(0, 4);

        const newIds = sortedQueue.map((op) => op.agentId);

        const renderQueueItemInner = (op: any, index: number) => {
          let dotClass = "bg-base-content/30";
          let itemStyle = "";
          let subtitleStyle = "";

          if (index === 0) {
            dotClass = "bg-primary";
            itemStyle = "text-lg sm:text-xl font-black text-primary tracking-tight truncate";
            subtitleStyle = "text-xxs font-bold uppercase tracking-wider text-base-content/40";
          } else if (index === 1) {
            itemStyle = "text-base font-bold text-base-content/70 truncate";
            subtitleStyle = "text-xxs font-bold uppercase tracking-wider text-base-content/30";
          } else if (index === 2) {
            itemStyle = "text-sm font-semibold text-base-content/50 truncate";
            subtitleStyle = "text-xxs font-bold uppercase tracking-wider text-base-content/30";
          } else {
            itemStyle = "text-xs font-medium text-base-content/35 truncate";
            subtitleStyle = "text-xxs font-bold uppercase tracking-wider text-base-content/30";
          }

          return `
            <div class="flex items-center gap-2 py-1.5">
              <div class="w-1.5 h-1.5 rounded-full ${dotClass} shrink-0"></div>
              <div class="min-w-0">
                <div class="${itemStyle}">${escapeHtml(op.nombre)}</div>
                <div class="${subtitleStyle}">${escapeHtml(op.modalidadHoy === "Home Office" ? "Home" : "Presencial")}</div>
              </div>
            </div>
          `;
        };

        if (JSON.stringify(newIds) !== JSON.stringify(prevQueueIds)) {
          if (newIds.length === 0) {
            const currentItems = Array.from(queueContainer.querySelectorAll("[data-agent-id]")) as HTMLElement[];
            currentItems.forEach((el) => {
              el.style.top = "-48px";
              el.style.opacity = "0";
            });
            setTimeout(() => {
              if (prevQueueIds.length === 0) {
                queueContainer.innerHTML = `
                  <div class="text-xs text-base-content/40 italic py-2" id="stat-suggested-name-empty">
                    No hay operadores disponibles
                  </div>
                `;
              }
            }, 400);
          } else {
            const emptyMsg = document.getElementById("stat-suggested-name-empty");
            if (emptyMsg) {
              emptyMsg.remove();
            }

            const currentItems = Array.from(queueContainer.querySelectorAll("[data-agent-id]")) as HTMLElement[];

            // Animate out orphans
            currentItems.forEach((el) => {
              const id = Number(el.getAttribute("data-agent-id"));
              if (!newIds.includes(id)) {
                el.style.top = "-48px";
                el.style.opacity = "0";
                setTimeout(() => el.remove(), 400);
              }
            });

            // Update or create items
            sortedQueue.forEach((op, index) => {
              let el = queueContainer.querySelector(`[data-agent-id="${op.agentId}"]`) as HTMLElement | null;
              if (el) {
                el.innerHTML = renderQueueItemInner(op, index);
                el.style.top = `${index * 48}px`;
                el.style.opacity = "1";
              } else {
                el = document.createElement("div");
                el.setAttribute("data-agent-id", op.agentId.toString());
                el.setAttribute("data-queue-item", "");
                el.className = "absolute inset-x-0";
                el.style.top = `${(index + 1) * 48}px`;
                el.style.opacity = "0";
                el.innerHTML = renderQueueItemInner(op, index);
                queueContainer.appendChild(el);

                el.offsetHeight; // Force reflow
                el.style.top = `${index * 48}px`;
                el.style.opacity = "1";
              }
            });
          }
          prevQueueIds = newIds;
        }
      }


      // 4. Update each table row
      data.forEach((op) => {
        const row = document.querySelector(
          `[data-op-id="${op.agentId}"]`,
        ) as HTMLElement | null;
        if (!row) return;

        const stateKey = op.disponible ? "disponible" : op.motivo || "offline";
        row.setAttribute("data-op-estado", stateKey);
        row.setAttribute("data-sort-estado", stateKey);

        // Clear previous conditional classes to ensure fresh state
        row.classList.remove(
          "bg-primary/10",
          "border-l-primary",
          "bg-secondary/10",
          "border-l-secondary",
          "border-l-4",
          "opacity-50",
          "grayscale-[30%]",
        );

        const isExceptional = !!op.estadoExcepcional;
        const isHighlighted = op.agentId === maxAgentId && maxAssignedTime > 0;

        if (isExceptional) {
          row.classList.add(
            "bg-secondary/10",
            "border-l-4",
            "border-l-secondary",
          );
        } else if (isHighlighted) {
          row.classList.add("bg-primary/10", "border-l-4", "border-l-primary");
        }

        if (!op.disponible && !isExceptional) {
          row.classList.add("opacity-50", "grayscale-[30%]");
        }

        // Update Horario / Break content
        const horarioEl = row.querySelector(`[data-op-horario]`);
        if (horarioEl) {
          if (op.horarioHoy) {
            let breakHtml = "";
            if (op.breakInicioHoy && op.breakFinHoy) {
              breakHtml = `
                <span class="flex items-center gap-1 opacity-70">
                  <svg class="size-3 opacity-60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path><line x1="6" y1="2" x2="6" y2="4"></line><line x1="10" y1="2" x2="10" y2="4"></line><line x1="14" y1="2" x2="14" y2="4"></line></svg>
                  ${op.breakInicioHoy} - ${op.breakFinHoy}
                </span>
              `;
            }
            horarioEl.innerHTML = `
              <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-small text-base-content/70">
                <span class="flex items-center gap-1 font-semibold">
                  <svg class="size-3.5 opacity-60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                  ${op.horarioHoy}
                </span>
                ${breakHtml}
              </div>
            `;
          } else {
            horarioEl.innerHTML = `<span class="text-base-content/40 italic">Sin horario</span>`;
          }
        }

        // Update Modality text
        const modEl = row.querySelector(`[data-op-modalidad]`);
        if (modEl) {
          if (op.modalidadHoy && op.modalidadHoy !== "Franco") {
            const isHome = op.modalidadHoy === "Home Office";
            modEl.innerHTML = `
              <span class="text-xxs font-bold opacity-60 uppercase tracking-tight">
                ${isHome ? "Home" : "Presencial"}
              </span>
            `;
          } else {
            modEl.innerHTML = "";
          }
        }

        // Update status cell (badge + comment)
        const statusCell = row.querySelector(
          `[data-op-status-cell="${op.agentId}"]`,
        );
        if (statusCell) {
          let badgeHtml = "";
          let commentHtml = "";

          if (op.estadoExcepcional) {
            const badgeClass =
              "badge-secondary text-secondary-content shadow-sm shadow-secondary/20";
            let shortLabel = "⚠ Excepción";
            if (op.estadoExcepcional === "devolucion_supervisor")
              shortLabel = "⚠ Dev. Supervisor";
            else if (op.estadoExcepcional === "break_extendido") {
              const returnSuffix =
                op.retornoEstimado === "Manual"
                  ? " (Manual)"
                  : op.retornoEstimado
                    ? ` - vuelve ${op.retornoEstimado}`
                    : "";
              shortLabel = `⚠ Break extendido${returnSuffix}`;
            } else if (op.estadoExcepcional === "problema_tecnico")
              shortLabel = "⚠ Prob. técnico";

            const timeStr = op.estadoExcepcionalAt
              ? new Date(op.estadoExcepcionalAt).toLocaleTimeString("es-AR", {
                  hour: "2-digit",
                  minute: "2-digit",
                })
              : "";
            const tooltipTip = `${op.estadoExcepcionalMotivo || "Sin comentario"} — marcado a las ${timeStr}`;

            badgeHtml = `
              <div class="tooltip tooltip-bottom before:text-xxs before:px-2 before:py-1" data-tip="${tooltipTip}">
                <span
                  data-op-status-badge="${op.agentId}"
                  class="badge ${badgeClass} gap-1.5 badge-xs font-semibold uppercase text-tiny tracking-wider py-2 cursor-help"
                >
                  ${shortLabel}
                </span>
              </div>
            `;
            if (op.estadoExcepcionalMotivo) {
              commentHtml = `
                <div data-op-exception-comment="${op.agentId}" class="text-small text-base-content/50 italic font-medium leading-none max-w-[150px] truncate mt-0.5" title="${op.estadoExcepcionalMotivo}">
                  "${op.estadoExcepcionalMotivo}"
                </div>
              `;
            }
          } else {
            let badgeClass = "badge-neutral";
            let badgeText = op.motivo || "Franco";
            let dotHtml = "";

            if (op.disponible) {
              badgeClass =
                "badge-success text-white shadow-sm shadow-success/20";
              badgeText = "Disponible";
              dotHtml = `<span class="size-1.5 rounded-full bg-white animate-ping"></span>`;
            } else if (op.motivo === "En break") {
              badgeClass =
                "badge-warning text-warning-content shadow-sm shadow-warning/20";
              badgeText = `En break - vuelve ${op.retornoEstimado || ""}`;
              dotHtml = `<span class="size-1.5 rounded-full bg-warning-content/75 animate-pulse"></span>`;
            } else if (op.motivo === "Fuera de horario") {
              badgeClass = "badge-neutral text-neutral-content/75 opacity-70";
              badgeText = "Fuera de horario";
            } else if (op.motivo === "Licencia") {
              badgeClass = "badge-error text-white shadow-sm shadow-error/20";
            } else if (op.motivo === "Vacaciones") {
              badgeClass = "badge-info text-white shadow-sm shadow-info/20";
            } else if (op.motivo === "Franco") {
              badgeClass = "badge-neutral text-neutral-content/50";
            }

            badgeHtml = `
              <span
                data-op-status-badge="${op.agentId}"
                class="badge ${badgeClass} gap-1.5 badge-xs font-semibold uppercase text-tiny tracking-wider py-2"
              >
                ${dotHtml}${badgeText}
              </span>
            `;
          }

          statusCell.innerHTML = `${badgeHtml}${commentHtml}`;
        }

        // Update actions container
        const exceptionContainer = row.querySelector(
          `[data-op-exception-container="${op.agentId}"]`,
        );
        if (exceptionContainer) {
          if (op.estadoExcepcional) {
            exceptionContainer.innerHTML = `
              <button
                type="button"
                class="btn btn-error btn-xs btn-outline font-bold uppercase tracking-wider"
                data-action-lift-exception="${op.agentId}"
                title="Levantar estado excepcional"
              >
                Levantar
              </button>
            `;
          } else {
            exceptionContainer.innerHTML = `
              <button
                type="button"
                class="btn btn-ghost btn-xs text-base-content/60 hover:text-secondary hover:bg-secondary/10 px-1"
                data-action-open-exception-modal="${op.agentId}"
                data-op-nombre="${op.nombre}"
                title="Marcar estado excepcional"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </button>
            `;
          }
        }

        // Update Last Assigned text
        const lastAssignedEl = row.querySelector(
          `[data-op-last-assigned-container]`,
        );
        if (lastAssignedEl) {
          if (op.lastAutogestionAssignedAt) {
            const timeStr = new Date(
              op.lastAutogestionAssignedAt,
            ).toLocaleTimeString("es-AR", {
              hour: "2-digit",
              minute: "2-digit",
            });
            lastAssignedEl.innerHTML = `
              <span class="text-tiny text-base-content/75 bg-base-300/50 rounded px-1.5 py-0.5 inline-block font-semibold mt-0.5" data-last-assigned="${op.lastAutogestionAssignedAt}">
                Asignado: ${timeStr}
              </span>
            `;
          } else {
            lastAssignedEl.innerHTML = `<span class="text-tiny text-base-content/40 bg-base-200/40 rounded px-1.5 py-0.5 inline-block italic mt-0.5">Nunca asignado</span>`;
          }
        }

        // Update assign button disabled state
        const assignBtn = row.querySelector(
          `[data-op-assign-btn="${op.agentId}"]`,
        ) as HTMLButtonElement | null;
        if (assignBtn) {
          assignBtn.disabled = !op.disponible;
        }
      });

      // Filter rows based on "Ver solo disponibles" toggle check
      updateVisibility();
    };

    const showAlert = (type: "success" | "error", message: string) => {
      const alertContainer = document.getElementById("alert-container");
      if (!alertContainer) return;

      const alertClass = type === "success" ? "alert-success" : "alert-error";
      const iconSvg = type === "success"
        ? `<svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`
        : `<svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;

      alertContainer.innerHTML = `
        <div class="alert mb-6 shadow-md ${alertClass}" role="alert">
          ${iconSvg}
          <span>${message}</span>
        </div>
      `;
    };

    // Event delegation for exceptional states and assignments
    document.addEventListener("click", async (e) => {
      const target = e.target as HTMLElement;

      // 0. Open exception modal
      const openModalBtn = target.closest("[data-action-open-exception-modal]");
      if (openModalBtn) {
        const agentId = openModalBtn.getAttribute(
          "data-action-open-exception-modal",
        );
        const nombre = openModalBtn.getAttribute("data-op-nombre") || "";

        const modal = document.getElementById(
          "modal-marcar-excepcion",
        ) as HTMLDialogElement | null;
        const agentIdInput = document.getElementById(
          "modal-agent-id",
        ) as HTMLInputElement | null;
        const operatorNameSpan = document.getElementById(
          "modal-operador-nombre",
        );
        const selectTipo = document.getElementById(
          "modal-select-tipo",
        ) as HTMLSelectElement | null;
        const containerTiempoExtra = document.getElementById(
          "container-tiempo-extra",
        );
        const selectTiempoExtra = document.getElementById(
          "modal-select-tiempo-extra",
        ) as HTMLSelectElement | null;
        const inputMotivo = document.getElementById(
          "modal-input-motivo",
        ) as HTMLInputElement | null;

        if (modal && agentIdInput && operatorNameSpan) {
          agentIdInput.value = agentId || "";
          operatorNameSpan.innerText = nombre;
          if (selectTipo) selectTipo.value = "devolucion_supervisor";
          if (containerTiempoExtra)
            containerTiempoExtra.classList.add("hidden");
          if (selectTiempoExtra) selectTiempoExtra.value = "20";
          if (inputMotivo) inputMotivo.value = "";

          document.body.classList.add("overflow-hidden");
          document.documentElement.classList.add("overflow-hidden");
          modal.showModal();
        }
        return;
      }

      // 0.5. Close exception modal
      const closeModalBtn = target.closest("#btn-close-modal-excepcion");
      if (closeModalBtn) {
        const modal = document.getElementById(
          "modal-marcar-excepcion",
        ) as HTMLDialogElement | null;
        if (modal) {
          modal.close();
        }
        return;
      }

      // 1. Confirm exceptional state from modal
      const confirmModalBtn = target.closest("#btn-confirmar-modal-excepcion");
      if (confirmModalBtn) {
        const agentIdInput = document.getElementById(
          "modal-agent-id",
        ) as HTMLInputElement | null;
        const selectTipo = document.getElementById(
          "modal-select-tipo",
        ) as HTMLSelectElement | null;
        const selectTiempoExtra = document.getElementById(
          "modal-select-tiempo-extra",
        ) as HTMLSelectElement | null;
        const inputMotivo = document.getElementById(
          "modal-input-motivo",
        ) as HTMLInputElement | null;
        const modal = document.getElementById(
          "modal-marcar-excepcion",
        ) as HTMLDialogElement | null;

        if (agentIdInput && selectTipo && modal) {
          const agentId = Number(agentIdInput.value);
          const tipo = selectTipo.value;
          const motivo = inputMotivo ? inputMotivo.value : "";
          const tiempoExtra =
            tipo === "break_extendido" &&
            selectTiempoExtra &&
            selectTiempoExtra.value !== "manual"
              ? Number(selectTiempoExtra.value)
              : null;

          if (!isNaN(agentId)) {
            confirmModalBtn.setAttribute("disabled", "true");
            try {
              const res = await fetch("/api/disponibilidad/excepcional", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ agentId, tipo, motivo, tiempoExtra }),
              });
              const resData = await res.json();
              if (res.status === 423) {
                modal.close();
                showAlert("error", resData.error || "Perdiste el control de asignación. Recargando...");
                setTimeout(() => window.location.reload(), 1500);
                return;
              }
              if (res.ok) {
                modal.close();
                await fetchDisponibilidad();
              } else {
                showAlert("error", resData.error || "No se pudo marcar el estado excepcional");
              }
            } catch (err) {
              console.error(err);
            } finally {
              confirmModalBtn.removeAttribute("disabled");
            }
          }
        }
        return;
      }

      // 2. Lift/clear exceptional state
      const liftBtn = target.closest("[data-action-lift-exception]");
      if (liftBtn) {
        const agentId = Number(
          liftBtn.getAttribute("data-action-lift-exception"),
        );
        if (!isNaN(agentId)) {
          liftBtn.setAttribute("disabled", "true");
          try {
            const res = await fetch("/api/disponibilidad/excepcional", {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ agentId }),
            });
            const resData = await res.json();
            if (res.status === 423) {
              showAlert("error", resData.error || "Perdiste el control de asignación. Recargando...");
              setTimeout(() => window.location.reload(), 1500);
              return;
            }
            if (res.ok) {
              await fetchDisponibilidad();
            } else {
              showAlert("error", resData.error || "No se pudo levantar la excepción");
            }
          } catch (err) {
            console.error(err);
          } finally {
            liftBtn.removeAttribute("disabled");
          }
        }
        return;
      }

      // 2.5 Deshacer assign
      const btnUndoEl = target.closest("#btn-undo");
      if (btnUndoEl && !btnUndoEl.hasAttribute("disabled")) {
        btnUndoEl.setAttribute("disabled", "true");
        try {
          const res = await fetch("/api/disponibilidad/deshacer", {
            method: "POST",
            headers: { "Content-Type": "application/json" }
          });
          const resData = await res.json();
          if (res.status === 423) {
            showAlert("error", resData.error || "Perdiste el control de asignación. Recargando...");
            setTimeout(() => window.location.reload(), 1500);
            return;
          }
          if (res.ok && resData.success) {
            showAlert("success", `Asignación de ${resData.agentName} deshecha.`);
            await fetchDisponibilidad();
          } else {
            showAlert("error", resData.error || "No se pudo deshacer la asignación.");
          }
        } catch (err: any) {
          console.error(err);
          showAlert("error", `Ocurrió un error al deshacer: ${err.message || err}`);
        }
        return;
      }

      // 3. Cyclic assign
      const assignCyclicBtn = target.closest("#btn-assign-cyclic");
      if (assignCyclicBtn) {
        assignCyclicBtn.setAttribute("disabled", "true");
        try {
          const res = await fetch("/api/disponibilidad/asignar", {
            method: "POST",
            headers: { "Content-Type": "application/json" }
          });
          const data = await res.json();
          if (res.status === 423) {
            showAlert("error", data.error || "Perdiste el control de asignación. Recargando...");
            setTimeout(() => window.location.reload(), 1500);
            return;
          }
          if (res.ok && data.success && data.agent) {
            showAlert("success", `Autogestión asignada cíclicamente a ${data.agent.nombre || data.agent.name}.`);
            await fetchDisponibilidad();
          } else {
            showAlert("error", data.error || "No hay operadores disponibles o dentro de horario operativo para asignar.");
          }
        } catch (err: any) {
          console.error(err);
          showAlert("error", `Ocurrió un error al procesar la asignación cíclica: ${err.message || err}`);
        } finally {
          assignCyclicBtn.removeAttribute("disabled");
        }
        return;
      }

      // 4. Manual assign
      const assignManualBtn = target.closest("[data-op-assign-btn]");
      if (assignManualBtn) {
        const agentId = Number(assignManualBtn.getAttribute("data-op-assign-btn"));
        if (!isNaN(agentId)) {
          assignManualBtn.setAttribute("disabled", "true");
          try {
            const res = await fetch("/api/disponibilidad/asignar-manual", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ agentId }),
            });
            const data = await res.json();
            if (res.status === 423) {
              showAlert("error", data.error || "Perdiste el control de asignación. Recargando...");
              setTimeout(() => window.location.reload(), 1500);
              return;
            }
            if (res.ok && data.success) {
              showAlert("success", `Autogestión asignada manualmente a ${data.agentName}.`);
              await fetchDisponibilidad();
            } else {
              showAlert("error", data.error || "No se pudo realizar la asignación manual.");
            }
          } catch (err: any) {
            console.error(err);
            showAlert("error", `Ocurrió un error al procesar la asignación manual: ${err.message || err}`);
          } finally {
            assignManualBtn.removeAttribute("disabled");
          }
        }
        return;
      }
    });

    // Fetch availability data
    const fetchDisponibilidad = async () => {
      if (refreshIcon) refreshIcon.classList.add("animate-spin");
      if (btnRefresh) btnRefresh.disabled = true;

      try {
        const res = await fetch("/api/disponibilidad");
        if (!res.ok) throw new Error("Error fetching availability");
        const data = await res.json();

        updateUI(data);

        secondsSinceSync = 0;
        updateIndicatorText();
      } catch (error) {
        console.error("Failed to sync availability data:", error);
      } finally {
        if (refreshIcon) refreshIcon.classList.remove("animate-spin");
        if (btnRefresh) btnRefresh.disabled = false;
      }
    };

    // Fetch lock status
    const fetchLockStatus = async () => {
      try {
        const res = await fetch("/api/disponibilidad/lock");
        if (!res.ok) throw new Error("Error fetching lock status");
        return await res.json();
      } catch (error) {
        console.error("Failed to fetch lock status:", error);
        return null;
      }
    };

    // Dynamic lock banner UI update
    const updateLockBanner = (lockStatus: any) => {
      if (!lockStatus) return;
      currentLockStatus = lockStatus;

      const banner = document.getElementById("lock-banner");
      if (!banner) return;

      const currentUserId = Number(banner.getAttribute("data-user-id"));

      let hasLock = false;
      let lockHolderName = null;
      let lockReleaseRequested = false;

      if (lockStatus.status === "occupied") {
        hasLock = lockStatus.user?.userId === currentUserId;
        lockHolderName = lockStatus.user?.username;
        lockReleaseRequested = lockStatus.user?.releaseRequested;

        lockTimeoutMs = lockReleaseRequested ? 60000 : 300000;
        lockExpiresAt = lockStatus.user.lastActivityAt + lockTimeoutMs;
        startCountdown();
      } else {
        stopCountdown();
      }

      banner.classList.remove(
        "bg-success/10", "border-success/30", "text-success-content",
        "bg-warning/10", "border-warning/30", "text-warning-content",
        "bg-error/10", "border-error/30", "text-error-content",
        "bg-neutral/10", "border-neutral/30", "text-neutral-content"
      );

      if (hasLock) {
        banner.classList.add("bg-success/10", "border-success/30", "text-success-content");
      } else if (lockStatus.status === "free") {
        banner.classList.add("bg-warning/10", "border-warning/30", "text-warning-content");
      } else if (lockStatus.status === "occupied") {
        banner.classList.add("bg-error/10", "border-error/30", "text-error-content");
      } else if (lockStatus.status === "expired") {
        banner.classList.add("bg-neutral/10", "border-neutral/30", "text-neutral-content");
      }

      let statusTextHtml = "";
      if (hasLock) {
        const initialCountdown = lockExpiresAt > 0 ? formatCountdown(lockExpiresAt - Date.now()) : "5:00";
        statusTextHtml = `
          <span>
            Tenés el control de asignación — <span id="lock-countdown" class="tabular-nums font-mono">${initialCountdown}</span>
            ${lockReleaseRequested ? '<span class="text-warning ml-2 font-bold">(Solicitaron que liberes el control)</span>' : ''}
          </span>
        `;
      } else if (lockStatus.status === "free") {
        statusTextHtml = `<span>Sin asignador activo</span>`;
      } else if (lockStatus.status === "occupied") {
        const initialCountdown = lockExpiresAt > 0 ? formatCountdown(lockExpiresAt - Date.now()) : "0:00";
        statusTextHtml = `<span><strong>${escapeHtml(lockHolderName)}</strong> está asignando autogestiones — <span id="lock-countdown" class="tabular-nums font-mono">${initialCountdown}</span></span>`;
      } else if (lockStatus.status === "expired") {
        statusTextHtml = `<span>La sesión de <strong>${escapeHtml(lockHolderName)}</strong> expiró</span>`;
      }

      let buttonHtml = "";
      if (!hasLock && lockStatus.status !== "occupied") {
        buttonHtml = `<button type="button" id="btn-acquire-lock" class="btn btn-primary btn-sm font-bold uppercase tracking-wider shadow-sm">Tomar control</button>`;
      } else if (!hasLock && lockStatus.status === "occupied") {
        buttonHtml = `
          <button type="button" id="btn-request-release" class="btn btn-ghost btn-sm font-bold uppercase tracking-wider" ${lockReleaseRequested ? 'disabled' : ''}>
            ${lockReleaseRequested ? 'Solicitud enviada' : 'Pedir liberación'}
          </button>
        `;
      } else if (hasLock) {
        buttonHtml = `<button type="button" id="btn-release-lock" class="btn btn-ghost btn-sm font-bold uppercase tracking-wider text-error">Liberar control</button>`;
      }

      banner.innerHTML = `
        <div class="flex items-center gap-2">
          ${statusTextHtml}
        </div>
        <div class="flex items-center gap-2">
          ${buttonHtml}
        </div>
      `;

      if (hasLock) {
        startHeartbeat();
      } else {
        stopHeartbeat();
      }
    };

    // Click handler for manual refresh
    if (btnRefresh) {
      btnRefresh.addEventListener("click", async () => {
        await Promise.all([
          fetchDisponibilidad(),
          fetchLockStatus().then(updateLockBanner)
        ]);
      });
    }

    // Set up 10-second polling interval
    const polling = setInterval(async () => {
      await Promise.all([
        fetchDisponibilidad(),
        fetchLockStatus().then(updateLockBanner)
      ]);
    }, 10000);

    // Close dropdowns on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        document.querySelectorAll(".dropdown.dropdown-open").forEach((d) => {
          d.classList.remove("dropdown-open");
        });
      }
    });

    // Lock heartbeat cada 2 minutos
    const LOCK_HEARTBEAT_MS = 2 * 60 * 1000;
    let heartbeatInterval: any = null;

    const startHeartbeat = () => {
      if (heartbeatInterval) clearInterval(heartbeatInterval);
      heartbeatInterval = setInterval(async () => {
        try {
          const res = await fetch("/api/disponibilidad/lock/heartbeat", { method: "POST" });
          if (res.ok) {
            lockExpiresAt = Date.now() + lockTimeoutMs;
          } else {
            console.warn("Heartbeat failed, lock might have been lost");
          }
        } catch (err) {
          console.error("Heartbeat error:", err);
        }
      }, LOCK_HEARTBEAT_MS);
    };

    const stopHeartbeat = () => {
      if (heartbeatInterval) {
        clearInterval(heartbeatInterval);
        heartbeatInterval = null;
      }
    };

    // Event delegation on #lock-banner
    const bannerEl = document.getElementById("lock-banner");
    if (bannerEl) {
      bannerEl.addEventListener("click", async (e) => {
        const target = e.target as HTMLElement;

        // Acquire lock
        const acquireLockBtn = target.closest("#btn-acquire-lock") as HTMLButtonElement | null;
        if (acquireLockBtn) {
          acquireLockBtn.setAttribute("disabled", "true");
          acquireLockBtn.innerText = "Adquiriendo...";
          try {
            const res = await fetch("/api/disponibilidad/lock", { method: "POST" });
            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              showAlert("error", data.error || "No se pudo adquirir el control");
              const lockStatus = await fetchLockStatus();
              if (lockStatus) updateLockBanner(lockStatus);
            }
          } catch (err: any) {
            showAlert("error", "Error al adquirir el control");
            const lockStatus = await fetchLockStatus();
            if (lockStatus) updateLockBanner(lockStatus);
          }
          return;
        }

        // Release lock
        const releaseLockBtn = target.closest("#btn-release-lock") as HTMLButtonElement | null;
        if (releaseLockBtn) {
          releaseLockBtn.setAttribute("disabled", "true");
          try {
            const res = await fetch("/api/disponibilidad/lock", { method: "DELETE" });
            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              showAlert("error", data.error || "No se pudo liberar el control");
              const lockStatus = await fetchLockStatus();
              if (lockStatus) updateLockBanner(lockStatus);
            }
          } catch (err: any) {
            showAlert("error", "Error al liberar el control");
            const lockStatus = await fetchLockStatus();
            if (lockStatus) updateLockBanner(lockStatus);
          }
          return;
        }

        // Request release
        const requestReleaseBtn = target.closest("#btn-request-release") as HTMLButtonElement | null;
        if (requestReleaseBtn) {
          requestReleaseBtn.setAttribute("disabled", "true");
          requestReleaseBtn.innerText = "Enviando...";
          try {
            const res = await fetch("/api/disponibilidad/lock/request-release", { method: "POST" });
            if (res.ok) {
              requestReleaseBtn.innerText = "Solicitud enviada";
              const lockStatus = await fetchLockStatus();
              if (lockStatus) updateLockBanner(lockStatus);
            } else {
              showAlert("error", "No se pudo enviar la solicitud");
              const lockStatus = await fetchLockStatus();
              if (lockStatus) updateLockBanner(lockStatus);
            }
          } catch (err: any) {
            showAlert("error", "Error al solicitar liberación");
            const lockStatus = await fetchLockStatus();
            if (lockStatus) updateLockBanner(lockStatus);
          }
          return;
        }
      });
    }

    // Initial fetch of lock status immediately
    fetchLockStatus().then(updateLockBanner);

    // Release lock on page unload using fetch with keepalive: true
    window.addEventListener("beforeunload", () => {
      const currentBanner = document.getElementById("lock-banner");
      if (currentBanner && currentBanner.classList.contains("bg-success/10")) {
        fetch("/api/disponibilidad/lock", { method: "DELETE", keepalive: true });
      }
    });

    // Run first UI update visibility check
    updateVisibility();

    return true;
  };

  // Wait for dynamic server island component initialization
  if (!init()) {
    const checkReady = setInterval(() => {
      if (init()) {
        clearInterval(checkReady);
      }
    }, 50);
  }
</script>

<style is:global>
  [data-queue-item] {
    position: absolute;
    transition: top 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease-out;
  }
</style>
