          target.closest("input") ||
          target.closest("button") ||
          target.closest(".avatar")
        ) {
          return;
        }
        toggleDetails();
      });

      const handleEdit = (field: string, value: any) => {
        if (!pendingEdits[agentId]) {
          pendingEdits[agentId] = { agentId };
        }

        pendingEdits[agentId][field] = value;

        if (field === "entradaReal" || field === "cumplimiento") {
          const edit = pendingEdits[agentId];
          const curEntrada =
            edit.entradaReal !== undefined ? edit.entradaReal : op.entradaReal;

          if (field === "cumplimiento") {
            if (value === "") {
              edit.cumplimientoForzado = false;
              edit.cumplimiento = calculateCompliance(
                curEntrada,
                op.horarioEstipulado,
              );
            } else {
              edit.cumplimientoForzado = true;
              edit.cumplimiento = value;
            }
          } else {
            const curForced =
              edit.cumplimientoForzado !== undefined
                ? edit.cumplimientoForzado
                : op.cumplimientoForzado;
            if (!curForced) {
              edit.cumplimiento = calculateCompliance(
                curEntrada,
                op.horarioEstipulado,
              );
            }
          }

          const badge = document.getElementById(`badge-cump-${agentId}`);
          if (badge) {
            const finalCump = edit.cumplimiento;
            badge.textContent = complianceLabels[finalCump] || finalCump;
            badge.className = `badge badge-sm py-2 px-3 rounded-lg text-tiny whitespace-nowrap ${complianceClasses[finalCump] || "badge-ghost"}`;
          }
        }

        const edit = pendingEdits[agentId];
        let changed = false;

        const fieldsToCheck = [
          "asistencia",
          "ausencia",
          "entradaReal",
          "cumplimiento",
          "cumplimientoForzado",
          "motivoLoguin",
          "detalle",
        ];
        fieldsToCheck.forEach((f) => {
          if (edit[f] !== undefined && edit[f] !== op[f]) {
            changed = true;
          }
        });

        if (!changed) {
          delete pendingEdits[agentId];
        }

        updateToolbar();
      };

      selectAsistencia.addEventListener("change", (e) => {
        const target = e.target as HTMLSelectElement;
        handleEdit("asistencia", target.value);
        updateSelectColor(target, "asistencia");
      });
      selectAusencia.addEventListener("change", (e) => {
        const target = e.target as HTMLSelectElement;
        handleEdit("ausencia", target.value);
        updateSelectColor(target, "ausencia");
      });
      inputMotivo.addEventListener("input", (e) => {
        const target = e.target as HTMLInputElement;
        handleEdit("motivoLoguin", target.value);
      });
      inputDetalle.addEventListener("input", (e) => {
        const target = e.target as HTMLTextAreaElement;
        handleEdit("detalle", target.value);
      });

      const formatTimeInput = (input: HTMLInputElement, field: string) => {
        let val = input.value.replace(/[^0-9]/g, "");
        if (val.length >= 2) {
          val = val.slice(0, 2) + ":" + val.slice(2, 4);
        }
        input.value = val;
        handleEdit(field, val);
      };

      inputEntrada.addEventListener("input", () =>
        formatTimeInput(inputEntrada, "entradaReal"),
      );

      selectCumplimiento.addEventListener("change", (e) => {
        const target = e.target as HTMLSelectElement;
        handleEdit("cumplimiento", target.value);
      });
    });
  }

  function updateToolbar() {
    const editCount = Object.keys(pendingEdits).length;
    if (editCount > 0) {
      if (pendingCountText)
        pendingCountText.textContent = `${editCount} operador(es) con modificaciones pendientes.`;
      saveToolbar?.classList.remove(
        "translate-y-32",
        "opacity-0",
        "pointer-events-none",
      );
    } else {
      saveToolbar?.classList.add(
        "translate-y-32",
        "opacity-0",
        "pointer-events-none",
      );
    }
  }

  function formatToDDMMYYYY(dateStr: string): string {
    if (!dateStr) return "";
    const parts = dateStr.split("-");
    if (parts.length === 3) {
      return `${parts[2]}-${parts[1]}-${parts[0]}`;
    }
    return dateStr;
  }

  dateInput?.addEventListener("change", (e) => {
    const target = e.target as HTMLInputElement;
    selectedDate = target.value;
    if (dateDisplay) dateDisplay.textContent = formatToDDMMYYYY(selectedDate);
    if (dayOfWeekLabel)
      dayOfWeekLabel.textContent = getSpanishDayName(selectedDate);
    fetchAttendance(selectedDate);
  });

  dateInput?.addEventListener("click", () => {
    try {
      dateInput.showPicker();
    } catch (err) {
      console.warn(
        "dateInput.showPicker() is not supported by this browser.",
        err,
      );
    }
  });

  tableBody?.querySelectorAll(".toggle-row-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const agentId = target.dataset.agentId;
        const detailsRow = document.getElementById(`details-row-${agentId}`);
        const icon = target.querySelector("svg");

        if (detailsRow) {
          detailsRow.classList.toggle("hidden");
          target.classList.toggle("bg-base-200");
          if (icon) {
            if (detailsRow.classList.contains("hidden")) {
              icon.innerHTML = '<polyline points="6 9 12 15 18 9"></polyline>';
            } else {
              icon.innerHTML =
                '<polyline points="18 15 12 9 6 15"></polyline>';
            }
          }
        }
      });
    });

    document.querySelectorAll(".dropdown-content").forEach((dropdown) => {
      dropdown.addEventListener("click", (e) => {
        e.stopPropagation();
      });
    });

  // Set up checkbox filters behavior
  document.querySelectorAll('input.checkbox[data-filter-col]').forEach(cb => {
    cb.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      const col = target.getAttribute('data-filter-col');
      const isAll = target.value === 'all';
      
      const allCb = document.querySelector(`input[data-filter-col="${col}"][value="all"]`) as HTMLInputElement;
      const specificCbs = document.querySelectorAll(`input[data-filter-col="${col}"]:not([value="all"])`);

      if (isAll) {
        if (target.checked) {
          specificCbs.forEach(c => (c as HTMLInputElement).checked = false);
        } else {
          target.checked = true;
        }
      } else {
        if (target.checked) {
          if (allCb) allCb.checked = false;
        } else {
          const anyChecked = Array.from(specificCbs).some(c => (c as HTMLInputElement).checked);
          if (!anyChecked && allCb) {
            allCb.checked = true;
          }
        }
      }
      
      renderTable();
    });
  });

  const clearFiltersBtn = document.getElementById("clear-filters-btn");
  if (clearFiltersBtn) {
    clearFiltersBtn.addEventListener('click', () => {
      document.querySelectorAll('input.checkbox[data-filter-col]').forEach(cb => {
        const checkbox = cb as HTMLInputElement;
        if (checkbox.value === 'all') {
          checkbox.checked = true;
        } else {
          checkbox.checked = false;
        }
      });
      renderTable();
    });
  }

  searchInput?.addEventListener("input", renderTable);

  const updateSortUI = () => {
    document.querySelectorAll('#sort-menu button').forEach(btn => {
      const htmlBtn = btn as HTMLButtonElement;
      if (htmlBtn.dataset.sort === currentSort || 
         (currentSort === 'alpha' && htmlBtn.dataset.sort === 'alpha-asc') ||
         (currentSort === 'sede' && htmlBtn.dataset.sort === 'sede-pp')) {
        htmlBtn.classList.add('active');
        const label = document.getElementById('current-sort-label');
        if (label) label.textContent = `Ordenar: ${htmlBtn.textContent}`;
      } else {
        htmlBtn.classList.remove('active');
      }
    });
  };

  document.querySelectorAll('#sort-menu button').forEach(btn => {
    btn.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const newSort = target.dataset.sort;
      if (newSort) {
        currentSort = newSort;
        localStorage.setItem("asistenciaActiveSort", newSort);
        updateSortUI();
        renderTable();
        (document.activeElement as HTMLElement)?.blur();
      }
    });
  });

  updateSortUI();

  function cleanCsvCell(value: any) {
    if (value === null || value === undefined) return '""';
    let str = String(value);
    str = str.replace(/\r?\n|\r/g, " ");
    str = str.replace(/"/g, '""');
    return `"${str}"`;
  }

  exportCsvBtn?.addEventListener("click", () => {
    if (renderedData.length === 0) {
      showGlobalToast("No hay datos cargados para exportar.", "alert-error");
      return;
    }

    const headers = [
      "Fecha",
      "Operador",
      "Sede",
      "Asistencia Real",
      "Ausencia/Eventualidad",
      "Horario Estipulado",
      "Entrada Real",
      "Cumplimiento",
      "Motivo Login",
      "Detalle/Comentario",
    ];

    let csvRows = [];
    csvRows.push(headers.join(","));

    renderedData.forEach((op) => {
      const row = [
        op.date,
        op.nombre,
        op.location,
        op.asistencia,
        op.ausencia || "NINGUNA",
        op.horarioEstipulado || "Franco",
        op.entradaReal || "--:--",
        op.cumplimiento,
        op.motivoLoguin || "",
        op.detalle || "",
      ];

      const cleanRow = row.map((val) => cleanCsvCell(val));
      csvRows.push(cleanRow.join(","));
    });

    const csvContent = "\uFEFF" + csvRows.join("\n");
    const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);

    const link = document.createElement("a");
    link.setAttribute("href", url);

    const filename = `asistencia_${selectedDate}.csv`;

    link.setAttribute("download", filename);
    link.style.visibility = "hidden";
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    showGlobalToast("Archivo CSV descargado correctamente.", "alert-success");
  });

  discardBtn?.addEventListener("click", () => {
    pendingEdits = {};
    updateToolbar();
    renderTable();
    showGlobalToast("Cambios descartados.", "alert-info");
  });

  saveBtn?.addEventListener("click", async () => {
    const editCount = Object.keys(pendingEdits).length;
    if (editCount === 0) return;

    saveBtn.disabled = true;
    discardBtn.disabled = true;
    const originalText = saveBtn.innerHTML;
    saveBtn.innerHTML = `<span class="loading loading-spinner loading-xs"></span> Guardando...`;

    try {
      const editsArray = Object.values(pendingEdits);
      const response = await fetch(
        `${import.meta.env.BASE_URL || "/"}api/asistencia`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            date: selectedDate,
            edits: editsArray,
          }),
        },
      );

      const responseData = await response.json();
      if (!response.ok) throw new Error(responseData.error || "Failed to save");

      showGlobalToast(
        `¡Se guardaron los cambios de ${editCount} operador(es) correctamente!`,
        "alert-success",
      );
      pendingEdits = {};
      updateToolbar();
      await fetchAttendance(selectedDate);
    } catch (error: any) {
      console.error(error);
      showGlobalToast(
        error.message ||
          "Hubo un error al guardar los cambios en la base de datos.",
        "alert-error",
      );
    } finally {
      saveBtn.disabled = false;
      discardBtn.disabled = false;
      saveBtn.innerHTML = originalText;
    }
  });

  // Consumir datos iniciales pre-cargados
  const urlParams = new URLSearchParams(window.location.search);
  const queryDate = urlParams.get("date");
  const dateRegex = /^\d{4}-\d{2}-\d{2}$/;

  if (queryDate && dateRegex.test(queryDate)) {
    selectedDate = queryDate;
    if (dateInput) dateInput.value = queryDate;
  } else {
    selectedDate = dateInput?.value || "";
  }

  if (dateDisplay) dateDisplay.textContent = formatToDDMMYYYY(selectedDate);
  if (dayOfWeekLabel)
    dayOfWeekLabel.textContent = getSpanishDayName(selectedDate);

  const initWindow = window as any;
  if (
    initWindow.__ATTENDANCE_INITIAL_DATA__ &&
    initWindow.__ATTENDANCE_INITIAL_DATA_DATE__ === selectedDate
  ) {
    attendanceData = initWindow.__ATTENDANCE_INITIAL_DATA__;
    delete initWindow.__ATTENDANCE_INITIAL_DATA__;
    delete initWindow.__ATTENDANCE_INITIAL_DATA_DATE__;
    pendingEdits = {};
    updateToolbar();
    updateSortUI();
    renderTable();
  } else {
    updateSortUI();
    fetchAttendance(selectedDate);
  }
  // Close details dropdowns when clicking outside
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("details.dropdown")) {
      document.querySelectorAll("details.dropdown[open]").forEach((dropdown) => {
        dropdown.removeAttribute("open");
      });
    } else {
      const currentDropdown = target.closest("details.dropdown");
      document.querySelectorAll("details.dropdown[open]").forEach((dropdown) => {
        if (dropdown !== currentDropdown) {
          dropdown.removeAttribute("open");
        }
      });
    }
  });
</script>
