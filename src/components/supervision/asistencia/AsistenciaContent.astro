      let cumplimiento = edit.cumplimiento !== undefined ? edit.cumplimiento : op.cumplimiento;
      if (!cumplimientoForzado) {
        cumplimiento = calculateCompliance(entradaReal, op.horarioEstipulado);
      }

      // 3. Filtro de Asistencia
      if (asisFilters.length > 0) {
        if (!asisFilters.includes(asistencia)) return false;
