---
import { getCleanBase } from "@lib/baseUrl";
import { Icon } from "astro-icon/components";
import SearchBar from "@components/ui/SearchBar.astro";
import { getAttendanceData } from "@lib/attendance";

const cleanBase = getCleanBase();

// Define current date string YYYY-MM-DD in Argentina timezone
const todayStr = new Date().toLocaleDateString("en-CA", { timeZone: "America/Argentina/Buenos_Aires" });
const [y, m, d] = todayStr.split("-");

const urlDate = Astro.url.searchParams.get("date");
const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
const defaultDate =
  urlDate && dateRegex.test(urlDate) ? urlDate : `${y}-${m}-${d}`;

const formattedDefaultDate = (() => {
  const parts = defaultDate.split("-");
  return `${parts[2]}-${parts[1]}-${parts[0]}`;
})();

const initialData = await getAttendanceData(defaultDate, defaultDate);
---

<script define:vars={{ initialData, defaultDate }}>
  window.__ATTENDANCE_INITIAL_DATA__ = initialData;
  window.__ATTENDANCE_INITIAL_DATA_DATE__ = defaultDate;
</script>

<div class="flex flex-col gap-6 w-full pb-24 animate-in fade-in duration-500">
  <!-- Filters bar -->
  <div
    class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-base-100 p-4 rounded-2xl border border-base-300 shadow-sm relative z-50"
  >
    <!-- Date Selector -->
    <div class="flex items-center gap-3">
      <div
        class="relative flex items-center gap-2 bg-base-200/50 px-4 py-2 rounded-xl border border-base-300 hover:border-secondary/40 transition-colors duration-200 focus-within:ring-2 focus-within:ring-secondary/20"
      >
        <Icon name="boxicons:calendar" size={18} class="text-base-content/40" />
        <span
          id="date-display"
          class="text-sm font-semibold tabular-nums text-base-content pointer-events-none"
        >
          {formattedDefaultDate}
        </span>
        <input
          type="date"
          id="attendance-date"
          value={defaultDate}
          class="absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none border-0 opacity-0"
          title="Seleccionar fecha"
        />
      </div>
      <span
        class="text-xs text-base-content/50 uppercase font-black tracking-wider"
        id="day-of-week-label"></span>
    </div>

    <!-- Search, Sort and Export Actions -->
    <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
      <SearchBar id="operator-search" placeholder="Buscar operador..." class="w-full sm:w-48" />

      <!-- Sort Dropdown -->
      <details class="dropdown dropdown-bottom dropdown-end w-full sm:w-auto">
        <summary class="btn btn-outline btn-sm border-base-300 text-base-content/75 hover:bg-base-200 rounded-xl px-4 flex items-center justify-between sm:justify-start gap-1.5 w-full sm:w-auto font-bold h-10 bg-base-100 shadow-sm list-none">
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="20" x2="12" y2="10"></line>
              <line x1="18" y1="20" x2="18" y2="4"></line>
              <line x1="6" y1="20" x2="6" y2="16"></line>
            </svg>
            <span id="current-sort-label">Ordenar: Alfabético (A-Z)</span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </summary>
        <ul class="dropdown-content z-[100] menu p-2 shadow-lg bg-base-100 rounded-xl w-60 border border-base-300 gap-1 text-xs font-semibold normal-case tracking-normal mt-1" id="sort-menu">
          <li><button type="button" data-sort="alpha-asc" class="active">Alfabético (A-Z)</button></li>
          <li><button type="button" data-sort="alpha-desc">Alfabético (Z-A)</button></li>
          <li class="pointer-events-none p-0"><div class="divider my-0 h-1"></div></li>
          <li><button type="button" data-sort="sede-mg">Sede (MG → PP)</button></li>
          <li><button type="button" data-sort="sede-pp">Sede (PP → MG)</button></li>
          <li class="pointer-events-none p-0"><div class="divider my-0 h-1"></div></li>
          <li><button type="button" data-sort="time-asc">Horario (Más temprano primero)</button></li>
          <li><button type="button" data-sort="time-desc">Horario (Más tarde primero)</button></li>
        </ul>
      </details>

      <!-- Estadísticas -->
      <a
        href={`${cleanBase}supervision/asistencia/estadisticas`}
        class="btn btn-outline btn-sm border-base-300 text-base-content/75 hover:bg-base-200 rounded-xl px-3 w-10 h-10 flex items-center justify-center shrink-0"
        title="Ver estadísticas y reportes mensuales"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-base-content/75"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="20" x2="18" y2="10"></line>
          <line x1="12" y1="20" x2="12" y2="4"></line>
          <line x1="6" y1="20" x2="6" y2="14"></line>
        </svg>
      </a>

      <!-- Exportar CSV -->
      <button
        type="button"
        id="export-csv-btn"
        class="btn btn-outline btn-sm border-base-300 text-base-content/75 hover:bg-base-200 rounded-xl px-4 flex items-center gap-1.5 w-full sm:w-auto font-bold h-10"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-base-content/75"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Exportar CSV
      </button>

      <!-- Limpiar Filtros -->
      <button
        type="button"
        id="clear-filters-btn"
        disabled
        class="btn btn-ghost btn-sm rounded-xl px-3 flex items-center gap-1.5 hidden md:flex font-bold h-10 opacity-50 cursor-not-allowed text-base-content/60"
        title="Limpiar filtros de cabecera"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        Limpiar Filtros
      </button>
    </div>
  </div>

  <!-- Main attendance table -->
  <div
    class="bg-base-100 rounded-2xl border border-base-300 shadow-md overflow-hidden relative z-0"
  >
    <div class="overflow-x-auto min-h-[300px]">
      <table
        class="w-full text-xs text-left border-collapse"
        id="attendance-table"
      >
        <thead
          class="bg-base-200/80 border-b border-base-300 font-bold uppercase tracking-wider text-base-content/60"
        >
          <tr>
            <th class="py-3.5 px-4 w-[28%] min-w-[180px]">Operador</th>
            <th class="py-3.5 px-3 w-[20%] min-w-[230px]">
              <div class="flex items-center gap-1">
                Asistencia Real
                <details class="dropdown dropdown-bottom">
                  <summary class="btn btn-ghost btn-xs btn-circle text-base-content/50 hover:text-base-content list-none" title="Filtrar">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                  </summary>
                  <div class="dropdown-content z-[100] p-2 shadow-lg bg-base-100 rounded-xl w-64 border border-base-300 flex flex-col gap-1 text-xs font-normal normal-case tracking-normal mt-1">
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="asistencia" value="all" checked />
                      <span>Todos</span>
                    </label>
                    <div class="divider my-0 h-1"></div>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="asistencia" value="HOME OFFICE" />
                      <span>HOME OFFICE</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="asistencia" value="PRESENCIAL MONTE GRANDE" />
                      <span>PRESENCIAL MONTE GRANDE</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="asistencia" value="PRESENCIAL PARQUE PATRICIOS" />
                      <span>PRESENCIAL PARQUE PATRICIOS</span>
                    </label>
                  </div>
                </details>
              </div>
            </th>
            <th class="py-3.5 px-3 w-[20%] min-w-[180px]">
              <div class="flex items-center gap-1">
                Ausencia / Eventualidad
                <details class="dropdown dropdown-bottom">
                  <summary class="btn btn-ghost btn-xs btn-circle text-base-content/50 hover:text-base-content list-none" title="Filtrar">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                  </summary>
                  <div class="dropdown-content z-[100] p-2 shadow-lg bg-base-100 rounded-xl w-60 border border-base-300 flex flex-col gap-1 text-xs font-normal normal-case tracking-normal max-h-64 overflow-y-auto mt-1">
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="all" checked />
                      <span>Todos</span>
                    </label>
                    <div class="divider my-0 h-1"></div>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="SIN EVENTUALIDAD" />
                      <span>SIN EVENTUALIDAD</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Tramite" />
                      <span>Tramite</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Demorado" />
                      <span>Demorado</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Se reporta enfermo" />
                      <span>Se reporta enfermo</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Ausente Justificado" />
                      <span>Ausente Justificado</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Ausente con Permiso" />
                      <span>Ausente con Permiso</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Ausente No Justificado" />
                      <span>Ausente No Justificado</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Ausencia sin aviso" />
                      <span>Ausencia sin aviso</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Estudio" />
                      <span>Lic. Estudio</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Medica" />
                      <span>Lic. Medica</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Anual" />
                      <span>Lic. Anual</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. UI" />
                      <span>Lic. UI</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Gremial" />
                      <span>Lic. Gremial</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Paternidad" />
                      <span>Lic. Paternidad</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Maternidad" />
                      <span>Lic. Maternidad</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="Lic. Fallecimiento" />
                      <span>Lic. Fallecimiento</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="ausencia" value="ART" />
                      <span>ART</span>
                    </label>
                  </div>
                </details>
              </div>
            </th>
            <th class="py-3.5 px-3 w-[12%] min-w-[100px] text-center">Horario Estipulado</th>
            <th class="py-3.5 px-3 w-[10%] min-w-[80px] text-center">Entrada Real</th>
            <th class="py-3.5 px-3 w-[10%] min-w-[110px] text-center">
              <div class="flex items-center justify-center gap-1">
                Cumplimiento
                <details class="dropdown dropdown-bottom dropdown-end">
                  <summary class="btn btn-ghost btn-xs btn-circle text-base-content/50 hover:text-base-content list-none" title="Filtrar">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                  </summary>
                  <div class="dropdown-content z-[100] p-2 shadow-lg bg-base-100 rounded-xl w-52 border border-base-300 flex flex-col gap-1 text-xs font-normal normal-case tracking-normal mt-1 text-left">
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="all" checked />
                      <span>Todos</span>
                    </label>
                    <div class="divider my-0 h-1"></div>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="Cumplió" />
                      <span>Cumplió</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="Incumplió" />
                      <span>Incumplió</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="Llegada Tarde" />
                      <span>Llegada Tarde</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="Retiro Anticipado" />
                      <span>Retiro Anticipado</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="Tarde y Retiro Anticipado" />
                      <span>Tarde y R. Antic.</span>
                    </label>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-base-200 rounded-lg cursor-pointer">
                      <input type="checkbox" class="checkbox checkbox-xs" data-filter-col="cumplimiento" value="Sin Registro" />
                      <span>Sin Registro</span>
                    </label>
                  </div>
                </details>
              </div>
            </th>
          </tr>
        </thead>
        <tbody id="attendance-table-body" class="divide-y divide-base-200">
          <tr>
            <td colspan="6" class="py-12 text-center text-base-content/40">
              <span class="loading loading-spinner loading-md"></span>
              <p class="mt-2 font-medium">Cargando registros...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Floating Save Toolbar -->
<div
  id="save-toolbar"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-base-100/95 backdrop-blur-xl rounded-2xl shadow-[0_12px_40px_rgba(0,0,0,0.15)] border border-base-300 p-3.5 flex items-center justify-between gap-6 z-100 transition-all duration-300 translate-y-32 opacity-0 pointer-events-none w-[90%] max-w-2xl"
>
  <div class="flex items-center gap-3">
    <div
      class="w-8 h-8 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20 animate-pulse"
    >
      <Icon name="boxicons:save" size={18} />
    </div>
    <div>
      <h4 class="text-xs font-black text-base-content uppercase tracking-wider">
        Cambios sin guardar
      </h4>
      <p id="pending-count-text" class="text-xxs text-base-content/60">
        0 modificaciones pendientes.
      </p>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <button
      type="button"
      id="discard-btn"
      class="btn btn-sm btn-outline border-base-300 text-base-content/60 hover:bg-base-200 rounded-lg px-4"
    >
      Descartar
    </button>
    <button
      type="button"
      id="save-btn"
      class="btn btn-sm btn-primary rounded-lg px-5 shadow-lg shadow-primary/10 flex items-center gap-1.5"
    >
      <span id="save-btn-text">Guardar Cambios</span>
    </button>
  </div>
</div>

<script>
  let attendanceData: any[] = [];
  let renderedData: any[] = [];
  let pendingEdits: Record<number, any> = {};
  let selectedDate = "";
  let currentSort = (() => {
    try {
      return localStorage.getItem("asistenciaActiveSort") || "alpha-asc";
    } catch {
      return "alpha-asc";
    }
  })();

  const dateInput = document.getElementById(
    "attendance-date",
  ) as HTMLInputElement;
  const serverToday = dateInput.defaultValue || dateInput.value;
  const currentYear = parseInt(serverToday.substring(0, 4));
  const dateDisplay = document.getElementById("date-display");
  const dayOfWeekLabel = document.getElementById("day-of-week-label");
  const searchInput = document.getElementById(
    "operator-search",
  ) as HTMLInputElement;
  const sortAlphaBtn = document.getElementById("sort-alpha-btn");
  const sortSedeBtn = document.getElementById("sort-sede-btn");
  const exportCsvBtn = document.getElementById("export-csv-btn");
  const tableBody = document.getElementById("attendance-table-body");
  const saveToolbar = document.getElementById("save-toolbar");
  const pendingCountText = document.getElementById("pending-count-text");
  const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
  const discardBtn = document.getElementById(
    "discard-btn",
  ) as HTMLButtonElement;

  const asistenciaOptions = [
    "HOME OFFICE",
    "PRESENCIAL MONTE GRANDE",
    "PRESENCIAL PARQUE PATRICIOS",
  ];

  const ausenciaOptions = [
    { value: "", label: "SIN EVENTUALIDAD" },
    { value: "Tramite", label: "Tramite" },
    { value: "Demorado", label: "Demorado" },
    { value: "Se reporta enfermo", label: "Se reporta enfermo" },
    { value: "Ausente Justificado", label: "Ausente Justificado" },
    { value: "Ausente con Permiso", label: "Ausente con Permiso" },
    { value: "Ausente No Justificado", label: "Ausente No Justificado" },
    { value: "Ausencia sin aviso", label: "Ausencia sin aviso" },
    { value: "Lic. Estudio", label: "Lic. Estudio" },
    { value: "Lic. Medica", label: "Lic. Medica" },
    { value: "Lic. Anual", label: "Lic. Anual" },
    { value: "Lic. UI", label: "Lic. UI" },
    { value: "Lic. Gremial", label: "Lic. Gremial" },
    { value: "Lic. Paternidad", label: "Lic. Paternidad" },
    { value: "Lic. Maternidad", label: "Lic. Maternidad" },
    { value: "Lic. Fallecimiento", label: "Lic. Fallecimiento" },
    { value: "ART", label: "ART" },
  ];

  const complianceLabels: Record<string, string> = {
    Cumplió: "Cumplió",
    Incumplió: "Incumplió",
    "Llegada Tarde": "Llegada Tarde",
    "Retiro Anticipado": "Retiro Anticipado",
    "Tarde y Retiro Anticipado": "Tarde y R. Antic.",
    "Sin Registro": "Sin Registro",
  };

  const complianceClasses: Record<string, string> = {
    Cumplió: "bg-success/15 text-success border border-success/30 font-bold",
    Incumplió:
      "bg-error/15 text-error border border-error/30 font-bold animate-pulse",
    "Llegada Tarde":
      "bg-warning/15 text-warning border border-warning/30 font-bold",
    "Retiro Anticipado":
      "bg-warning/15 text-warning border border-warning/30 font-bold",
    "Tarde y Retiro Anticipado":
      "bg-error/15 text-error border border-error/30 font-bold animate-pulse",
    "Sin Registro":
