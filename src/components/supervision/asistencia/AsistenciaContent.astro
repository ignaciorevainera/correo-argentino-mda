        const wA = getSedeWeight(a);
        const wB = getSedeWeight(b);
        if (wA !== wB) return wA - wB;
        return a.nombre.localeCompare(b.nombre);
      });
    } else if (currentSort === "sede-pp") {
      filtered.sort((a, b) => {
        const getSedeWeight = (op: any) => {
          const loc = (op.location || "").toLowerCase();
          if (loc.includes("parque patricios") || loc.includes("pp")) return 1;
          if (loc.includes("monte grande") || loc.includes("mg")) return 2;
          return 3;
