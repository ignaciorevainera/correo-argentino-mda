    const getActiveFilters = (col: string) => {
      const checkboxes = document.querySelectorAll(`input[data-filter-col="${col}"]:not([value="all"]):checked`);
      return Array.from(checkboxes).map(cb => (cb as HTMLInputElement).value);
    };

    const asisFilters = getActiveFilters('asistencia');
    const ausFilters = getActiveFilters('ausencia');
    const cumpFilters = getActiveFilters('cumplimiento');

    const clearBtn = document.getElementById('clear-filters-btn') as HTMLButtonElement | null;
    if (clearBtn) {
      const hasFilters = asisFilters.length > 0 || ausFilters.length > 0 || cumpFilters.length > 0;
      if (hasFilters) {
        clearBtn.disabled = false;
        clearBtn.classList.remove('opacity-50', 'cursor-not-allowed', 'text-base-content/60');
        clearBtn.classList.add('text-error', 'hover:bg-error/15', 'bg-error/5');
      } else {
        clearBtn.disabled = true;
        clearBtn.classList.add('opacity-50', 'cursor-not-allowed', 'text-base-content/60');
        clearBtn.classList.remove('text-error', 'hover:bg-error/15', 'bg-error/5');
      }
    }

    let filtered = attendanceData.filter((op) => {
