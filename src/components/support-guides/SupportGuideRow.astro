---
import { Icon } from "astro-icon/components";
import ActionEditButton from "@/components/ui/ActionEditButton.astro";
import ActionDeleteButton from "@/components/ui/ActionDeleteButton.astro";
import ActionInfoButton from "@/components/ui/ActionInfoButton.astro";
import { isAllowed } from "@lib/rolesMatrix";

interface Props {
  guide: any;
}

const { guide } = Astro.props;
const user = Astro.locals.user;
const isAllowedAdmin = user
  ? isAllowed("Administrar Contenido", user.role)
  : false;
let topicsList: string[] = [];
if (guide.topics) {
  try {
    const parsed = JSON.parse(guide.topics);
    topicsList = Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof guide.topics === "string") {
      topicsList = guide.topics
        .split(",")
        .map((t: string) => t.trim())
        .filter(Boolean);
    }
  }
}

const searchText = `${guide.helpDeskName || ""} ${guide.invgateName || ""} ${guide.route || ""} ${topicsList.join(" ")}`;
const rowGridClass =
  "grid grid-cols-[1fr_1.1fr_2.2fr_1.2fr_150px] items-start gap-4";
const modalId = `modal_guide_${guide.id}`;
---

<article
  data-table-row
  data-master-detail-sort-item
  data-search-text={searchText}
  data-sort-legacy={guide.legacyName || ""}
  data-sort-invgate={guide.invgateName || ""}
  class="block"
>
  <div
    class:list={[
      rowGridClass,
      "border-b border-base-300 px-4 py-4 transition-colors hover:bg-base-200/50 group",
    ]}
  >
    <!-- Nombre Anterior -->
    <div class="min-w-0">
      {
        guide.legacyName ? (
          <span
            class="font-bold text-sm text-base-content/95"
            data-highlight-target
          >
            {guide.legacyName}
          </span>
        ) : (
          <span class="text-base-content/30 text-xs italic">N/A</span>
        )
      }
    </div>

    <!-- Invgate -->
    <div class="min-w-0 flex items-center">
      {
        guide.invgateName ? (
          <span
            class="px-2 py-0.5 bg-secondary text-white rounded text-xs font-bold shadow-sm inline-block break-all"
            data-highlight-target
          >
            {guide.invgateName}
          </span>
        ) : (
          <span class="text-base-content/30 text-xs italic">N/A</span>
        )
      }
    </div>

    <!-- Ruta -->
    <div class="min-w-0">
      {
        guide.route ? (
          <p
            class="text-base-content/70 font-mono text-xs wrap-break-word whitespace-normal"
            data-highlight-target
          >
            {guide.route}
          </p>
        ) : (
          <span class="text-base-content/30 italic text-xs">Sin ruta</span>
        )
      }
    </div>

    <!-- Temas -->
    <div class="min-w-0">
      <div class="flex flex-wrap gap-1.5">
        {
          topicsList.length > 0 ? (
            topicsList.map((tema: string) => (
              <span
                class="px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded border border-secondary/20 font-medium wrap-break-word text-center"
                data-highlight-target
              >
                {tema}
              </span>
            ))
          ) : (
            <span class="text-base-content/30 italic text-xs">Sin tópicos</span>
          )
        }
      </div>
    </div>

    <!-- Acciones -->
    <div class="min-w-0 flex items-start justify-end gap-2">
      <ActionInfoButton
        onclick={`document.getElementById('${modalId}').showModal()`}
        ariaLabel={`Más información sobre ${guide.helpDeskName}`}
      />
      {
        isAllowedAdmin && (
          <>
            <ActionEditButton
              href={`${import.meta.env.BASE_URL}soportes/edit/${guide.id}`}
              ariaLabel={`Editar soporte ${guide.helpDeskName}`}
            />
            <form
              method="POST"
              action={`${import.meta.env.BASE_URL}soportes/edit/${guide.id}/eliminar`}
              class="inline"
              onsubmit={`return confirm('¿Estás seguro de que deseas eliminar el soporte "${guide.helpDeskName}"?');`}
            >
              <ActionDeleteButton
                ariaLabel={`Eliminar soporte ${guide.helpDeskName}`}
              />
            </form>
          </>
        )
      }
    </div>
  </div>
</article>

<!-- Modal -->
<dialog id={modalId} class="modal modal-bottom sm:modal-middle">
  <div class="modal-box bg-base-100 border-t-4 border-t-secondary shadow-xl">
    <h3
      class="font-black text-lg text-base-content flex items-center gap-2 mb-4"
    >
      <Icon name="boxicons:buoy-filled" class="size-6 text-secondary" />
      {guide.helpDeskName}
    </h3>

    <div class="space-y-4 text-sm text-base-content/80">
      <!-- Contactos -->
      <div class="bg-base-200/50 p-3 rounded-lg border border-base-300">
        <h4 class="font-bold flex items-center gap-1 mb-1 text-base-content/90">
          <Icon name="boxicons:phone" class="size-4 text-secondary" />
          Contactos
        </h4>
        <p class="whitespace-pre-wrap">
          {
            guide.contacts || (
              <span class="italic text-base-content/50">
                Sin información de contactos
              </span>
            )
          }
        </p>
      </div>

      <!-- Referentes -->
      <div class="bg-base-200/50 p-3 rounded-lg border border-base-300">
        <h4 class="font-bold flex items-center gap-1 mb-1 text-base-content/90">
          <Icon name="boxicons:user-filled" class="size-4 text-secondary" />
          Referentes
        </h4>
        <p class="whitespace-pre-wrap">
          {
            guide.referents || (
              <span class="italic text-base-content/50">
                Sin referentes designados
              </span>
            )
          }
        </p>
      </div>

      <!-- Notas -->
      <div class="bg-base-200/50 p-3 rounded-lg border border-base-300">
        <h4 class="font-bold flex items-center gap-1 mb-1 text-base-content/90">
          <Icon name="boxicons:note" class="size-4 text-secondary" />
          Notas
        </h4>
        <p class="whitespace-pre-wrap">
          {
            guide.notes || (
              <span class="italic text-base-content/50">
                Sin notas adicionales
              </span>
            )
          }
        </p>
      </div>
    </div>

    <div class="modal-action">
      <form method="dialog">
        <!-- if there is a button in form, it will close the modal -->
        <button class="btn btn-sm">Cerrar</button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
