---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
---

<PageContainer width="xl">
  <div class="skeleton-debounced">
    <PageHeader
      description="Descarga herramientas de operatoria diaria de mesa de ayuda en formato paquete .zip o por aplicativo individual según tu necesidad."
    />

    <!-- Bundle Banner Skeleton -->
    <div class="h-32 w-full skeleton rounded-2xl mb-8"></div>

    <!-- Folders & Cards Skeleton -->
    <div class="space-y-8 mt-4">
      {Array.from({ length: 2 }).map(() => (
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <div class="size-5 skeleton rounded"></div>
            <div class="h-5 w-40 skeleton rounded"></div>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {Array.from({ length: 3 }).map(() => (
              <div class="card bg-base-100 border border-base-300 p-6 rounded-2xl h-44 flex flex-col justify-between">
                <div class="space-y-2">
                  <div class="h-5 w-32 skeleton rounded"></div>
                  <div class="h-3 w-full skeleton rounded"></div>
                  <div class="h-3 w-3/4 skeleton rounded"></div>
                </div>
                <div class="flex justify-between items-center mt-4">
                  <div class="h-4 w-16 skeleton rounded"></div>
                  <div class="h-8 w-24 skeleton rounded"></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</PageContainer>
