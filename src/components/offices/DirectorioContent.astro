---
import { Icon } from "astro-icon/components";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import MasterDetailTable from "@components/ui/MasterDetailTable.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import ViewSwitcher from "@components/ui/ViewSwitcher.astro";
import FilterTabsBox from "@components/ui/FilterTabsBox.astro";
import SearchEmptyState from "@components/ui/SearchEmptyState.astro";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ExportCsvButton from "@components/ui/ExportCsvButton.astro";
import { getOffices } from "@lib/officeQueries";
import OfficeRow from "@components/offices/OfficeRow.astro";
import Modal from "@components/ui/Modal.astro";
import {
  officeTypeLabelByType,
  officeTypeTabActiveClassByType,
  formatTypeLabel,
} from "@lib/officeHelpers";
import { db } from "@db/index";
import { provinces, regions, offices } from "@db/schema";
import { eq, sql } from "drizzle-orm";
import { getResolvedSearchParams } from "@lib/navigation";
import { isAllowed } from "@lib/rolesMatrix";
import { can } from "@lib/roleConfig";
import "leaflet/dist/leaflet.css";

const user = Astro.locals.user;
const isAllowedAdmin = user
  ? isAllowed("Administrar Contenido", user.role)
  : false;
const canViewInvgateStats = user ? can(user.role, "team_leader") : false;

const searchParams = getResolvedSearchParams(Astro.request, Astro.url);

const typeFilter = searchParams.get("type") || "all";
const regionFilter = searchParams.get("region") || "all";
let provinceFilter = searchParams.get("province") || "all";
const zoneFilter = searchParams.get("zone") || "all";
const paqarFilter = searchParams.get("paqar") || "all";
const hasParentFilter = searchParams.get("hasParent") === "true";
const isHeadquarterFilter = searchParams.get("isHeadquarter") === "true";
const searchFilter = searchParams.get("search") || "";

const allProvincesWithRegion = await db
  .select({
    code: provinces.code,
    name: provinces.name,
    regionId: provinces.regionId,
    regionName: regions.name,
  })
  .from(provinces)
  .leftJoin(regions, eq(provinces.regionId, regions.id))
  .orderBy(regions.name, provinces.name);

const provincesByRegion: Record<string, { code: string; name: string }[]> = {};
for (const p of allProvincesWithRegion) {
  const rName = p.regionName ?? "Sin región";
  if (!provincesByRegion[rName]) provincesByRegion[rName] = [];
  provincesByRegion[rName].push({ code: p.code, name: p.name });
}

if (regionFilter !== "all" && provinceFilter !== "all") {
  const regionProvinces = provincesByRegion[regionFilter] || [];
  if (!regionProvinces.find((p) => p.code === provinceFilter)) {
    provinceFilter = "all";
  }
} else if (regionFilter === "all") {
  provinceFilter = "all";
}

const sortBy = (searchParams.get("sortBy") || undefined) as
  | "code"
  | "name"
  | "parent-nis"
  | "address"
  | undefined;
const sortOrder = (searchParams.get("sortOrder") || undefined) as
  | "asc"
  | "desc"
  | undefined;

const { data: officeDirectoryItems, count: totalOffices, hasMore } = await getOffices({
  page: 1,
  limit: 100,
  type: typeFilter,
  region: regionFilter,
  province: provinceFilter,
  zone: zoneFilter,
  paqar: paqarFilter,
  hasParent: hasParentFilter,
  isHeadquarter: isHeadquarterFilter,
  search: searchFilter,
  sortBy,
  sortOrder,
});

const rawCounts = await db
  .select({
    type: offices.type,
    officeType: offices.officeType,
    count: sql<number>`count(*)`,
  })
  .from(offices)
  .groupBy(offices.type, offices.officeType);

const processedCounts: { type: string; count: number }[] = [];
let sucursalAutoCount = 0;
let sucursalNoAutoCount = 0;

for (const row of rawCounts) {
  if (!row.type) continue;
  if (row.type === "SUCURSAL") {
    if (row.officeType === "AUTOMATIZADA") {
      sucursalAutoCount += row.count;
    } else {
      sucursalNoAutoCount += row.count;
    }
  } else {
    const existing = processedCounts.find((p) => p.type === row.type);
    if (existing) {
      existing.count += row.count;
    } else {
      processedCounts.push({ type: row.type, count: row.count });
    }
  }
}

if (sucursalAutoCount > 0 || sucursalNoAutoCount > 0) {
  if (sucursalAutoCount > 0) {
    processedCounts.push({
      type: "SUCURSAL_AUTOMATIZADA",
      count: sucursalAutoCount,
    });
  }
  if (sucursalNoAutoCount > 0) {
    processedCounts.push({
      type: "SUCURSAL_NO_AUTOMATIZADA",
      count: sucursalNoAutoCount,
    });
  }
}

const officeCountByType = processedCounts.reduce(
  (acc, row) => {
    acc.all += row.count;
    acc[row.type] = row.count;
    return acc;
  },
  { all: 0 } as Record<string, number>,
);

processedCounts.forEach((row) => {
  if (row.type && !officeTypeLabelByType[row.type]) {
    officeTypeLabelByType[row.type] = formatTypeLabel(row.type);
  }
});

const officeTypeTabs = [
  { type: "all", label: "Todas" },
  ...processedCounts
    .sort((a, b) => b.count - a.count)
    .map((row) => ({
      type: row.type,
      label: officeTypeLabelByType[row.type] || formatTypeLabel(row.type),
    })),
];

const uniqueRegions = [
  ...new Set(
    allProvincesWithRegion
      .map((p) => p.regionName)
      .filter((r): r is string => Boolean(r)),
  ),
].sort((a, b) => a.localeCompare(b, "es", { sensitivity: "base" }));

const allRegions = await db.select().from(regions).orderBy(regions.name);

const allZonesRaw = await db
  .select({ zone: offices.zone })
  .from(offices)
  .where(sql`${offices.zone} IS NOT NULL AND ${offices.zone} != ''`)
  .groupBy(offices.zone);

const uniqueZones = allZonesRaw
  .map((z) => z.zone)
  .filter((z): z is string => Boolean(z))
  .sort((a, b) => a.localeCompare(b, "es", { numeric: true }));

const officeDirectoryHeaderGridClass = isAllowedAdmin
  ? "grid-cols-[48px_80px_1.2fr_90px_1.8fr_110px_120px] gap-4"
  : "grid-cols-[48px_80px_1.2fr_90px_1.8fr_110px] gap-4";

const mainTabs = [
  { label: "Directorio de Oficinas", value: "directory" },
  { label: "Mapa de Regiones", value: "map" },
];
---

<PageContainer width="xxl">
  <PageHeader
    description="Visualización centralizada de la infraestructura, buscador de oficinas y mapa interactivo de cobertura nacional."
  />

  <!-- Main View Switcher (Tabs) -->
  <ViewSwitcher
    tabs={mainTabs}
    activeValue="directory"
    name="main_view_tabs"
    id="main-view-switcher"
    class="w-full grid grid-cols-2"
    containerClass="w-full"
  />
  <!-- Contenedor de Directorio -->
  <div id="main-view-directory" class="space-y-6">
    <div id="provinces-data" data-provinces={JSON.stringify(provincesByRegion)} class="hidden"></div>
    <form
      method="GET"
      class="flex flex-col gap-4 rounded-box border border-base-300 bg-base-100 p-4 shadow-md"
      aria-label="Filtros del directorio"
    >
      <div class="w-full">
        <input type="hidden" name="type" id="filter-tabs-hidden-type" value={typeFilter} />
        <FilterTabsBox
          tabs={officeTypeTabs.map((tab) => ({
            value: tab.type,
            label: tab.label,
            count: officeCountByType[tab.type],
          }))}
          activeValue={typeFilter}
          name="type"
          activeClasses={officeTypeTabActiveClassByType}
          class="flex-wrap bg-base-200/50 p-2"
          submitOnChange={false}
        />
      </div>

      <div class="flex flex-wrap items-center gap-3 w-full">
        <div class="form-control grow">
          <select
            name="region"
            id="regionFilter"
            class="select border-base-300 w-full focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            aria-label="Filtrar por región"
          >
            <option value="all" selected={regionFilter === "all"}
              >Regiones (Todas)</option
            >
            {
              uniqueRegions.map((region) => (
                <option value={region} selected={regionFilter === region}>
                  {region}
                </option>
              ))
            }
          </select>
        </div>

        <div class="form-control grow">
          <select
            name="province"
            id="provinceFilter"
            class="select border-base-300 w-full focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            aria-label="Filtrar por provincia"
            disabled={regionFilter === "all"}
          >
            <option value="all" selected={provinceFilter === "all"}
              >Provincias (Todas)</option
            >
            {
              regionFilter !== "all" &&
                (provincesByRegion[regionFilter] || []).map((prov) => (
                  <option
                    value={prov.code}
                    selected={provinceFilter === prov.code}
                  >
                    {prov.name}
                  </option>
                ))
            }
          </select>
        </div>

        <div class="form-control grow">
          <select
            name="zone"
            id="zoneFilter"
            class="select border-base-300 w-full focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            aria-label="Filtrar por zona"
          >
            <option value="all" selected={zoneFilter === "all"}
              >Zonas (Todas)</option
            >
            {
              uniqueZones.map((zone) => (
                <option value={zone} selected={zoneFilter === zone}>
                  {zone}
                </option>
              ))
            }
          </select>
        </div>

        <div class="form-control grow">
          <select
            name="paqar"
            id="paqarFilter"
            class="select border-base-300 w-full focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            aria-label="Filtrar por servicios Paq.AR"
          >
            <option value="all" selected={paqarFilter === "all"}
              >Paq.AR (Todos)</option
            >
            <option value="admision" selected={paqarFilter === "admision"}
              >Admite Paq.AR</option
            >
            <option value="entrega" selected={paqarFilter === "entrega"}
              >Entrega Paq.AR</option
            >
            <option value="ambos" selected={paqarFilter === "ambos"}
              >Admite y Entrega</option
            >
          </select>
        </div>
        <div class="flex items-center gap-4 px-2">
          <label class="label cursor-pointer gap-2 p-0">
            <span class="label-text font-medium text-base-content/80 text-xs sm:text-sm">Depende de otra</span>
            <input type="checkbox" name="hasParent" value="true" class="toggle toggle-sm toggle-primary" checked={hasParentFilter} aria-label="Mostrar solo oficinas que dependen de otra" />
          </label>
          <label class="label cursor-pointer gap-2 p-0">
            <span class="label-text font-medium text-base-content/80 text-xs sm:text-sm">Solo Cabeceras</span>
            <input type="checkbox" name="isHeadquarter" value="true" class="toggle toggle-sm toggle-primary" checked={isHeadquarterFilter} aria-label="Mostrar solo oficinas cabecera" />
          </label>
        </div>
        <button
          type="button"
          id="clear-filters-btn"
          class="btn btn-outline btn-error font-semibold gap-2"
          aria-label="Limpiar todos los filtros"
          title="Limpiar todos los filtros"
        >
          <Icon name="boxicons:trash" class="size-4" />
          Limpiar filtros
        </button>
      </div>

      <div class="flex flex-wrap sm:flex-nowrap items-center gap-3 w-full">
        <div class="w-full">
          <SearchBar
            id="office-search"
            placeholder="Buscar por nombre, código, región o CP"
          />
        </div>
        <div class="badge badge-neutral badge-lg whitespace-nowrap">
          <Icon name="boxicons:eye-filled" size={16} />
          <span id="total-count-badge">{totalOffices} resultados</span>
        </div>
        <ExportCsvButton
          href={import.meta.env.BASE_URL + "api/export/offices"}
          ariaLabel="Exportar directorio a CSV"
        />
        {
          isAllowedAdmin && (
            <a
              href={`${import.meta.env.BASE_URL}oficinas/create`}
              class="btn btn-secondary font-semibold shadow-sm shrink-0 gap-2"
              aria-label="Registrar nueva oficina"
            >
              <Icon name="boxicons:plus" class="size-5" />
              <span class="hidden sm:inline">Registrar oficina</span>
              <span class="sm:hidden">Registrar</span>
            </a>
          )
        }
        {
          canViewInvgateStats && (
            <button id="sync-invgate-btn" type="button" class="btn btn-neutral btn-soft gap-2">
              <span id="sync-btn-text">Sincronizar ahora</span>
              <span id="sync-btn-spinner" class="loading loading-spinner loading-sm hidden"></span>
            </button>
          )
        }
      </div>
    </form>

    {
      canViewInvgateStats && (
        <div id="invgate-stats-bar" class="rounded-box border border-base-300 bg-base-100 p-4 shadow-md">
          <div id="stats-cards" class="flex flex-wrap items-center gap-4">
            <div class="card bg-base-100 shadow-sm border border-base-200 p-3 min-w-[140px]">
              <span class="text-xxs font-semibold uppercase tracking-wider text-base-content/60">Total MDA</span>
              <span id="stat-totalMda" class="text-xl font-bold mt-0.5 text-base-content">—</span>
            </div>
            <div class="card bg-base-100 shadow-sm border border-base-200 p-3 min-w-[140px]">
              <span class="text-xxs font-semibold uppercase tracking-wider text-base-content/60">Matcheadas</span>
              <span id="stat-matched" class="text-xl font-bold mt-0.5 text-success">—</span>
            </div>
            <div class="card bg-base-100 shadow-sm border border-base-200 p-3 min-w-[140px]">
              <span class="text-xxs font-semibold uppercase tracking-wider text-base-content/60">Solo en MDA</span>
              <span id="stat-unmatchedMda" class="text-xl font-bold mt-0.5 text-warning">—</span>
            </div>
            <div class="card bg-base-100 shadow-sm border border-base-200 p-3 min-w-[140px]">
              <span class="text-xxs font-semibold uppercase tracking-wider text-base-content/60">Solo en InvGate</span>
              <span id="stat-unmatchedInvgate" class="text-xl font-bold mt-0.5 text-error">—</span>
            </div>
            <a
              href={`${import.meta.env.BASE_URL}admin/invgate/ubicaciones?sync=true`}
              class="btn btn-primary btn-sm gap-1.5 ml-auto shrink-0"
            >
              <Icon name="boxicons:pie-chart-filled" size={16} />
              Ver comparativa
            </a>
          </div>
        </div>
      )
    }

    <div id="office-table-wrapper">
      <div
        id="office-table-container"
        class:list={[officeDirectoryItems.length === 0 && "hidden"]}
      >
        <MasterDetailTable
          ariaLabel="Directorio de oficinas"
          minWidthClass="min-w-280"
          headerGridClass={officeDirectoryHeaderGridClass}
          class="bg-base-100"
          serverSideSort={true}
        >
          <div slot="header">
            <DataTableHeaderCell>
              <span class="sr-only">Expandir detalle</span>
            </DataTableHeaderCell>
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="code"> Código </DataTableHeaderCell>
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="name">Nombre</DataTableHeaderCell>
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="parent-nis"
              >Dependencia</DataTableHeaderCell
            >
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="address"
              >Dirección</DataTableHeaderCell
            >
          </div>
          <div slot="header">
            <DataTableHeaderCell sortKey="cost-center"
              >CECO</DataTableHeaderCell
            >
          </div>
          {
            isAllowedAdmin && (
              <div slot="header">
                <DataTableHeaderCell>Acciones</DataTableHeaderCell>
              </div>
            )
          }
          {officeDirectoryItems.map((office) => <OfficeRow office={office} />)}
        </MasterDetailTable>
      </div>

      <SearchEmptyState
        id="no-results-state"
        class={officeDirectoryItems.length > 0 ? "hidden" : "flex"}
        title="No hay coincidencias"
        description="No hemos podido encontrar oficinas que coincidan con los filtros seleccionados. Probá modificando los criterios o restableciendo la búsqueda para explorar el directorio completo."
        showClearButton={true}
        clearButtonHref={import.meta.env.BASE_URL + "oficinas"}
        clearButtonText="Restablecer filtros"
      />

      <div
        id="scroll-sentinel"
        class:list={[
          "py-8 text-center flex justify-center",
          !hasMore && "hidden",
        ]}
        data-has-more={hasMore ? "true" : "false"}
      >
        <span
          class="loading loading-spinner loading-md text-primary hidden"
          id="loading-spinner"></span>
      </div>
    </div>
  </div>

  <!-- Contenedor de Mapa -->
  <div id="main-view-map" class="hidden space-y-6">
    <div id="views-wrapper" class="relative">
      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Vista Mapa -->
        <section
          id="view-map"
          class="flex-1 min-w-0 bg-base-100 rounded-xl shadow-lg border border-base-content/10 overflow-hidden relative z-0 transition-all duration-500"
        >
          <div
            id="map-loading"
            class="absolute inset-0 z-50 flex flex-col items-center justify-center bg-base-100/80 backdrop-blur-sm"
            style="display: none;"
          >
            <span class="loading loading-spinner loading-lg text-primary"
            ></span>
            <p class="mt-4 font-semibold text-base-content/70">
              Cargando datos geográficos...
            </p>
          </div>
          <div id="mapa-sucursales" class="h-[600px] w-full z-0 relative"></div>
        </section>

        <!-- Controles del Mapa -->
        <div id="map-controls" class="flex flex-col gap-2 shrink-0 lg:w-64 w-full">
          <div class="rounded-box border border-base-300 bg-base-200/30 p-3 flex flex-col gap-2">
            <label class="label cursor-pointer justify-start gap-3 p-0">
              <input
                type="checkbox"
                class="toggle toggle-primary toggle-sm"
                checked
                id="chk-polygons"
              />
              <span class="label-text font-medium text-xs">Regiones</span>
            </label>
            <label class="label cursor-pointer justify-start gap-3 p-0">
              <input
                type="checkbox"
                class="toggle toggle-primary toggle-sm"
                checked
                id="chk-labels"
              />
              <span class="label-text font-medium text-xs">Códigos</span>
            </label>
          </div>

          <div class="divider my-0"></div>

          <div id="map-legend" class="flex flex-col gap-2">
            {
              allRegions.map((r) => (
                <div
                  class="legend-item-group border border-base-300 rounded-lg bg-base-100 transition-colors duration-150 overflow-hidden"
                  data-region={r.name}
                >
                  <div class="legend-item flex items-center justify-between px-3 py-2 gap-2 cursor-pointer hover:bg-base-200/50 transition-colors">
                    <div class="flex items-center gap-3">
                      <span
                        class="size-4 rounded-sm shrink-0"
                        style={`background-color: ${r.color}`}
                      />
                      <span class="text-sm font-semibold">{r.name}</span>
                    </div>
                    <button
                      type="button"
                      class="inline-flex size-8 cursor-pointer items-center justify-center rounded-lg border border-base-300 bg-base-200 text-base-content/70 transition-colors hover:bg-base-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 btn-toggle-referents shrink-0"
                      data-region-id={r.id}
                      data-region-name={r.name}
                      aria-label="Ver tecnológicos regionales"
                      aria-expanded="false"
                    >
                      <Icon
                        name="boxicons:chevron-down-filled"
                        data-chevron-closed
                        size={16}
                      />
                      <Icon
                        name="boxicons:chevron-up-filled"
                        data-chevron-open
                        class="hidden"
                        size={16}
                      />
                    </button>
                  </div>
                  <div 
                    class="referents-collapse-content hidden px-3 pb-3 pt-1.5 border-t border-base-200 bg-base-200/20 text-xs" 
                    data-region-id={r.id} 
                  >
                    <div class="flex items-center justify-between border-b border-base-300 pb-1">
                      <span class="text-xs font-semibold text-base-content/50 uppercase tracking-wider">Tecnológicos</span>
                      {isAllowedAdmin && (
                        <ActionEditButton
                          class="btn-edit-region"
                          size="xs"
                          data-region-id={r.id}
                          ariaLabel={`Editar tecnológicos de ${r.name}`}
                        />
                      )}
                    </div>
                    <div class="referents-list-container flex flex-col gap-1.5 mt-2">
                      <!-- JS will inject the list here -->
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
  <Modal id="region-referents-modal" zIndex="z-9999" class="max-w-md shadow-xl">
    <Fragment slot="content">
      <form method="dialog">
        <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" aria-label="Cerrar modal">✕</button>
      </form>
      <div id="modal-region-content"></div>
    </Fragment>
  </Modal>
</PageContainer>

<script>
  import { highlightSearchTargets } from "@lib/clientSearch";
  import { showToast } from "@lib/toastClient";

  let regionsDataCache: any[] = [];

  const escapeHTML = (str: string) => {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  };

  const mainViewDir = document.getElementById("main-view-directory");
  const mainViewMap = document.getElementById("main-view-map");

  const tableRoot = document.querySelector<HTMLElement>(
    "[data-master-detail-table-root]",
  );
  const container = tableRoot?.querySelector<HTMLElement>(
    "[data-master-detail-table-body]",
  );
  const sentinel = document.getElementById("scroll-sentinel");
  const spinner = document.getElementById("loading-spinner");
  const noResultsState = document.getElementById("no-results-state");
  const searchInput =
    document.querySelector<HTMLInputElement>("#office-search");
  const form = document.querySelector<HTMLFormElement>("form");

  let currentPage = 1;
  let currentSearch = searchInput?.value.trim() || "";
  let isLoading = false;
  let hasMore = sentinel?.getAttribute("data-has-more") === "true";

  const urlParams = new URLSearchParams(window.location.search);
  let currentSortBy: string | null = urlParams.get("sortBy");
  let currentSortOrder: "asc" | "desc" | null =
    (urlParams.get("sortOrder") as "asc" | "desc") || null;



  const syncFiltersToURL = () => {
    const params = new URLSearchParams();
    if (form) {
      const formData = new FormData(form);
      for (const [key, value] of formData.entries()) {
        if (value && value !== "all" && key !== "search") {
          params.set(key, value.toString());
        }
      }
    }
    if (currentSearch) {
      params.set("search", currentSearch);
    }
    if (currentSortBy) {
      params.set("sortBy", currentSortBy);
      if (currentSortOrder) params.set("sortOrder", currentSortOrder);
    }
    const queryString = params.toString();
    const newUrl = `${window.location.pathname}${queryString ? "?" + queryString : ""}`;
    window.history.replaceState({}, "", newUrl);

    // Update export CSV href
    const exportBtn = document.getElementById("export-csv-btn") as HTMLAnchorElement | null;
    if (exportBtn) {
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      exportBtn.href = `${baseUrl}/api/export/offices${queryString ? "?" + queryString : ""}`;
    }
  };

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
  });

  // Dynamically handle region -> province mapping client-side
  const provincesContainer = document.getElementById("provinces-data");
  let provincesByRegion: Record<string, { code: string; name: string }[]> = {};
  if (provincesContainer && provincesContainer.dataset.provinces) {
    try {
      provincesByRegion = JSON.parse(provincesContainer.dataset.provinces);
    } catch (e) {
      console.error("Error parsing provinces data", e);
    }
  }

  const regionSelect = document.getElementById("regionFilter") as HTMLSelectElement | null;
  const provinceSelect = document.getElementById("provinceFilter") as HTMLSelectElement | null;
  const zoneSelect = document.getElementById("zoneFilter") as HTMLSelectElement | null;
  const paqarSelect = document.getElementById("paqarFilter") as HTMLSelectElement | null;
  const hasParentToggle = document.querySelector<HTMLInputElement>('input[name="hasParent"]');
  const isHeadquarterToggle = document.querySelector<HTMLInputElement>('input[name="isHeadquarter"]');
  const typeHiddenInput = document.getElementById("filter-tabs-hidden-type") as HTMLInputElement | null;
  const typeTabsContainer = document.querySelector(".filter-tabs-box");

  const handleFilterChange = () => {
    currentPage = 1;
    fetchOffices(true);
    syncFiltersToURL();
  };

  regionSelect?.addEventListener("change", () => {
    const region = regionSelect.value;
    if (provinceSelect) {
      if (region === "all") {
        provinceSelect.value = "all";
        provinceSelect.disabled = true;
        provinceSelect.innerHTML = '<option value="all">Provincias (Todas)</option>';
      } else {
        provinceSelect.disabled = false;
        const regionProvinces = provincesByRegion[region] || [];
        let htmlOptions = '<option value="all">Provincias (Todas)</option>';
        regionProvinces.forEach((p) => {
          htmlOptions += `<option value="${p.code}">${escapeHTML(p.name)}</option>`;
        });
        provinceSelect.innerHTML = htmlOptions;
        provinceSelect.value = "all";
      }
    }
    handleFilterChange();
  });

  provinceSelect?.addEventListener("change", handleFilterChange);
  zoneSelect?.addEventListener("change", handleFilterChange);
  paqarSelect?.addEventListener("change", handleFilterChange);
  hasParentToggle?.addEventListener("change", handleFilterChange);
  isHeadquarterToggle?.addEventListener("change", handleFilterChange);

  // Tab buttons click listeners
  if (typeTabsContainer) {
    const tabButtons = typeTabsContainer.querySelectorAll<HTMLButtonElement>('button[role="tab"]');
    tabButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const val = btn.getAttribute("data-tab-value") || "all";
        if (typeHiddenInput) {
          typeHiddenInput.value = val;
        }

        // Toggle active states on DOM
        tabButtons.forEach((b) => {
          b.setAttribute("aria-selected", "false");
          b.classList.remove("tab-active");
        });
        btn.setAttribute("aria-selected", "true");
        btn.classList.add("tab-active");

        handleFilterChange();
      });
    });
  }

  const bindRowEvents = (parent: HTMLElement | Document = document) => {
    const toggleButtons = Array.from(
      parent.querySelectorAll<HTMLElement>("[data-chevron-toggle]"),
    );

    toggleButtons.forEach((btn) => {
      if (btn.dataset.eventsBound === "true") return;
      btn.dataset.eventsBound = "true";

      const masterRow = btn.closest<HTMLElement>("[data-office-master-row]");
      if (!masterRow) return;

      const officeId = masterRow.dataset.officeId ?? "";
      const detailRow = document.querySelector<HTMLElement>(
        `[data-office-detail-row][data-office-id="${officeId}"]`,
      );

      const toggleRow = (): void => {
        const isExpanded = masterRow.getAttribute("aria-expanded") === "true";
        const newExpanded = !isExpanded;

        masterRow.classList.toggle("bg-base-200/70", newExpanded);
        masterRow.setAttribute("aria-expanded", newExpanded ? "true" : "false");

        const openIcon = masterRow.querySelector<HTMLElement>(
          "[data-chevron-open]",
        );
        const closedIcon = masterRow.querySelector<HTMLElement>(
          "[data-chevron-closed]",
        );

        openIcon?.classList.toggle("hidden", !newExpanded);
        closedIcon?.classList.toggle("hidden", newExpanded);
        detailRow?.classList.toggle("hidden", !newExpanded);
      };

      btn.addEventListener("click", toggleRow);
    });
  };

  const getQueryParams = (pageNumber: number) => {
    const params = new URLSearchParams();
    if (form) {
      const formData = new FormData(form);
      for (const [key, value] of formData.entries()) {
        if (value && value !== "all" && key !== "search") {
          params.set(key, value.toString());
        }
      }
    }
    params.set("page", pageNumber.toString());
    params.set("limit", "100");
    if (currentSearch) {
      params.set("search", currentSearch);
    }
    if (currentSortBy) {
      params.set("sortBy", currentSortBy);
      if (currentSortOrder) params.set("sortOrder", currentSortOrder);
    }
    return params.toString();
  };

  const fetchOffices = async (isNewSearch: boolean, showLoadingUI = true) => {
    if (isLoading) return;
    isLoading = true;
    if (showLoadingUI) {
      spinner?.classList.remove("hidden");
    }

    try {
      const query = getQueryParams(currentPage);
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const response = await fetch(`${baseUrl}/api/offices?${query}`);
      if (!response.ok) throw new Error("API call failed");

      const html = await response.text();
      const newHasMore = response.headers.get("X-Has-More") === "true";
      const totalCount = parseInt(
        response.headers.get("X-Total-Count") || "0",
        10,
      );

      hasMore = newHasMore;

      const badgeText = document.getElementById("total-count-badge");
      if (badgeText) {
        badgeText.textContent = `${totalCount} resultados`;
      }

      if (container) {
        if (isNewSearch) {
          const oldItems = container.querySelectorAll(
            "[data-master-detail-sort-item], [data-office-detail-row]",
          );
          oldItems.forEach((el) => el.remove());
          container.insertAdjacentHTML("beforeend", html);
        } else {
          container.insertAdjacentHTML("beforeend", html);
        }
      }

      const tableContainer = document.getElementById("office-table-container");
      if (noResultsState && tableContainer) {
        if (totalCount === 0) {
          noResultsState.classList.remove("hidden");
          noResultsState.classList.add("flex");
          tableContainer.classList.add("hidden");
        } else {
          noResultsState.classList.add("hidden");
          noResultsState.classList.remove("flex");
          tableContainer.classList.remove("hidden");
        }
      }

      bindRowEvents(container || document);

      if (currentSearch && container) {
        const newArticles = Array.from(
          container.querySelectorAll<HTMLElement>(
            "[data-master-detail-sort-item]",
          ),
        );
        newArticles.forEach((item) => {
          highlightSearchTargets(item, currentSearch);
        });
      }

      if (!hasMore) {
        sentinel?.classList.add("hidden");
      } else {
        sentinel?.classList.remove("hidden");
      }
    } catch (err) {
      console.error("Error fetching offices:", err);
    } finally {
      isLoading = false;
      if (showLoadingUI) {
        spinner?.classList.add("hidden");
      }
    }
  };

  let map: any = null;
  const initializeMap = async () => {
    if (map) return;

    const L = (await import("leaflet")).default;
    const { feature } = await import("topojson-client");

    const mapLoading = document.getElementById("map-loading");
    if (mapLoading) mapLoading.style.display = "flex";

    let dataMap = [];
    let provincesData = {};
    const regionColorMap: Record<string, string> = {};

    try {
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const res = await fetch(`${baseUrl}/api/offices-map-data`);
      if (res.ok) {
        const json = await res.json();
        dataMap = json.sucursales || [];
        provincesData = json.provincesByRegion || {};
        regionsDataCache = json.regions || [];
        for (const r of json.regions || []) {
          regionColorMap[r.name] = r.color;
        }
      }
    } catch (err) {
      console.error("Error fetching map data:", err);
    } finally {
      if (mapLoading) mapLoading.style.display = "none";
    }

    const provinceToRegion: Record<string, string> = {};
    for (const [regionName, provs] of Object.entries(provincesData)) {
      for (const p of provs as any[]) {
        provinceToRegion[p.name] = regionName;
      }
    }

    const normalizeProvinceName = (geoName: string) => {
      if (geoName === "Tierra del Fuego, Antártida e Islas del Atlántico Sur")
        return "Tierra del Fuego";
      if (geoName === "Ciudad Autónoma de Buenos Aires") return "CABA";
      return geoName;
    };

    const getRegionColor = (provinceName: string) => {
      const dbName = normalizeProvinceName(provinceName);
      const region = provinceToRegion[dbName];
      return regionColorMap[region] || "#7F8C8D";
    };

    const bounds = [
      [-56.0, -74.0],
      [-21.0, -53.0],
    ];

    map = L.map("mapa-sucursales", {
      maxBounds: bounds as any,
      maxBoundsViscosity: 1.0,
    }).setView([-38.5, -64.0], 4);

    L.tileLayer(
      "https://wms.ign.gob.ar/geoserver/gwc/service/tms/1.0.0/capabaseargenmap@EPSG%3A3857@png/{z}/{x}/{-y}.png",
      {
        maxZoom: 18,
        minZoom: 3,
      },
    ).addTo(map);

    const grupoPoligonos = L.layerGroup().addTo(map);
    const grupoEtiquetas = L.layerGroup().addTo(map);
    const grupoSucursales = L.layerGroup().addTo(map);

    const regionLayers: Record<string, any[]> = {};

    const chkPolygons = document.getElementById(
      "chk-polygons",
    ) as HTMLInputElement | null;
    const chkLabels = document.getElementById(
      "chk-labels",
    ) as HTMLInputElement | null;

    if (chkPolygons) {
      chkPolygons.addEventListener("change", () => {
        if (chkPolygons.checked) {
          map.addLayer(grupoPoligonos);
        } else {
          map.removeLayer(grupoPoligonos);
        }
      });
    }

    if (chkLabels) {
      chkLabels.addEventListener("change", () => {
        if (chkLabels.checked) {
          map.addLayer(grupoEtiquetas);
          setTimeout(updateLabelsScale, 0);
        } else {
          map.removeLayer(grupoEtiquetas);
        }
      });
    }

    function updateLabelsScale() {
      const z = map.getZoom();
      let scale = 0;
      let opacity = 0;
      if (z >= 5) {
        scale = Math.min(Math.max(0.45, (z - 5) * 0.2 + 0.45), 0.8);
        opacity = z >= 6 ? 0.9 : 0.7;
      }
      document.querySelectorAll<HTMLElement>(".polygon-label").forEach((el) => {
        el.style.transform = `translate(-50%, -50%) scale(${scale})`;
        el.style.opacity = opacity.toString();
        el.style.pointerEvents = scale > 0.3 ? "auto" : "none";
        el.style.visibility = z < 5 ? "hidden" : "visible";
      });
    }
    map.on("zoomend", updateLabelsScale);
    map.on("zoom", updateLabelsScale);

    const sucursalMarkerIcon = L.divIcon({
      className: "bg-transparent",
      html: `
            <div class="relative group cursor-pointer animate-fade-in" style="margin-top: -10px; margin-left: -10px;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" 
                   class="w-10 h-10 transition-transform hover:scale-110 text-secondary drop-shadow-lg"
                   style="filter: drop-shadow(0 4px 4px rgba(0,0,0,0.4));">
                <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
              </svg>
            </div>
          `,
      iconSize: [40, 40],
      iconAnchor: [20, 40],
      popupAnchor: [0, -38],
    });

    const provinceLetters: Record<string, string> = {
      "Ciudad Autónoma de Buenos Aires": "C",
      "Buenos Aires": "B",
      Catamarca: "K",
      Chaco: "H",
      Chubut: "U",
      Córdoba: "X",
      Corrientes: "W",
      "Entre Ríos": "E",
      Formosa: "P",
      Jujuy: "Y",
      "La Pampa": "L",
      "La Rioja": "F",
      Mendoza: "M",
      Misiones: "N",
      Neuquén: "Q",
      "Río Negro": "R",
      Salta: "A",
      "San Juan": "J",
      "San Luis": "D",
      "Santa Cruz": "Z",
      "Santa Fe": "S",
      "Santiago del Estero": "G",
      "Tierra del Fuego, Antártida e Islas del Atlántico Sur": "V",
      Tucumán: "T",
    };

    const labelOverrides: Record<string, [number, number]> = {
      "Santa Fe": [-30.8, -61.6],
      "Buenos Aires": [-36.8, -60.1],
      "Tierra del Fuego, Antártida e Islas del Atlántico Sur": [-54.3, -67.0],
    };

    fetch("/data/argentina_provincias.topojson")
      .then((res) => res.json())
      .then((topoData) => {
        const geoData = feature(topoData, topoData.objects.argentina_provincias);
        L.geoJSON(geoData, {
          style: function (feature: any) {
            const name = feature.properties.nombre;
            const color = getRegionColor(name);
            return {
              color: color,
              weight: 1.5,
              fillColor: color,
              fillOpacity:
                name === "Ciudad Autónoma de Buenos Aires" ? 0.35 : 0.15,
            };
          },
          onEachFeature: function (feature: any, layer: any) {
            const name = feature.properties.nombre;
            const dbName = normalizeProvinceName(name);
            const regionName = provinceToRegion[dbName] || "Sin región";
            if (!regionLayers[regionName]) regionLayers[regionName] = [];
            regionLayers[regionName].push(layer);
            const color = getRegionColor(name);
            layer.bindPopup(
              `<div class='text-center p-1'><b style='color: ${color};'>${name}</b><br/><span class='text-xs text-base-content/60'>${regionName}</span></div>`,
              { className: "custom-popup" },
            );


            const letter = provinceLetters[name];
            if (letter) {
              const centroid = feature.properties.centroide;
              const pos = labelOverrides[name] || [centroid.lat, centroid.lon];
              const color = getRegionColor(name);
              let fontSize = "3.5rem";
              if (letter === "C") fontSize = "2rem";
              if (["B", "S", "X"].includes(letter)) fontSize = "4.2rem";
              L.marker(pos as any, {
                icon: L.divIcon({
                  className: "bg-transparent",
                  html: `<div class="polygon-label font-black text-secondary opacity-80 pointer-events-none transition-all duration-300" style="transform: translate(-50%, -50%); line-height: 1; color: ${color}; font-size: ${fontSize};">${letter}</div>`,
                  iconSize: [0, 0],
                }),
                interactive: false,
              }).addTo(grupoEtiquetas);
            }
          },
        }).addTo(grupoPoligonos);
        updateLabelsScale();

        const legendEl = document.getElementById("map-legend");
        if (legendEl) {
          const highlightRegion = (
            regionName: string | undefined,
            highlight: boolean,
          ) => {
            if (!regionName || !regionLayers[regionName]) return;
            regionLayers[regionName].forEach((layer: any) => {
              if (highlight) {
                layer.setStyle({ fillOpacity: 0.45, weight: 2.5 });
                if (map && map.hasLayer(layer)) {
                  layer.bringToFront();
                }
              } else {
                const name = layer.feature?.properties?.nombre;
                const opacity =
                  name === "Ciudad Autónoma de Buenos Aires" ? 0.35 : 0.15;
                layer.setStyle({ fillOpacity: opacity, weight: 1.5 });
              }
            });
          };

          legendEl.addEventListener("mouseover", (e) => {
            const item = (e.target as HTMLElement).closest(".legend-item-group");
            if (!item) return;
            highlightRegion(
              item.getAttribute("data-region") ?? undefined,
              true,
            );
          });

          legendEl.addEventListener("mouseout", (e) => {
            const item = (e.target as HTMLElement).closest(".legend-item-group");
            if (!item) return;
            highlightRegion(
              item.getAttribute("data-region") ?? undefined,
              false,
            );
          });

          legendEl.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;

            const toggleBtn = target.closest(".btn-toggle-referents");
            if (toggleBtn) {
              e.preventDefault();
              e.stopPropagation();
              const regionId = toggleBtn.getAttribute("data-region-id");
              if (regionId) {
                toggleRegionReferents(regionId, toggleBtn as HTMLButtonElement);
              }
              return;
            }

            const editBtn = target.closest(".btn-edit-region");
            if (editBtn) {
              e.preventDefault();
              e.stopPropagation();
              const regionId = editBtn.getAttribute("data-region-id");
              if (regionId) {
                renderRegionEditModal(regionId);
                const modal = document.getElementById("region-referents-modal") as HTMLDialogElement | null;
                if (modal) modal.showModal();
              }
              return;
            }

            if (target.closest(".referents-collapse-content")) {
              return;
            }

            const item = target.closest(".legend-item-group");
            if (!item) return;
            const regionName = item.getAttribute("data-region");
            if (!regionName || !regionLayers[regionName]) return;

            if (chkPolygons && !chkPolygons.checked) {
              chkPolygons.checked = true;
              chkPolygons.dispatchEvent(new Event("change"));
            }

            const group = L.featureGroup(regionLayers[regionName]);
            map.fitBounds(group.getBounds(), { padding: [40, 40] });
          });
        }
      });

    dataMap.forEach((sucursal: any) => {
      const { lat, lng, nombre, nis, direccion } = sucursal;
      const popupContent = `<div class="px-1 py-1 min-w-56"><div class="border-b border-base-300 pb-2 mb-2"><h3 class="font-bold text-base-content text-sm m-0">${nombre}</h3><span class="inline-block mt-1.5 px-2 py-0.5 bg-primary/10 text-primary text-xs font-black rounded uppercase tracking-wider">NIS: ${nis}</span></div><div class="text-xs text-base-content/85 space-y-1.5"><div class="flex flex-col gap-0.5"><span class="font-semibold text-base-content/60">Dirección</span><span class="text-base-content/90 font-medium">${direccion}</span></div></div></div>`;
      L.marker([lat, lng], { icon: sucursalMarkerIcon })
        .addTo(grupoSucursales)
        .bindPopup(popupContent, { className: "custom-popup" });
    });
  };

  const switcher = document.getElementById("main-view-switcher");
  switcher?.addEventListener("view-change", (e: any) => {
    const value = e.detail.value;
    if (value === "directory") {
      mainViewDir?.classList.remove("hidden");
      mainViewMap?.classList.add("hidden");
    } else if (value === "map") {
      mainViewDir?.classList.add("hidden");
      mainViewMap?.classList.remove("hidden");
      initializeMap()
        .then(() => {
          if (map) map.invalidateSize();
        })
        .catch((err) => {
          console.error("Error initializing map:", err);
        });
    }
  });

  if (sentinel) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore) {
          currentPage++;
          fetchOffices(false);
        }
      },
      { rootMargin: "200px" },
    );
    observer.observe(sentinel);
  }

  let debounceTimeout: number;
  searchInput?.addEventListener("input", () => {
    clearTimeout(debounceTimeout);
    debounceTimeout = window.setTimeout(() => {
      currentPage = 1;
      currentSearch = searchInput.value.trim();
      fetchOffices(true);
    }, 300);
  });

  const clearFiltersBtn = document.getElementById("clear-filters-btn");
  clearFiltersBtn?.addEventListener("click", () => {
    if (searchInput) searchInput.value = "";
    currentSearch = "";

    if (regionSelect) regionSelect.value = "all";
    if (provinceSelect) {
      provinceSelect.innerHTML = '<option value="all">Provincias (Todas)</option>';
      provinceSelect.value = "all";
      provinceSelect.disabled = true;
    }
    if (zoneSelect) zoneSelect.value = "all";
    if (paqarSelect) paqarSelect.value = "all";

    if (hasParentToggle) hasParentToggle.checked = false;
    if (isHeadquarterToggle) isHeadquarterToggle.checked = false;

    if (typeHiddenInput) typeHiddenInput.value = "all";
    if (typeTabsContainer) {
      const tabButtons = typeTabsContainer.querySelectorAll<HTMLButtonElement>('button[role="tab"]');
      tabButtons.forEach((b) => {
        b.setAttribute("aria-selected", "false");
        b.classList.remove("tab-active");
        if (b.getAttribute("data-tab-value") === "all" || (!b.getAttribute("data-tab-value") && b.textContent?.trim() === "Todas")) {
          b.setAttribute("aria-selected", "true");
          b.classList.add("tab-active");
        }
      });
    }

    handleFilterChange();
  });

  bindRowEvents();

  tableRoot?.addEventListener("master-detail-sort-change", (e: any) => {
    const { sortKey, direction } = e.detail;
    currentSortBy = direction === "none" ? null : sortKey;
    currentSortOrder = direction === "ascending" ? "asc" : direction === "descending" ? "desc" : null;
    currentPage = 1;
    fetchOffices(true, false); // isNewSearch = true, showLoadingUI = false
    syncFiltersToURL();
  });

  if (currentSortBy && tableRoot) {
    const dir = currentSortOrder === "desc" ? "descending" : "ascending";
    tableRoot.dataset.masterDetailSortKey = currentSortBy;
    tableRoot.dataset.masterDetailSortDirection = dir;

    const control = tableRoot.querySelector(`[data-table-sort-key="${currentSortBy}"]`);
    if (control) {
      control.setAttribute("data-table-sort-direction", dir);
      control.setAttribute("aria-sort", dir);
      control.querySelectorAll("[data-table-sort-icon]").forEach((icon: any) => {
        const shouldShow = icon.dataset.tableSortIcon === dir;
        icon.classList.toggle("hidden", !shouldShow);
        icon.classList.toggle("opacity-0", !shouldShow);
      });
    }
  }

  const toggleRegionReferents = (regionId: string, toggleBtn: HTMLButtonElement) => {
    const collapseContent = document.querySelector(`.referents-collapse-content[data-region-id="${regionId}"]`) as HTMLElement | null;
    if (!collapseContent) return;

    const isHidden = collapseContent.classList.contains("hidden");

    if (isHidden) {
      // close all other accordions first
      const openCollapses = document.querySelectorAll(".referents-collapse-content:not(.hidden)");
      openCollapses.forEach((el) => {
        el.classList.add("hidden");
        const rId = el.getAttribute("data-region-id");
        if (rId) {
          const btn = document.querySelector(`.btn-toggle-referents[data-region-id="${rId}"]`);
          if (btn) {
            btn.setAttribute("aria-expanded", "false");
            const openIcon = btn.querySelector("[data-chevron-open]");
            const closedIcon = btn.querySelector("[data-chevron-closed]");
            openIcon?.classList.add("hidden");
            closedIcon?.classList.remove("hidden");
          }
        }
      });

      collapseContent.classList.remove("hidden");
      toggleBtn.setAttribute("aria-expanded", "true");
      const openIcon = toggleBtn.querySelector("[data-chevron-open]");
      const closedIcon = toggleBtn.querySelector("[data-chevron-closed]");
      openIcon?.classList.remove("hidden");
      closedIcon?.classList.add("hidden");
      renderRegionDetailsInline(regionId);
    } else {
      collapseContent.classList.add("hidden");
      toggleBtn.setAttribute("aria-expanded", "false");
      const openIcon = toggleBtn.querySelector("[data-chevron-open]");
      const closedIcon = toggleBtn.querySelector("[data-chevron-closed]");
      openIcon?.classList.add("hidden");
      closedIcon?.classList.remove("hidden");
    }
  };

  const renderRegionDetailsInline = (regionId: string) => {
    const collapseContent = document.querySelector(`.referents-collapse-content[data-region-id="${regionId}"]`) as HTMLElement | null;
    if (!collapseContent) return;

    const listContainer = collapseContent.querySelector(".referents-list-container") as HTMLElement | null;
    if (!listContainer) return;

    const region = regionsDataCache.find((r) => r.id === regionId);
    if (!region) return;

    if (!region.referents || region.referents.length === 0) {
      listContainer.innerHTML = `<p class="text-xs text-base-content/60 italic">Sin referentes asignados</p>`;
    } else {
      listContainer.innerHTML = `
        <ul class="list-disc list-inside space-y-1">
          ${region.referents
            .map(
              (ref: any) => `
            <li class="text-xs font-medium text-base-content">${escapeHTML(ref.firstName)} ${escapeHTML(ref.lastName)}</li>
          `
            )
            .join("")}
        </ul>
      `;
    }
  };

  const renderRegionEditModal = (regionId: string) => {
    const modalContent = document.getElementById("modal-region-content");
    if (!modalContent) return;

    const region = regionsDataCache.find((r) => r.id === regionId);
    if (!region) return;

    let localReferents = region.referents ? [...region.referents] : [];

    const renderForm = () => {
      let rowsHtml = "";
      if (localReferents.length === 0) {
        rowsHtml = `<p class="text-xs text-base-content/60 italic my-2">No hay referentes asignados. Podés agregar uno.</p>`;
      } else {
        rowsHtml = localReferents
          .map(
            (ref: any, idx: number) => `
          <div class="flex items-center gap-1.5 referent-row" data-index="${idx}">
            <input type="text" placeholder="Nombre" class="input input-bordered input-sm w-full font-medium input-name" value="${escapeHTML(ref.firstName || "")}" required />
            <input type="text" placeholder="Apellido" class="input input-bordered input-sm w-full font-medium input-lastname" value="${escapeHTML(ref.lastName || "")}" required />
            <button type="button" class="btn btn-sm btn-circle btn-ghost text-error btn-remove-referent" data-index="${idx}" title="Eliminar referente">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
              </svg>
            </button>
          </div>
        `
          )
          .join("");
      }

      modalContent.innerHTML = `
        <div class="flex flex-col gap-4">
          <div>
            <h3 class="text-lg font-bold text-base-content">Editar Tecnológicos de ${escapeHTML(region.name)}</h3>
            <p class="text-xs text-base-content/60">Modificá la lista de tecnológicos para esta región.</p>
          </div>
          <form class="flex flex-col gap-3 edit-referents-form">
            <span class="text-xs font-semibold text-base-content/50 uppercase tracking-wider">Editar Tecnológicos</span>
            <div class="flex flex-col gap-2 referents-rows-container">
              ${rowsHtml}
            </div>
            <button type="button" class="btn btn-sm btn-outline gap-1 text-xs self-start btn-add-referent">
              + Agregar Tecnológico
            </button>
            <div class="text-xs text-error hidden form-error-msg"></div>
            <div class="flex items-center justify-end gap-2 mt-4">
              <button type="button" class="btn btn-sm btn-ghost btn-cancel-edit">Cancelar</button>
              <button type="submit" class="btn btn-sm btn-primary btn-save-edit">Guardar</button>
            </div>
          </form>
        </div>
      `;

      const addBtn = modalContent.querySelector(".btn-add-referent");
      if (addBtn) {
        addBtn.addEventListener("click", () => {
          updateLocalReferentsFromDOM();
          localReferents.push({ firstName: "", lastName: "" });
          renderForm();
        });
      }

      const removeBtns = modalContent.querySelectorAll(".btn-remove-referent");
      removeBtns.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget as HTMLElement;
          const idx = parseInt(target.getAttribute("data-index") || "0", 10);
          updateLocalReferentsFromDOM();
          localReferents.splice(idx, 1);
          renderForm();
        });
      });

      const cancelBtn = modalContent.querySelector(".btn-cancel-edit");
      if (cancelBtn) {
        cancelBtn.addEventListener("click", () => {
          const modal = document.getElementById("region-referents-modal") as HTMLDialogElement | null;
          if (modal) modal.close();
        });
      }

      const form = modalContent.querySelector(".edit-referents-form") as HTMLFormElement | null;
      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          updateLocalReferentsFromDOM();

          const sanitized: { firstName: string; lastName: string }[] = [];
          for (const ref of localReferents) {
            const fName = (ref.firstName || "").trim();
            const lName = (ref.lastName || "").trim();
            if (!fName || !lName) {
              const errorMsg = modalContent.querySelector(".form-error-msg") as HTMLElement | null;
              if (errorMsg) {
                errorMsg.textContent = "El nombre y apellido no pueden estar vacíos";
                errorMsg.classList.remove("hidden");
              }
              return;
            }
            sanitized.push({ firstName: fName, lastName: lName });
          }

          const saveBtn = modalContent.querySelector(".btn-save-edit") as HTMLButtonElement | null;
          const cancelBtnEl = modalContent.querySelector(".btn-cancel-edit") as HTMLButtonElement | null;
          const addBtnEl = modalContent.querySelector(".btn-add-referent") as HTMLButtonElement | null;
          if (saveBtn) {
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Guardando...';
          }
          if (cancelBtnEl) cancelBtnEl.disabled = true;
          if (addBtnEl) addBtnEl.disabled = true;

          const errorMsg = modalContent.querySelector(".form-error-msg") as HTMLElement | null;
          if (errorMsg) errorMsg.classList.add("hidden");

          try {
            const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
            const res = await fetch(`${baseUrl}/api/technology-referents`, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                regionId,
                referents: sanitized,
              }),
            });

            if (!res.ok) {
              const errData = await res.json();
              throw new Error(errData.error || "Error al guardar los referentes");
            }

            region.referents = sanitized;

            const modal = document.getElementById("region-referents-modal") as HTMLDialogElement | null;
            if (modal) modal.close();

            renderRegionDetailsInline(regionId);
          } catch (err: any) {
            console.error("Error saving referents:", err);
            if (saveBtn) {
              saveBtn.disabled = false;
              saveBtn.textContent = "Guardar";
            }
            if (cancelBtnEl) cancelBtnEl.disabled = false;
            if (addBtnEl) addBtnEl.disabled = false;

            if (errorMsg) {
              errorMsg.textContent = err.message || "Error al guardar los referentes";
              errorMsg.classList.remove("hidden");
            }
          }
        });
      }
    };

    const updateLocalReferentsFromDOM = () => {
      const rows = modalContent.querySelectorAll(".referent-row");
      rows.forEach((row) => {
        const idx = parseInt(row.getAttribute("data-index") || "0", 10);
        const nameInput = row.querySelector(".input-name") as HTMLInputElement | null;
        const lastnameInput = row.querySelector(".input-lastname") as HTMLInputElement | null;
        if (localReferents[idx]) {
          localReferents[idx].firstName = nameInput ? nameInput.value : "";
          localReferents[idx].lastName = lastnameInput ? lastnameInput.value : "";
        }
      });
    };

    renderForm();
  };

  let isInvgateSyncing = false;

  const handleInvgateSync = async () => {
    if (isInvgateSyncing) return;
    isInvgateSyncing = true;

    const btn = document.getElementById("sync-invgate-btn") as HTMLButtonElement | null;
    const text = document.getElementById("sync-btn-text");
    const spinner = document.getElementById("sync-btn-spinner");
    if (!btn || !text || !spinner) { isInvgateSyncing = false; return; }

    text.textContent = "Sincronizando...";
    spinner.classList.remove("hidden");

    try {
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const res = await fetch(`${baseUrl}/api/admin/invgate/locations/sync`, { method: "POST" });
      const data = await res.json();
      if (data.ok) {
        showToast(`Sincronización completada: ${data.matched} oficinas vinculadas`, "alert-success");
        setTimeout(() => window.location.reload(), 1500);
      } else {
        showToast(data.error || "Error al sincronizar", "alert-error");
      }
    } catch {
      showToast("Error de red al sincronizar", "alert-error");
    } finally {
      isInvgateSyncing = false;
      text.textContent = "Sincronizar ahora";
      spinner.classList.add("hidden");
    }
  };

  document.getElementById("sync-invgate-btn")?.addEventListener("click", handleInvgateSync);

  // Load InvGate comparison stats
  const statsCards = document.getElementById("stats-cards");
  if (statsCards) {
    (async () => {
      try {
        const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
        const res = await fetch(`${baseUrl}/api/invgate/stats`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const stats = await res.json();
        const setStat = (id: string, val: number | undefined | null) => {
          const el = document.getElementById(id);
          if (el) el.textContent = val != null ? String(val) : "—";
        };
        setStat("stat-totalMda", stats.totalMda);
        setStat("stat-matched", stats.matched);
        setStat("stat-unmatchedMda", stats.unmatchedMda);
        setStat("stat-unmatchedInvgate", stats.unmatchedInvgate);
      } catch (err) {
        console.error("Error loading InvGate stats:", err);
      }
    })();
  }
</script>

