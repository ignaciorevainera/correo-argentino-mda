---
import { Icon } from "astro-icon/components";
import CopyButton from "@components/ui/CopyButton.astro";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ActionDeleteButton from "@components/ui/ActionDeleteButton.astro";
import { isAllowed } from "@lib/rolesMatrix";
import type { OfficeDirectoryItem } from "@types/offices";
import {
  officeTypeLabelByType,
  officeTypeChipClassByType,
  assetColorByType,
  assetIconByType,
  assetLabelByType,
  assetOrderByType,
} from "@lib/officeHelpers";
import {
  getTerminalColorClass,
  getTerminalTypeLabel,
} from "@lib/terminalHelpers";

interface Props {
  office: OfficeDirectoryItem;
  isVisibleByDefault?: boolean;
}

const { office, isVisibleByDefault = true } = Astro.props;

const user = Astro.locals.user;
const isAllowedAdmin = user
  ? isAllowed("Administrar Contenido", user.role)
  : false;

const normalizedType =
  office.type === "SUCURSAL"
    ? office.officeType === "AUTOMATIZADA"
      ? "SUCURSAL_AUTOMATIZADA"
      : "SUCURSAL_NO_AUTOMATIZADA"
    : office.type;

const searchText = `${office.name} ${office.code} ${office.region} ${office.provinceName} ${office.location} ${office.postalCode} ${officeTypeLabelByType[normalizedType] || office.type} ${office.parentNis ?? ""} ${office.costCenter}`;
const hasContacts = office.contacts && office.contacts.length > 0;
const hasInfo = Boolean(office.email || office.notes);
const hasInfoSection = hasContacts || hasInfo;

const totalAssets =
  (office.assets?.length || 0) + (office.terminals?.length || 0);
const hasAssetsSection = totalAssets > 0;

const hasDetails = hasInfoSection || hasAssetsSection;

const activeSectionsCount =
  (hasInfoSection ? 1 : 0) + (hasAssetsSection ? 1 : 0);

const officeDirectoryRowGridClass = isAllowedAdmin
  ? "grid grid-cols-[48px_80px_1.2fr_90px_1.8fr_110px_120px] items-center gap-4"
  : "grid grid-cols-[48px_80px_1.2fr_90px_1.8fr_110px] items-center gap-4";
---

<article
  data-master-detail-sort-item
  data-office-id={office.id}
  data-office-type={office.type}
  data-office-location={office.location}
  data-region={office.region}
  data-province-code={office.provinceCode}
  data-search-text={searchText}
  data-sort-code={office.code}
  data-sort-name={office.name}
  data-sort-parent-nis={office.parentNis ?? ""}
  data-sort-address={`${office.address} ${office.location} ${office.region} ${office.postalCode}`}
  data-sort-group={office.location}
  class:list={["block", !isVisibleByDefault && "hidden"]}
>
  <div
    data-office-master-row={hasDetails ? "" : undefined}
    data-office-id={office.id}
    aria-expanded={hasDetails ? "false" : undefined}
    class:list={[
      officeDirectoryRowGridClass,
      "border-b border-base-300 px-4 py-3 transition-colors",
    ]}
  >
    <div>
      {
        hasDetails ? (
          <button
            type="button"
            data-chevron-toggle
            class="inline-flex size-8 cursor-pointer items-center justify-center rounded-lg border border-base-300 bg-base-200 text-base-content/70 transition-colors hover:bg-base-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
            aria-label="Expandir detalle"
          >
            <Icon
              name="boxicons:chevron-down-filled"
              data-chevron-closed
              size={16}
            />
            <Icon
              name="boxicons:chevron-up-filled"
              data-chevron-open
              class="hidden"
              size={16}
            />
          </button>
        ) : (
          <span class="inline-flex size-8" />
        )
      }
    </div>

    <div class="relative inline-flex">
      {
        office.invgateLinked ? (
          <span
            class="absolute -top-0.5 right-4.5 z-10 size-2 rounded-full bg-info"
            title="Presente en InvGate"
          />
        ) : (
          <span class="absolute -top-0.5 right-4.5 z-10 size-2 rounded-full bg-neutral" title="No registrada en InvGate" />
        )
      }
      <CopyButton
        value={office.code}
        variant="value"
        feedbackOnly={true}
        copiedLabel={`NIS ${office.code} copiado al portapapeles`}
        size="xs"
        appearance="ghost"
        monospace={true}
        highlightable={true}
        class={`font-semibold ${officeTypeChipClassByType[normalizedType] || "office-type-chip bg-base-300 text-base-content"}`}
      />
    </div>

    <div class="min-w-0">
      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-base-content">
          <span data-highlight-target>{office.name}</span>
        </p>
        <div
          class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-base-content/55"
        >
          <span>
            {officeTypeLabelByType[normalizedType] || office.type}
          </span>
          <span class="text-base-content/35">/</span>
          <span>{office.contacts.length} contactos</span>
          <span class="text-base-content/35">/</span>
          <span>{totalAssets} activos</span>
        </div>
      </div>
    </div>

    {/* Dependencia (parent NIS) */}
    <div class="min-w-0">
      {
        office.parentNis ? (
          <span
            data-highlight-target
            class="inline-flex px-2 py-1 font-mono text-xs font-semibold bg-base-200 border border-base-300 rounded text-base-content/70"
          >
            {office.parentNis}
          </span>
        ) : (
          <span class="text-base-content/30">&mdash;</span>
        )
      }
    </div>

    <div class="min-w-0">
      <div class="min-w-0 space-y-1">
        <p class="flex min-w-0 items-center gap-2 text-sm text-base-content/75">
          <Icon
            name="boxicons:location-pin-filled"
            class="shrink-0 text-secondary"
            size={16}
            aria-hidden="true"
          />
          <span class="truncate" title={office.address}>
            {office.address}
          </span>
        </p>
        <p class="truncate text-xs text-base-content/55">
          {office.location}
        </p>
        <div
          class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-base-content/60"
        >
          <span data-highlight-target>
            {office.region}
          </span>
          {
            office.postalCode && (
              <>
                <span class="text-base-content/35">/</span>
                <span class="font-mono" data-highlight-target>
                  CP {office.postalCode}
                </span>
              </>
            )
          }
        </div>
      </div>
    </div>

    <div class="min-w-0">
      <span
        data-highlight-target
        class="font-mono text-xs text-base-content/70"
      >
        {office.costCenter}
      </span>
    </div>

    {
      isAllowedAdmin && (
        <div class="min-w-0 flex items-center justify-end gap-2">
          <ActionEditButton
            href={`${import.meta.env.BASE_URL}oficinas/edit/${office.dbId}`}
            ariaLabel={`Editar oficina ${office.name}`}
          />
          <form
            method="POST"
            action={`${import.meta.env.BASE_URL}oficinas/edit/${office.dbId}/eliminar`}
            class="inline"
            onsubmit={`return confirm('¿Estás seguro de que deseas eliminar la oficina \`${office.name}\` (${office.code})?');`}
          >
            <ActionDeleteButton ariaLabel={`Eliminar oficina ${office.name}`} />
          </form>
        </div>
      )
    }
  </div>

  <div
    data-office-detail-row
    data-office-id={office.id}
    class="hidden border-b border-base-300 bg-base-200/20"
  >
    <div class="office-detail-panel mx-4 my-3">
      <div class="bg-base-100 border border-base-300 rounded-box p-4">
        <div class="flex flex-col lg:flex-row gap-6">
          {
            hasInfoSection && (
              <div
                class:list={[
                  "space-y-5",
                  hasAssetsSection ? "lg:w-2/5" : "w-full",
                ]}
              >
                {hasContacts && (
                  <section class="min-w-0 space-y-3">
                    <h2 class="flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-base-content/70">
                      <Icon
                        name="boxicons:user-filled"
                        size={16}
                        class="text-secondary"
                        aria-hidden="true"
                      />
                      Contactos
                    </h2>

                    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-3">
                      {office.contacts.map((contact) => (
                        <article class="rounded-lg border border-base-300 bg-base-100/50 p-3 shadow-sm">
                          <h3 class="truncate text-sm font-semibold text-base-content">
                            {contact.name}
                          </h3>
                          <div class="mt-3 space-y-2 text-xs text-base-content/70">
                            {contact.timeSlot && (
                              <p class="flex items-center gap-2">
                                <Icon
                                  name="boxicons:clock-filled"
                                  size={14}
                                  class="shrink-0 text-base-content/50"
                                  aria-hidden="true"
                                />
                                <span>{contact.timeSlot}</span>
                              </p>
                            )}
                            {contact.phone && (
                              <p class="flex items-center gap-2">
                                <Icon
                                  name="boxicons:phone-filled"
                                  size={14}
                                  class="shrink-0 text-base-content/50"
                                  aria-hidden="true"
                                />
                                <span class="font-mono">{contact.phone}</span>
                              </p>
                            )}
                          </div>
                        </article>
                      ))}
                    </div>
                  </section>
                )}

                {hasInfo && (
                  <section class="space-y-3">
                    <h2 class="flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-base-content/70">
                      <Icon
                        name="boxicons:info-circle"
                        size={16}
                        class="text-secondary"
                        aria-hidden="true"
                      />
                      Información
                    </h2>
                    <div class="rounded-lg border border-base-300 bg-base-100/50 p-3 shadow-sm space-y-2">
                      {office.email && (
                        <p class="flex items-center gap-2 text-sm text-base-content/80">
                          <Icon
                            name="boxicons:envelope-filled"
                            size={14}
                            class="shrink-0 text-base-content/50"
                            aria-hidden="true"
                          />
                          <span class="font-mono text-xs break-all">
                            {office.email}
                          </span>
                        </p>
                      )}
                      {office.notes && (
                        <p class="flex items-start gap-2 text-xs text-base-content/60">
                          <Icon
                            name="boxicons:note-filled"
                            size={14}
                            class="mt-0.5 shrink-0 text-base-content/40"
                            aria-hidden="true"
                          />
                          <span>{office.notes}</span>
                        </p>
                      )}
                    </div>
                  </section>
                )}
              </div>
            )
          }

          {
            hasAssetsSection && (
              <div
                class:list={[
                  "flex flex-col min-w-0",
                  hasInfoSection ? "lg:w-3/5" : "w-full",
                ]}
              >
                <h2 class="flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-base-content/70 mb-3">
                  <Icon
                    name="boxicons:desktop-filled"
                    size={16}
                    class="text-secondary"
                    aria-hidden="true"
                  />
                  Equipos ({totalAssets})
                </h2>
                <div class="max-h-[320px] overflow-y-auto pr-1">
                  <div
                    class:list={[
                      "grid gap-3 p-1",
                      hasInfoSection
                        ? "grid-cols-1 xl:grid-cols-2"
                        : "grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3",
                    ]}
                  >
                    {/* Terminales sincronizadas */}
                    {[...office.terminals]
                      .sort((a, b) => {
                        const osCompare = (
                          a.operatingSystem || ""
                        ).localeCompare(b.operatingSystem || "");
                        if (osCompare !== 0) return osCompare;
                        return (a.hostname || "").localeCompare(
                          b.hostname || "",
                        );
                      })
                      .map((terminal) => (
                        <div class="flex items-center gap-3 p-3 bg-base-100 rounded-lg border border-base-300 shadow-sm hover:shadow-md transition-shadow min-w-0">
                          <span
                            class:list={[
                              "inline-flex size-9 shrink-0 items-center justify-center rounded-lg border",
                              getTerminalColorClass(
                                terminal.operatingSystem,
                                office.type === "TELEGRAFIA",
                              ),
                            ]}
                            aria-hidden="true"
                          >
                            <Icon name="boxicons:desktop-filled" size={18} />
                          </span>
                          <div class="min-w-0 flex-1">
                            <p class="text-xxs font-medium text-base-content/60 truncate">
                              {getTerminalTypeLabel(terminal.operatingSystem)}
                            </p>
                            <p class="truncate font-mono text-xs font-semibold text-base-content">
                              {terminal.hostname}
                            </p>
                          </div>
                          <div class="text-right shrink-0">
                            <CopyButton
                              value={terminal.ipAddress}
                              variant="value"
                              monospace={true}
                              size="xs"
                              appearance="surface"
                              class="text-xxs font-medium"
                            />
                          </div>
                        </div>
                      ))}

                    {/* Activos manuales */}
                    {[...office.assets]
                      .sort(
                        (a, b) =>
                          assetOrderByType[a.type] - assetOrderByType[b.type],
                      )
                      .map((asset) => (
                        <div class="flex items-center gap-3 p-3 bg-base-100 rounded-lg border border-base-300 shadow-sm hover:shadow-md transition-shadow min-w-0">
                          <span
                            class:list={[
                              "inline-flex size-9 shrink-0 items-center justify-center rounded-lg border",
                              assetColorByType[asset.type],
                            ]}
                            aria-hidden="true"
                          >
                            <Icon
                              name={
                                assetIconByType[asset.type] ||
                                "boxicons:info-circle"
                              }
                              size={18}
                            />
                          </span>
                          <div class="min-w-0 flex-1">
                            <p class="text-xxs font-medium text-base-content/60 truncate">
                              {assetLabelByType[asset.type]}
                            </p>
                            <p class="truncate font-mono text-xs font-semibold text-base-content">
                              {asset.hostname}
                            </p>
                          </div>
                          <div class="text-right shrink-0">
                            <CopyButton
                              value={asset.ip}
                              variant="value"
                              monospace={true}
                              size="xs"
                              appearance="surface"
                              class="text-xxs font-medium"
                            />
                          </div>
                        </div>
                      ))}
                  </div>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</article>
