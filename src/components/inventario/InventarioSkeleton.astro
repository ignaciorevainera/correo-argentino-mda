---
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";

const terminalHeaderGridClass = "grid-cols-12 gap-4";
const terminalRowGridClass = "grid grid-cols-12 items-start gap-4";
---

<PageContainer width="xxl">
  <div class="skeleton-debounced gap-4 flex flex-col">
    <PageHeader
      description="Gestión centralizada del parque operativo: terminales y estaciones de trabajo."
    />

    <!-- ViewSwitcher Skeleton -->
    <div class="w-full">
      <div class="h-12 w-full skeleton rounded-lg"></div>
    </div>

    <div class="flex flex-col gap-4 w-full">
      <!-- Filters Skeleton -->
      <div class="flex flex-wrap items-center gap-3 w-full">
        <div class="h-12 w-32 skeleton grow rounded-lg"></div>
        <div class="h-12 w-32 skeleton grow rounded-lg"></div>
        <div class="h-12 w-32 skeleton grow rounded-lg"></div>
        <div class="h-12 w-32 skeleton grow rounded-lg"></div>
        <div class="h-12 w-32 skeleton grow rounded-lg"></div>
        <div class="h-12 w-48 skeleton rounded-lg"></div>
        <div class="h-12 w-32 skeleton rounded-lg"></div>
      </div>

      <!-- Search Input Skeleton -->
      <div class="w-full">
        <div class="h-14 w-full skeleton rounded-lg"></div>
      </div>
    </div>

    <!-- Table Skeleton -->
    <div class="space-y-6">
      <section class="space-y-3">
        <div
          class="border border-base-300 rounded-xl overflow-hidden bg-base-100 shadow-sm"
        >
          <!-- Table Header Skeleton -->
          <div
            class={`grid ${terminalHeaderGridClass} border-b border-base-300 px-4 py-3 bg-base-200/50`}
          >
            <div class="col-span-2">
              <div class="h-5 w-20 skeleton rounded"></div>
            </div>
            <div class="col-span-3">
              <div class="h-5 w-24 skeleton rounded"></div>
            </div>
            <div class="col-span-3">
              <div class="h-5 w-32 skeleton rounded"></div>
            </div>
            <div class="col-span-2">
              <div class="h-5 w-20 skeleton rounded"></div>
            </div>
            <div class="col-span-2 flex justify-end">
              <div class="h-5 w-28 skeleton rounded"></div>
            </div>
          </div>

          <!-- Table Rows Skeleton (10 rows) -->
          <div class="divide-y divide-base-300">
            {
              Array.from({ length: 10 }).map(() => (
                <div class={`${terminalRowGridClass} px-4 py-4`}>
                  <div class="col-span-2 flex items-center gap-3">
                    <div class="size-8 rounded-lg skeleton shrink-0" />
                    <div class="h-4 w-24 skeleton rounded" />
                  </div>
                  <div class="col-span-3 flex flex-col gap-1.5">
                    <div class="h-4 w-28 skeleton rounded" />
                    <div class="h-3 w-40 skeleton rounded" />
                  </div>
                  <div class="col-span-3 flex flex-col gap-1.5">
                    <div class="h-4 w-36 skeleton rounded" />
                    <div class="h-3 w-20 skeleton rounded" />
                  </div>
                  <div class="col-span-2 flex flex-col gap-1.5">
                    <div class="h-4 w-24 skeleton rounded" />
                    <div class="h-3 w-16 skeleton rounded" />
                  </div>
                  <div class="col-span-2 flex flex-col items-end gap-1.5">
                    <div class="h-4 w-12 skeleton rounded" />
                    <div class="h-3 w-28 skeleton rounded" />
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </div>
</PageContainer>
