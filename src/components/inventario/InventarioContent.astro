---
import { Icon } from "astro-icon/components";
import DataTable from "@components/ui/DataTable.astro";
import SearchEmptyState from "@components/ui/SearchEmptyState.astro";
import DataTableHeaderCell from "@components/ui/DataTableHeaderCell.astro";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SearchBar from "@components/ui/SearchBar.astro";
import CopyButton from "@components/ui/CopyButton.astro";
import ExportCsvButton from "@components/ui/ExportCsvButton.astro";
import ViewSwitcher from "@components/ui/ViewSwitcher.astro";
import TerminalRow from "@components/inventario/TerminalRow.astro";
import { getActiveMachineCount, type CubicStatus } from "@lib/cubics";
import { db } from "@db/index";
import {
  terminals as terminalsTable,
  agents,
  operatorAttendance,
} from "@db/schema";
import { getTerminals, getTerminalModelsByBrand } from "@lib/terminalQueries";
import type { TerminalSortKey, SortOrder } from "@lib/terminalQueries";
import { and, eq } from "drizzle-orm";
import { getShiftType } from "@lib/cubics";
import OperatorAvatar from "@components/cubics/OperatorAvatar.astro";
import { isAllowed } from "@lib/rolesMatrix";
import ActionEditButton from "@components/ui/ActionEditButton.astro";
import ActionDeleteButton from "@components/ui/ActionDeleteButton.astro";
import { getResolvedSearchParams } from "@lib/navigation";
import { getCleanBase, getBaseNoSlash } from "@lib/baseUrl";

const user = Astro.locals.user;
const isAllowedAdmin = user
  ? isAllowed("Administrar Contenido", user.role)
  : false;

const canExport = user ? ["team_leader", "supervisor", "admin"].includes(user.role) : false;

const terminalHeaderGridClass = "grid-cols-12 gap-4";
const terminalRowGridClass = "grid grid-cols-12 items-start gap-4";

const rawUniqueOs = await db
  .select({ os: terminalsTable.operatingSystem })
  .from(terminalsTable)
  .groupBy(terminalsTable.operatingSystem);
const osVariations = rawUniqueOs.map((r) => r.os).filter(Boolean);

const osMap = {
  win11: osVariations.filter((os) => os?.toLowerCase().includes("windows 11")),
  win10: osVariations.filter((os) => os?.toLowerCase().includes("windows 10")),
  win7: osVariations.filter((os) => os?.toLowerCase().includes("windows 7")),
  winxp: osVariations.filter((os) => os?.toLowerCase().includes("windows xp")),
  winserver: osVariations.filter((os) =>
    os?.toLowerCase().includes("windows server"),
  ),
  ubuntu: osVariations.filter((os) => os?.toLowerCase().includes("ubuntu")),
  debian: osVariations.filter((os) => os?.toLowerCase().includes("debian")),
};

const terminalModelsByBrand = await getTerminalModelsByBrand();

const resolvedParams = getResolvedSearchParams(Astro.request, Astro.url);
const sortBy = (resolvedParams.get("sortBy") || undefined) as
  | TerminalSortKey
  | undefined;
const sortOrder = (resolvedParams.get("sortOrder") || undefined) as
  | SortOrder
  | undefined;
const activeTab = resolvedParams.get("inventory_tabs") || "terminales";

const {
  data: terminals,
  count: totalTerminals,
  hasMore,
} = await getTerminals({
  page: 1,
  limit: 50,
  sortBy,
  sortOrder,
});

const formatLastPing = (lastPing: Date | string | null | undefined): string => {
  if (!lastPing) return "Pendiente";
  const dateObj = new Date(lastPing);
  if (Number.isNaN(dateObj.getTime())) return "Pendiente";

  const day = String(dateObj.getDate()).padStart(2, "0");
  const month = String(dateObj.getMonth() + 1).padStart(2, "0");
  const year = dateObj.getFullYear();
  const hours = String(dateObj.getHours()).padStart(2, "0");
  const minutes = String(dateObj.getMinutes()).padStart(2, "0");

  return `${day}/${month}/${year} - ${hours}:${minutes} hs`;
};

const cubicMachines = await db.query.cubics.findMany({
  with: {
    assignments: {
      with: {
        agent: true,
      },
    },
  },
});

const onlineCount = getActiveMachineCount(cubicMachines as any);
const totalMachines = cubicMachines.length;

const statusCopy: Record<CubicStatus, string> = {
  online: "Online",
  offline: "Offline",
};

const todayStr = new Date().toLocaleDateString("en-CA", {
  timeZone: "America/Argentina/Buenos_Aires",
});

const allAgents = await db
  .select({
    id: agents.id,
    horarioDefault: agents.horarioDefault,
    entradaReal: operatorAttendance.entradaReal,
  })
  .from(agents)
  .leftJoin(
    operatorAttendance,
    and(
      eq(operatorAttendance.agentId, agents.id),
      eq(operatorAttendance.date, todayStr),
    ),
  );

const agentShiftMap = new Map<number, "Diurno" | "Nocturno">();
for (const agent of allAgents) {
  const shiftType = getShiftType(agent.entradaReal, agent.horarioDefault);
  agentShiftMap.set(agent.id, shiftType);
}

const cubicHeaderGridClass = "grid-cols-12 gap-4";
const cubicRowGridClass = "grid grid-cols-12 items-center gap-4";

const hostSpan = isAllowedAdmin ? "col-span-3" : "col-span-4";
const ipSpan = "col-span-3";
const statusSpan = isAllowedAdmin ? "col-span-2" : "col-span-3";
const assignedSpan = "col-span-2";
const actionsSpan = "col-span-2";

const inventoryTabs = [
  {
    label: "Terminales",
    value: "terminales",
    icon: "boxicons:desktop-filled",
  },
  {
    label: "Mediterránea",
    value: "mediterranea",
    icon: "boxicons:tv",
  },
  { label: "Cúbics", value: "cubics", icon: "boxicons:server-filled" },
];
---

<PageContainer width="xxl">
  <PageHeader>
    <span slot="description">
      Los datos mostrados en esta página son provistos por la página de <a
        href="http://b1842zacs0255/mda/index.php"
        class="link link-accent link-hover font-semibold"
        target="_blank"
        rel="noopener noreferrer">Inventario de Terminales</a
      >.
    </span>
  </PageHeader>

  <div class="w-full">
    <ViewSwitcher
      tabs={inventoryTabs}
      activeValue={activeTab}
      name="inventory_tabs"
      id="inventory-view-switcher"
      class="w-full grid grid-cols-3"
      containerClass="w-full"
    />
  </div>

  <div
    class="flex flex-col gap-4 w-full rounded-box border border-base-300 bg-base-100 p-4 shadow-md"
  >
    <!-- Contenedor de Filtros (Fila Superior) -->
    <div class="w-full">
      <!-- Filtros para Terminales -->
      <div
        id="header-right-terminales"
        class:list={[
          "flex flex-wrap items-center gap-3 w-full transition-opacity duration-300",
          activeTab === "terminales" ? "flex" : "hidden",
        ]}
      >
        <div class="form-control grow">
          <select
            id="filter-os"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por sistema operativo"
          >
            <option value="all">Sist. Op. (Todos)</option>
            <option value="win11">Windows 11</option>
            <option value="win10">Windows 10</option>
            <option value="win7">Windows 7</option>
            <option value="winxp">Windows XP</option>
            <option value="winserver">Windows Server</option>
            <option value="ubuntu">Ubuntu</option>
            <option value="debian">Debian</option>
          </select>
        </div>
        <div class="form-control grow">
          <select
            id="filter-os-variant"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por variante de sistema operativo"
            disabled
          >
            <option value="all">Variante (Todas)</option>
          </select>
        </div>
        <div class="form-control grow">
          <select
            id="filter-arch"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por arquitectura"
          >
            <option value="all">Arquitectura (Todas)</option>
            <option value="64 bits">64 bits</option>
            <option value="32 bits">32 bits</option>
          </select>
        </div>
        <div class="form-control grow">
          <select
            id="filter-brand"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por marca"
          >
            <option value="all">Marca (Todas)</option>
            <option value="dell">Dell</option>
            <option value="lenovo">Lenovo</option>
            <option value="hp">HP</option>
            <option value="bangho">Banghó</option>
            <option value="coradir">Coradir</option>
          </select>
        </div>
        <div class="form-control grow">
          <select
            id="filter-model"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por modelo de terminal"
          >
            <option value="all">Modelo (Todos)</option>
            {
              terminalModelsByBrand.map((entry) => (
                <option value={entry.model} data-brand={entry.brand}>
                  {entry.model}
                </option>
              ))
            }
          </select>
        </div>
        <div class="form-control grow">
          <select
            id="filter-ram"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por memoria RAM"
          >
            <option value="all">RAM (Todas)</option>
            <option value="<=1gb">&le; 1 GB</option>
            <option value="2gb">2 GB</option>
            <option value="4gb">4 GB</option>
            <option value="8gb">8 GB</option>
            <option value=">=16gb">&ge; 16 GB</option>
          </select>
        </div>
        <div
          class="tabs tabs-box"
          role="radiogroup"
          aria-label="Estado de conexión"
        >
          <input
            type="radio"
            name="terminal_status"
            class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
            aria-label="Todas"
            checked
            data-terminal-status="all"
          />
          <input
            type="radio"
            name="terminal_status"
            class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
            aria-label="Online"
            data-terminal-status="online"
          />
          <input
            type="radio"
            name="terminal_status"
            class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
            aria-label="Offline"
            data-terminal-status="offline"
          />
        </div>
        <button
          id="btn-clear-filters-terminales"
          class="btn btn-outline btn-error font-semibold gap-2"
          type="button"
          aria-label="Limpiar todos los filtros de terminales"
          title="Limpiar todos los filtros"
        >
          <Icon name="boxicons:trash" class="size-4" />
          Limpiar filtros
        </button>
      </div>

      <!-- Filtros para Cúbics -->
      <div
        id="header-right-cubics"
        class:list={[
          "flex-wrap items-center justify-between gap-4 w-full transition-opacity duration-300",
          activeTab === "cubics" ? "flex" : "hidden",
        ]}
      >
        <div class="flex flex-wrap items-center gap-3">
          <div
            class="tabs tabs-box"
            role="radiogroup"
            aria-label="Filtros por estado"
          >
            <input
              type="radio"
              name="cubic_filters"
              class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
              aria-label="Todas"
              checked
              data-filter-tab
              data-filter="all"
            />
            <input
              type="radio"
              name="cubic_filters"
              class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
              aria-label="Online"
              data-filter-tab
              data-filter="online"
            />
            <input
              type="radio"
              name="cubic_filters"
              class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
              aria-label="Offline"
              data-filter-tab
              data-filter="offline"
            />
          </div>
          <button
            id="btn-clear-filters-cubics"
            class="btn btn-outline btn-error font-semibold gap-2"
            type="button"
            aria-label="Limpiar todos los filtros de cúbics"
            title="Limpiar todos los filtros"
          >
            <Icon name="boxicons:trash" class="size-4" />
            Limpiar filtros
          </button>
        </div>

        <div class="flex flex-row gap-3 items-center">
          <aside
            class="card border border-base-300 bg-base-100 shadow-sm w-full sm:w-auto"
            aria-label="Resumen de conectividad"
          >
            <div
              class="card-body flex-row items-center justify-between sm:justify-start gap-2 px-3 py-2"
            >
              <p
                class="text-xs font-semibold uppercase tracking-wide text-base-content/60 m-0"
              >
                Conectividad
              </p>
              <div class="flex items-center gap-2">
                <span class="badge badge-success font-mono"
                  >{onlineCount}/{totalMachines}</span
                >
              </div>
            </div>
          </aside>
          {
            isAllowedAdmin && (
              <div>
                <a
                  href={`${import.meta.env.BASE_URL}inventario-terminales/cubics/create`}
                  class="btn btn-secondary font-semibold shadow-sm shrink-0 gap-2"
                  aria-label="Registrar nueva cubic"
                >
                  <Icon name="boxicons:plus" class="size-4" />
                  <span class="hidden sm:inline">Registrar cubic</span>
                  <span class="sm:hidden">Registrar</span>
                </a>
              </div>
            )
          }
        </div>
      </div>

      <div
        id="header-right-mediterranea"
        class:list={[
          "flex-wrap items-center gap-3 w-full transition-opacity duration-300",
          activeTab === "mediterranea" ? "flex" : "hidden",
        ]}
      >
        <div class="form-control grow">
          <select
            id="filter-medi-type"
            class="select select-bordered w-full font-medium text-base-content/80"
            aria-label="Filtrar por tipo de Mediterránea"
          >
            <option value="all">Tipos (Todos)</option>
            <option value="turnero">Turneros</option>
            <option value="tv">TVs</option>
          </select>
        </div>
        <div
          class="tabs tabs-box"
          role="radiogroup"
          aria-label="Estado de conexión Mediterránea"
        >
          <input
            type="radio"
            name="medi_status"
            class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
            aria-label="Todas"
            checked
            data-medi-status="all"
          />
          <input
            type="radio"
            name="medi_status"
            class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
            aria-label="Online"
            data-medi-status="online"
          />
          <input
            type="radio"
            name="medi_status"
            class="tab text-base-content/70 checked:text-primary-content checked:[--tab-bg:var(--color-primary)]"
            aria-label="Offline"
            data-medi-status="offline"
          />
        </div>
        <button
          id="btn-clear-filters-medi"
          class="btn btn-outline btn-error font-semibold gap-2"
          type="button"
          aria-label="Limpiar todos los filtros de Mediterránea"
          title="Limpiar todos los filtros"
        >
          <Icon name="boxicons:trash" size={16} />
          Limpiar filtros
        </button>
      </div>
    </div>

    <!-- Contenedor de Búsqueda (Fila Inferior) -->
    <div class="w-full">
      <div
        id="header-search-terminales"
        class:list={[
          "w-full transition-opacity duration-300",
          activeTab !== "terminales" && "hidden",
        ]}
      >
        <div class="flex flex-wrap sm:flex-nowrap items-center gap-3 w-full">
          <div class="w-full">
            <SearchBar
              id="terminal-search"
              placeholder="Buscar por hostname, IP, MAC o sucursal"
            />
          </div>
          <div
            class="badge badge-neutral badge-lg whitespace-nowrap"
            aria-label="Cantidad de resultados"
          >
            <Icon name="boxicons:eye-filled" size={16} />
            <span id="total-count-badge-terminales"
              >{totalTerminals} resultados</span
            >
          </div>
          {canExport && (
            <ExportCsvButton
              id="export-csv-terminales-btn"
              href={import.meta.env.BASE_URL + "api/export/terminals"}
              ariaLabel="Exportar terminales a CSV"
            />
          )}
        </div>
      </div>

      <div
        id="header-search-cubics"
        class:list={[
          "w-full transition-opacity duration-300",
          activeTab !== "cubics" && "hidden",
        ]}
      >
        <SearchBar
          id="machine-search"
          placeholder="Buscar por hostname, IP o usuario"
        />
      </div>

      <div
        id="header-search-mediterranea"
        class:list={[
          "w-full transition-opacity duration-300",
          activeTab !== "mediterranea" && "hidden",
        ]}
      >
        <div class="flex flex-wrap sm:flex-nowrap items-center gap-3 w-full">
          <div class="w-full">
            <SearchBar
              id="medi-search"
              placeholder="Buscar por hostname, IP o sucursal"
            />
          </div>
          <div
            class="badge badge-neutral badge-lg whitespace-nowrap"
            aria-label="Cantidad de resultados de Mediterránea"
          >
            <Icon name="boxicons:eye-filled" size={16} />
            <span id="total-count-badge-mediterranea">0 resultados</span>
          </div>
          {canExport && (
            <ExportCsvButton
              id="export-csv-medi-btn"
              href={getCleanBase() + "api/export/terminals?isMediterranea=true"}
              ariaLabel="Exportar Mediterránea a CSV"
            />
          )}
        </div>
      </div>
    </div>
  </div>

  <div
    id="view-terminales"
    class:list={["space-y-6", activeTab !== "terminales" && "hidden"]}
  >
    {
      terminals.length === 0 ? (
        <div class="card border border-error/20 bg-error/5 text-error-content max-w-2xl mx-auto my-8 shadow-sm">
          <div class="card-body items-center text-center p-6 sm:p-8">
            <span class="inline-flex size-14 items-center justify-center rounded-full bg-error/10 text-error mb-2 border border-error/20">
              <Icon name="boxicons:x-circle-filled-filled" class="size-8" />
            </span>
            <h3 class="text-lg font-bold text-base-content">
              Sin datos de terminales
            </h3>
            <p class="text-sm text-base-content/70 max-w-md mt-1">
              El servicio no pudo obtener datos de las terminales. Por favor,
            </p>
          </div>
        </div>
      ) : (
        <section class="space-y-3">
          <div id="terminals-table-wrapper">
            <DataTable
              id="table-terminales"
              ariaLabel="Inventario de terminales"
              minWidthClass="min-w-280"
              headerGridClass={terminalHeaderGridClass}
              rowGridClass={terminalRowGridClass}
              serverSideSort={true}
            >
              <div slot="header" class="col-span-2">
                <DataTableHeaderCell sortKey="hostname">
                  Hostname
                </DataTableHeaderCell>
              </div>
              <div slot="header" class="col-span-3">
                <DataTableHeaderCell sortKey="hardware">
                  Hardware
                </DataTableHeaderCell>
              </div>
              <div slot="header" class="col-span-3">
                <DataTableHeaderCell sortKey="os">
                  Sistema operativo
                </DataTableHeaderCell>
              </div>
              <div slot="header" class="col-span-2">
                <DataTableHeaderCell sortKey="location">
                  Ubicación
                </DataTableHeaderCell>
              </div>
              <div slot="header" class="col-span-2">
                <DataTableHeaderCell align="right">
                  Último contacto
                </DataTableHeaderCell>
              </div>
              <div id="table-terminales-body" class="contents">
                {terminals.map((terminal) => (
                  <TerminalRow
                    terminal={terminal}
                    terminalRowGridClass={terminalRowGridClass}
                  />
                ))}
              </div>
            </DataTable>

            <div
              id="scroll-sentinel-terminales"
              class:list={[
                "py-8 text-center flex justify-center",
                !hasMore && "hidden",
              ]}
              data-has-more={hasMore ? "true" : "false"}
            >
              <span
                class="loading loading-spinner loading-md text-primary hidden"
                id="loading-spinner-terminales"
              />
            </div>
          </div>

          <SearchEmptyState
            id="no-results-state-terminales"
            class="hidden"
            title="No hay coincidencias"
            description="No hemos podido encontrar terminales que coincidan con los filtros seleccionados. Probá modificando los criterios o limpiando los filtros."
            showClearButton={true}
            clearButtonId="btn-clear-empty-terminales"
            clearButtonText="Limpiar filtros"
          />
        </section>
      )
    }
  </div>

  <div
    id="view-cubics"
    class:list={["space-y-6", activeTab !== "cubics" && "hidden"]}
  >
    <section class="space-y-3">
      <DataTable
        id="table-cubics"
        ariaLabel="Listado de cubics"
        minWidthClass="min-w-220 md:min-w-full"
        headerGridClass={cubicHeaderGridClass}
        rowGridClass={cubicRowGridClass}
      >
        <div slot="header" class={hostSpan}>
          <DataTableHeaderCell sortKey="hostname">Hostname</DataTableHeaderCell>
        </div>
        <div slot="header" class={ipSpan}>
          <DataTableHeaderCell sortKey="ip">Dirección IP</DataTableHeaderCell>
        </div>
        <div slot="header" class={statusSpan}>
          <DataTableHeaderCell>Estado</DataTableHeaderCell>
        </div>
        <div slot="header" class={assignedSpan}>
          <DataTableHeaderCell>Asignado a</DataTableHeaderCell>
        </div>
        {
          isAllowedAdmin && (
            <div slot="header" class={actionsSpan}>
              <DataTableHeaderCell>Acciones</DataTableHeaderCell>
            </div>
          )
        }

        {
          cubicMachines.map((machine) => {
            const assignmentSearchValue =
              machine.assignments.length > 0
                ? machine.assignments.map((a) => a.agent.name).join(" ")
                : "Sin asignar";
            return (
              <article
                data-table-row
                data-machine-row
                data-name={machine.name}
                data-ip={machine.ip}
                data-agent={assignmentSearchValue}
                data-status={machine.status}
                data-sort-hostname={machine.name}
                data-sort-ip={machine.ip ?? ""}
                class:list={[
                  cubicRowGridClass,
                  "border-b border-base-300 px-4 py-4 transition-colors hover:bg-base-300/50 last:border-b-0",
                ]}
              >
                <div class={hostSpan + " min-w-0"}>
                  <div class="flex items-center gap-3">
                    <span class="inline-flex size-8 shrink-0 self-center items-center justify-center rounded-lg border-sky-500/30 bg-sky-500/15 text-sky-500 dark:text-sky-400 border">
                      <Icon name="boxicons:desktop-filled" size={16} />
                    </span>
                    <div class="min-w-0 flex-1">
                      <CopyButton
                        value={machine.name}
                        variant="value"
                        appearance="ghost"
                        label={machine.name}
                        ariaLabel={`Copiar ${machine.name}`}
                        monospace
                        fullWidth
                        highlightable
                        class="-ml-2"
                      />
                    </div>
                  </div>
                </div>
                <div class={ipSpan + " min-w-0"}>
                  <CopyButton
                    value={machine.ip ?? ""}
                    variant="value"
                    appearance="ghost"
                    label={machine.ip ?? "Sin IP"}
                    ariaLabel={`Copiar ${machine.ip ?? "IP"}`}
                    monospace
                    fullWidth
                    highlightable
                    class="-ml-2"
                  />
                </div>
                <div class={statusSpan + " min-w-0"}>
                  <div class="flex flex-col gap-0.5">
                    <div class="flex items-center gap-2">
                      <div class="inline-grid *:[grid-area:1/1]">
                        <div
                          class:list={[
                            "status",
                            machine.status === "online"
                              ? "status-success"
                              : "status-error",
                            "animate-ping",
                          ]}
                        />
                        <div
                          class:list={[
                            "status",
                            machine.status === "online"
                              ? "status-success"
                              : "status-error",
                          ]}
                        />
                      </div>
                      <span class="text-sm text-base-content/80">
                        {statusCopy[machine.status as CubicStatus]}
                      </span>
                    </div>
                    <p class="text-xxs text-base-content/50">
                      Último ping: {formatLastPing((machine as any).lastPing)}
                    </p>
                  </div>
                </div>
                <div class={assignedSpan + " min-w-0"}>
                  <div class="flex items-center gap-2">
                    {machine.assignments.length > 0 ? (
                      machine.assignments.map((assignment) => {
                        const shift =
                          agentShiftMap.get(assignment.agent.id) || "Diurno";
                        return (
                          <OperatorAvatar
                            name={assignment.agent.name}
                            avatarInitials={assignment.agent.avatarInitials}
                            shiftType={shift}
                            size="md"
                          />
                        );
                      })
                    ) : (
                      <div
                        class="tooltip tooltip-top tooltip-neutral z-20"
                        data-tip="Sin asignar"
                      >
                        <div
                          class="avatar avatar-placeholder"
                          role="img"
                          tabindex="0"
                          aria-label="Usuario asignado: Sin asignar"
                        >
                          <div class="w-9 rounded-full bg-base-200 text-base-content/70">
                            <span class="text-xs font-semibold select-none">
                              --
                            </span>
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
                {isAllowedAdmin && (
                  <div
                    class={
                      actionsSpan +
                      " min-w-0 flex items-center justify-end gap-2"
                    }
                  >
                    <ActionEditButton
                      href={`${import.meta.env.BASE_URL}inventario-terminales/cubics/edit/${machine.id}`}
                      ariaLabel={`Editar cubic ${machine.name}`}
                    />
                    <form
                      method="POST"
                      action={`${import.meta.env.BASE_URL}inventario-terminales/cubics/edit/${machine.id}/eliminar`}
                      class="inline"
                      onsubmit={`return confirm('¿Estás seguro de que deseas dar de baja el ordenador "${machine.name}"?');`}
                    >
                      <ActionDeleteButton
                        ariaLabel={`Eliminar cubic ${machine.name}`}
                      />
                    </form>
                  </div>
                )}
              </article>
            );
          })
        }
      </DataTable>
    </section>
  </div>

  <div
    id="view-mediterranea"
    class:list={["space-y-6", activeTab !== "mediterranea" && "hidden"]}
  >
    <section class="space-y-3">
      <div id="mediterranea-table-wrapper">
        <DataTable
          id="table-mediterranea"
          ariaLabel="Inventario de Mediterránea"
          minWidthClass="min-w-280"
          headerGridClass="grid grid-cols-10 gap-4"
          rowGridClass="grid grid-cols-10 items-start gap-4"
          serverSideSort={true}
        >
          <div slot="header" class="col-span-2">
            <DataTableHeaderCell sortKey="hostname">
              Hostname
            </DataTableHeaderCell>
          </div>
          <div slot="header" class="col-span-3">
            <DataTableHeaderCell sortKey="hardware">
              Hardware
            </DataTableHeaderCell>
          </div>
          <div slot="header" class="col-span-3">
            <DataTableHeaderCell sortKey="os">
              Sistema operativo
            </DataTableHeaderCell>
          </div>
          <div slot="header" class="col-span-2">
            <DataTableHeaderCell align="right">
              Último contacto
            </DataTableHeaderCell>
          </div>
          <div id="table-mediterranea-body" class="contents"></div>
        </DataTable>

        <div
          id="scroll-sentinel-mediterranea"
          class:list={[
            "py-8 text-center flex justify-center",
            "hidden",
          ]}
          data-has-more="false"
        >
          <span
            class="loading loading-spinner loading-md text-primary"
            id="loading-spinner-mediterranea"></span>
        </div>
      </div>

      <SearchEmptyState
        id="no-results-state-mediterranea"
        class="hidden"
        title="No hay coincidencias"
        description="No hemos podido encontrar terminales de Mediterránea que coincidan con los filtros seleccionados. Probá modificando los criterios o limpiando los filtros."
        showClearButton={true}
        clearButtonId="btn-clear-empty-mediterranea"
        clearButtonText="Limpiar filtros"
      />
    </section>
  </div>
</PageContainer>

<script>
  import {
    highlightSearchTargets,
    matchesSearchQuery,
  } from "@lib/clientSearch";

  const switcher = document.getElementById("inventory-view-switcher");
  const viewTerminales = document.getElementById("view-terminales");
  const viewCubics = document.getElementById("view-cubics");
  const viewMediterranea = document.getElementById("view-mediterranea");
  const searchTerminales = document.getElementById("header-search-terminales");
  const searchCubics = document.getElementById("header-search-cubics");
  const searchMediterranea = document.getElementById(
    "header-search-mediterranea",
  );
  const rightTerminales = document.getElementById("header-right-terminales");
  const rightCubics = document.getElementById("header-right-cubics");
  const rightMediterranea = document.getElementById(
    "header-right-mediterranea",
  );

  const updateTabs = (activeValue: string) => {
    const isTerminales = activeValue === "terminales";
    const isCubics = activeValue === "cubics";
    const isMediterranea = activeValue === "mediterranea";

    viewTerminales?.classList.toggle("hidden", !isTerminales);
    viewCubics?.classList.toggle("hidden", !isCubics);
    viewMediterranea?.classList.toggle("hidden", !isMediterranea);

    if (isTerminales) {
      searchTerminales?.classList.remove("hidden");
      searchCubics?.classList.add("hidden");
      searchMediterranea?.classList.add("hidden");

      rightTerminales?.classList.remove("hidden");
      rightTerminales?.classList.add("flex");

      rightCubics?.classList.add("hidden");
      rightCubics?.classList.remove("flex");

      rightMediterranea?.classList.add("hidden");
      rightMediterranea?.classList.remove("flex");
    } else if (isCubics) {
      searchTerminales?.classList.add("hidden");
      searchCubics?.classList.remove("hidden");
      searchMediterranea?.classList.add("hidden");

      rightTerminales?.classList.add("hidden");
      rightTerminales?.classList.remove("flex");

      rightCubics?.classList.remove("hidden");
      rightCubics?.classList.add("flex");

      rightMediterranea?.classList.add("hidden");
      rightMediterranea?.classList.remove("flex");
    } else {
      searchTerminales?.classList.add("hidden");
      searchCubics?.classList.add("hidden");
      searchMediterranea?.classList.remove("hidden");

      rightTerminales?.classList.add("hidden");
      rightTerminales?.classList.remove("flex");

      rightCubics?.classList.add("hidden");
      rightCubics?.classList.remove("flex");

      rightMediterranea?.classList.remove("hidden");
      rightMediterranea?.classList.add("flex");
    }
  };

  switcher?.addEventListener("view-change", (e: any) => {
    updateTabs(e.detail.value);
    syncFiltersToURL();
    if (
      e.detail.value === "mediterranea" &&
      mediContainer?.children.length === 0
    ) {
      mediCurrentPage = 1;
      fetchMediterranea(true);
    }
  });

  const terminalSearchInput =
    document.querySelector<HTMLInputElement>("#terminal-search");
  const osFilterSelect =
    document.querySelector<HTMLSelectElement>("#filter-os");
  const osVariantFilterSelect =
    document.querySelector<HTMLSelectElement>("#filter-os-variant");
  const archFilterSelect =
    document.querySelector<HTMLSelectElement>("#filter-arch");
  const brandFilterSelect =
    document.querySelector<HTMLSelectElement>("#filter-brand");
  const ramFilterSelect =
    document.querySelector<HTMLSelectElement>("#filter-ram");
  const modelFilterSelect =
    document.querySelector<HTMLSelectElement>("#filter-model");
  const statusRadioInputs = Array.from(
    document.querySelectorAll<HTMLInputElement>("[data-terminal-status]"),
  );
  const terminalsSentinel = document.getElementById(
    "scroll-sentinel-terminales",
  );
  const terminalsSpinner = document.getElementById(
    "loading-spinner-terminales",
  );
  const terminalsContainer = document.getElementById("table-terminales-body");
  const totalCountBadge = document.getElementById(
    "total-count-badge-terminales",
  );
  const exportCsvBtn = document.getElementById("export-csv-terminales-btn");

  let currentPage = 1;
  let currentSearch = terminalSearchInput?.value.trim() || "";
  let currentOs = osFilterSelect?.value || "all";
  let currentOsVariant = osVariantFilterSelect?.value || "all";
  let currentArch = archFilterSelect?.value || "all";
  let currentBrand = brandFilterSelect?.value || "all";
  let currentRam = ramFilterSelect?.value || "all";
  let currentModel = modelFilterSelect?.value || "all";
  let currentStatus =
    statusRadioInputs.find((r) => r.checked)?.dataset.terminalStatus || "all";
  let isLoading = false;
  let hasMore = terminalsSentinel?.getAttribute("data-has-more") === "true";
  let terminalRows = Array.from(
    document.querySelectorAll<HTMLElement>("[data-terminal-row]"),
  );

  const mediSearchInput =
    document.querySelector<HTMLInputElement>("#medi-search");
  const mediTypeSelect =
    document.querySelector<HTMLSelectElement>("#filter-medi-type");
  const mediStatusRadioInputs = Array.from(
    document.querySelectorAll<HTMLInputElement>("[data-medi-status]"),
  );
  const mediSentinel = document.getElementById("scroll-sentinel-mediterranea");
  const mediSpinner = document.getElementById("loading-spinner-mediterranea");
  const mediContainer = document.getElementById("table-mediterranea-body");
  const mediTotalCountBadge = document.getElementById(
    "total-count-badge-mediterranea",
  );
  const mediExportCsvBtn = document.getElementById("export-csv-medi-btn");

  let mediCurrentPage = 1;
  let mediCurrentSearch = mediSearchInput?.value.trim() || "";
  let mediCurrentType = mediTypeSelect?.value || "all";
  let mediCurrentStatus =
    mediStatusRadioInputs.find((r) => r.checked)?.dataset.mediStatus || "all";
  let mediHasMore = false;
  let mediIsLoading = false;

  const urlParams = new URLSearchParams(window.location.search);
  let currentSortBy: string | null = urlParams.get("sortBy");
  let currentSortOrder: "asc" | "desc" | null =
    (urlParams.get("sortOrder") as "asc" | "desc") || null;

  const syncFiltersToURL = () => {
    const params = new URLSearchParams(window.location.search);
    const activeTabRadio = switcher?.querySelector(
      'input[type="radio"]:checked',
    ) as HTMLInputElement;
    const activeTab = activeTabRadio ? activeTabRadio.value : "terminales";

    params.set("inventory_tabs", activeTab);

    if (activeTab === "terminales") {
      params.delete("mediterraneaType");

      const filters: Record<string, string> = {
        search: currentSearch,
        os: currentOs,
        osVariant: currentOsVariant,
        architecture: currentArch,
        brand: currentBrand,
        ram: currentRam,
        model: currentModel,
        status: currentStatus,
      };

      for (const [key, val] of Object.entries(filters)) {
        if (val && val !== "all") {
          params.set(key, val);
        } else {
          params.delete(key);
        }
      }
    } else if (activeTab === "mediterranea") {
      params.delete("os");
      params.delete("osVariant");
      params.delete("architecture");
      params.delete("brand");
      params.delete("ram");
      params.delete("model");

      const filters: Record<string, string> = {
        search: mediCurrentSearch,
        mediterraneaType: mediCurrentType,
        status: mediCurrentStatus,
      };

      for (const [key, val] of Object.entries(filters)) {
        if (val && val !== "all") {
          params.set(key, val);
        } else {
          params.delete(key);
        }
      }
    } else {
      params.delete("os");
      params.delete("osVariant");
      params.delete("architecture");
      params.delete("brand");
      params.delete("ram");
      params.delete("model");
      params.delete("mediterraneaType");
      params.delete("status");
      params.delete("search");
    }

    if (currentSortBy && currentSortOrder) {
      params.set("sortBy", currentSortBy);
      params.set("sortOrder", currentSortOrder);
    } else {
      params.delete("sortBy");
      params.delete("sortOrder");
    }

    const newUrl = `${window.location.pathname}${params.toString() ? "?" + params.toString() : ""}`;
    window.history.replaceState({}, "", newUrl);

    const baseUrl = import.meta.env.BASE_URL.endsWith("/")
      ? import.meta.env.BASE_URL
      : `${import.meta.env.BASE_URL}/`;

    if (exportCsvBtn) {
      const queryParams = new URLSearchParams();
      const filters: Record<string, string> = {
        search: currentSearch,
        os: currentOs,
        osVariant: currentOsVariant,
        architecture: currentArch,
        brand: currentBrand,
        ram: currentRam,
        model: currentModel,
        status: currentStatus,
      };
      for (const [key, val] of Object.entries(filters)) {
        if (val && val !== "all") {
          queryParams.set(key, val);
        }
      }
      exportCsvBtn.setAttribute(
        "href",
        `${baseUrl}api/export/terminals${queryParams.toString() ? "?" + queryParams.toString() : ""}`,
      );
    }

    if (mediExportCsvBtn) {
      const queryParams = new URLSearchParams();
      queryParams.set("isMediterranea", "true");
      if (mediCurrentSearch) queryParams.set("search", mediCurrentSearch);
      if (mediCurrentType && mediCurrentType !== "all")
        queryParams.set("mediterraneaType", mediCurrentType);
      if (mediCurrentStatus && mediCurrentStatus !== "all")
        queryParams.set("status", mediCurrentStatus);
      mediExportCsvBtn.setAttribute(
        "href",
        `${baseUrl}api/export/terminals${queryParams.toString() ? "?" + queryParams.toString() : ""}`,
      );
    }
  };

  const fetchTerminals = async (isNewSearch: boolean, showLoadingUI = true) => {
    if (isLoading) return;
    isLoading = true;
    if (showLoadingUI) terminalsSpinner?.classList.remove("hidden");

    try {
      const params = new URLSearchParams();
      params.set("page", currentPage.toString());
      params.set("limit", "50");
      if (currentSearch) params.set("search", currentSearch);
      if (currentOs && currentOs !== "all") params.set("os", currentOs);
      if (currentOsVariant && currentOsVariant !== "all")
        params.set("osVariant", currentOsVariant);
      if (currentArch && currentArch !== "all")
        params.set("architecture", currentArch);
      if (currentBrand && currentBrand !== "all")
        params.set("brand", currentBrand);
      if (currentRam && currentRam !== "all") params.set("ram", currentRam);
      if (currentModel && currentModel !== "all")
        params.set("model", currentModel);
      if (currentStatus && currentStatus !== "all")
        params.set("status", currentStatus);
      if (currentSortBy) {
        params.set("sortBy", currentSortBy);
        if (currentSortOrder) params.set("sortOrder", currentSortOrder);
      }

      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const response = await fetch(
        `${baseUrl}/api/terminals?${params.toString()}`,
      );
      if (!response.ok) throw new Error("API call failed");

      const html = await response.text();
      const newHasMore = response.headers.get("X-Has-More") === "true";
      const totalCount = response.headers.get("X-Total-Count") || "0";

      hasMore = newHasMore;

      if (totalCountBadge) {
        totalCountBadge.textContent = `${totalCount} resultados`;
      }

      if (terminalsContainer) {
        if (isNewSearch) {
          terminalsContainer.innerHTML = html;
        } else {
          terminalsContainer.insertAdjacentHTML("beforeend", html);
        }
      }

      const rowCount =
        terminalsContainer?.querySelectorAll("[data-terminal-row]").length ?? 0;
      const noResultsState = document.getElementById(
        "no-results-state-terminales",
      );
      const tableWrapper = document.getElementById("terminals-table-wrapper");

      if (noResultsState && tableWrapper) {
        if (rowCount === 0) {
          noResultsState.classList.remove("hidden");
          noResultsState.classList.add("flex");
          tableWrapper.classList.add("hidden");
        } else {
          noResultsState.classList.add("hidden");
          noResultsState.classList.remove("flex");
          tableWrapper.classList.remove("hidden");
        }
      }

      if (currentSearch && terminalsContainer) {
        const newArticles = Array.from(
          terminalsContainer.querySelectorAll<HTMLElement>(
            "[data-terminal-row]",
          ),
        );
        newArticles.forEach((item) => {
          highlightSearchTargets(item, currentSearch);
        });
      }

      // Re-bind sorting elements since DOM changed
      terminalRows = Array.from(
        document.querySelectorAll<HTMLElement>("[data-terminal-row]"),
      );

      if (!hasMore) {
        terminalsSentinel?.classList.add("hidden");
      } else {
        terminalsSentinel?.classList.remove("hidden");
      }
    } catch (err) {
      console.error("Error fetching terminals:", err);
    } finally {
      isLoading = false;
      if (showLoadingUI) terminalsSpinner?.classList.add("hidden");
    }
  };

  if (terminalsSentinel) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !isLoading && hasMore) {
          currentPage++;
          fetchTerminals(false);
        }
      },
      { rootMargin: "200px" },
    );
    observer.observe(terminalsSentinel);
  }

  const fetchMediterranea = async (
    isNewSearch: boolean,
    showLoadingUI = true,
  ) => {
    if (mediIsLoading) return;
    mediIsLoading = true;
    if (showLoadingUI) mediSpinner?.classList.remove("hidden");

    try {
      const params = new URLSearchParams();
      params.set("isMediterranea", "true");
      params.set("page", mediCurrentPage.toString());
      params.set("limit", "50");
      if (mediCurrentSearch) params.set("search", mediCurrentSearch);
      if (mediCurrentType && mediCurrentType !== "all")
        params.set("mediterraneaType", mediCurrentType);
      if (mediCurrentStatus && mediCurrentStatus !== "all")
        params.set("status", mediCurrentStatus);
      if (currentSortBy) {
        params.set("sortBy", currentSortBy);
        if (currentSortOrder) params.set("sortOrder", currentSortOrder);
      }

      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
      const response = await fetch(
        `${baseUrl}/api/terminals?${params.toString()}`,
      );
      if (!response.ok) throw new Error("API call failed");

      const html = await response.text();
      const newHasMore = response.headers.get("X-Has-More") === "true";
      const totalCount = response.headers.get("X-Total-Count") || "0";

      mediHasMore = newHasMore;

      if (mediTotalCountBadge) {
        mediTotalCountBadge.textContent = `${totalCount} resultados`;
      }

      if (mediContainer) {
        if (isNewSearch) {
          mediContainer.innerHTML = html;
        } else {
          mediContainer.insertAdjacentHTML("beforeend", html);
        }

        // Post-procesamiento de filas visibles para agrupar por NIS
        mediContainer
          .querySelectorAll("[data-medi-group-header]")
          .forEach((el) => el.remove());
        const rows = Array.from(
          mediContainer.querySelectorAll<HTMLElement>("[data-terminal-row]"),
        );

        let currentNis = "";
        let currentGroupRows: HTMLElement[] = [];
        const groups: {
          nis: string;
          branch: string;
          region: string;
          rows: HTMLElement[];
        }[] = [];

        const extractNisFromHostname = (hostname: string): string => {
          const match = hostname.match(/MEDI\d{2}(.+)/i);
          return match ? match[1] : "";
        };

        rows.forEach((row) => {
          const hostname = row.getAttribute("data-hostname") || "";
          const nis = extractNisFromHostname(hostname);
          if (nis !== currentNis) {
            if (currentGroupRows.length > 0) {
              groups.push({
                nis: currentNis,
                branch: currentGroupRows[0].getAttribute("data-branch") || "",
                region: currentGroupRows[0].getAttribute("data-region") || "",
                rows: currentGroupRows,
              });
            }
            currentNis = nis;
            currentGroupRows = [row];
          } else {
            currentGroupRows.push(row);
          }
        });

        if (currentGroupRows.length > 0) {
          groups.push({
            nis: currentNis,
            branch: currentGroupRows[0].getAttribute("data-branch") || "",
            region: currentGroupRows[0].getAttribute("data-region") || "",
            rows: currentGroupRows,
          });
        }

        groups.forEach((group) => {
          const firstRow = group.rows[0];
          const groupHeader = document.createElement("div");
          groupHeader.className =
            "col-span-full bg-base-200 border-b border-base-300 px-4 py-2 flex items-center justify-between";
          groupHeader.setAttribute("data-medi-group-header", "true");

          const countText =
            group.rows.length === 1
              ? "1 equipo"
              : `${group.rows.length} equipos`;
          groupHeader.innerHTML = `
            <div class="flex items-center gap-2">
              <span class="font-semibold text-sm text-base-content">${group.branch}</span>
              <div class="badge badge-sm badge-soft font-mono text-xs">${group.nis}</div>
              ${
                group.region && group.region !== "--"
                  ? `
                <span class="text-xs text-base-content/40">•</span>
                <span class="text-xs text-base-content/50 font-normal uppercase tracking-wider">${group.region}</span>
              `
                  : ""
              }
            </div>
            <span class="badge badge-neutral badge-sm font-medium">${countText}</span>
          `;

          firstRow.parentNode?.insertBefore(groupHeader, firstRow);
        });
      }

      const rowCount =
        mediContainer?.querySelectorAll("[data-terminal-row]").length ?? 0;
      const noResultsState = document.getElementById(
        "no-results-state-mediterranea",
      );
      const tableWrapper = document.getElementById(
        "mediterranea-table-wrapper",
      );

      if (noResultsState && tableWrapper) {
        if (rowCount === 0) {
          noResultsState.classList.remove("hidden");
          noResultsState.classList.add("flex");
          tableWrapper.classList.add("hidden");
        } else {
          noResultsState.classList.add("hidden");
          noResultsState.classList.remove("flex");
          tableWrapper.classList.remove("hidden");
        }
      }

      if (mediCurrentSearch && mediContainer) {
        const newArticles = Array.from(
          mediContainer.querySelectorAll<HTMLElement>("[data-terminal-row]"),
        );
        newArticles.forEach((item) => {
          highlightSearchTargets(item, mediCurrentSearch);
        });
      }

      if (!mediHasMore) {
        mediSentinel?.classList.add("hidden");
      } else {
        mediSentinel?.classList.remove("hidden");
      }
    } catch (err) {
      console.error("Error fetching Mediterránea:", err);
    } finally {
      mediIsLoading = false;
      if (showLoadingUI) mediSpinner?.classList.add("hidden");
    }
  };

  if (mediSentinel) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !mediIsLoading && mediHasMore) {
          mediCurrentPage++;
          fetchMediterranea(false);
        }
      },
      { rootMargin: "200px" },
    );
    observer.observe(mediSentinel);
  }

  let debounceTimeout: number;
  const triggerSearch = () => {
    clearTimeout(debounceTimeout);
    debounceTimeout = window.setTimeout(() => {
      currentPage = 1;
      currentSearch = terminalSearchInput?.value.trim() || "";
      currentOs = osFilterSelect?.value || "all";
      currentOsVariant = osVariantFilterSelect?.value || "all";
      currentArch = archFilterSelect?.value || "all";
      currentBrand = brandFilterSelect?.value || "all";
      currentRam = ramFilterSelect?.value || "all";
      currentModel = modelFilterSelect?.value || "all";
      currentStatus =
        statusRadioInputs.find((r) => r.checked)?.dataset.terminalStatus ||
        "all";
      fetchTerminals(true);
      syncFiltersToURL();
    }, 300);
  };

  terminalSearchInput?.addEventListener("input", triggerSearch);

  const btnClearTerminales = document.getElementById(
    "btn-clear-filters-terminales",
  );
  btnClearTerminales?.addEventListener("click", () => {
    if (terminalSearchInput) terminalSearchInput.value = "";
    if (osFilterSelect) osFilterSelect.value = "all";
    if (osVariantFilterSelect) {
      osVariantFilterSelect.innerHTML =
        '<option value="all">Variante (Todas)</option>';
      osVariantFilterSelect.disabled = true;
      osVariantFilterSelect.value = "all";
    }
    if (archFilterSelect) archFilterSelect.value = "all";
    if (brandFilterSelect) brandFilterSelect.value = "all";
    syncModelOptionsWithBrand();
    if (ramFilterSelect) ramFilterSelect.value = "all";
    if (modelFilterSelect) modelFilterSelect.value = "all";
    statusRadioInputs.forEach((radio, idx) => {
      radio.checked = idx === 0;
    });
    currentPage = 1;
    currentSearch = "";
    currentOs = "all";
    currentOsVariant = "all";
    currentArch = "all";
    currentBrand = "all";
    currentRam = "all";
    currentModel = "all";
    currentStatus = "all";
    fetchTerminals(true);
    syncFiltersToURL();
  });

  const btnClearEmptyTerminales = document.getElementById(
    "btn-clear-empty-terminales",
  );
  btnClearEmptyTerminales?.addEventListener("click", () => {
    btnClearTerminales?.click();
  });

  const btnClearCubics = document.getElementById("btn-clear-filters-cubics");
  btnClearCubics?.addEventListener("click", () => {
    if (machineSearchInput) machineSearchInput.value = "";
    filterTabs.forEach((tab, idx) => {
      tab.checked = idx === 0;
    });
    selectedCubicFilter = "all";
    updateMachineRows();
  });

  // Parse model brand mapping from server
  const modelBrandData = JSON.parse(
    document.getElementById("model-brand-data")?.textContent || "[]",
  );

  // Style for disabled model options
  const modelSelectStyle = document.createElement("style");
  modelSelectStyle.textContent =
    "#filter-model option:disabled { opacity: 0.4; }";
  document.head.appendChild(modelSelectStyle);

  // Keep model options in sync with selected brand
  const syncModelOptionsWithBrand = () => {
    if (!modelFilterSelect || !brandFilterSelect) return;
    const selectedBrand = brandFilterSelect.value;
    let currentModelStillValid = false;

    Array.from(modelFilterSelect.options).forEach((opt) => {
      if (opt.value === "all") return;
      const brand = (opt as HTMLOptionElement).dataset.brand || "";
      const matches = selectedBrand === "all" || brand === selectedBrand;
      opt.disabled = !matches;
      opt.classList.toggle("opacity-40", !matches);
      if (opt.value === modelFilterSelect.value && matches) {
        currentModelStillValid = true;
      }
    });

    if (!currentModelStillValid) {
      modelFilterSelect.value = "all";
      currentModel = "all";
    }
  };

  // Configurar mapa de OS desde el servidor usando un JSON en el script o variable global inyectada
  const osMapData = JSON.parse(
    document.getElementById("os-map-data")?.textContent || "{}",
  );

  osFilterSelect?.addEventListener("change", () => {
    if (osVariantFilterSelect) {
      const val = osFilterSelect.value;
      osVariantFilterSelect.innerHTML =
        '<option value="all">Variante (Todas)</option>';
      if (val === "all" || !osMapData[val] || osMapData[val].length === 0) {
        osVariantFilterSelect.disabled = true;
        osVariantFilterSelect.value = "all";
      } else {
        osVariantFilterSelect.disabled = false;
        osMapData[val].forEach((variant: string) => {
          const opt = document.createElement("option");
          opt.value = variant;
          opt.textContent = variant;
          osVariantFilterSelect.appendChild(opt);
        });
      }
    }
    triggerSearch();
  });

  osVariantFilterSelect?.addEventListener("change", triggerSearch);
  archFilterSelect?.addEventListener("change", triggerSearch);
  brandFilterSelect?.addEventListener("change", () => {
    syncModelOptionsWithBrand();
    triggerSearch();
  });
  ramFilterSelect?.addEventListener("change", triggerSearch);
  modelFilterSelect?.addEventListener("change", triggerSearch);
  statusRadioInputs.forEach((radio) =>
    radio.addEventListener("change", triggerSearch),
  );

  const machineSearchInput =
    document.querySelector<HTMLInputElement>("#machine-search");
  const filterTabs = Array.from(
    document.querySelectorAll<HTMLInputElement>("[data-filter-tab]"),
  );
  const machineRows = Array.from(
    document.querySelectorAll<HTMLElement>("[data-machine-row]"),
  );
  let selectedCubicFilter = "all";

  const updateMachineRows = () => {
    if (!machineSearchInput) return;
    const query = machineSearchInput.value.trim();
    let visibleCount = 0;

    machineRows.forEach((row) => {
      const status = row.dataset.status ?? "";
      const matchesSearch = matchesSearchQuery(query, [
        row.dataset.name,
        row.dataset.ip,
        row.dataset.agent,
      ]);
      const matchesFilter =
        selectedCubicFilter === "all" || status === selectedCubicFilter;

      const isVisible = matchesSearch && matchesFilter;
      row.classList.toggle("hidden", !isVisible);
      highlightSearchTargets(row, isVisible ? query : "");
    });
  };

  machineSearchInput?.addEventListener("input", updateMachineRows);
  filterTabs.forEach((tab) => {
    tab.addEventListener("change", () => {
      if (tab.checked) {
        selectedCubicFilter = tab.dataset.filter ?? "all";
        updateMachineRows();
      }
    });
  });

  function bindSorting(tableId: string, rows: HTMLElement[]) {
    const table = document.getElementById(tableId);
    if (!table || rows.length === 0) return;

    const headerCells = table.querySelectorAll("[data-table-sort-key]");
    let currentSortColumn: string | null = null;
    let currentSortDirection: "asc" | "desc" | null = null;

    table.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(
        "button[data-table-sort-key]",
      );
      if (!btn) return;

      const key = (btn as HTMLElement).dataset.tableSortKey;
      if (!key) return;

      if (currentSortColumn === key) {
        if (currentSortDirection === "asc") {
          currentSortDirection = "desc";
        } else {
          currentSortColumn = null;
          currentSortDirection = null;
        }
      } else {
        currentSortColumn = key;
        currentSortDirection = "asc";
      }

      headerCells.forEach((cell) => {
        const cellKey = (cell as HTMLElement).dataset.tableSortKey;
        const isActive = cellKey === currentSortColumn;
        const direction = isActive
          ? currentSortDirection === "asc"
            ? "ascending"
            : "descending"
          : "none";

        (cell as HTMLElement).dataset.tableSortDirection = direction;
        cell.setAttribute("aria-sort", direction);

        const icons = cell.querySelectorAll("[data-table-sort-icon]");
        icons.forEach((icon) => {
          const shouldShow =
            (icon as HTMLElement).dataset.tableSortIcon === direction;
          (icon as HTMLElement).classList.toggle("hidden", !shouldShow);
          (icon as HTMLElement).classList.toggle("opacity-0", !shouldShow);
        });
      });

      if (currentSortColumn) {
        const dataKey = `sort${currentSortColumn.charAt(0).toUpperCase()}${currentSortColumn.slice(1)}`;
        rows.sort((a, b) => {
          const valA = a.dataset[dataKey] || "";
          const valB = b.dataset[dataKey] || "";

          if (currentSortColumn === "ip") {
            const aParts = valA.split(".").map(Number);
            const bParts = valB.split(".").map(Number);
            for (let i = 0; i < 4; i++) {
              const numA = aParts[i] || 0;
              const numB = bParts[i] || 0;
              if (numA !== numB) {
                return currentSortDirection === "asc"
                  ? numA - numB
                  : numB - numA;
              }
            }
            return 0;
          }

          const valALower = valA.toLowerCase();
          const valBLower = valB.toLowerCase();

          if (valALower < valBLower)
            return currentSortDirection === "asc" ? -1 : 1;
          if (valALower > valBLower)
            return currentSortDirection === "asc" ? 1 : -1;
          return 0;
        });

        const parent = rows[0].parentElement;
        if (parent) {
          rows.forEach((row) => parent.appendChild(row));
        }
      }
    });
  }

  bindSorting("table-cubics", machineRows);
  updateMachineRows();

  let mediDebounceTimeout: number;
  const triggerMediSearch = () => {
    clearTimeout(mediDebounceTimeout);
    mediDebounceTimeout = window.setTimeout(() => {
      mediCurrentPage = 1;
      mediCurrentSearch = mediSearchInput?.value.trim() || "";
      mediCurrentType = mediTypeSelect?.value || "all";
      mediCurrentStatus =
        mediStatusRadioInputs.find((r) => r.checked)?.dataset.mediStatus ||
        "all";
      fetchMediterranea(true);
      syncFiltersToURL();
    }, 300);
  };

  mediSearchInput?.addEventListener("input", triggerMediSearch);
  mediTypeSelect?.addEventListener("change", triggerMediSearch);
  mediStatusRadioInputs.forEach((radio) =>
    radio.addEventListener("change", triggerMediSearch),
  );

  const btnClearMedi = document.getElementById("btn-clear-filters-medi");
  btnClearMedi?.addEventListener("click", () => {
    if (mediSearchInput) mediSearchInput.value = "";
    if (mediTypeSelect) mediTypeSelect.value = "all";
    mediStatusRadioInputs.forEach((radio, idx) => {
      radio.checked = idx === 0;
    });
    mediCurrentPage = 1;
    mediCurrentSearch = "";
    mediCurrentType = "all";
    mediCurrentStatus = "all";
    fetchMediterranea(true);
    syncFiltersToURL();
  });

  const btnClearEmptyMedi = document.getElementById(
    "btn-clear-empty-mediterranea",
  );
  btnClearEmptyMedi?.addEventListener("click", () => {
    btnClearMedi?.click();
  });

  const terminalTable = document.getElementById("table-terminales");
  terminalTable?.addEventListener("table-sort-change", (e: any) => {
    const { sortKey, direction } = e.detail;
    currentSortBy = direction === "none" ? null : sortKey;
    currentSortOrder =
      direction === "ascending"
        ? "asc"
        : direction === "descending"
          ? "desc"
          : null;
    currentPage = 1;
    fetchTerminals(true, false);
    syncFiltersToURL();
  });

  const mediterraneaTable = document.getElementById("table-mediterranea");
  mediterraneaTable?.addEventListener("table-sort-change", (e: any) => {
    const { sortKey, direction } = e.detail;
    currentSortBy = direction === "none" ? null : sortKey;
    currentSortOrder =
      direction === "ascending"
        ? "asc"
        : direction === "descending"
          ? "desc"
          : null;
    mediCurrentPage = 1;
    fetchMediterranea(true, false);
    syncFiltersToURL();
  });

  if (currentSortBy) {
    const dir = currentSortOrder === "desc" ? "descending" : "ascending";

    if (terminalTable) {
      terminalTable.dataset.tableSortKey = currentSortBy;
      terminalTable.dataset.tableSortDirection = dir;
      const control = terminalTable.querySelector(
        `[data-table-sort-key="${currentSortBy}"]`,
      );
      if (control) {
        control.setAttribute("data-table-sort-direction", dir);
        control.setAttribute("aria-sort", dir);
        control
          .querySelectorAll("[data-table-sort-icon]")
          .forEach((icon: any) => {
            const shouldShow = icon.dataset.tableSortIcon === dir;
            icon.classList.toggle("hidden", !shouldShow);
            icon.classList.toggle("opacity-0", !shouldShow);
          });
      }
    }

    if (mediterraneaTable) {
      mediterraneaTable.dataset.tableSortKey = currentSortBy;
      mediterraneaTable.dataset.tableSortDirection = dir;
      const control = mediterraneaTable.querySelector(
        `[data-table-sort-key="${currentSortBy}"]`,
      );
      if (control) {
        control.setAttribute("data-table-sort-direction", dir);
        control.setAttribute("aria-sort", dir);
        control
          .querySelectorAll("[data-table-sort-icon]")
          .forEach((icon: any) => {
            const shouldShow = icon.dataset.tableSortIcon === dir;
            icon.classList.toggle("hidden", !shouldShow);
            icon.classList.toggle("opacity-0", !shouldShow);
          });
      }
    }
  }

  const initialUrlParams = new URLSearchParams(window.location.search);
  const initialActiveTab =
    initialUrlParams.get("inventory_tabs") || "terminales";

  if (initialActiveTab === "mediterranea") {
    if (mediSearchInput && initialUrlParams.has("search")) {
      mediSearchInput.value = initialUrlParams.get("search") || "";
      mediCurrentSearch = mediSearchInput.value.trim();
    }
    if (mediTypeSelect && initialUrlParams.has("mediterraneaType")) {
      mediTypeSelect.value = initialUrlParams.get("mediterraneaType") || "all";
      mediCurrentType = mediTypeSelect.value;
    }
    if (initialUrlParams.has("status")) {
      const statusVal = initialUrlParams.get("status") || "all";
      mediStatusRadioInputs.forEach((radio) => {
        radio.checked = radio.dataset.mediStatus === statusVal;
      });
      mediCurrentStatus = statusVal;
    }

    fetchMediterranea(true);
  }
</script>
<script
  type="application/json"
  id="os-map-data"
  set:html={JSON.stringify(osMap)}
/>
<script
  type="application/json"
  id="model-brand-data"
  set:html={JSON.stringify(terminalModelsByBrand)}
/>

